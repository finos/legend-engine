function <<PCT.test, PCTRelationQualifier.relation, PCTRelationQualifier.olap>> meta::pure::functions::relation::tests::reduce::testRows_UnboundedPreceding_UnboundedFollowing_WithSinglePartition_WithoutOrderBy<T|m>(f:Function<{Function<{->T[m]}>[1]->T[m]}>[1]):Boolean[1]
{
    let expr = {
                | #TDS
                  p, o, i
                  0, 1, 10
                  0, 2, 20
                  0, 3, 30
                  100, 1, 10
                  100, 2, 30
                  100, 2, 5
                  100, 3, 11
                  100, 3, 120
                  200, 1, 10000
                  200, 1, 200
                  200, 1, 808080
                  200, 2, 33333
                  200, 3, 0
                  200, 3, 4
                  300, 1, 0
                  300, 2, 0
                #->extend(over(~p, rows(meta::pure::functions::relation::unbounded(), meta::pure::functions::relation::unbounded())), ~sum_i_Rows:{p,w,r|reduce($p, $w, $r, {r|$r.i}, {y|$y->plus()})})
               };


    let res =  $f->eval($expr);

    assertTdsEquivalent(
        #TDS
            p,o,i,sum_i_Rows
            0,1,10,60
