import meta::json::*;
import meta::pure::executionPlan::profiles::*;


function <<meta::pure::profiles::test.Test, meta::pure::profiles::test.AlloyOnly, meta::pure::executionPlan::engine::java::roadmap::feature.M2MBasics>>
{  serverVersion.start='v1_20_0',
   doc.doc='Simple example of map to process data and provide quick lookup during M2M transform'
}
meta::pure::mapping::modelToModel::test::alloy::simple::mapFunction::simpleM2MUsingMap() : Boolean[1]
{
  let grammar = '###Pure\n'+
    'Class test::model::Source\n'+
    '{\n'+
    '  i: Integer[*];\n'+
    '  s: String[*];\n'+
    '  inputs: Integer[*];\n'+
    '}\n'+
    '\n'+
    'Class test::model::Target\n'+
    '{\n'+
    '  resolved: String[*];\n'+
    '}\n'+
    '\n'+
    'function test::model::resolve(i: Integer[*], s: String[*], input: Integer[*]): String[*]\n'+
    '{\n'+
    '  let m = zip($i, $s)->newMap();\n'+
    '  $input->map(iv | if(get($m, $iv)->isEmpty(), | [], | get($m, $iv)));\n'+
    '}\n'+
    '\n'+
    'function test::query::getResolved(): String[1]\n'+
    '{\n'+
    '  test::model::Target.all()->graphFetch(\n'+
    '    #{\n'+
    '      test::model::Target {\n'+
    '        resolved\n'+
    '      }\n'+
    '    }#\n'+
    '  )->serialize(\n'+
    '    #{\n'+
    '      test::model::Target {\n'+
    '        resolved\n'+
    '      }\n'+
    '    }#\n'+
    '  )->from(test::mapping::M2MUseMap, test::runtime::testRuntime)\n'+
    '}\n'+
    '\n'+
    '###Mapping\n'+
    'Mapping test::mapping::M2MUseMap\n'+
    '(\n'+
    '  *test::model::Target: Pure\n'+
    '  {\n'+
    '    ~src test::model::Source\n'+
    '    resolved: test::model::resolve($src.i, $src.s, $src.inputs)\n'+
    '  }\n'+
    ')\n'+
    '\n'+
    '###Connection\n'+
    'JsonModelConnection test::connection::testConnection\n'+
    '{\n'+
    '  class: test::model::Source;\n'+
    '  url: \'data:application/json,{"i":[0,1,2,3,4], "s":["a","b","c","d","e"], "inputs":[0,2,4]}\';\n'+
    '}\n'+
    '\n'+
    '###Runtime\n'+
    'Runtime test::runtime::testRuntime\n'+
    '{\n'+
    '  mappings:\n'+
    '  [\n'+
    '    test::mapping::M2MUseMap\n'+
    '  ];\n'+
    '  connections:\n'+
    '  [\n'+
    '    ModelStore:\n'+
    '    [\n'+
    '      connection_1: test::connection::testConnection\n'+
    '    ]\n'+
    '  ];\n'+
    '}';

  let elements = meta::legend::compileLegendGrammar($grammar);
  let function = $elements->filter(e|$e->instanceOf(FunctionDefinition) && $e->cast(@PackageableElement)->elementToPath() == 'test::query::getResolved__String_1_')->at(0)->cast(@FunctionDefinition<{->String[1]}>);

  let result = meta::legend::executeLegendQuery($function, [], meta::pure::extension::defaultExtensions());

  assert(jsonEquivalent('{"builder":{"_type":"json"},"values":{"resolved":["a","c","e"]}}'->parseJSON(), $result->toOne()->parseJSON()));
}
