import meta::pure::test::pct::*;
import meta::pure::functions::date::*;

Enum meta::pure::functions::date::DateTimeFormat
{
   ISO8601_NanoSecondPrecision
}

function
   <<PCT.function>>
   {
      doc.doc = 'Formats a DateTime to a string using the specified DateTimeFormat'
   }
meta::pure::functions::date::formatDateTime(dateTime:DateTime[1], dateTimeFormat:DateTimeFormat[1]):String[1]
{
   if($dateTimeFormat == DateTimeFormat.ISO8601_NanoSecondPrecision,
      | formatDateTimeISO8601NanoSecondPrecision($dateTime),
      | assert(false, |'Unsupported DateTimeFormat: ' + $dateTimeFormat->toString()); '';);
}

function <<access.private>> meta::pure::functions::date::formatDateTimeISO8601NanoSecondPrecision(dateTime:DateTime[1]):String[1]
{
   let base = format('%t{yyyy-MM-dd"T"HH:mm:ss}', $dateTime);
   if($dateTime->hasSubsecond(),
      | $base + '.' + format('%t{SSSSSSSSS}', $dateTime),
      | $base + '.000000000');
}

function <<PCT.test>> meta::pure::functions::date::tests::formatDateTime::testFormatDateTime_ISO8601_NanoSecondPrecision<Z|y>(f:Function<{Function<{->Z[y]}>[1]->Z[y]}>[1]):Boolean[1]
{
   assertEquals('2024-08-15T15:33:42.000000000', $f->eval(|formatDateTime(%2024-08-15T15:33:42, DateTimeFormat.ISO8601_NanoSecondPrecision)));
}
