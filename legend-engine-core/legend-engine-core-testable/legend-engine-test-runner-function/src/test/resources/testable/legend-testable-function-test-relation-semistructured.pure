###Pure
import meta::pure::precisePrimitives::*;

Class model::SemiStructuredFirm
{
  id: Integer[1];
  legalName: String[1];
  employeeCount: Integer[1];
}

function model::FirmLegalNameQuery(): meta::pure::metamodel::relation::Relation<('LegalName':String)>[1]
{
  model::SemiStructuredFirm.all()
    ->project(~['LegalName': f | $f.legalName])
    ->from(
       execution::SemiStructuredMapping,
       execution::SemiStructuredRuntime
    )
}
{
  testSuite_1
  (
    store::SemiStructuredTestDB:
        Relation
        #{
          default.FIRM_TABLE:
            ID,FIRM_DETAILS
            1,"{""legalName"":""Firm X"",""employeeCount"":4}"
            2,"{""legalName"":""Firm A"",""employeeCount"":1}";
        }#;
    test_extractVarcharIsUnquoted | FirmLegalNameQuery() => Relation
                                                                                                                          #{
                                                                                                                              LegalName
                                                                                                                              Firm A
                                                                                                                              Firm X;
                                                                                                                          }#;
  )
}

function model::FirmEmployeeCountQuery(): meta::pure::metamodel::relation::Relation<('Employee Count':Integer)>[1]
{
  model::SemiStructuredFirm.all()
    ->project(~['Employee Count': f | $f.employeeCount])
    ->from(
       execution::SemiStructuredMapping,
       execution::SemiStructuredRuntime
    )
}
{
  testSuite_1
  (
    store::SemiStructuredTestDB:
        Relation
        #{
          default.FIRM_TABLE:
            ID,FIRM_DETAILS
            1,"{""legalName"":""Firm X"",""employeeCount"":4}"
            2,"{""legalName"":""Firm A"",""employeeCount"":1}";
        }#;
    test_extractIntegerCast | FirmEmployeeCountQuery() => Relation
                                                              #{
                                                                  Employee Count
                                                                  1
                                                                  4;
                                                              }#;
  )
}


