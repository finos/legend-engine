{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Pure",
  "scopeName": "source.pure",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#stereotypes" },
    { "include": "#multiplicity" },
    { "include": "#typeAnnotations" },
    { "include": "#variables" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#packagePaths" },
    { "include": "#functionCalls" },
    { "include": "#propertyAccess" },
    { "include": "#arrows" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.pure",
          "match": "//.*$"
        },
        {
          "name": "comment.block.pure",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.pure",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.pure",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "stereotypes": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.stereotype.pure",
          "match": "<<[^>]*>>"
        }
      ]
    },
    "multiplicity": {
      "patterns": [
        {
          "name": "constant.numeric.multiplicity.pure",
          "match": "\\[(\\d+(\\.\\.(\\d+|\\*))?|\\*)\\]"
        }
      ]
    },
    "typeAnnotations": {
      "patterns": [
        {
          "name": "entity.name.type.annotation.pure",
          "match": "@[A-Z][a-zA-Z0-9_]*(::([a-zA-Z_][a-zA-Z0-9_]*))*"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.pure",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.pure",
          "match": "\\b(if|let|import|extends|in)\\b"
        },
        {
          "name": "keyword.declaration.pure",
          "match": "\\b(Class|Enum|Association|Profile|function|native|Mapping|Runtime|Connection|Service|Measure|Unit)\\b"
        },
        {
          "name": "keyword.other.pure",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.pure",
          "match": "\\b(String|Integer|Float|Boolean|Date|StrictDate|DateTime|Number|Any|Nil)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.pure",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.pure",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "packagePaths": {
      "patterns": [
        {
          "name": "entity.name.type.package.pure",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(::([a-zA-Z_][a-zA-Z0-9_]*))+"
        }
      ]
    },
    "functionCalls": {
      "patterns": [
        {
          "comment": "Arrow function calls: ->functionName(. Requires ( to distinguish from lambda type signatures like {String[1]->Type[*]}",
          "match": "->\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.pure" }
          }
        }
      ]
    },
    "propertyAccess": {
      "patterns": [
        {
          "match": "\\.([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "variable.other.property.pure" }
          }
        }
      ]
    },
    "arrows": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.pure",
          "match": "->"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pure",
          "match": "(==|!=|<=|>=|<|>|\\+|-|\\*|/|&&|\\|\\||!|=)"
        }
      ]
    }
  }
}
