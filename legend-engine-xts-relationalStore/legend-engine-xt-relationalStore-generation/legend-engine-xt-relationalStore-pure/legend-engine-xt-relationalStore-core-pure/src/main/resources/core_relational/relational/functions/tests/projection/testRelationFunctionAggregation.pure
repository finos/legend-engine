###Pure
import meta::pure::metamodel::tds::*;
import meta::pure::mapping::*;
import meta::pure::router::*;
import meta::relational::mapping::*;
import meta::relational::tests::mapping::relation::*;
import meta::relational::metamodel::execute::*;

// Sub-aggregation tests for RelationFunctionInstanceSetImplementation.
// Analogous to meta::relational::tests::projection::aggregation::testSubAggregation
// but with a relation (~func) class mapping as the root.

function <<access.private>> meta::relational::tests::projection::aggregation::runFirmAgg(query:FunctionDefinition<{->TabularDataSet[1]}>[1]):TabularDataSet[1]
{
   execute(
      $query,
      meta::relational::tests::mapping::relation::SimpleMapping,
      meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
      meta::relational::extension::relationalExtensions()
   ).values->at(0);
}

// (1) Average — basic single sub-aggregation.
function <<meta::pure::profiles::test.Test>> meta::relational::tests::projection::aggregation::testSubAggregationOnRelationMapping():Boolean[1]
{
   let result = meta::relational::tests::projection::aggregation::runFirmAgg(
      |Firm.all()->project(~[a:f|$f.employees.age->average()])->cast(@TabularDataSet)
   );
   assertSize($result.rows, 5);
   assertSameElements(['30.0', '35.5', '52.0', 'TDSNull', 'TDSNull'], $result.rows->map(r|$r.values->at(0)->toString()));
}

// Average + simple property.
function <<meta::pure::profiles::test.Test>> meta::relational::tests::projection::aggregation::testSubAggregationOnRelationMappingWithSimpleProperty():Boolean[1]
{
   let result = meta::relational::tests::projection::aggregation::runFirmAgg(
      |Firm.all()->project(~[name:f|$f.legalName, a:f|$f.employees.age->average()])->cast(@TabularDataSet)
   );
   assertSameElements(
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | 35.5', 'Firm D | 52.0', 'Firm X | 30.0'],
      $result.rows->map(r|$r.values->makeString(' | '))
   );
}

// Two sub-aggregations on the same root (count + average).
function <<meta::pure::profiles::test.Test>> meta::relational::tests::projection::aggregation::testTwoSubAggregationOnRelationMapping():Boolean[1]
{
   let result = meta::relational::tests::projection::aggregation::runFirmAgg(
      |Firm.all()->project(~[
         b:f|$f.employees.firstName->count(),
         a:f|$f.employees.age->average()
      ])->cast(@TabularDataSet)
   );
   assertSameElements(
      ['0 | TDSNull', '0 | TDSNull', '1 | 30.0', '1 | 52.0', '2 | 35.5'],
      $result.rows->map(r|$r.values->makeString(' | '))
   );
}

// Sum (NULL for empty groups via LEFT OUTER JOIN).
function <<meta::pure::profiles::test.Test>> meta::relational::tests::projection::aggregation::testSubAggregationSumOnRelationMapping():Boolean[1]
{
   let result = meta::relational::tests::projection::aggregation::runFirmAgg(
      |Firm.all()->project(~[name:f|$f.legalName, s:f|$f.employees.age->sum()])->cast(@TabularDataSet)
   );
   assertSameElements(
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | 71', 'Firm D | 52', 'Firm X | 30'],
      $result.rows->map(r|$r.values->makeString(' | '))
   );
}

// Max.
function <<meta::pure::profiles::test.Test>> meta::relational::tests::projection::aggregation::testSubAggregationMaxOnRelationMapping():Boolean[1]
{
   let result = meta::relational::tests::projection::aggregation::runFirmAgg(
      |Firm.all()->project(~[name:f|$f.legalName, m:f|$f.employees.age->max()])->cast(@TabularDataSet)
   );
   assertSameElements(
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | 45', 'Firm D | 52', 'Firm X | 30'],
      $result.rows->map(r|$r.values->makeString(' | '))
   );
}

// Sub-aggregation with a filter inside the collection navigation.
function <<meta::pure::profiles::test.Test>> meta::relational::tests::projection::aggregation::testSubAggregationWithFilterOnRelationMapping():Boolean[1]
{
   let result = meta::relational::tests::projection::aggregation::runFirmAgg(
      |Firm.all()->project(~[name:f|$f.legalName, a:f|$f.employees->filter(e|$e.age > 30).age->average()])->cast(@TabularDataSet)
   );
   assertSameElements(
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | 45.0', 'Firm D | 52.0', 'Firm X | TDSNull'],
      $result.rows->map(r|$r.values->makeString(' | '))
   );
}
