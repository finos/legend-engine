// Relation-mapping equivalent of the classic ~filter mapping tests. Classic
// relational mappings declare a named class-level ~filter; a relation mapping
// applies the ->filter(...) inside the backing ~func, so rows excluded there
// never surface through Class.all(). Reuses the classic filter Org domain but
// maps against the local NOT NULL coverage store. The join-in-function-body
// variants cover the "filter referencing a joined table" scenario.

###Pure
import meta::pure::functions::relation::*;
import meta::pure::metamodel::relation::*;
import meta::relational::tests::mapping::relation::*;

function meta::relational::tests::mapping::relation::orgRelationFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.orgTable}#
      ->filter(x | $x.filterVal <= 4)
      ->select(~[id, name, parentId]);
}

function meta::relational::tests::mapping::relation::orgRelationWithJoinFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.orgTable}#
      ->select(~[id, name, parentId])
      ->join(
         #>{meta::relational::tests::mapping::relation::coverageDB.otherTable}#->project(~[joinOrgId:t|$t.orgTableId, otherFilterVal:t|$t.filterVal]),
         JoinKind.INNER,
         {o, t | $o.id == $t.joinOrgId}
       )
      ->filter(x | $x.otherFilterVal <= 4)
      ->select(~[id, name, parentId]);
}

function meta::relational::tests::mapping::relation::orgRelationWithParentNameFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.orgTable}#
      ->filter(x | $x.filterVal <= 4)
      ->select(~[id, name, parentId])
      ->join(
         #>{meta::relational::tests::mapping::relation::coverageDB.orgTable}#->project(~[pId:p|$p.id, pParentId:p|$p.parentId]),
         JoinKind.LEFT,
         {r, p | $r.parentId == $p.pId}
       )
      ->join(
         #>{meta::relational::tests::mapping::relation::coverageDB.orgTable}#->project(~[gpId:g|$g.id, parentName:g|$g.name]),
         JoinKind.LEFT,
         {r, g | $r.pParentId == $g.gpId}
       )
      ->select(~[id, name, parentName]);
}

###Mapping
import meta::relational::tests::mapping::filter::model::domain::*;
import meta::relational::tests::mapping::relation::*;

Mapping meta::relational::tests::mapping::relation::orgRelationMapping
(
   *Org: Relation
   {
      ~func meta::relational::tests::mapping::relation::orgRelationFunc():Relation<Any>[1]
      name: name
   }
)

Mapping meta::relational::tests::mapping::relation::orgRelationMappingWithJoin
(
   *Org: Relation
   {
      ~func meta::relational::tests::mapping::relation::orgRelationWithJoinFunc():Relation<Any>[1]
      name: name
   }
)

Mapping meta::relational::tests::mapping::relation::orgRelationMappingWithParentName
(
   *Org: Relation
   {
      ~func meta::relational::tests::mapping::relation::orgRelationWithParentNameFunc():Relation<Any>[1]
      name: name,
      parentName: parentName
   }
)

###Pure
import meta::relational::functions::asserts::*;
import meta::relational::tests::mapping::filter::model::domain::*;
import meta::relational::tests::mapping::relation::*;
import meta::pure::functions::relation::*;
import meta::external::store::relational::tests::*;

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testFilterMapping():Boolean[1]
{
   let result = execute(
      |Org.all()->project(~[name:o|$o.name]),
      orgRelationMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions());
   assertEquals(
     #TDS
        name
        Banking
        Federation
        Firm A
        Firm X
        ROOT
        Securities
     #->toString(),
     $result.values->at(0)->sort([~name->ascending()])->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testFilterMappingWithJoin():Boolean[1]
{
   let result = execute(
      |Org.all()->project(~[name:o|$o.name]),
      orgRelationMappingWithJoin,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions());
   assertEquals(
     #TDS
        name
        Banking
        Federation
        Firm A
        Firm X
        ROOT
        Securities
     #->toString(),
     $result.values->at(0)->sort([~name->ascending()])->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testFilterMappingWithJoinNotEmpty():Boolean[1]
{
   let result = execute(
      |Org.all()->filter(o|$o.parentName->isNotEmpty())->project(~[name:o|$o.name]),
      orgRelationMappingWithParentName,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions());
   assertEquals(
     #TDS
        name
        Banking
        Federation
        Securities
     #->toString(),
     $result.values->at(0)->sort([~name->ascending()])->toString());
}
