      CITY VARCHAR(100),
      COUNTRY VARCHAR(100),
      CODE VARCHAR(50)
    )

    Table firmTableB
    (
      ID INTEGER PRIMARY KEY,
      LEGALNAME VARCHAR(100),
      CITY VARCHAR(100),
      COUNTRY VARCHAR(100),
      CODE VARCHAR(50)
    )

    Table personTable
    (
      ID INTEGER PRIMARY KEY,
      FIRSTNAME VARCHAR(100),
      LASTNAME VARCHAR(100),
      FIRMID INTEGER,
      AGE INTEGER
    )

    Table fullTimeTable
    (
      ID INTEGER PRIMARY KEY,
      FIRSTNAME VARCHAR(100),
      LASTNAME VARCHAR(100),
      FIRMID INTEGER,
      AGE INTEGER
    )

    Table contractTable
    (
      ID INTEGER PRIMARY KEY,
      FIRSTNAME VARCHAR(100),
      LASTNAME VARCHAR(100),
      FIRMID INTEGER,
      AGE INTEGER
    )

    Table addressTableA
    (
      ID INTEGER PRIMARY KEY,
      PERSONID INTEGER,
      CITY VARCHAR(100),
      COUNTRY VARCHAR(100)
    )

    Table addressTableB
    (
      ID INTEGER PRIMARY KEY,
      PERSONID INTEGER,
      CITY VARCHAR(100),
      COUNTRY VARCHAR(100)
    )

    Table hqTableA
    (
      ID INTEGER PRIMARY KEY,
      FIRMID INTEGER,
      CITY VARCHAR(100),
      COUNTRY VARCHAR(100)
    )

    Table hqTableB
    (
      ID INTEGER PRIMARY KEY,
      FIRMID INTEGER,
      CITY VARCHAR(100),
      COUNTRY VARCHAR(100)
    )
  )
) 

