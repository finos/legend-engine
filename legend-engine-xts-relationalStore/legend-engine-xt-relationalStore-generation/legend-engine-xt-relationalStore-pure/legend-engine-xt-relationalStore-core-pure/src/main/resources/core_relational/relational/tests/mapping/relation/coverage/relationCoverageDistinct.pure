function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testDistinctMappingWithDistinctInJoinWithFilterOnJoin():Boolean[1]
{
   let result = execute(
      |Classification.all()->filter(c | $c.incomeFunctions->exists(i | $i.name == 'IF 2'))->project(~[name:c|$c.name, incomeFunction:c|$c.incomeFunctions.name]),
      distinctRelationMappingWithJoin,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        name, incomeFunction
        IfName2, IF 2
     #->toString(),
     $result.values->at(0)->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testDistinctMappingWithCaseStatement():Boolean[1]
{
   let result = execute(
      |IncomeFunction.all()->project(~[name:i|$i.name, IfName:i|$i.Classification.name])->sort([~name->ascending(), ~IfName->ascending()]),
      distinctRelationMappingWithCase,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        name, IfName
        IF 1, IfName1
        IF 2, IfName2
        IF 2, TDSNull
     #->toString(),
     $result.values->at(0)->sort([~name->ascending(), ~IfName->ascending()])->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testDistinctMappingWithSize():Boolean[1]
{
   let result = execute(
      |IncomeFunction.all()->size(),
      distinctRelationMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(3, $result.values->toOne());
}
