// Relation-mapping equivalent of the classic ~distinct mapping tests. The classic
// relational mapping pins DISTINCT with a class-level ~distinct clause; in a
// relation mapping the ->distinct() lives inside the backing ~func, so the class
// set is already the distinct relation. Reuses the classic distinct domain
// (IncomeFunction / Classification / SDI_IF) but maps against the local NOT NULL
// coverage store.

###Pure
import meta::pure::functions::relation::*;
import meta::pure::metamodel::relation::*;
import meta::relational::tests::mapping::relation::coverage::*;

function meta::relational::tests::mapping::relation::coverage::incomeFunctionFunc():Relation<Any>[1]
{
   #>{coverageDB.ACCOUNT_INFO}#
      ->select(~[IF_CODE, IF_NAME])
      ->distinct();
}

// Discriminating filter: only the single 'Type 2' row survives, so after distinct the
// mapped class has one row. The unfiltered mapping yields 3 distinct rows, making the
// func-body filter's effect observable in the asserted TDS.
function meta::relational::tests::mapping::relation::coverage::incomeFunctionWithFilterFunc():Relation<Any>[1]
{
   #>{coverageDB.ACCOUNT_INFO}#
      ->filter(r | $r.IF_TYPE == 'Type 2')
      ->select(~[IF_CODE, IF_NAME])
      ->distinct();
}

function meta::relational::tests::mapping::relation::coverage::incomeFunctionWithOtherInfoFunc():Relation<Any>[1]
{
   #>{coverageDB.ACCOUNT_INFO}#
      ->join(
         #>{coverageDB.IF_OTHER_INFO}#
            ->extend(~joinIfCode:r | $r.IF_CODE)
            ->select(~[joinIfCode, IF_OTHER_NAME]),
         JoinKind.LEFT,
         {a, o | $a.IF_CODE == $o.joinIfCode}
      )
      ->select(~[IF_CODE, IF_NAME, IF_OTHER_NAME])
      ->distinct();
}

function meta::relational::tests::mapping::relation::coverage::classificationFunc():Relation<Any>[1]
{
   #>{coverageDB.IF_OTHER_INFO}#
      ->select(~[IF_CODE, IF_OTHER_NAME]);
}

function meta::relational::tests::mapping::relation::coverage::incomeFunctionWithOtherInfo2Func():Relation<Any>[1]
{
   #>{coverageDB.ACCOUNT_INFO}#
      ->join(
         #>{coverageDB.IF_OTHER_INFO}#
            ->extend(~joinIfCode:r | $r.IF_CODE)
            ->select(~[joinIfCode, IF_OTHER_NAME]),
         JoinKind.LEFT,
         {a, o | $a.IF_CODE == $o.joinIfCode && $a.IF_CODE->isNotEmpty()}
      )
      ->select(~[IF_CODE, IF_NAME, IF_OTHER_NAME])
      ->distinct();
}

function meta::relational::tests::mapping::relation::coverage::incomeFunctionWithCaseFunc():Relation<Any>[1]
{
   #>{coverageDB.ACCOUNT_INFO}#
      ->extend(~name:r | if($r.IF_NAME->isEmpty(), | 'C', | $r.IF_NAME->toOne()))
      ->select(~[IF_CODE, name])
      ->distinct();
}

function meta::relational::tests::mapping::relation::coverage::classificationWithCaseFunc():Relation<Any>[1]
{
   #>{coverageDB.IF_OTHER_INFO}#
      ->extend(~name:r | if($r.IF_OTHER_NAME->isEmpty(), | 'Unknown', | $r.IF_OTHER_NAME->toOne()))
      ->select(~[IF_CODE, name]);
}

###Mapping
import meta::relational::tests::mapping::distinct::model::domain::*;
import meta::relational::tests::mapping::relation::coverage::*;

Mapping meta::relational::tests::mapping::relation::coverage::distinctRelationMapping
(
   *IncomeFunction[incomeFunction]: Relation
   {
      ~func meta::relational::tests::mapping::relation::coverage::incomeFunctionFunc():Relation<Any>[1]
      code: IF_CODE,
      name: IF_NAME
   }
)

Mapping meta::relational::tests::mapping::relation::coverage::distinctRelationMappingWithFilter
(
   *IncomeFunction[incomeFunction]: Relation
   {
      ~func meta::relational::tests::mapping::relation::coverage::incomeFunctionWithFilterFunc():Relation<Any>[1]
      code: IF_CODE,
      name: IF_NAME
   }
)

Mapping meta::relational::tests::mapping::relation::coverage::distinctRelationMappingWithJoin
(
   *IncomeFunction[incomeFunction]: Relation
   {
      ~func meta::relational::tests::mapping::relation::coverage::incomeFunctionWithOtherInfoFunc():Relation<Any>[1]
      code: IF_CODE,
      name: IF_NAME,
      IfName: IF_OTHER_NAME,
      +ifCode: Integer[1]: IF_CODE
   }

   *Classification[classification]: Relation
   {
      ~func meta::relational::tests::mapping::relation::coverage::classificationFunc():Relation<Any>[1]
      name: IF_OTHER_NAME,
      +ifCode: Integer[1]: IF_CODE
   }

   SDI_IF: ModelJoin
   {
      {incomeFunctions: meta::relational::tests::mapping::distinct::model::domain::IncomeFunction[1], Classification: meta::relational::tests::mapping::distinct::model::domain::Classification[1] | $incomeFunctions.ifCode == $Classification.ifCode}
   }
)

Mapping meta::relational::tests::mapping::relation::coverage::distinctRelationMappingWithJoinWithDup
(
   *IncomeFunction[incomeFunction]: Relation
   {
      ~func meta::relational::tests::mapping::relation::coverage::incomeFunctionWithOtherInfo2Func():Relation<Any>[1]
      name: IF_NAME,
      IfName: IF_OTHER_NAME,
      +ifCode: Integer[1]: IF_CODE
   }

   *Classification[classification]: Relation
   {
      ~func meta::relational::tests::mapping::relation::coverage::classificationFunc():Relation<Any>[1]
      name: IF_OTHER_NAME,
      +ifCode: Integer[1]: IF_CODE
   }

   SDI_IF: ModelJoin
   {
      {incomeFunctions: meta::relational::tests::mapping::distinct::model::domain::IncomeFunction[1], Classification: meta::relational::tests::mapping::distinct::model::domain::Classification[1] | $incomeFunctions.ifCode == $Classification.ifCode && $incomeFunctions.ifCode->isNotEmpty()}
   }
)

Mapping meta::relational::tests::mapping::relation::coverage::distinctRelationMappingWithCase
(
   *IncomeFunction[incomeFunction]: Relation
   {
      ~func meta::relational::tests::mapping::relation::coverage::incomeFunctionWithCaseFunc():Relation<Any>[1]
      code: IF_CODE,
      name: name,
      +ifCode: Integer[1]: IF_CODE
   }

   *Classification[classification]: Relation
   {
      ~func meta::relational::tests::mapping::relation::coverage::classificationWithCaseFunc():Relation<Any>[1]
      name: name,
      +ifCode: Integer[1]: IF_CODE
   }

   SDI_IF: ModelJoin
   {
      {incomeFunctions: meta::relational::tests::mapping::distinct::model::domain::IncomeFunction[1], Classification: meta::relational::tests::mapping::distinct::model::domain::Classification[1] | $incomeFunctions.ifCode == $Classification.ifCode}
   }
)

###Pure
import meta::relational::functions::asserts::*;
import meta::relational::tests::mapping::distinct::model::domain::*;
import meta::relational::tests::mapping::relation::coverage::*;
import meta::pure::functions::relation::*;
import meta::external::store::relational::tests::*;

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testDistinctMappingSelectAll():Boolean[1]
{
   let result = execute(
      |IncomeFunction.all()->project(~[name:i|$i.name]),
      distinctRelationMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        name
        IF 1
        IF 2
        IF 2
     #->toString(),
     $result.values->at(0)->sort([~name->ascending()])->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testDistinctMappingSelectAllWithFilter():Boolean[1]
{
   let result = execute(
      |IncomeFunction.all()->filter(i | $i.code == 1002)->project(~[name:i|$i.name, code:i|$i.code]),
      distinctRelationMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        name, code
        IF 2, 1002
     #->toString(),
     $result.values->at(0)->sort([~name->ascending()])->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testDistinctMappingSimpleProjectSelectAll():Boolean[1]
{
   let result = execute(
      |IncomeFunction.all()->project(~[name:i|$i.name, code:i|$i.code])->sort([~code->ascending()]),
      distinctRelationMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        name, code
        IF 1, 1001
        IF 2, 1002
        IF 2, 1022
     #->toString(),
     $result.values->at(0)->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testDistinctMappingSimpleProjectDistinct():Boolean[1]
{
   let result = execute(
      |IncomeFunction.all()->project(~[name:i|$i.name])->distinct(),
      distinctRelationMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        name
        IF 1
        IF 2
     #->toString(),
     $result.values->at(0)->sort([~name->ascending()])->toString());
}

// The func body filters to IF_TYPE = 'Type 2' then distincts, so only one row survives.
// Projecting name + code proves which row the func-body filter kept (1002, 'IF 2').
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testDistinctMappingWithFilterSelectAll():Boolean[1]
{
   let result = execute(
      |IncomeFunction.all()->project(~[name:i|$i.name, code:i|$i.code]),
      distinctRelationMappingWithFilter,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        name, code
        IF 2, 1002
     #->toString(),
     $result.values->at(0)->sort([~name->ascending()])->toString());
}

// Contrast with testDistinctMappingSelectAll (3 rows, unfiltered): the func-body filter here
// excludes every 'Type 1' row, so the mapped class exposes exactly one row. Asserting the row
// count makes the exclusion - not just the projection - the thing under test.
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testDistinctMappingWithFilterExcludesRows():Boolean[1]
{
   let result = execute(
      |IncomeFunction.all()->project(~[name:i|$i.name]),
      distinctRelationMappingWithFilter,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(1, $result.values->at(0)->cast(@meta::pure::tds::TabularDataSet).rows->size());
   assertEquals(
     #TDS
        name
        IF 2
     #->toString(),
     $result.values->at(0)->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testDistinctMappingWithJoinSelectAll():Boolean[1]
{
   let result = execute(
      |IncomeFunction.all()->project(~[name:i|$i.name]),
      distinctRelationMappingWithJoin,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        name
        IF 1
        IF 2
        IF 2
     #->toString(),
     $result.values->at(0)->sort([~name->ascending()])->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testDistinctMappingWithJoinProject():Boolean[1]
{
   let result = execute(
      |IncomeFunction.all()->project(~[IfName:i|$i.IfName]),
      distinctRelationMappingWithJoin,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        IfName
        IfName1
        IfName2
        TDSNull
     #->toString(),
     $result.values->at(0)->sort([~IfName->ascending()])->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testProjectDistinctMappingWithDistinctInJoin():Boolean[1]
{
   let result = execute(
      |Classification.all()->project(~[name:c|$c.name, incomeFunction:c|$c.incomeFunctions.name]),
      distinctRelationMappingWithJoin,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        name, incomeFunction
        IfName1, IF 1
        IfName2, IF 2
     #->toString(),
     $result.values->at(0)->sort([~name->ascending()])->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testProjectDistinctMappingWithDistinctInJoinWithDup():Boolean[1]
{
   let result = execute(
      |Classification.all()->project(~[name:c|$c.name, incomeFunction:c|$c.incomeFunctions.name]),
