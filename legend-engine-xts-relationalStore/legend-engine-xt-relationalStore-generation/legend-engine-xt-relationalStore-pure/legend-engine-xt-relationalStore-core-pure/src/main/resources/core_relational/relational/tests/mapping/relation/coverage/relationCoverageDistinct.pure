function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testDistinctMappingWithDistinctInJoinWithFilter():Boolean[1]
{
   let result = execute(
      |Classification.all()->filter(c | $c.name == 'IfName2')->project(~[name:c|$c.name, incomeFunction:c|$c.incomeFunctions.name]),
      distinctRelationMappingWithJoin,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
