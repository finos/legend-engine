import meta::pure::runtime::*;
import meta::relational::tests::mapping::modelJoin::domain::*;
import meta::relational::tests::mapping::modelJoin::union::*;

// =============================================================================
// Union source: Person = union(fullTimeTable, contractTable), Firm = simple.
//
// Expected: Apple has Alice+Bob, Google has Charlie.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::union::testRelationalUnionSource():Boolean[1]
{
  let fullTimeCsv =
    'default\n' +
    'fullTimeTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n';

  let contractCsv =
    'default\n' +
    'contractTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '2,Bob,Jones,1,25\n' +
    '3,Charlie,Brown,2,35\n';

  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let db = meta::relational::tests::mapping::modelJoin::union::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$fullTimeCsv, $contractCsv, $firmCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'Employee First Name': x|$x.employees.firstName
       ]
    ),
    RelationalUnionSourceMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "root".LEGALNAME as "Legal Name", "unionalias_0"."fullTimeTableFIRSTNAME_contractTableFIRSTNAME" as "Employee First Name" ' +
    'from firmTable as "root" ' +
    'left outer join (select "root".FIRMID as firmId, "root".FIRSTNAME as "fullTimeTableFIRSTNAME_contractTableFIRSTNAME" ' +
    'from fullTimeTable as "root" union all select "root".FIRMID as firmId, "root".FIRSTNAME as "fullTimeTableFIRSTNAME_contractTableFIRSTNAME" ' +
    'from contractTable as "root") as "unionalias_0" on ("unionalias_0".firmId = "root".ID)';
  assertEquals($expectedSql, $result->sql());

  assertEquals( '#TDS\n' +
            '   \'Legal Name\',\'Employee First Name\'\n' +
            '   Apple,Alice\n' +
            '   Apple,Bob\n' +
            '   Google,Charlie\n' +
            '#',
            $result.values->at(0)->sort([~'Legal Name'->ascending(), ~'Employee First Name'->ascending()])->toString());
}

// =============================================================================
// Union both sides: Person = union(FT, CT), Firm = union(firmA, firmB).
//
// Expected: Apple has Alice+Bob, Meta has Charlie.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::union::testRelationalUnionBothSides():Boolean[1]
{
  let fullTimeCsv =
    'default\n' +
    'fullTimeTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n';

  let contractCsv =
    'default\n' +
    'contractTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '2,Bob,Jones,1,25\n' +
    '3,Charlie,Brown,3,35\n';

  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n';

  let firmBCsv =
    'default\n' +
    'firmTableB\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '3,Meta,,,\n';

  let db = meta::relational::tests::mapping::modelJoin::union::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$fullTimeCsv, $contractCsv, $firmCsv, $firmBCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'Employee First Name': x|$x.employees.firstName
       ]
    ),
    RelationalUnionBothSidesMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "unionBase"."firmTableLEGALNAME_firmTableBLEGALNAME" as "Legal Name", ' +
    '"unionalias_1"."fullTimeTableFIRSTNAME_contractTableFIRSTNAME" as "Employee First Name" ' +
    'from (select "root".ID as "pk_0_0", null as "pk_0_1", "root".LEGALNAME as "firmTableLEGALNAME_firmTableBLEGALNAME", "root".ID as id ' +
    'from firmTable as "root" union all select null as "pk_0_0", "root".ID as "pk_0_1", "root".LEGALNAME as "firmTableLEGALNAME_firmTableBLEGALNAME", "root".ID as id ' +
    'from firmTableB as "root") as "unionBase" ' +
    'left outer join (select "root".FIRMID as firmId, "root".FIRSTNAME as "fullTimeTableFIRSTNAME_contractTableFIRSTNAME" ' +
    'from fullTimeTable as "root" union all select "root".FIRMID as firmId, "root".FIRSTNAME as "fullTimeTableFIRSTNAME_contractTableFIRSTNAME" ' +
    'from contractTable as "root") as "unionalias_1" on ("unionalias_1".firmId = "unionBase".id)';
  assertEquals($expectedSql, $result->sql()); 

  assertEquals( '#TDS\n' +
            '   \'Legal Name\',\'Employee First Name\'\n' +
            '   Apple,Alice\n' +
            '   Apple,Bob\n' +
            '   Meta,Charlie\n' +
            '#',
            $result.values->at(0)->sort([~'Legal Name'->ascending(), ~'Employee First Name'->ascending()])->toString());
}

// =============================================================================
// Union + exists() filter: only firms with at least one employee age > 30.
//
// Expected: Only Google (Charlie, age=35) passes the exists filter.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::union::testUnionWithExistsFilter():Boolean[1]
{
  let fullTimeCsv =
    'default\n' +
    'fullTimeTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,25\n';

  let contractCsv =
    'default\n' +
    'contractTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '3,Charlie,Brown,2,35\n' +
    '4,Diana,White,3,22\n';

  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n' +
    '3,Meta,,,\n';

  let db = meta::relational::tests::mapping::modelJoin::union::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$fullTimeCsv, $contractCsv, $firmCsv], $db, $runtime);

  let result = execute(
    |Firm.all()
      ->filter(f | $f.employees->exists(e | $e.age > 30))
      ->project(
        ~[
          'Legal Name': x|$x.legalName,
          'Employee First Name': x|$x.employees.firstName
         ]
      ),
    UnionWithExistsMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "root".LEGALNAME as "Legal Name", "unionalias_0"."fullTimeTableFIRSTNAME_contractTableFIRSTNAME" as "Employee First Name" ' +
    'from firmTable as "root" ' +
    'left outer join (select "root".FIRMID as firmId, "root".FIRSTNAME as "fullTimeTableFIRSTNAME_contractTableFIRSTNAME" ' +
    'from fullTimeTable as "root" union all select "root".FIRMID as firmId, "root".FIRSTNAME as "fullTimeTableFIRSTNAME_contractTableFIRSTNAME" ' +
    'from contractTable as "root") as "unionalias_0" on ("unionalias_0".firmId = "root".ID) ' +
    'where exists (select 1 from (select "root".FIRMID as firmId, "root".AGE as "fullTimeTableAGE_contractTableAGE" ' +
    'from fullTimeTable as "root" union all select "root".FIRMID as firmId, "root".AGE as "fullTimeTableAGE_contractTableAGE" ' +
    'from contractTable as "root") as "unionalias_1" where "unionalias_1".firmId = "root".ID and "unionalias_1"."fullTimeTableAGE_contractTableAGE" > 30)';
  assertEquals($expectedSql, $result->sql());

  assertEquals( '#TDS\n' +
            '   \'Legal Name\',\'Employee First Name\'\n' +
            '   Google,Charlie\n' +
            '#',
            $result.values->at(0)->sort([~'Legal Name'->ascending(), ~'Employee First Name'->ascending()])->toString());
}

// =============================================================================
// Union + sub-aggregation: count employees per firm across union.
//
// Expected: Apple=2 (Alice from FT + Bob from CT), Google=1 (Charlie from CT).
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::union::testRelationalUnionSubAggregation():Boolean[1]
{
  let fullTimeCsv =
    'default\n' +
    'fullTimeTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n';

  let contractCsv =
    'default\n' +
    'contractTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '2,Bob,Jones,1,25\n' +
    '3,Charlie,Brown,2,35\n';

  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let db = meta::relational::tests::mapping::modelJoin::union::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$fullTimeCsv, $contractCsv, $firmCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'Employee Count': x|$x.employees->count()
       ]
    ),
    UnionWithExistsMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "root".LEGALNAME as "Legal Name", "firmtable_1".aggCol as "Employee Count" ' +
    'from firmTable as "root" ' +
    'left outer join (select "firmtable_2".ID as ID, count(*) as aggCol from firmTable as "firmtable_2" ' +
    'left outer join (select "root".FIRMID as firmId from fullTimeTable as "root" union all select "root".FIRMID as firmId ' +
    'from contractTable as "root") as "unionalias_0" on ("unionalias_0".firmId = "firmtable_2".ID) ' +
    'group by "firmtable_2".ID) as "firmtable_1" on ("root".ID = "firmtable_1".ID)';
  assertEquals($expectedSql, $result->sql());

  assertEquals( '#TDS\n' +
            '   \'Legal Name\',\'Employee Count\'\n' +
            '   Apple,2\n' +
            '   Google,1\n' +
            '#',
            $result.values->at(0)->sort([~'Legal Name'->ascending()])->toString());
}

// =============================================================================
// Union source + exists() filter
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testUnionWithExistsFilter():Boolean[1]
{
  let fullTimeCsv =
    'default\n' +
    'fullTimeTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,25\n';

  let contractCsv =
    'default\n' +
    'contractTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '3,Charlie,Brown,2,35\n' +
    '4,Diana,White,3,22\n';

  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n' +
    '3,Meta,,,\n';

  let db = meta::relational::tests::mapping::modelJoin::union::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$fullTimeCsv, $contractCsv, $firmCsv], $db, $runtime);

  let result = execute(
    |Firm.all()
      ->filter(f|$f.employees->exists(e|$e.age > 30))
      ->project(
        ~[
          'Legal Name': x|$x.legalName,
          'Employee First Name': x|$x.employees.firstName
         ]
      ),
    meta::relational::tests::mapping::modelJoin::union::UnionWithExistsMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "root".LEGALNAME as "Legal Name", "unionalias_0"."fullTimeTableFIRSTNAME_contractTableFIRSTNAME" as "Employee First Name" ' +
    'from firmTable as "root" left outer join (select "root".FIRMID as firmId, ' +
    '"root".FIRSTNAME as "fullTimeTableFIRSTNAME_contractTableFIRSTNAME" from fullTimeTable as "root" ' +
    'union all select "root".FIRMID as firmId, "root".FIRSTNAME as "fullTimeTableFIRSTNAME_contractTableFIRSTNAME" ' +
    'from contractTable as "root") as "unionalias_0" on ("unionalias_0".firmId = "root".ID) ' +
    'where exists (select 1 from (select "root".FIRMID as firmId, "root".AGE as "fullTimeTableAGE_contractTableAGE" ' +
    'from fullTimeTable as "root" union all select "root".FIRMID as firmId, ' +
    '"root".AGE as "fullTimeTableAGE_contractTableAGE" from contractTable as "root") as "unionalias_1" ' +
    'where "unionalias_1".firmId = "root".ID and "unionalias_1"."fullTimeTableAGE_contractTableAGE" > 30)';
  assertEquals($expectedSql, $result->sql());

  assertEquals( '#TDS\n' +
            '   \'Legal Name\',\'Employee First Name\'\n' +
            '   Google,Charlie\n' +
            '#',
            $result.values->at(0)->sort([~'Legal Name'->ascending()])->toString());
}
// =============================================================================
// Union-mapped properties in condition (all unions)
// =============================================================================
function <<test.ToFix, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testUnionPropertyInCondition():Boolean[1]
{
  let fullTimeCsv =
    'default\n' +
    'fullTimeTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n';
  let contractCsv =
    'default\n' +
    'contractTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '2,Bob,Jones,2,25\n';
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n';
  let firmBCsv =
    'default\n' +
    'firmTableB\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '2,Google,,,\n';
  let addrACsv =
    'default\n' +
    'addressTableA\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n';
  let addrBCsv =
    'default\n' +
    'addressTableB\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '2,2,London,UK\n';
  let hqACsv =
    'default\n' +
    'hqTableA\n' +
    'ID,FIRMID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n';
  let hqBCsv =
    'default\n' +
    'hqTableB\n' +
    'ID,FIRMID,CITY,COUNTRY\n' +
    '2,2,London,UK\n';

  let db = meta::relational::tests::mapping::modelJoin::union::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$fullTimeCsv, $contractCsv, $firmCsv, $firmBCsv, $addrACsv, $addrBCsv, $hqACsv, $hqBCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'Employee First Name': x|$x.employees.firstName
       ]
    ),
    meta::relational::tests::mapping::modelJoin::union::UnionPropertyInConditionMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  assertEquals( '#TDS\n' +
            '   \'Legal Name\',\'Employee First Name\'\n' +
            '   Apple,Alice\n' +
            '   Google,Bob\n' +
            '#',
            $result.values->at(0)->sort([~'Legal Name'->ascending()])->toString());
}
// =============================================================================
// Union with subType in query
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testUnionWithSubtypeQuery():Boolean[1]
{
  let fullTimeCsv =
    'default\n' +
    'fullTimeTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,ACODE,1,30\n';

  let contractCsv =
    'default\n' +
    'contractTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '2,Bob,BCODE,2,25\n';

  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n';

  let firmBCsv =
    'default\n' +
    'firmTableB\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '2,Google,,,\n';

  let db = meta::relational::tests::mapping::modelJoin::union::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$fullTimeCsv, $contractCsv, $firmCsv, $firmBCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'Employee Code': x|$x.employees->subType(@meta::relational::tests::mapping::modelJoin::domain::ExtendedPerson).employeeCode
       ]
    ),
    meta::relational::tests::mapping::modelJoin::union::UnionWithSubtypeQueryMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "unionBase"."firmTableLEGALNAME_firmTableBLEGALNAME" as "Legal Name", ' +
    '"contracttable_0".LASTNAME as "Employee Code" from (select "root".ID as "pk_0_0", null as "pk_0_1", ' +
    '"root".LEGALNAME as "firmTableLEGALNAME_firmTableBLEGALNAME", "root".ID as id from firmTable as "root" ' +
    'union all select null as "pk_0_0", "root".ID as "pk_0_1", ' +
    '"root".LEGALNAME as "firmTableLEGALNAME_firmTableBLEGALNAME", "root".ID as id from firmTableB as "root") as "unionBase" ' +
    'left outer join contractTable as "contracttable_0" on ("contracttable_0".FIRMID = "unionBase".id)';
  assertEquals($expectedSql, $result->sql());

  assertEquals( '#TDS\n' +
            '   \'Legal Name\',\'Employee Code\'\n' +
            '   Apple,TDSNull\n' +
            '   Google,BCODE\n' +
            '#',
            $result.values->at(0)->sort([~'Legal Name'->ascending()])->toString());
}

