// Gap G-5: Binding transformer execution. A JSON string column (FIRM_JSON) is
// decoded through a Binding into a complex Firm[1] property, then navigated.
// (Compile coverage exists via testValidRelationFunctionMappingWithBinding; this
// exercises the execution path.) Reuses the shared Firm class as the bound type.

###ExternalFormat
Binding meta::relational::tests::mapping::relation::coverage::FirmBinding
{
   contentType: 'application/json';
   modelIncludes: [ meta::relational::tests::mapping::relation::Firm ];
}

###Pure
Class meta::relational::tests::mapping::relation::coverage::PersonWithFirmDetails
{
   firstName: String[1];
   firm: meta::relational::tests::mapping::relation::Firm[1];
}

###Pure
import meta::pure::functions::relation::*;
import meta::pure::metamodel::relation::*;
import meta::relational::tests::mapping::relation::coverage::*;

function meta::relational::tests::mapping::relation::coverage::bindingPersonFunc():Relation<Any>[1]
{
   #>{coverageDB.personTable}#
      ->select(~[FIRSTNAME, FIRM_JSON]);
}

###Mapping
import meta::relational::tests::mapping::relation::coverage::*;

Mapping meta::relational::tests::mapping::relation::coverage::bindingMapping
(
   *PersonWithFirmDetails: Relation
   {
      ~func meta::relational::tests::mapping::relation::coverage::bindingPersonFunc():Relation<Any>[1]
      firstName: FIRSTNAME,
      firm: Binding meta::relational::tests::mapping::relation::coverage::FirmBinding : FIRM_JSON
   }
)

###Pure
import meta::relational::functions::asserts::*;
import meta::relational::tests::mapping::relation::coverage::*;
import meta::pure::functions::relation::*;
import meta::external::store::relational::tests::*;

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testBindingDecodesComplexProperty():Boolean[1]
{
   let result = execute(
      |PersonWithFirmDetails.all()->project(~[firstName:p|$p.firstName, legalName:p|$p.firm.legalName]),
      bindingMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions());
   assertEquals(
     #TDS
        firstName, legalName
        Anthony, Firm A
        Jane, Firm A
        John, Firm X
        Peter, Firm X
     #->toString(),
     $result.values->at(0)->sort([~firstName->ascending()])->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testBindingFilterOnDecodedProperty():Boolean[1]
{
   let result = execute(
      |PersonWithFirmDetails.all()->filter(p|$p.firm.legalName == 'Firm X')->project(~[firstName:p|$p.firstName]),
      bindingMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions());
   assertEquals(
     #TDS
        firstName
        John
        Peter
     #->toString(),
     $result.values->at(0)->sort([~firstName->ascending()])->toString());
}
