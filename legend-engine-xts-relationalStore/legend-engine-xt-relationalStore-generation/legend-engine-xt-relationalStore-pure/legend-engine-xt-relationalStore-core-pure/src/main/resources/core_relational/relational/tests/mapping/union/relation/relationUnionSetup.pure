Mapping meta::relational::tests::mapping::union::relation::mapping::unionOfTwoRelationMappings
(
   *Person : Operation
   {
      meta::pure::router::operations::union_OperationSetImplementation_1__SetImplementation_MANY_(rfSet1, rfSet2)
   }

   Person[rfSet1] : Relation
   {
      ~func meta::relational::tests::mapping::union::relation::personSet1Func():Relation<Any>[1]
      lastName: lastName_s1
   }

   Person[rfSet2] : Relation
   {
      ~func meta::relational::tests::mapping::union::relation::personSet2Func():Relation<Any>[1]
      lastName: lastName_s2
   }
)

Mapping meta::relational::tests::mapping::union::relation::mapping::unionOfRelationAndRelationalMappings
(
   *Person : Operation
   {
      meta::pure::router::operations::union_OperationSetImplementation_1__SetImplementation_MANY_(rfSet1, relSet2)
   }

   Person[rfSet1] : Relation
   {
      ~func meta::relational::tests::mapping::union::relation::personSet1Func():Relation<Any>[1]
      lastName: lastName_s1
   }

   Person[relSet2] : Relational
   {
      ~primaryKey
      (
         [myDB]PersonSet2.ID
      )
      ~mainTable [myDB]PersonSet2
      lastName: [myDB]PersonSet2.lastName_s2
   }
)

Mapping meta::relational::tests::mapping::union::relation::mapping::unionOfRelationAndRelationalMappingsWithFirm
(
   *Person : Operation
   {
      meta::pure::router::operations::union_OperationSetImplementation_1__SetImplementation_MANY_(rfSet1, relSet2)
   }

   Person[rfSet1] : Relation
   {
      ~func meta::relational::tests::mapping::union::relation::advanced::personSet1WithFirmIdFunc():Relation<Any>[1]
      lastName: lastName_s1,
      +firmId: Integer[1]: FirmID
   }

   Person[relSet2] : Relational
   {
      ~primaryKey
      (
         [myDB]PersonSet2.ID
      )
      ~mainTable [myDB]PersonSet2
      lastName: [myDB]PersonSet2.lastName_s2,
      +firmId: Integer[1]: [myDB]PersonSet2.FirmID
   }

   *Firm[firm] : Relational
   {
      ~primaryKey
      (
         [myDB]Firm.ID
      )
      ~mainTable [myDB]Firm
      legalName: [myDB]Firm.name,
      +id: Integer[1]: [myDB]Firm.ID
   }

   Employment: ModelJoin
   {
      {employees: meta::relational::tests::model::simple::Person[1], firm: meta::relational::tests::model::simple::Firm[1]|$employees.firmId == $firm.id}
   }
)

