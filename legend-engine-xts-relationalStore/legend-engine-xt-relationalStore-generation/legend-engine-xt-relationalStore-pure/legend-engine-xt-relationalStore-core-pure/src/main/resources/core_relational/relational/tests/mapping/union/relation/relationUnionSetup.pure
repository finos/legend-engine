###Pure
import meta::relational::tests::mapping::union::*;
import meta::pure::metamodel::relation::*;

function <<test.BeforePackage>> meta::relational::tests::mapping::union::relation::setUp():Boolean[1]
{
   meta::relational::tests::mapping::union::createTablesAndFillDb();
}

function meta::relational::tests::mapping::union::relation::personSet1Func():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.PersonSet1}#->select(~[lastName_s1]);
}

function meta::relational::tests::mapping::union::relation::personSet2Func():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.PersonSet2}#->select(~[lastName_s2]);
}

function meta::relational::tests::mapping::union::relation::personSet1FirmXOnlyFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.PersonSet1}#->filter(r | $r.FirmID == 1)->select(~[lastName_s1]);
}

function meta::relational::tests::mapping::union::relation::personSet1WithPrefixFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.PersonSet1}#
      ->extend(~prefixedLastName:r | '1' + $r.lastName_s1->toOne())
      ->select(~[prefixedLastName]);
}

function meta::relational::tests::mapping::union::relation::personSet2WithPrefixFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.PersonSet2}#
      ->extend(~prefixedLastName:r | '2' + $r.lastName_s2->toOne())
      ->select(~[prefixedLastName]);
}

function meta::relational::tests::mapping::union::relation::personSet1WithConstantFirstNameFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.PersonSet1}#
      ->extend(~firstName:r | 'Bob')
      ->select(~[lastName_s1, firstName]);
}

function meta::relational::tests::mapping::union::relation::personSet2WithConstantFirstNameFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.PersonSet2}#
      ->extend(~firstName:r | 'George')
      ->select(~[lastName_s2, firstName]);
}

function meta::relational::tests::mapping::union::relation::personSet1WithEmbeddedFirmFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.PersonSet1}#
      ->join(
         #>{meta::relational::tests::mapping::union::myDB.Firm}#
            ->extend(~[firmId:r|$r.ID, firmName:r|$r.name])
            ->select(~[firmId, firmName]),
         JoinKind.LEFT,
         {p, f | $p.FirmID == $f.firmId}
      )
      ->select(~[lastName_s1, firmName]);
}

function meta::relational::tests::mapping::union::relation::personSet2WithEmbeddedFirmFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.PersonSet2}#
      ->join(
         #>{meta::relational::tests::mapping::union::myDB.Firm}#
            ->extend(~[firmId:r|$r.ID, firmName:r|$r.name])
            ->select(~[firmId, firmName]),
         JoinKind.LEFT,
         {p, f | $p.FirmID == $f.firmId}
      )
      ->select(~[lastName_s2, firmName]);
}

function meta::relational::tests::mapping::union::relation::addressSet1WithTypeFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.AddressSet1}#
      ->extend(~city_REGION:r | 'CITY')
      ->select(~[name, city_REGION]);
}

function meta::relational::tests::mapping::union::relation::addressSet2WithTypeFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.AddressSet2}#
      ->extend(~city_REGION:r | 'REGION')
      ->select(~[name, city_REGION]);
}

