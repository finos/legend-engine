// Gap G-7: graph fetch / serialize over a simple relation mapping (all existing
// relation tests use TDS ->project()). Queries are filtered to a single object to
// keep serialized output deterministic. Reuses the shared Person class.

###Pure
import meta::pure::functions::relation::*;
import meta::pure::metamodel::relation::*;
import meta::relational::tests::mapping::relation::coverage::*;

function meta::relational::tests::mapping::relation::coverage::graphFetchPersonFunc():Relation<Any>[1]
{
   #>{coverageDB.personTable}#
      ->select(~[FIRSTNAME, AGE]);
}

###Mapping
import meta::relational::tests::mapping::relation::*;
import meta::relational::tests::mapping::relation::coverage::*;

Mapping meta::relational::tests::mapping::relation::coverage::graphFetchMapping
(
   *Person: Relation
   {
      ~func meta::relational::tests::mapping::relation::coverage::graphFetchPersonFunc():Relation<Any>[1]
      ~primaryKey: [FIRSTNAME]
      firstName: FIRSTNAME,
      age: AGE
   }
)

###Pure
import meta::relational::functions::asserts::*;
import meta::relational::tests::mapping::relation::*;
import meta::relational::tests::mapping::relation::coverage::*;
import meta::external::store::relational::tests::*;

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testGraphFetchSimple():Boolean[1]
{
   let result = execute(
      |Person.all()->filter(p|$p.firstName == 'Peter')
         ->meta::pure::graphFetch::execution::graphFetch(#{meta::relational::tests::mapping::relation::Person{firstName, age}}#)
         ->meta::pure::graphFetch::execution::serialize(#{meta::relational::tests::mapping::relation::Person{firstName, age}}#),
      graphFetchMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions());
   assertEquals('[{"firstName":"Peter","age":23}]', $result.values->toOne());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testGraphFetchWithFilter():Boolean[1]
{
   let result = execute(
      |Person.all()->filter(p|$p.age > 35)
         ->meta::pure::graphFetch::execution::graphFetch(#{meta::relational::tests::mapping::relation::Person{firstName, age}}#)
         ->meta::pure::graphFetch::execution::serialize(#{meta::relational::tests::mapping::relation::Person{firstName, age}}#),
      graphFetchMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions());
   assertEquals('[{"firstName":"Anthony","age":40}]', $result.values->toOne());
}
