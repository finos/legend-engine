// =============================================================================
// Filter on target: ~filter AGE > 25, so Bob (age=20) is excluded.
//
// Expected: Apple→Alice only, Google→Charlie.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testFilterOnTarget():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,20\n' +
    '3,Charlie,Brown,2,35\n';

  let db = meta::relational::tests::mapping::modelJoin::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$firmCsv, $personCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'Employee First Name': x|$x.employees.firstName
       ]
    ),
    FilterOnTargetMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "root".LEGALNAME as "Legal Name", "persontable_0".FIRSTNAME as "Employee First Name" ' +
    'from firmTable as "root" ' +
    'left outer join (select "root".FIRSTNAME as "firstName", "root".LASTNAME as "lastName", "root".AGE as "age", ' +
         '"root".ID as "id", "root".FIRMID as "firmId", "root".FIRMID as FIRMID, "root".FIRSTNAME as FIRSTNAME ' +
         'from personTable as "root" where "root".AGE > 25) as "persontable_0" ' +
    'on ("persontable_0".FIRMID = "root".ID)';
  assertEquals($expectedSql, $result->sql());

  assertEquals(
    #TDS
       'Legal Name', 'Employee First Name'
       Apple, Alice
       Google, Charlie
    #->toString(),
    $result.values->at(0)->sort([~'Legal Name'->ascending(), ~'Employee First Name'->ascending()])->toString());
}

// =============================================================================
// Filter on target + nested condition: ~filter AGE>25, condition via address.city
//
// Expected: Bob excluded (age=20). Alice(NYC)→Apple, Charlie(SF)→Google.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testFilterOnTargetNestedCondition():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,NYC,\n' +
    '2,Google,,SF,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,20\n' +
    '3,Charlie,Brown,2,35\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,NYC,US\n' +
    '3,3,SF,US\n';

  let db = meta::relational::tests::mapping::modelJoin::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$firmCsv, $personCsv, $addressCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'Employee First Name': x|$x.employees.firstName
       ]
    ),
    FilterOnTargetNestedConditionMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "root".LEGALNAME as "Legal Name", "persontable_0".FIRSTNAME as "Employee First Name" ' +
    'from firmTable as "root" ' +
    'left outer join (select "root".FIRSTNAME as "firstName", "root".LASTNAME as "lastName", "root".AGE as "age", ' +
         '"root".ID as "id", "root".FIRMID as "firmId", "addresstable_0".CITY as CITY, "root".FIRSTNAME as FIRSTNAME ' +
         'from personTable as "root" left outer join addressTable as "addresstable_0" ' +
         'on ("root".ID = "addresstable_0".PERSONID) where "root".AGE > 25) as "persontable_0" ' +
    'on ("persontable_0".CITY = "root".CITY)';
  assertEquals($expectedSql, $result->sql());

  assertEquals(
    #TDS
       'Legal Name', 'Employee First Name'
       Apple, Alice
       Google, Charlie
    #->toString(),
    $result.values->at(0)->sort([~'Legal Name'->ascending(), ~'Employee First Name'->ascending()])->toString());
}

