// =============================================================================
// Filter with INNER join on target: PersonProfile inner join + ProfileRankFilter.
// Only persons with profile rank='US' pass.
//
// Expected: Alice(US)→Apple, Charlie(US)→Google. Bob(UK) excluded.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testFilterWithInnerJoinOnTarget():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,25\n' +
    '3,Charlie,Brown,2,35\n';

  let profileCsv =
    'default\n' +
    'profileTable\n' +
    'ID,PERSONID,RANK\n' +
    '1,1,US\n' +
    '2,2,UK\n' +
    '3,3,US\n';

  let db = meta::relational::tests::mapping::modelJoin::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$firmCsv, $personCsv, $profileCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'Employee First Name': x|$x.employees.firstName
       ]
    ),
    FilterWithInnerJoinOnTargetMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "root".LEGALNAME as "Legal Name", "persontable_0".FIRSTNAME as "Employee First Name" ' +
    'from firmTable as "root" ' +
    'left outer join (select "root".FIRSTNAME as "firstName", "root".LASTNAME as "lastName", "root".AGE as "age", ' +
         '"root".ID as "id", "root".FIRMID as "firmId", "root".FIRMID as FIRMID, "root".FIRSTNAME as FIRSTNAME ' +
         'from (select "root".ID as ID, "root".FIRSTNAME as FIRSTNAME, "root".LASTNAME as LASTNAME, ' +
         '"root".FIRMID as FIRMID, "root".AGE as AGE from personTable as "root" ' +
         'inner join profileTable as "profiletable_0" on ("root".ID = "profiletable_0".PERSONID) ' +
         'where "profiletable_0".RANK = \'US\') as "root") as "persontable_0" ' +
    'on ("persontable_0".FIRMID = "root".ID)';
  assertEquals($expectedSql, $result->sql());

  assertEquals(
    #TDS
       'Legal Name', 'Employee First Name'
       Apple, Alice
       Google, Charlie
    #->toString(),
    $result.values->at(0)->sort([~'Legal Name'->ascending(), ~'Employee First Name'->ascending()])->toString());
}

// =============================================================================
// Complex relation function: join via nested address city
//
// Expected: Apple←Alice (NYC), Google←Bob,Charlie (London).
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testComplexRelationFunction():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,NYC,US\n' +
    '2,Google,,London,UK\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,25\n' +
    '3,Charlie,Brown,2,35\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n' +
    '3,3,London,UK\n';

  let db = meta::relational::tests::mapping::modelJoin::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$firmCsv, $personCsv, $addressCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'Employee First Name': x|$x.employees.firstName
       ]
    ),
    meta::relational::tests::mapping::modelJoin::advanced::ComplexRelationFunctionMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "firmtable_0".LEGALNAME as "Legal Name", "persontable_0"."FIRSTNAME" as "Employee First Name" ' +
    'from (select "firmtable_1".ID as ID, "firmtable_1".LEGALNAME as LEGALNAME, "firmtable_1".CITY as CITY, ' +
    '"firmtable_1".COUNTRY as COUNTRY, "firmtable_1".CODE as CODE from firmTable as "firmtable_1") as "firmtable_0" ' +
    'left outer join (select "persontable_1"."ID" as "ID", "persontable_1"."FIRSTNAME" as "FIRSTNAME", ' +
    '"persontable_1"."LASTNAME" as "LASTNAME", "persontable_1"."FIRMID" as "FIRMID", "persontable_1"."AGE" as "AGE", ' +
    '"persontable_1"."CITY" as "CITY", "persontable_1"."COUNTRY" as "COUNTRY" from (select * from ' +
    '(select "persontable_3".ID as "ID", "persontable_3".FIRSTNAME as "FIRSTNAME", "persontable_3".LASTNAME as "LASTNAME", ' +
    '"persontable_3".FIRMID as "FIRMID", "persontable_3".AGE as "AGE" from personTable as "persontable_3") as "persontable_2" ' +
    'left outer join (select "addresstable_1".PERSONID as "PERSONID", "addresstable_1".CITY as "CITY", ' +
    '"addresstable_1".COUNTRY as "COUNTRY" from addressTable as "addresstable_1") as "addresstable_0" ' +
    'on ("persontable_2"."ID" = "addresstable_0"."PERSONID")) as "persontable_1") as "persontable_0" ' +
    'on ("persontable_0"."CITY" = "firmtable_0".CITY)';
  assertEquals($expectedSql, $result->sql());

  assertEquals(
    #TDS
       'Legal Name', 'Employee First Name'
       Apple, Alice
       Google, Bob
       Google, Charlie
    #->toString(),
    $result.values->at(0)->sort([~'Legal Name'->ascending(), ~'Employee First Name'->ascending()])->toString());
}

