function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testSubAggregationRelational():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,25\n' +
    '3,Charlie,Brown,2,35\n';

  let db = meta::relational::tests::mapping::modelJoin::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$firmCsv, $personCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'Employee Count': x|$x.employees->count()
       ]
    ),
    meta::relational::tests::mapping::modelJoin::advanced::RelationalSimpleEqualityMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "root".LEGALNAME as "Legal Name", "firmtable_1".aggCol as "Employee Count" ' +
    'from firmTable as "root" left outer join (select "firmtable_2".ID as ID, count(*) as aggCol ' +
    'from firmTable as "firmtable_2" left outer join personTable as "persontable_0" ' +
    'on ("persontable_0".FIRMID = "firmtable_2".ID) group by "firmtable_2".ID) as "firmtable_1" ' +
    'on ("root".ID = "firmtable_1".ID)';
  assertEquals($expectedSql, $result->sql());

  assertEquals(
    #TDS
       'Legal Name', 'Employee Count'
       Apple, 2
       Google, 1
    #->toString(),
    $result.values->at(0)->sort([~'Legal Name'->ascending()])->toString());
}