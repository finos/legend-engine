// =============================================================================
// Column collision in materializeTargetAsSubselect
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testColumnCollisionInSubselect():Boolean[1]
{
  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,2,25\n';

  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,NYC,US\n' +
    '2,Google,,London,UK\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n';

  let hqCsv =
    'default\n' +
    'headquartersTable\n' +
    'ID,FIRMID,CITY,COUNTRY\n' +
    '1,1,US,\n' +
    '2,2,UK,\n';

  let db = meta::relational::tests::mapping::modelJoin::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$personCsv, $firmCsv, $addressCsv, $hqCsv], $db, $runtime);

  let result = execute(
    |Person.all()->project(
      ~[
        'First Name': x|$x.firstName,
        'Firm Name': x|$x.firm.legalName
       ]
    ),
    meta::relational::tests::mapping::modelJoin::advanced::ColumnCollisionMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "root".FIRSTNAME as "First Name", "firmtable_0".LEGALNAME as "Firm Name" ' +
    'from personTable as "root" left outer join addressTable as "addresstable_0" ' +
    'on ("root".ID = "addresstable_0".PERSONID) left outer join (select "root".LEGALNAME as "legalName", ' +
    '"root".CITY as "city", "root".ID as "id", "root".CITY as CITY, "headquarterstable_0".CITY as CITY_1, ' +
    '"root".LEGALNAME as LEGALNAME from firmTable as "root" left outer join headquartersTable as "headquarterstable_0" ' +
    'on ("root".ID = "headquarterstable_0".FIRMID)) as "firmtable_0" ' +
    'on ("addresstable_0".CITY = "firmtable_0".CITY and "addresstable_0".COUNTRY = "firmtable_0".CITY_1)';
  assertEquals($expectedSql, $result->sql());

  assertEquals(
    #TDS
       'First Name', 'Firm Name'
       Alice, Apple
       Bob, Google
    #->toString(),
    $result.values->at(0)->sort([~'First Name'->ascending()])->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testNestedModelJoinCompoundInnerCondition():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let profileCsv =
    'default\n' +
    'profileTable\n' +
    'ID,PERSONID,RANK\n' +
    '1,1,US\n' +
    '2,2,UK\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n' +
    '3,3,Paris,FR\n';

  let hqCsv =
    'default\n' +
    'headquartersTable\n' +
    'ID,FIRMID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n';

  let db = meta::relational::tests::mapping::modelJoin::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$firmCsv, $personCsv, $profileCsv, $addressCsv, $hqCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'Employee First Name': x|$x.employees.firstName
       ]
    ),
    meta::relational::tests::mapping::modelJoin::advanced::NestedModelJoinWithPropertyAccess,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  assertEquals(
    #TDS
       'Legal Name', 'Employee First Name'
       Apple, Alice
       Google, Bob
    #->toString(),
    $result.values->at(0)->sort([~'Legal Name'->ascending()])->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testSubFilter():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,NYC,US\n' +
    '2,Google,,London,UK\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n' +
    '3,3,NYC,US\n';

  let db = meta::relational::tests::mapping::modelJoin::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$firmCsv, $personCsv, $addressCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'NYC Employee': x|$x.employees->filter(e|$e.address.city == 'NYC').firstName
       ]
    ),
    meta::relational::tests::mapping::modelJoin::advanced::NestedPropertyChainMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  assertEquals(
    #TDS
       'Legal Name', 'NYC Employee'
       Apple, Alice
       Apple, Charlie
       Google, TDSNull
    #->toString(),
    $result.values->at(0)->sort([~'Legal Name'->ascending(), ~'NYC Employee'->ascending()])->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testSubAggregation():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,25\n' +
    '3,Charlie,Brown,2,35\n';

  let db = meta::relational::tests::mapping::modelJoin::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$firmCsv, $personCsv], $db, $runtime);
  
  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'Employee Count': x|$x.employees->count()
       ]
    ),
    meta::relational::tests::mapping::modelJoin::simple::SimpleEqualityMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  assertEquals(
    #TDS
       'Legal Name', 'Employee Count'
       Apple, 2
       Google, 1
    #->toString(),
    $result.values->at(0)->sort([~'Legal Name'->ascending()])->toString());
}

