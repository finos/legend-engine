// =============================================================================
// Nested property chain: employees.address.city == firm.city && ...country
//
// Expected: Match via nested address city/country — Alice→Apple, Bob→Google.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testNestedPropertyChain():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,NYC,US\n' +
    '2,Google,,London,UK\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n' +
    '3,3,Paris,FR\n';

  let db = meta::relational::tests::mapping::modelJoin::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$firmCsv, $personCsv, $addressCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'Employee First Name': x|$x.employees.firstName
       ]
    ),
    NestedPropertyChainMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "firmtable_0".LEGALNAME as "Legal Name", "persontable_0".FIRSTNAME as "Employee First Name" ' +
    'from (select "firmtable_1".ID as ID, "firmtable_1".LEGALNAME as LEGALNAME, "firmtable_1".CITY as CITY, ' +
         '"firmtable_1".COUNTRY as COUNTRY, "firmtable_1".CODE as CODE from firmTable as "firmtable_1") as "firmtable_0" ' +
    'left outer join ' +
        '(select "addresstable_0".CITY as CITY, "addresstable_0".COUNTRY as COUNTRY, "persontable_1".FIRSTNAME as FIRSTNAME ' +
         'from (select "persontable_2".ID as ID, "persontable_2".FIRSTNAME as FIRSTNAME, "persontable_2".LASTNAME as LASTNAME, ' +
              '"persontable_2".FIRMID as FIRMID, "persontable_2".AGE as AGE from personTable as "persontable_2") as "persontable_1" ' +
         'left outer join (select "addresstable_1".ID as ID, "addresstable_1".PERSONID as PERSONID, "addresstable_1".CITY as CITY, ' +
              '"addresstable_1".COUNTRY as COUNTRY from addressTable as "addresstable_1") as "addresstable_0" ' +
         'on ("persontable_1".ID = "addresstable_0".PERSONID)) as "persontable_0" ' +
    'on ("persontable_0".CITY = "firmtable_0".CITY and "persontable_0".COUNTRY = "firmtable_0".COUNTRY)';
  assertEquals($expectedSql, $result->sql());

  assertEquals(
    #TDS
       'Legal Name', 'Employee First Name'
       Apple, Alice
       Google, Bob
    #->toString(),
    $result.values->at(0)->sort([~'Legal Name'->ascending(), ~'Employee First Name'->ascending()])->toString());
}

// =============================================================================
// Double-nested both sides: employees.address.city == firm.headquarters.city
//
// Expected: Alice(addr=NYC)→Apple(HQ=NYC), Bob(addr=London)→Google(HQ=London).
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testDoubleNestedBothSides():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n' +
    '3,3,Paris,FR\n';

  let hqCsv =
    'default\n' +
    'headquartersTable\n' +
    'ID,FIRMID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n';

  let db = meta::relational::tests::mapping::modelJoin::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$firmCsv, $personCsv, $addressCsv, $hqCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'Employee First Name': x|$x.employees.firstName
       ]
    ),
    DoubleNestedModelJoinMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "firmtable_0".LEGALNAME as "Legal Name", "persontable_0".FIRSTNAME as "Employee First Name" ' +
    'from (select "firmtable_1".ID as ID, "firmtable_1".LEGALNAME as LEGALNAME, "firmtable_1".CITY as CITY, ' +
         '"firmtable_1".COUNTRY as COUNTRY, "firmtable_1".CODE as CODE from firmTable as "firmtable_1") as "firmtable_0" ' +
    'left outer join (select "addresstable_1".ID as ID, "addresstable_1".FIRMID as FIRMID, "addresstable_1".CITY as CITY, ' +
         '"addresstable_1".COUNTRY as COUNTRY from headquartersTable as "addresstable_1") as "headquarterstable_0" ' +
    'on ("firmtable_0".ID = "headquarterstable_0".FIRMID) ' +
    'left outer join ' +
        '(select "addresstable_0".CITY as CITY, "persontable_1".FIRSTNAME as FIRSTNAME ' +
         'from (select "persontable_2".ID as ID, "persontable_2".FIRSTNAME as FIRSTNAME, "persontable_2".LASTNAME as LASTNAME, ' +
              '"persontable_2".FIRMID as FIRMID, "persontable_2".AGE as AGE from personTable as "persontable_2") as "persontable_1" ' +
         'left outer join (select "addresstable_1".ID as ID, "addresstable_1".PERSONID as PERSONID, "addresstable_1".CITY as CITY, ' +
              '"addresstable_1".COUNTRY as COUNTRY from addressTable as "addresstable_1") as "addresstable_0" ' +
         'on ("persontable_1".ID = "addresstable_0".PERSONID)) as "persontable_0" ' +
    'on ("persontable_0".CITY = "headquarterstable_0".CITY)';
  assertEquals($expectedSql, $result->sql());

  assertEquals(
    #TDS
       'Legal Name', 'Employee First Name'
       Apple, Alice
       Google, Bob
    #->toString(),
    $result.values->at(0)->sort([~'Legal Name'->ascending(), ~'Employee First Name'->ascending()])->toString());
}

// =============================================================================
// Chained two-hop: Firm→Department→Project
//
// Expected: Apple→ProjectX, ProjectY (via Engineering) + null (via Marketing).
//   Google→ProjectZ (via Research).
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testChainedTwoHops():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let deptCsv =
    'default\n' +
    'departmentTable\n' +
    'ID,FIRMID,NAME,CODE\n' +
    '10,1,Engineering,ENG\n' +
    '20,1,Marketing,MKT\n' +
    '30,2,Research,RES\n';

  let projectCsv =
    'default\n' +
    'projectTable\n' +
    'ID,DEPTID,NAME,CITY\n' +
    '100,10,ProjectX,NYC\n' +
    '200,10,ProjectY,LA\n' +
    '300,30,ProjectZ,London\n';

  let db = meta::relational::tests::mapping::modelJoin::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$firmCsv, $deptCsv, $projectCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'Project Name': x|$x.departments.projects.name
       ]
    ),
    ChainedTwoHopsMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "firmtable_0".LEGALNAME as "Legal Name", "projecttable_0".NAME as "Project Name" ' +
    'from (select "firmtable_1".ID as ID, "firmtable_1".LEGALNAME as LEGALNAME, "firmtable_1".CITY as CITY, ' +
         '"firmtable_1".COUNTRY as COUNTRY, "firmtable_1".CODE as CODE from firmTable as "firmtable_1") as "firmtable_0" ' +
    'left outer join (select "departmenttable_1".ID as ID, "departmenttable_1".FIRMID as FIRMID, "departmenttable_1".NAME as NAME, ' +
         '"departmenttable_1".CODE as CODE from departmentTable as "departmenttable_1") as "departmenttable_0" ' +
    'on ("firmtable_0".ID = "departmenttable_0".FIRMID) ' +
    'left outer join (select "projecttable_1".ID as ID, "projecttable_1".DEPTID as DEPTID, "projecttable_1".NAME as NAME, ' +
         '"projecttable_1".CITY as CITY from projectTable as "projecttable_1") as "projecttable_0" ' +
    'on ("departmenttable_0".ID = "projecttable_0".DEPTID)';
  assertEquals($expectedSql, $result->sql());

  assertEquals(
    #TDS
       'Legal Name', 'Project Name'
       Apple, TDSNull
       Apple, ProjectY
       Apple, ProjectX
       Google, ProjectZ
    #->toString(),
    $result.values->at(0)->sort([~'Legal Name'->ascending(), ~'Project Name'->descending()])->toString());
}

// =============================================================================
// Direct single-hop property access: Person.all()->project(~[firstName, address.city])
//
// Expected: Alice→NYC, Bob→London, Charlie→null.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testDirectPropertyAccess():Boolean[1]
{
  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n';

  let db = meta::relational::tests::mapping::modelJoin::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$personCsv, $addressCsv], $db, $runtime);

  let result = execute(
    |Person.all()->project(
      ~[
        'First Name': x|$x.firstName,
        'City': x|$x.address.city
       ]
    ),
    NestedPropertyChainMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "persontable_0".FIRSTNAME as "First Name", "addresstable_0".CITY as "City" ' +
    'from (select "persontable_1".ID as ID, "persontable_1".FIRSTNAME as FIRSTNAME, "persontable_1".LASTNAME as LASTNAME, ' +
         '"persontable_1".FIRMID as FIRMID, "persontable_1".AGE as AGE from personTable as "persontable_1") as "persontable_0" ' +
    'left outer join (select "addresstable_1".ID as ID, "addresstable_1".PERSONID as PERSONID, "addresstable_1".CITY as CITY, ' +
         '"addresstable_1".COUNTRY as COUNTRY from addressTable as "addresstable_1") as "addresstable_0" ' +
    'on ("persontable_0".ID = "addresstable_0".PERSONID)';
  assertEquals($expectedSql, $result->sql());

  assertEquals(
    #TDS
       'First Name', City
       Alice, NYC
       Bob, London
       Charlie, TDSNull
    #->toString(),
    $result.values->at(0)->sort([~'First Name'->ascending()])->toString());
}

// =============================================================================
// Filter on double-nested model-join property:
//   Firm.all()->filter(f | f.headquarters.city == 'NYC')->project(~[legalName])
//
// Expected: Only Apple (HQ in NYC) passes.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testNestedInFilter():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n' +
    '3,Meta,,,\n';

  let hqCsv =
    'default\n' +
    'headquartersTable\n' +
    'ID,FIRMID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n';

  let db = meta::relational::tests::mapping::modelJoin::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$firmCsv, $hqCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->filter(f|$f.headquarters.city == 'NYC')->project(
      ~[
        'Legal Name': x|$x.legalName
       ]
    ),
    DoubleNestedModelJoinMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "firmtable_0".LEGALNAME as "Legal Name" ' +
    'from (select "firmtable_1".ID as ID, "firmtable_1".LEGALNAME as LEGALNAME, "firmtable_1".CITY as CITY, ' +
         '"firmtable_1".COUNTRY as COUNTRY, "firmtable_1".CODE as CODE from firmTable as "firmtable_1") as "firmtable_0" ' +
    'left outer join (select "headquarterstable_1".ID as ID, "headquarterstable_1".FIRMID as FIRMID, ' +
         '"headquarterstable_1".CITY as CITY, "headquarterstable_1".COUNTRY as COUNTRY ' +
         'from headquartersTable as "headquarterstable_1") as "headquarterstable_0" ' +
    'on ("firmtable_0".ID = "headquarterstable_0".FIRMID) ' +
    'where "headquarterstable_0".CITY = \'NYC\'';
  assertEquals($expectedSql, $result->sql());

  assertEquals(
    #TDS
       'Legal Name'
       Apple
    #->toString(),
    $result.values->at(0)->toString());
}

// =============================================================================
// Relational nested property chain: same as testNestedPropertyChain but with
// Relational class mappings.
//
// Expected: Alice→Apple, Bob→Google (same logic).
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testRelationalNestedPropertyChain():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,NYC,US\n' +
    '2,Google,,London,UK\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n' +
    '3,3,Paris,FR\n';

  let db = meta::relational::tests::mapping::modelJoin::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$firmCsv, $personCsv, $addressCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'Employee First Name': x|$x.employees.firstName
       ]
    ),
    RelationalNestedPropertyChainMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "root".LEGALNAME as "Legal Name", "persontable_0".FIRSTNAME as "Employee First Name" ' +
    'from firmTable as "root" ' +
    'left outer join (select "root".FIRSTNAME as "firstName", "root".LASTNAME as "lastName", "root".AGE as "age", ' +
         '"root".ID as "id", "root".FIRMID as "firmId", "addresstable_0".CITY as CITY, "addresstable_0".COUNTRY as COUNTRY, ' +
         '"root".FIRSTNAME as FIRSTNAME from personTable as "root" ' +
         'left outer join addressTable as "addresstable_0" on ("root".ID = "addresstable_0".PERSONID)) as "persontable_0" ' +
    'on ("persontable_0".CITY = "root".CITY and "persontable_0".COUNTRY = "root".COUNTRY)';
  assertEquals($expectedSql, $result->sql());

  assertEquals(
    #TDS
       'Legal Name', 'Employee First Name'
       Apple, Alice
       Google, Bob
    #->toString(),
    $result.values->at(0)->sort([~'Legal Name'->ascending(), ~'Employee First Name'->ascending()])->toString());
}

// =============================================================================
// Relational double-nested both sides: employees.address.city == firm.headquarters.city
//
// Expected: Alice→Apple, Bob→Google.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::advanced::testRelationalDoubleNestedBothSides():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n' +
    '3,3,Paris,FR\n';

  let hqCsv =
    'default\n' +
    'headquartersTable\n' +
    'ID,FIRMID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n';

  let db = meta::relational::tests::mapping::modelJoin::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$firmCsv, $personCsv, $addressCsv, $hqCsv], $db, $runtime);

  let result = execute(
    |Firm.all()->project(
      ~[
        'Legal Name': x|$x.legalName,
        'Employee First Name': x|$x.employees.firstName
       ]
    ),
    RelationalDoubleNestedMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "root".LEGALNAME as "Legal Name", "persontable_0".FIRSTNAME as "Employee First Name" ' +
    'from firmTable as "root" ' +
    'left outer join headquartersTable as "headquarterstable_0" on ("root".ID = "headquarterstable_0".FIRMID) ' +
    'left outer join (select "root".FIRSTNAME as "firstName", "root".LASTNAME as "lastName", "root".AGE as "age", ' +
         '"root".ID as "id", "root".FIRMID as "firmId", "addresstable_0".CITY as CITY, ' +
