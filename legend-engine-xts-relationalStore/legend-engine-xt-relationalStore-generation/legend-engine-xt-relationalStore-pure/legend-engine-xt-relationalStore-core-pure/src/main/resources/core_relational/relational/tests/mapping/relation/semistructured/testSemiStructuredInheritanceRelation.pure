// Translation of tests/semistructured/testSemiStructuredInheritanceMapping.pure to the RFPM
// variant-lift form.
//
// Sources merged:
//   testSemiStructuredInheritanceMapping.pure -> InheritanceSemiStructuredMapping
//     under meta::relational::tests::mapping::relation::semistructured::inheritance::*
//
// Source binding-based mapping replaced by a single lift mapping:
//   firm: $src.FIRM_DETAILS->to(@Firm)->toOne()
// Class hierarchy (Address -> AddressWithLines; AddressLine -> Street/City/StateAddressLine)
// is lifted via SS-embedded; subtype navigation happens in test lambdas via ->subType(@...).
// No DB-level Join; manager self-reference omitted (no tests exercise it).
// Tests parametrized over conn:Connection[1] via <<paramTest.Test>>, mirroring the
// source's relationFunctionMapping:: namespace annotations (all source rfpm variants
// are <<paramTest.Test>>, so all 4 collapsed scenarios are <<paramTest.Test>> here too).


###Relational
Database meta::relational::tests::mapping::relation::semistructured::inheritance::H2DB
(
  Schema PERSON_SCHEMA
  (
    Table PERSON_TABLE
    (
      ID INTEGER PRIMARY KEY,
      FIRSTNAME VARCHAR(100) NOT NULL,
      LASTNAME VARCHAR(100) NOT NULL,
      FIRM_DETAILS SEMISTRUCTURED,
      MANAGERID INTEGER
    )
  )
)


###Pure
import meta::pure::functions::variant::convert::*;
import meta::pure::functions::variant::navigation::*;
import meta::pure::metamodel::variant::*;

Class meta::relational::tests::mapping::relation::semistructured::inheritance::Person
{
  firstName: String[1];
  lastName : String[1];
  firm     : meta::relational::tests::mapping::relation::semistructured::inheritance::Firm[1];
}

Class meta::relational::tests::mapping::relation::semistructured::inheritance::Firm
{
  legalName: String[1];
  address  : meta::relational::tests::mapping::relation::semistructured::inheritance::Address[1];
}

Class meta::relational::tests::mapping::relation::semistructured::inheritance::Address
{
  name: String[1];
}

Class meta::relational::tests::mapping::relation::semistructured::inheritance::AddressWithLines extends meta::relational::tests::mapping::relation::semistructured::inheritance::Address
{
  lines: meta::relational::tests::mapping::relation::semistructured::inheritance::AddressLine[*];
}

Class meta::relational::tests::mapping::relation::semistructured::inheritance::AddressLine
{
  lineno: Integer[1];
}

Class meta::relational::tests::mapping::relation::semistructured::inheritance::StreetAddressLine extends meta::relational::tests::mapping::relation::semistructured::inheritance::AddressLine
{
  street: String[1];
}

Class meta::relational::tests::mapping::relation::semistructured::inheritance::CityAddressLine extends meta::relational::tests::mapping::relation::semistructured::inheritance::AddressLine
{
  city: String[1];
}

Class meta::relational::tests::mapping::relation::semistructured::inheritance::StateAddressLine extends meta::relational::tests::mapping::relation::semistructured::inheritance::AddressLine
{
  state: String[1];
}

function meta::relational::tests::mapping::relation::semistructured::inheritance::personFunction(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::relation::semistructured::inheritance::H2DB.PERSON_SCHEMA.PERSON_TABLE}#
    ->select(~[ID, FIRSTNAME, LASTNAME, FIRM_DETAILS, MANAGERID])
}


###Mapping
import meta::relational::tests::mapping::relation::semistructured::inheritance::*;
import meta::pure::functions::variant::convert::*;
import meta::pure::functions::variant::navigation::*;

Mapping meta::relational::tests::mapping::relation::semistructured::inheritance::InheritanceSemiStructuredMapping
(
  *Person[person]: Relation
  {
    ~func meta::relational::tests::mapping::relation::semistructured::inheritance::personFunction():Relation<Any>[1]
    firstName: FIRSTNAME,
    lastName : LASTNAME,
    firm     : $src.FIRM_DETAILS->to(@meta::relational::tests::mapping::relation::semistructured::inheritance::Firm)->toOne()
  }
)


###Pure
import meta::pure::test::*;
import meta::core::runtime::*;
import meta::relational::metamodel::execute::tests::*;
import meta::relational::tests::mapping::relation::semistructured::inheritance::*;

function <<access.private>> meta::relational::tests::mapping::relation::semistructured::inheritance::inheritanceCsv(): String[1]
{
  'PERSON_SCHEMA\n' +
  'PERSON_TABLE\n' +
  'ID,FIRSTNAME,LASTNAME,FIRM_DETAILS,MANAGERID\n' +
  '1,Peter,Smith,"{""legalName"": ""Firm X"", ""address"": {""name"": ""A1"", ""lines"": [{""lineno"": 1, ""street"": ""s1""}, {""lineno"": 2, ""city"": ""c1""}, {""lineno"": 3, ""state"": ""s1""}]}}",2\n' +
  '2,John,Johnson,"{""legalName"": ""Firm X"", ""address"": {""name"": ""A1"", ""lines"": [{""lineno"": 1, ""street"": ""s1""}, {""lineno"": 2, ""city"": ""c1""}, {""lineno"": 3, ""state"": ""s1""}]}}",4\n' +
  '3,John,Hill,"{""legalName"": ""Firm X"", ""address"": {""name"": ""A1"", ""lines"": [{""lineno"": 1, ""street"": ""s1""}, {""lineno"": 2, ""city"": ""c1""}, {""lineno"": 3, ""state"": ""s1""}]}}",2\n' +
  '4,Anthony,Allen,"{""legalName"": ""Firm X"", ""address"": {""name"": ""A1"", ""lines"": [{""lineno"": 1, ""street"": ""s1""}, {""lineno"": 2, ""city"": ""c1""}, {""lineno"": 3, ""state"": ""s1""}]}}",\n' +
  '5,Fabrice,Roberts,"{""legalName"": ""Firm A"", ""address"": {""name"": ""A2"", ""lines"": [{""lineno"": 1, ""street"": ""s2""}, {""lineno"": 2, ""city"": ""c2""}]}}",\n' +
  '6,Oliver,Hill,"{""legalName"": ""Firm B"", ""address"": {""name"": ""A3"", ""lines"": [{""lineno"": 1, ""street"": ""s3""}]}}",7\n' +
  '7,David,Harris,"{""legalName"": ""Firm B"", ""address"": {""name"": ""A3"", ""lines"": [{""lineno"": 1, ""street"": ""s3""}]}}",\n'
}

function <<access.private>> meta::relational::tests::mapping::relation::semistructured::inheritance::inheritanceExecute(conn: Connection[1], func: FunctionDefinition<Any>[1], expected: String[1]): Boolean[1]
{
  executeLegendFunction($func, InheritanceSemiStructuredMapping, H2DB, $conn, [inheritanceCsv()], $expected, false);
}

function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::inheritance::testSemiStructuredPropertyAccessAtBaseClass(conn: Connection[1]): Boolean[1]
{
  inheritanceExecute($conn,
    |Person.all()->project(~[
      'First Name'       : x|$x.firstName,
      'Firm Address Name': x|$x.firm.address.name
    ]),
    'First Name,Firm Address Name\n' +
    'Peter,A1\n' +
    'John,A1\n' +
    'John,A1\n' +
    'Anthony,A1\n' +
    'Fabrice,A2\n' +
    'Oliver,A3\n' +
    'David,A3\n'
  );
}

function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::inheritance::testSemiStructuredPropertyAccessAtSubClass(conn: Connection[1]): Boolean[1]
{
  inheritanceExecute($conn,
    |Person.all()->project(~[
      'First Name'             : x|$x.firstName,
      'Firm Address 0 Line No' : x|$x.firm.address->subType(@AddressWithLines).lines->at(0).lineno
    ]),
    'First Name,Firm Address 0 Line No\n' +
    'Peter,1\n' +
    'John,1\n' +
    'John,1\n' +
    'Anthony,1\n' +
    'Fabrice,1\n' +
    'Oliver,1\n' +
    'David,1\n'
  );
}

function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::inheritance::testSemiStructuredPropertyAccessAtSubClassNested(conn: Connection[1]): Boolean[1]
{
  inheritanceExecute($conn,
    |Person.all()->project(~[
      'First Name'             : x|$x.firstName,
      'Firm Address 0 Line No' : x|$x.firm.address->subType(@AddressWithLines).lines->at(0).lineno,
      'Firm Address Street'    : x|$x.firm.address->subType(@AddressWithLines).lines->at(0)->subType(@StreetAddressLine).street,
      'Firm Address City'      : x|$x.firm.address->subType(@AddressWithLines).lines->at(1)->subType(@CityAddressLine).city,
      'Firm Address State'     : x|$x.firm.address->subType(@AddressWithLines).lines->at(2)->subType(@StateAddressLine).state
    ]),
    'First Name,Firm Address 0 Line No,Firm Address Street,Firm Address City,Firm Address State\n' +
    'Peter,1,s1,c1,s1\n' +
    'John,1,s1,c1,s1\n' +
    'John,1,s1,c1,s1\n' +
    'Anthony,1,s1,c1,s1\n' +
    'Fabrice,1,s2,c2,\n' +
    'Oliver,1,s3,,\n' +
    'David,1,s3,,\n'
  );
}

function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::inheritance::testSemiStructuredPropertyAccessAtSubClassNestedUsingProjectWithFunctions(conn: Connection[1]): Boolean[1]
{
  inheritanceExecute($conn,
    |Person.all()->project(~[
      'First Name'             : x|$x.firstName,
      'Firm Address 0 Line No' : x|$x.firm.address->subType(@AddressWithLines).lines->at(0).lineno,
      'Firm Address Street'    : x|$x.firm.address->subType(@AddressWithLines).lines->at(0)->subType(@StreetAddressLine).street,
      'Firm Address City'      : x|$x.firm.address->subType(@AddressWithLines).lines->at(1)->subType(@CityAddressLine).city,
      'Firm Address State'     : x|$x.firm.address->subType(@AddressWithLines).lines->at(2)->subType(@StateAddressLine).state
    ]),
    'First Name,Firm Address 0 Line No,Firm Address Street,Firm Address City,Firm Address State\n' +
    'Peter,1,s1,c1,s1\n' +
    'John,1,s1,c1,s1\n' +
    'John,1,s1,c1,s1\n' +
    'Anthony,1,s1,c1,s1\n' +
    'Fabrice,1,s2,c2,\n' +
    'Oliver,1,s3,,\n' +
    'David,1,s3,,\n'
  );
}
