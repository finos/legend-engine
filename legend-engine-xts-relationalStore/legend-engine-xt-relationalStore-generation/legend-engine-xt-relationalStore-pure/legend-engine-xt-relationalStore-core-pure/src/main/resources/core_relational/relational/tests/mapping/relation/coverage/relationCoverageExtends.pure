// Gap #27: mapping extension (extends [setId]) for relation mappings. The child
// set inherits the parent set's property mappings and adds its own. Marked
// test.Test per request; the doc classifies this as NEW_DEV (the
// RelationFunctionClassMappingSecondPassCompiler extend-chain is unimplemented for
// execution — grammar round-trips today), so these may need to move to
// test.ToFix after the run.

###Pure
import meta::pure::functions::relation::*;
import meta::pure::metamodel::relation::*;
import meta::relational::tests::mapping::relation::coverage::*;

function meta::relational::tests::mapping::relation::coverage::extendsPersonFunc():Relation<Any>[1]
{
   #>{coverageDB.personTable}#
      ->select(~[FIRSTNAME, AGE]);
}

###Mapping
import meta::relational::tests::mapping::relation::*;
import meta::relational::tests::mapping::relation::coverage::*;

Mapping meta::relational::tests::mapping::relation::coverage::extendsMapping
(
   Person[parent]: Relation
   {
      ~func meta::relational::tests::mapping::relation::coverage::extendsPersonFunc():Relation<Any>[1]
      firstName: FIRSTNAME
   }

   *Person[child] extends [parent]: Relation
   {
      ~func meta::relational::tests::mapping::relation::coverage::extendsPersonFunc():Relation<Any>[1]
      age: AGE
   }
)

###Pure
import meta::relational::functions::asserts::*;
import meta::relational::tests::mapping::relation::*;
import meta::relational::tests::mapping::relation::coverage::*;
import meta::pure::functions::relation::*;
import meta::external::store::relational::tests::*;

// The child set inherits firstName from the parent set and adds age.
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testExtendsInheritedAndOwnProperties():Boolean[1]
{
   let result = execute(
      |Person.all()->project(~[firstName:p|$p.firstName, age:p|$p.age]),
      extendsMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions());
   assertEquals(
     #TDS
        firstName, age
        Anthony, 40
        Jane, 25
        John, 30
        Peter, 23
     #->toString(),
     $result.values->at(0)->sort([~firstName->ascending()])->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testExtendsFilterOnInheritedProperty():Boolean[1]
{
   let result = execute(
      |Person.all()->filter(p|$p.firstName == 'Peter')->project(~[firstName:p|$p.firstName, age:p|$p.age]),
      extendsMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions());
   assertEquals(
     #TDS
        firstName, age
        Peter, 23
     #->toString(),
     $result.values->at(0)->toString());
}
