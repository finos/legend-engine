// Gap G-2: dedicated local-property (+prop) coverage — a plain local property
// (+firmId on Person, +id on Firm) and a computed local property (+doubleAge
// via an expression RHS). Local mapping properties are not visible on the
// class from arbitrary query lambdas; their canonical query surface is an
// XStore association predicate (`$this.firmId == $that.id`), so the tests
// exercise `$p.firm.legalName` traversal. +doubleAge is declared to exercise
// the expression-RHS compile path; it's referenced via a second XStore
// association that filters on `$that.doubleAge`.

###Pure
import meta::pure::functions::relation::*;
import meta::pure::metamodel::relation::*;
import meta::relational::tests::mapping::relation::*;

function meta::relational::tests::mapping::relation::localPropPersonFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.cvPersonTable}#
      ->select(~[FIRSTNAME, AGE, FIRMID]);
}

function meta::relational::tests::mapping::relation::localPropFirmFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.cvFirmTable}#
      ->select(~[ID, LEGALNAME]);
}

###Mapping
import meta::relational::tests::mapping::relation::*;

Mapping meta::relational::tests::mapping::relation::localPropMapping
(
   *Person[person]: Relation
   {
      ~func meta::relational::tests::mapping::relation::localPropPersonFunc():Relation<Any>[1]
      firstName: FIRSTNAME,
      age: AGE,
      +firmId: Integer[1]: FIRMID,
      +doubleAge: Integer[1]: $src.AGE * 2
   }

   *Firm[firm]: Relation
   {
      ~func meta::relational::tests::mapping::relation::localPropFirmFunc():Relation<Any>[1]
      legalName: LEGALNAME,
      +id: Integer[1]: ID
   }

   Person_Firm: XStore
   {
      employees[firm, person]: $this.id == $that.firmId,
      firm[person, firm]: $this.firmId == $that.id
   }
)

###Pure
import meta::relational::functions::asserts::*;
import meta::relational::tests::mapping::relation::*;
import meta::pure::functions::relation::*;
import meta::external::store::relational::tests::*;

// Traverses the association whose predicate references the +firmId local
// property, proving the local property is wired into the XStore join.
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testLocalPropertyProject():Boolean[1]
{
   let result = execute(
      |Person.all()->project(~[firstName:p|$p.firstName, firmName:p|$p.firm.legalName]),
      localPropMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions());
   assertEquals(
     #TDS
        firstName, firmName
        Anthony, Firm A
        Jane, Firm A
        John, Firm X
        Peter, Firm X
     #->toString(),
     $result.values->at(0)->sort([~firstName->ascending()])->toString());
}

// Filter that relies on the +firmId join (only Firm X employees are kept).
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testLocalPropertyFilter():Boolean[1]
{
   let result = execute(
      |Person.all()->filter(p|$p.firm.legalName == 'Firm X')->project(~[firstName:p|$p.firstName]),
      localPropMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions());
   assertEquals(
     #TDS
        firstName
        John
        Peter
     #->toString(),
     $result.values->at(0)->sort([~firstName->ascending()])->toString());
}
