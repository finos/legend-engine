// Test for KS1768423660104: filter()->first() inside if/else derived property.
// The filter predicate must NOT leak to the outer WHERE clause.
// All 7 person rows must be returned — the filter only applies within the else branch.
function <<paramTest.Test>> meta::relational::tests::semistructured::flattening::testSemiStructuredArrayFilterFirstInIfElse(conn: Connection[1]):Boolean[1]
{
  semiStructuredExecute($conn,
    'flatten::semiStructuredArrayFilterFirstInIfElse__TabularDataSet_1_',
    'flatten::mapping::H2Mapping',
    'First Name,Firm Name,Conditional Address Name\n' +
    'Anthony,Firm X,Firm X\n' +
    'David,Firm B,Firm B\n' +
    'Fabrice,Firm A,Firm A\n' +
    'John,Firm X,Firm X\n' +
    'John,Firm X,Firm X\n' +
    'Oliver,Firm B,Firm B\n' +
    'Peter,Firm X,A1\n'
  );
}
