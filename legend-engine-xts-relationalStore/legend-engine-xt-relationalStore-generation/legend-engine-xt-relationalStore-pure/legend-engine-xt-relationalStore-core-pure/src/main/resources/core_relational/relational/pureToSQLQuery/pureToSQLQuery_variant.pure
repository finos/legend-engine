function meta::relational::functions::pureToSqlQuery::isVariantInput(v: ValueSpecification[1], vars:Map<VariableExpression, ValueSpecification>[1], state: State[1]):Boolean[1]
{
  $v->isVariantInputImpl($vars, $state, false);
}

function meta::relational::functions::pureToSqlQuery::isVariantInputWithInstanceValue(v: ValueSpecification[1], vars:Map<VariableExpression, ValueSpecification>[1], state: State[1]):Boolean[1]
{
  $v->isVariantInputImpl($vars, $state, true);
}

function meta::relational::functions::pureToSqlQuery::isVariantInputImpl(v: ValueSpecification[1], vars:Map<VariableExpression, ValueSpecification>[1], state: State[1], instanceValueLookup: Boolean[1]):Boolean[1]
{
  if($v.genericType.rawType == meta::pure::metamodel::variant::Variant,
    |
      true,
    |
      $v->match([
        fe: FunctionExpression[1] | 
          $fe.parametersValues->head()->map(x | $x->isVariantInputImpl($vars, $state, $instanceValueLookup))->orElse(false);,
        ve: VariableExpression[1] | 
          $state.functionReferenceScope->map(frs | $frs.resolveFunctionReferenceByName($ve.name)).select.columns->match([
            rlp: RelationalLambdaParameter[1] | 
              $rlp.type->type()->in(
                  [
                    meta::relational::metamodel::datatype::SemiStructured,
                    meta::relational::metamodel::datatype::Object, 
                    meta::relational::metamodel::datatype::Array
                  ]
                ),
            any: Any[*] |
               $vars->get($ve)->map(x | $x->isVariantInputImpl($vars, $state, $instanceValueLookup))->orElse(false);
          ]);,
        iv: InstanceValue[1]      | 
          $instanceValueLookup && ($iv.values->type()->instanceOf(PrimitiveType) || $iv.values->type() == Nil),
        rvs: RoutedValueSpecification[1] | 
          $rvs.value->isVariantInputImpl($vars, $state, $instanceValueLookup),
        any: Any[1] | 
          false;
      ])
  );
}

function meta::relational::functions::pureToSqlQuery::isAutomapWithVariantInput(v: ValueSpecification[1], vars:Map<VariableExpression, ValueSpecification>[1], state: State[1]):Boolean[1]
{
  $v->cast(@FunctionExpression)->instanceValuesAtParameter(1, $vars, $state.inScopeVars)->match([
    func: FunctionDefinition<Any>[1] |
      $func.expressionSequence->at(0)->byPassRouterInfo()->match([
        prop: FunctionExpression[1] |
          let isAutoMap = $prop.func->instanceOf(AbstractProperty) && $prop.parametersValues->at(0)->instanceOf(VariableExpression) && $prop.parametersValues->at(0)->cast(@VariableExpression).name == 'v_automap';
          $isAutoMap && isVariantInputWithInstanceValue($v, $vars, $state); 
        ,
        any :Any[1] | false
      ]);
    ,
    any: Any[1] | false
  ]);
}

// Returns true if any sub-expression of `v` involves a Variant. Used by the
// RelationFunctionPropertyMapping lift router (processRelationFunctionPropertyMapping)
// to decide whether to wrap the synthesised property mapping as semi-structured.
// Walks the head spine first via isVariantInputWithInstanceValue (covers most cases:
// `$src.payload->...`, `arr->filter(...)`, `arr->size()`, etc.), then recurses into
// all parametersValues and routed-value-spec wrappers for completeness (covers
// non-head-spine variants e.g. `if($cond, $variantA, $variantB)`).
function meta::relational::functions::pureToSqlQuery::expressionTouchesVariant(v:ValueSpecification[1], state:State[1]):Boolean[1]
{
  let emptyVars = newMap([]->cast(@Pair<VariableExpression, ValueSpecification>));
  if($v->isVariantInputWithInstanceValue($emptyVars, $state),
     | true,
     | $v->match([
         fe: FunctionExpression[1]        | $fe.parametersValues->exists(p | $p->expressionTouchesVariant($state)),
         rvs: RoutedValueSpecification[1] | $rvs.value->expressionTouchesVariant($state),
         a: Any[1]                        | false
       ]));
}

function meta::relational::functions::pureToSqlQuery::isSemiStructuredArrayInput(v: ValueSpecification[1], vars:Map<VariableExpression, ValueSpecification>[1], state: State[1]):Boolean[1]
{
  let firstParam = $v->cast(@FunctionExpression).parametersValues->evaluateAndDeactivate()->at(0)->byPassRouterInfo();
  $firstParam->isSemiStructuredArrayExpression($vars, $state);
}

function meta::relational::functions::pureToSqlQuery::isSemiStructuredArrayInputWithAutoFlattenDisabled(v: ValueSpecification[1], vars:Map<VariableExpression, ValueSpecification>[1], state: State[1]):Boolean[1]
{
  $state.disableAutoFlatten == true && $v->isSemiStructuredArrayInput($vars, $state);
}

function meta::relational::functions::pureToSqlQuery::isSemiStructuredArrayInputForFirstAt(v: ValueSpecification[1], vars:Map<VariableExpression, ValueSpecification>[1], state: State[1]):Boolean[1]
{
  // If disableAutoFlatten is already set, always allow (chained from isEmpty/size/fold)
  if($state.disableAutoFlatten == true,
    | $v->isSemiStructuredArrayInput($vars, $state),
    | // Entry point case: check that the first param is a non-property function
      // and exclude automaps (which are compiler-generated map(collection, v_automap | v_automap.prop))
      let firstParam = $v->cast(@FunctionExpression).parametersValues->evaluateAndDeactivate()->at(0)->byPassRouterInfo();
      $firstParam->match([
        fe: FunctionExpression[1] |
          if($fe.func->instanceOf(AbstractProperty),
            | false,  // Direct property access like addresses->at(0) — skip
            | // Check if this is an automap
              let isAutomap = $fe.functionName == 'map' && $fe->instanceValuesAtParameter(1, $vars, $state.inScopeVars)->match([
                func: FunctionDefinition<Any>[1] |
                  $func.expressionSequence->at(0)->byPassRouterInfo()->match([
                    innerFe: FunctionExpression[1] |
                      $innerFe.func->instanceOf(AbstractProperty) &&
                      $innerFe.parametersValues->at(0)->instanceOf(VariableExpression) &&
                      $innerFe.parametersValues->at(0)->cast(@VariableExpression).name == 'v_automap';,
                    a: Any[1] | false
                  ]);,
                a: Any[1] | false
              ]);
              !$isAutomap && $firstParam->isSemiStructuredArrayExpression($vars, $state);
          );,
        a: Any[1] | false
      ]);
  );
}

function <<access.private>> meta::relational::functions::pureToSqlQuery::isSemiStructuredArrayExpression(v: ValueSpecification[1], vars:Map<VariableExpression, ValueSpecification>[1], state: State[1]):Boolean[1]
{
  $v->match([
    fe: FunctionExpression[1] |
      $fe.func->match([
        prop: AbstractProperty<Any>[1] |
          let isToMany = !$prop.multiplicity->hasToOneUpperBound();
          let returnType = $fe.genericType.rawType;
          let isClassType = $returnType->isNotEmpty() && $returnType->toOne()->instanceOf(Class) && $returnType->toOne() != Variant;
          // Check if the property's owner class is accessed through a direct (non-join) semi-structured binding.
          // Exclude join-based bindings (e.g. location: Binding ... : @Join | ...) because the disableAutoFlatten
          // strategy does not support array operations across joins.
          let ownerClass = $prop.owner->toOne();
          let isSemiStructuredMapping = $isClassType && $state.mapping->isNotEmpty() &&
            $state.mapping->toOne()->classMappings()
              ->filter(cm | $cm->instanceOf(RelationalInstanceSetImplementation))
              ->cast(@RelationalInstanceSetImplementation)
              .propertyMappings
              ->exists(pm | $pm->instanceOf(SemiStructuredRelationalPropertyMapping)
                            && $pm.property.genericType.rawType->toOne() == $ownerClass
                            && !$pm->cast(@SemiStructuredRelationalPropertyMapping).relationalOperationElement->instanceOf(RelationalOperationElementWithJoin));
          $isToMany && $isClassType && $isSemiStructuredMapping;,
        a: Any[1] |
          if ($fe.parametersValues->evaluateAndDeactivate()->isNotEmpty(),
            | $fe.parametersValues->evaluateAndDeactivate()->at(0)->byPassRouterInfo()->isSemiStructuredArrayExpression($vars, $state),
            | false
          );
      ]);,
    rvs: RoutedValueSpecification[1] |
      $rvs.value->isSemiStructuredArrayExpression($vars, $state),
    a: Any[1] | false
  ]);
}

function <<access.private>> meta::relational::functions::pureToSqlQuery::resolveSemiStructuredBasePropertyMapping(v: ValueSpecification[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):PropertyMapping[*]
{
  let expr = $v->byPassRouterInfo();
  $expr->match([
    fe: FunctionExpression[1] |
      $fe.func->match([
        prop: AbstractProperty<Any>[1] |
          // This is the base property — resolve its mapping
          processValueSpecificationReturnPropertyMapping($expr, $currentPropertyMapping, $operation, $vars, ^$state(disableAutoFlatten = true), $joinType, $nodeId, $aggFromMap, $context, $extensions)->toOne().currentPropertyMapping;,
        a: Any[1] |
          // Intermediate function (filter, map, etc.) — recurse into its first parameter
          if ($fe.parametersValues->evaluateAndDeactivate()->isNotEmpty(),
            | $fe.parametersValues->evaluateAndDeactivate()->at(0)->resolveSemiStructuredBasePropertyMapping($currentPropertyMapping, $operation, $vars, $state, $joinType, $nodeId, $aggFromMap, $context, $extensions),
            | []
          );
      ]);,
    rvs: RoutedValueSpecification[1] |
      $rvs.value->resolveSemiStructuredBasePropertyMapping($currentPropertyMapping, $operation, $vars, $state, $joinType, $nodeId, $aggFromMap, $context, $extensions),
    a: Any[1] | []
  ]);
}

function meta::relational::functions::pureToSqlQuery::processSemiStructuredArrayFirst(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  let firstParam = $f.parametersValues->evaluateAndDeactivate()->at(0);

  // Resolve property mapping by walking through the chain to find the base semi-structured property
  let semiStructuredPropertyMapping = $firstParam->resolveSemiStructuredBasePropertyMapping($currentPropertyMapping, $operation, $vars, $state, $joinType, $nodeId, $aggFromMap, $context, $extensions);

  // Process the input chain with disableAutoFlatten — the chain (filter, map, etc.) will be
  // dispatched to their variant handlers which produce FilterRelationalLambda/MapRelationalLambda
  let disableAutoFlattenState = ^$state(disableAutoFlatten = true);
  let inputResult = $firstParam->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$disableAutoFlattenState(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)
    ->cast(@SelectWithCursor);
  let inputRelOp = if($state.inFilter, |$inputResult.select.filteringOperation->toOne(), |$inputResult.select.columns->toOne());
  let arrayFirstDyna = newDynaFunction('array_first', [$inputRelOp]);
  let select = $operation.select;
  let resultOp = ^$operation(select = $state.inFilter->if(|^$select(filteringOperation = $arrayFirstDyna), |^$select(columns = $arrayFirstDyna)));
  ^OperationWithParentPropertyMapping(element = $resultOp, currentPropertyMapping = $semiStructuredPropertyMapping);
}

function meta::relational::functions::pureToSqlQuery::processSemiStructuredArrayAt(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  let params = $f.parametersValues->evaluateAndDeactivate();
  let firstParam = $params->at(0);

  // Resolve property mapping by walking through the chain to find the base semi-structured property
  let semiStructuredPropertyMapping = $firstParam->resolveSemiStructuredBasePropertyMapping($currentPropertyMapping, $operation, $vars, $state, $joinType, $nodeId, $aggFromMap, $context, $extensions);

  // Process the input chain with disableAutoFlatten
  let disableAutoFlattenState = ^$state(disableAutoFlatten = true);
  let inputResult = $firstParam->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$disableAutoFlattenState(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)
    ->cast(@SelectWithCursor);
  let inputRelOp = if($state.inFilter, |$inputResult.select.filteringOperation->toOne(), |$inputResult.select.columns->toOne());
  let indexResult = $params->at(1)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)
    ->cast(@SelectWithCursor);
  let indexOp = $indexResult.select.columns->toOne();
  let arrayElementAccess = ^SemiStructuredArrayElementAccess(index = $indexOp, operand = $inputRelOp, returnType = $f.genericType.rawType);
  let select = $operation.select;
  let resultOp = ^$operation(select = $state.inFilter->if(|^$select(filteringOperation = $arrayElementAccess), |^$select(columns = $arrayElementAccess)));
  ^OperationWithParentPropertyMapping(element = $resultOp, currentPropertyMapping = $semiStructuredPropertyMapping);
}

function meta::relational::functions::pureToSqlQuery::processToVariant(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  let param = $f.parametersValues->evaluateAndDeactivate()->toOne();
  let value = $param->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor);
  let toVariantValue = if($param.multiplicity->isToMany(), |$value.select.columns->toVariantFriendlyValue($param.genericType->genericTypeToDataType($param.multiplicity)), |$value.select.columns->toOne());

  let dynaFunc = newDynaFunction('toVariant', $toVariantValue);

  let select = $operation.select;
  ^$operation(select = $state.inFilter->if(|^$select(filteringOperation = $dynaFunc),|^$select(columns = $dynaFunc)));  
}

function meta::relational::functions::pureToSqlQuery::processVariantConcatenate(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  let arr1 = $f.parametersValues->at(0)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor).select.columns->toVariantFriendlyValue($f.genericType->genericTypeToDataType(ZeroMany));
  let arr2 = $f.parametersValues->at(1)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor).select.columns->toVariantFriendlyValue($f.genericType->genericTypeToDataType(ZeroMany));

  let dynaFunc = newDynaFunction('array_concatenate', [$arr1, $arr2]);

  let select = $operation.select;
  ^$operation(select = $state.inFilter->if(|^$select(filteringOperation = $dynaFunc),|^$select(columns = $dynaFunc)));
}

function meta::relational::functions::pureToSqlQuery::processVariantDrop(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  processDynaFunction('array_drop', {reo | $reo->init()->toVariantFriendlyValue($f.parametersValues->at(0).genericType->genericTypeToDataType($f.parametersValues->at(0).multiplicity))->concatenate($reo->last())}, $f, $currentPropertyMapping, $operation, $vars, $state, $joinType, $nodeId, $aggFromMap, $context, $extensions);
}

