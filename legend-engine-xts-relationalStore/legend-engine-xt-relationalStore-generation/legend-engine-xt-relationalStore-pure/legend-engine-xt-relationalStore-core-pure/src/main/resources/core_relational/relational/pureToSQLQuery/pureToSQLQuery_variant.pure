function meta::relational::functions::pureToSqlQuery::processVariantSize(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  // Semi-structured guard: disable auto-flatten so the array stays as a scalar column
  let effectiveState = if($f->isSemiStructuredArrayInput($vars, $state), |^$state(disableAutoFlatten = true), |$state);
  processDynaFunction('array_size', {reo | $reo->toVariantFriendlyValue($f.parametersValues->at(0).genericType->genericTypeToDataType($f.parametersValues->at(0).multiplicity))}, $f, $currentPropertyMapping, $operation, $vars, $effectiveState, $joinType, $nodeId, $aggFromMap, $context, $extensions);
}

function meta::relational::functions::pureToSqlQuery::processVariantAdd(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  processDynaFunction('array_append', {reo | $reo->init()->toVariantFriendlyValue($f.parametersValues->at(0).genericType->genericTypeToDataType($f.parametersValues->at(0).multiplicity))->concatenate($reo->last())}, $f, $currentPropertyMapping, $operation, $vars, $state, $joinType, $nodeId, $aggFromMap, $context, $extensions);
}

function meta::relational::functions::pureToSqlQuery::processVariantIsNotEmpty(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  // Semi-structured guard: disable auto-flatten so the array stays as a scalar column
  let effectiveState = if($f->isSemiStructuredArrayInput($vars, $state), |^$state(disableAutoFlatten = true), |$state);
  processDynaFunction('not', $f->getVariantEmptyFunctionExpression()->evaluateAndDeactivate(), $currentPropertyMapping, $operation, $vars, $effectiveState, $joinType, $nodeId, $aggFromMap, $context, $extensions);
}

function meta::relational::functions::pureToSqlQuery::processVariantIsEmpty(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  // Semi-structured guard: disable auto-flatten so the array stays as a scalar column
  let effectiveState = if($f->isSemiStructuredArrayInput($vars, $state), |^$state(disableAutoFlatten = true), |$state);
  processEquals($f->getVariantEmptyFunctionExpression()->evaluateAndDeactivate(), $currentPropertyMapping, $operation, $vars, $effectiveState, $joinType, $nodeId, $aggFromMap, $context, $extensions);
}

function meta::relational::functions::pureToSqlQuery::getVariantEmptyFunctionExpression(f:FunctionExpression[1]):SimpleFunctionExpression[1]
{
  ^SimpleFunctionExpression(
    func=equal_Any_MANY__Any_MANY__Boolean_1_,
    functionName='equal',
    importGroup=system::imports::coreImport,
    genericType=^GenericType(rawType=Boolean),
    multiplicity=ZeroMany,
    parametersValues=[
      ^InstanceValue(genericType=^GenericType(rawType=Integer), multiplicity=PureOne, values=^$f(func=size_Any_MANY__Integer_1_, functionName='size', genericType=^GenericType(rawType=String))),
      ^InstanceValue(genericType=^GenericType(rawType=Integer), multiplicity=PureOne, values=0)
    ]
  );
}

function meta::relational::functions::pureToSqlQuery::processVariantIndexOf(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  processDynaFunction('array_position', {reo | $reo->init()->toVariantFriendlyValue($f.parametersValues->at(0).genericType->genericTypeToDataType($f.parametersValues->at(0).multiplicity))->concatenate($reo->last())}, $f, $currentPropertyMapping, $operation, $vars, $state, $joinType, $nodeId, $aggFromMap, $context, $extensions);
}

function meta::relational::functions::pureToSqlQuery::processVariant_notSupportedYet(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  fail('Variant ->' + $f.functionName->orElse('???') + '() not supported yet');
  $operation;
}

function meta::relational::functions::pureToSqlQuery::processVariantSlice(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  processDynaFunction('array_slice', {reo | $reo->take($reo->size() - 2)->toVariantFriendlyValue($f.parametersValues->at(0).genericType->genericTypeToDataType($f.parametersValues->at(0).multiplicity))->concatenate($reo->drop($reo->size() - 2))}, $f, $currentPropertyMapping, $operation, $vars, $state, $joinType, $nodeId, $aggFromMap, $context, $extensions);
}

function meta::relational::functions::pureToSqlQuery::processVariantContains(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  processDynaFunction('array_contains', {reo | $reo->init()->toVariantFriendlyValue($f.parametersValues->at(0).genericType->genericTypeToDataType($f.parametersValues->at(0).multiplicity))->concatenate($reo->last())}, $f, $currentPropertyMapping, $operation, $vars, $state, $joinType, $nodeId, $aggFromMap, $context, $extensions);
}

function meta::relational::functions::pureToSqlQuery::processVariantRemoveDuplicates(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  processDynaFunction('array_distinct', {reo | $reo->toVariantFriendlyValue($f.parametersValues->at(0).genericType->genericTypeToDataType($f.parametersValues->at(0).multiplicity))}, $f, $currentPropertyMapping, $operation, $vars, $state, $joinType, $nodeId, $aggFromMap, $context, $extensions);
}

function meta::relational::functions::pureToSqlQuery::findVariantType(value: RelationalOperationElement[1]):meta::relational::metamodel::datatype::TypedSemiStructured[0..1]
{
  $value->match([    
    df: DynaFunction[1] | 
      if ($df.name == 'variantTo' && $df.parameters->last()->toOne()->cast(@DataTypeInfo).dataType->instanceOf(meta::relational::metamodel::datatype::TypedSemiStructured),
        |
          $df.parameters->last()->toOne()->cast(@DataTypeInfo).dataType->cast(@meta::relational::metamodel::datatype::TypedSemiStructured)
        ,
        |
          $df.parameters->head()->map(x | $x->findVariantType())
      ),
    rlp: RelationalLambdaParameter[1] | 
      if($rlp.type->instanceOf(meta::relational::metamodel::datatype::TypedSemiStructured), 
        |
          $rlp.type->cast(@meta::relational::metamodel::datatype::TypedSemiStructured)
        ,
        |
          $rlp.value->findVariantType()
      ),
    rl: RelationalLambda[1] | 
      $rl.parameters->at(0)->findVariantType(),
    a: RelationalOperationElement[1] | 
      [];
  ])
}

function meta::relational::functions::pureToSqlQuery::processVariantInstanceOf(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  let variant = $f.parametersValues->at(0)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor).select.columns->toOne();
  let class = $f->instanceValueAtParameter(1)->toOne()->cast(@Class<Any>);

  let variantToMetadata = findVariantType($variant);
  let keyProp = $variantToMetadata.typeName->orElse('_type');
  let className = $variantToMetadata.typeLookup->filter(p | $p.second == $class)->head().first->orElse($class.name->toOne());

  let typeProp = ^SemiStructuredPropertyAccess(operand = $variant, property = ^Literal(value = $keyProp), returnType = String);
  let typePropCasted = newDynaFunction('variantTo', [$typeProp, ^DataTypeInfo(dataType = ^meta::relational::metamodel::datatype::Varchar(size=100))]);
  let instanceOf = newDynaFunction('equal', [$typePropCasted, ^Literal(value = $className)]);

  let select = $operation.select;
  ^$operation(select = $state.inFilter->if(|^$select(filteringOperation = $instanceOf),|^$select(columns = $instanceOf)));  
}

function meta::relational::functions::pureToSqlQuery::processList(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  let results = $f.parametersValues->map(valueParam | $valueParam->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor));
  let columns = $results.select.columns;

  let paramType = $f.parametersValues->at(0).genericType->genericTypeToDataType($f.parametersValues->at(0).multiplicity);
  let dynaFunc = $results.select.columns->toVariantFriendlyValue($paramType);

  let select = $operation.select;
  ^$operation(select = $state.inFilter->if(|^$select(filteringOperation = $dynaFunc),|^$select(columns = $dynaFunc)));
}

function meta::relational::functions::pureToSqlQuery::processNewMap(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  let results = $f.parametersValues->map(valueParam | $valueParam->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor));
  let columns = $results.select.columns->filter(x | !$x->instanceOf(Literal) || !$x->cast(@Literal).value->instanceOf(SQLNull))->cast(@DynaFunction);
  $columns->forAll(x | assertEquals('pair', $x.name));

  let variantObj = newDynaFunction('toVariantObject', $columns.parameters);
  let dynaFunc = newDynaFunction('cast', [$variantObj, ^DataTypeInfo(dataType = $f.genericType->genericTypeToDataType($f.multiplicity))]);

  let select = $operation.select;
  ^$operation(select = $state.inFilter->if(|^$select(filteringOperation = $dynaFunc),|^$select(columns = $dynaFunc)));
}

function meta::relational::functions::pureToSqlQuery::processPutAllPairs(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  let map = $f.parametersValues->at(0)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor).select.columns;

  let pairs = $f.parametersValues->at(1)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor).select.columns->filter(x | !$x->instanceOf(Literal) || !$x->cast(@Literal).value->instanceOf(SQLNull))->cast(@DynaFunction);
  $pairs->forAll(x | assertEquals('pair', $x.name));
  let pairsAsMap = newDynaFunction('toVariantObject', $pairs.parameters);
  let mapCasted = newDynaFunction('cast', [$pairsAsMap, ^DataTypeInfo(dataType = $f.parametersValues->at(1).genericType->genericTypeToDataType(ZeroOne))]);

  let dynaFunc = newDynaFunction('mapConcatenate', $map->concatenate($mapCasted));

  let select = $operation.select;
  ^$operation(select = $state.inFilter->if(|^$select(filteringOperation = $dynaFunc),|^$select(columns = $dynaFunc)));
}

function meta::relational::functions::pureToSqlQuery::processPutAllMap(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  let map = $f.parametersValues->at(0)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor).select.columns;

  let mapToPut = $f.parametersValues->at(1)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor).select.columns;

  let dynaFunc = newDynaFunction('mapConcatenate', $map->concatenate($mapToPut));

  let select = $operation.select;
  ^$operation(select = $state.inFilter->if(|^$select(filteringOperation = $dynaFunc),|^$select(columns = $dynaFunc)));
}

function meta::relational::functions::pureToSqlQuery::processPut(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  let map = $f.parametersValues->at(0)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor).select.columns;
  let key = $f.parametersValues->at(1)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor).select.columns;
  let value = $f.parametersValues->at(2)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor).select.columns;

  let keyValue = newDynaFunction('toVariantObject', $key->concatenate($value));
  let mapCasted = newDynaFunction('cast', [$keyValue, ^DataTypeInfo(dataType = $f.parametersValues->at(0).genericType->genericTypeToDataType($f.parametersValues->at(0).multiplicity))]);

  let dynaFunc = newDynaFunction('mapConcatenate', $map->concatenate($mapCasted));

  let select = $operation.select;
  ^$operation(select = $state.inFilter->if(|^$select(filteringOperation = $dynaFunc),|^$select(columns = $dynaFunc)));
}

function meta::relational::functions::pureToSqlQuery::processVariantAt(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  let params = $f.parametersValues->evaluateAndDeactivate();
  
  let arraySource = $params->at(0)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)
    ->cast(@SelectWithCursor);
  let operand = $arraySource.select.columns->toOne();

  let propertyToAccess = $params->at(1)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)
    ->cast(@SelectWithCursor);
  let property = $propertyToAccess.select.columns->toOne();

  let rawRelOpElement = ^SemiStructuredArrayElementAccess(index = $property, operand = $operand, returnType = $f.genericType.rawType);

  let dataType = $f.genericType->genericTypeToDataType(ZeroOne);

  // dont cast if going from variant to variant
  let relOpElement = $dataType->match([
    s: meta::relational::metamodel::datatype::SemiStructured[1] | $rawRelOpElement,
    o: meta::relational::metamodel::datatype::Object[1] | $rawRelOpElement,
    any: Any[1] | newDynaFunction('cast', [$rawRelOpElement, ^DataTypeInfo(dataType = $dataType)])
  ]);


  let select = $operation.select;
  ^$operation(select = $state.inFilter->if(|^$select(filteringOperation = $relOpElement),|^$select(columns = $relOpElement)));
}

function meta::relational::functions::pureToSqlQuery::processMapGet(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  let params = $f.parametersValues->evaluateAndDeactivate();
  
  let mapSource = $params->at(0)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)
    ->cast(@SelectWithCursor);
  let operand = $mapSource.select.columns->toOne();

  let propertyToAccess = $params->at(1)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)
    ->cast(@SelectWithCursor);
  let property = $propertyToAccess.select.columns->toOne();

  let rawRelOpElement = ^SemiStructuredPropertyAccess(property = $property, operand = $operand->unwrapAlias(), returnType = $f.genericType.rawType);

  let dataType = $f.genericType->genericTypeToDataType(ZeroOne);

  // dont cast if going from variant to variant
  let relOpElement = $dataType->match([
    s: meta::relational::metamodel::datatype::SemiStructured[1] | $rawRelOpElement,
    o: meta::relational::metamodel::datatype::Object[1] | $rawRelOpElement,
    any: Any[1] | newDynaFunction('cast', [$rawRelOpElement, ^DataTypeInfo(dataType = $dataType)])
  ]);

  let select = $operation.select;
  ^$operation(select = $state.inFilter->if(|^$select(filteringOperation = $relOpElement),|^$select(columns = $relOpElement)));  
}

function meta::relational::functions::pureToSqlQuery::processVariantFold(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  let params = $f.parametersValues->evaluateAndDeactivate();

  let foldFunctionType = $params->at(1).genericType.typeArguments.rawType->toOne()->cast(@FunctionType);

  let foldFunctionParamNames = $foldFunctionType.parameters->evaluateAndDeactivate().name;
  let foldFunctionParamTypes = $foldFunctionType.parameters->evaluateAndDeactivate().genericType;

  // Semi-structured guard: disable auto-flatten so the array stays as a scalar column
  let effectiveState = if($f->isSemiStructuredArrayInput($vars, $state), |^$state(disableAutoFlatten = true), |$state);

  let valueToFoldProcessed = $params->at(0)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$effectiveState(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)
    ->cast(@SelectWithCursor);
    
  let param1Type = $foldFunctionParamTypes->at(0)->genericTypeToDataType($foldFunctionType.parameters->at(0).multiplicity);
  let valueToFold = $valueToFoldProcessed.select.columns->toVariantFriendlyValue($param1Type);
  let param1 = ^RelationalLambdaParameter(name = $foldFunctionParamNames->at(0), value = $valueToFold, type = $param1Type);

  let foldStartingValueProcessed = $params->at(2)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)
    ->cast(@SelectWithCursor);

  let param2Type = $f.genericType->genericTypeToDataType($f.multiplicity);
  
  let foldStartingValue = if($f.multiplicity->isToMany(), |$foldStartingValueProcessed.select.columns->toVariantFriendlyValue($param2Type), |$foldStartingValueProcessed.select.columns->toOne());

  let param2 = ^RelationalLambdaParameter(name = $foldFunctionParamNames->at(1), value = $foldStartingValue, type = $param2Type);

  let select = $operation.select;
  let updatedState = $state->updateFunctionParamsScope($foldFunctionType,
      [
        ^$operation(select = ^$select(columns = $param1)),
        ^$operation(select = ^$select(columns = $param2))
      ]
    );    

  let lambdaBodyProcessed = $params->at(1)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$updatedState(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)
    ->cast(@SelectWithCursor);
  let lambdaBody = $lambdaBodyProcessed.select.columns->toOne();

  let relOpElement = ^FoldRelationalLambda(parameters = [$param1, $param2], body = $lambdaBody);

  ^$operation(select = $state.inFilter->if(|^$select(filteringOperation = $relOpElement),|^$select(columns = $relOpElement)));    
}

function meta::relational::functions::pureToSqlQuery::processVariantMap(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  let params = $f.parametersValues->evaluateAndDeactivate();

  let mapFunctionType = $params->at(1).genericType.typeArguments.rawType->toOne()->cast(@FunctionType);

  let mapFunctionParamNames = $mapFunctionType.parameters->evaluateAndDeactivate().name;
  let mapFunctionParamTypes = $mapFunctionType.parameters->evaluateAndDeactivate().genericType;

  let valueToMapProcessed = $params->at(0)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)
    ->cast(@SelectWithCursor);

  let valueToMapType = $mapFunctionParamTypes->at(0)->genericTypeToDataType($mapFunctionType.parameters->at(0).multiplicity);
  let valueToMap = $valueToMapProcessed.select.columns->toVariantFriendlyValue($valueToMapType);

  let param = ^RelationalLambdaParameter(name = $mapFunctionParamNames->at(0), value = $valueToMap, type = $valueToMapType);

  let select = $operation.select;
  let updatedState = $state->updateFunctionParamsScope($mapFunctionType,
      [
        ^$operation(select = ^$select(columns = $param))
      ]
    );      

  let lambdaBodyProcessed = $params->at(1)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$updatedState(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor);

  let lambdaBody = $lambdaBodyProcessed.select.columns->toOne();

  let relOpElement = ^MapRelationalLambda(parameters = $param, body = $lambdaBody);

  ^$operation(select = $state.inFilter->if(|^$select(filteringOperation = $relOpElement),|^$select(columns = $relOpElement)));    
}

function meta::relational::functions::pureToSqlQuery::processVariantPropertyNavigation(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  let params = $f.parametersValues->evaluateAndDeactivate();

  let operand = $params->at(0)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor);

  let inputMult = $params->at(0)->byPassRouterInfo()->match([
    e: Expression[1] | $e.multiplicity,
    i: InstanceValue[1] | $i.multiplicity
  ]);

  let func = if ($f.func->instanceOf(AbstractProperty), 
    |
      $f.func;
    ,
    |
      let funcDef = $f->instanceValueAtParameter(1)->cast(@FunctionDefinition<Any>);
      $funcDef.expressionSequence->at(0)->byPassRouterInfo()->cast(@FunctionExpression).func;
  )->cast(@AbstractProperty<Any>);
  
  let propMult = $func->functionReturnMultiplicity();
  let dataType = $f.genericType->genericTypeToDataType($propMult);

  let result = $func->match([
    prop: Property<Nil, Any|*>[1] | 
      
      print(if(!$context.debug, |'',
        | $context.space+'   Processing variant property navigation: ' + $prop->printProperty() + '  \n'));

      if ($inputMult->isToMany(),
        |
          let param = ^RelationalLambdaParameter(name = 'v_automap', value = $operand.select.columns->toOne(), type = ^meta::relational::metamodel::datatype::SemiStructured());
          let relOpElement = ^SemiStructuredPropertyAccess(property = ^Literal(value = $prop.name->toOne()), operand = $param);
        
          // dont cast if going from variant to variant
          let value = $dataType->match([
            s: meta::relational::metamodel::datatype::SemiStructured[1] | $relOpElement,
            o: meta::relational::metamodel::datatype::Object[1] | $relOpElement,
            any: Any[1] | newDynaFunction('variantTo', [$relOpElement, ^DataTypeInfo(dataType = $dataType)])
          ]);

          let autoMapOp = ^MapRelationalLambda(parameters = $param, body = $value);

          if ($propMult->isToMany(),
            |
              newDynaFunction('array_flatten', $autoMapOp)        
            ,
            | 
              $autoMapOp
          );
        ,
        |
          let relOpElement = ^SemiStructuredPropertyAccess(property = ^Literal(value = $prop.name->toOne()), operand = $operand.select.columns->unwrapAlias()->toOne());

          // dont cast if going from variant to variant
          $dataType->match([
            s: meta::relational::metamodel::datatype::SemiStructured[1] | $relOpElement,
            o: meta::relational::metamodel::datatype::Object[1] | $relOpElement,
            any: Any[1] | newDynaFunction('variantTo', [$relOpElement, ^DataTypeInfo(dataType = $dataType)])
          ]);
      );
    ,
    qprop: QualifiedProperty<Any>[1] |

      let ft =  $qprop->genericType().typeArguments.rawType->cast(@FunctionType)->toOne();

      let qtParams = $ft.parameters;

      print(if(!$context.debug, |'',
        | $context.space+'   Processing variant qualified property navigation: ' + $qprop->printProperty($params, [], ^GContext(space = '')) + '  \n'));  

      let thisVar = $qtParams->toOne($qprop.name->toOne() + ': Qualified properties with paramteters are not supported yet!');
      
      let expression = $qprop.expressionSequence->toOne($qprop.name->toOne() + ': Qualified properties with more than one line/expression are not supported!')->cast(@ValueSpecification);

      let paramValue = if ($inputMult->isToMany(), 
        | 
          $operand.select.columns->toOne(),
        | 
          newDynaFunction('toVariantList', $operand.select.columns->toOne())
      );

      let param = ^RelationalLambdaParameter(name = $thisVar.name->toOne(), value = $paramValue, type = ^meta::relational::metamodel::datatype::SemiStructured());
      
      let select = $operation.select;
            
      let updatedState = $state->updateFunctionParamScope($ft, ^$operation(select = ^$select(columns = $param)));            

      let lambdaBodyProcessed = $expression->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$updatedState(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor);

      let value = $lambdaBodyProcessed.select.columns->toOne();

      let autoMapOp = ^MapRelationalLambda(parameters = $param, body = $value);

      if ($propMult->isToMany(),
        |
          newDynaFunction('array_flatten', $autoMapOp)        
        ,
        |
          if ($inputMult->isToMany(), 
            | 
              $autoMapOp,
            | 
              let toOne = ^SemiStructuredArrayElementAccess(index =  ^Literal(value = 0), operand = $autoMapOp);
              $dataType->match([
                s: meta::relational::metamodel::datatype::SemiStructured[1] | $toOne,
                o: meta::relational::metamodel::datatype::Object[1] | $toOne,
                any: Any[1] | newDynaFunction('variantTo', [$toOne, ^DataTypeInfo(dataType = $dataType)])
              ]);
          );
      );
  ]);


  let select = $operation.select;
  ^$operation(select = $state.inFilter->if(|^$select(filteringOperation = $result),|^$select(columns = $result)));    
}

function meta::relational::functions::pureToSqlQuery::processVariantFilter(f:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
  let params = $f.parametersValues->evaluateAndDeactivate();

  let filterFunctionType = $params->at(1).genericType.typeArguments.rawType->toOne()->cast(@FunctionType);

  let filterFunctionParamNames = $filterFunctionType.parameters->evaluateAndDeactivate().name;
  let filterFunctionParamTypes = $filterFunctionType.parameters->evaluateAndDeactivate().genericType;

  let valueToFilterProcessed = $params->at(0)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)
    ->cast(@SelectWithCursor);

  let valueToFilterType = $filterFunctionParamTypes->at(0)->genericTypeToDataType($filterFunctionType.parameters->at(0).multiplicity);
  let valueToFilter = $valueToFilterProcessed.select.columns->toVariantFriendlyValue($valueToFilterType);

  let param = ^RelationalLambdaParameter(name = $filterFunctionParamNames->at(0), value = $valueToFilter, type = $valueToFilterType);

  let select = $operation.select;
  let updatedState = $state->updateFunctionParamsScope($filterFunctionType,
      [
        ^$operation(select = ^$select(columns = $param))
      ]
    );

  let lambdaBodyProcessed = $params->at(1)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$updatedState(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)
    ->cast(@SelectWithCursor);
  let lambdaBody = $lambdaBodyProcessed.select.columns->toOne();

  let relOp = ^FilterRelationalLambda(parameters = $param, body = $lambdaBody);

  ^$operation(select = $state.inFilter->if(|^$select(filteringOperation = $relOp),|^$select(columns = $relOp)));  
}

function meta::relational::functions::pureToSqlQuery::toVariantFriendlyValue(cols: RelationalOperationElement[*], dataType: meta::relational::metamodel::datatype::DataType[0..1]):RelationalOperationElement[1]
{
  let toList = {toList: RelationalOperationElement[*] |
    let arrayType = if ($dataType->isNotEmpty() && $dataType->toOne()->instanceOf(meta::relational::metamodel::datatype::Array), |$dataType->toOne(), |^meta::relational::metamodel::datatype::Array(type = $dataType));
    newDynaFunction('cast', newDynaFunction('toVariantList', $toList)->concatenate(^DataTypeInfo(dataType = $arrayType)));
  };

  $cols->unwrapAlias()->match([
    l: Literal[1] | $toList->eval($l->filter(v | !$v.value->instanceOf(SQLNull))),
    c: RelationalOperationElement[1] | $c,
    a: RelationalOperationElement[*] | $toList->eval($a)
  ]);
}

function meta::relational::functions::pureToSqlQuery::processVariantFlatten(expression:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
   assert(!$state.inFilter, |'Flatten not supported on inside filter');

   let isLateralFlatten = $state.functionExpressionStack->init()->last()->evaluateAndDeactivate().func == meta::pure::functions::relation::lateral_Relation_1__Function_1__Relation_1_;

   let columnName = $expression->instanceValuesAtParameter(1, $vars, $state.inScopeVars)->toOne()->cast(@meta::pure::metamodel::relation::ColSpec<Any>).name;

   let flattenNavigation = processValueSpecification($expression.parametersValues->at(0), $currentPropertyMapping, $operation, $vars, $state, $joinType, buildNodeId($nodeId,'_d0'), $aggFromMap, $context, $extensions)->cast(@SelectWithCursor);                        
   let flattenNavigationSelect = $flattenNavigation.select->mergeSQLQueryData($nodeId, $state, $context, $extensions);
   
   let paramType = $expression.parametersValues->at(0).genericType->genericTypeToDataType($expression.parametersValues->at(0).multiplicity);

   let navigation =$flattenNavigationSelect.columns->toVariantFriendlyValue($paramType);
   
   let column = ^Column(name = 'VALUE', type = ^meta::relational::metamodel::datatype::SemiStructured());
   let flattenOperation = if($isLateralFlatten, |^SemiStructuredArrayFlatten(navigation = $navigation), |^SemiStructuredArrayFlattenRelation(navigation = $navigation));

   let flattenTableAlias = ^TableAlias(relationalElement = $flattenOperation, name = 'flatten_' + $nodeId);

   let flattenedColumn = ^TableAliasColumn(alias = $flattenTableAlias, column = $column);
   let flattenedParamType = $expression.parametersValues->at(0).genericType->genericTypeToDataType(ZeroOne);
   let flattenOutput = ^Alias(name = $columnName->addQuotesIfNecessary(), relationalElement = newDynaFunction('cast', [$flattenedColumn, ^DataTypeInfo(dataType = $flattenedParamType)]));

   let node = ^RootJoinTreeNode(alias = $flattenTableAlias, columns = $flattenOutput);

   let resSelect = ^TdsSelectSqlQuery(data = $node, columns = $flattenOutput);
   
   $resSelect->validate($extensions);
   
   ^$operation(select = $resSelect);
}

function meta::relational::functions::pureToSqlQuery::processVariantJoinStrings(expression:FunctionExpression[1], currentPropertyMapping:PropertyMapping[*], operation:SelectWithCursor[1], vars:Map<VariableExpression, ValueSpecification>[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]):RelationalOperationElement[1]
{
   let params = $expression.parametersValues->evaluateAndDeactivate();
   let size = $params->size();
   let firstParam = $params->at(0);
   let semiStructuredPropertyMapping = $firstParam->resolveSemiStructuredBasePropertyMapping($currentPropertyMapping, $operation, $vars, $state, $joinType, $nodeId, $aggFromMap, $context, $extensions);

   let inputResult = $firstParam->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(disableAutoFlatten = true, inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor);
   let value = if($state.inFilter, |$inputResult.select.filteringOperation, |$inputResult.select.columns);
   let inputRelOp = $value->toVariantFriendlyValue($firstParam.genericType->genericTypeToDataType($firstParam.multiplicity));

   let separator = if(eq($size, 1),
                      | ^Literal(value=''),
                      | $params->at(if(eq($size, 2), |1, |2))->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor).select.columns->toOne()
                  );
   let arrayToStringDyna = newDynaFunction('array_to_string', [$inputRelOp, $separator]);
   let resultDyna = if(eq($size, 4),
                       | let prefix = $params->at(1)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor).select.columns->toOne();
                         let suffix = $params->at(3)->processValueSpecification($currentPropertyMapping, $operation, $vars, ^$state(inFilter = false), $joinType, $nodeId, $aggFromMap, $context, $extensions)->cast(@SelectWithCursor).select.columns->toOne();
                         newDynaFunction('concat', [$prefix, $arrayToStringDyna, $suffix]);,
                       | $arrayToStringDyna
                   );

   let select = $operation.select;
   let resultOp = ^$operation(select = $state.inFilter->if(|^$select(filteringOperation = $resultDyna), |^$select(columns = $resultDyna)));
   ^OperationWithParentPropertyMapping(element = $resultOp, currentPropertyMapping = $semiStructuredPropertyMapping);
}

// Resolves placeholder TACs inside a SemiStructuredPropertyAccess by recursing into operand.
function <<access.private>> meta::relational::functions::pureToSqlQuery::resolveSemiStructuredPropertyAccess(s:SemiStructuredPropertyAccess[1], state:State[1], srcOperation:SelectWithCursor[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], cancelJoinOnUnion:Boolean[1], context:DebugContext[1], extensions:Extension[*]):SelectWithCursor[1]
{
  // Two usage contexts for SemiStructuredPropertyAccess in processColumnsInRelationalOperationElements:
  //
  // 1. Top-level in a property mapping's relationalOperationElement (called from
  //    processSemiStructuredRelationalPropertyMapping): the caller pre-populates
  //    srcOperation.select.columns with the resolved parent value (e.g. array_first(...)).
  //    We must NOT recursively resolve the operand — just wrap what's already there.
  //
  // 2. Nested inside a DynaFunction (called from resolveDynaFunction's parameter map):
  //    srcOperation.select.columns is empty (select *). We must recursively resolve
  //    the SSPA's operand to find the actual column reference.
  let select = $srcOperation.select;
  let currentContent = $state.inFilter->if(|$select.filteringOperation, |$select.columns);
  if($currentContent->size() == 1,
    | // Case 1: caller prepared the select with a single resolved parent — use directly.
      let processedOperand = $currentContent->toOne();
      let resolved = ^$s(operand = $processedOperand);
      ^$srcOperation(select = $state.inFilter->if(|^$select(filteringOperation = $resolved), |^$select(columns = $resolved)));,
    | // Case 2: nested inside DynaFunction — recursively resolve the inner operand.
      let operandResult = $s.operand->processColumnsInRelationalOperationElements($state, $srcOperation, $nodeId, $aggFromMap, $cancelJoinOnUnion, $context, $extensions);
      let processedOperand = $state.inFilter->if(|$operandResult.select.filteringOperation, |$operandResult.select.columns)->toOne();
      let resolved = ^$s(operand = $processedOperand);
      let sel = $operandResult.select;
      ^$operandResult(select = $state.inFilter->if(|^$sel(filteringOperation = $resolved), |^$sel(columns = $resolved)));
  );
}

// Resolves placeholder TACs inside SemiStructuredArrayElementAccess by recursing
// into both operand and index.
function <<access.private>> meta::relational::functions::pureToSqlQuery::resolveSemiStructuredArrayAccess(ssa:SemiStructuredArrayElementAccess[1], state:State[1], srcOperation:SelectWithCursor[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], cancelJoinOnUnion:Boolean[1], context:DebugContext[1], extensions:Extension[*]):SelectWithCursor[1]
{
  let operandResult = $ssa.operand->processColumnsInRelationalOperationElements($state, $srcOperation, $nodeId, $aggFromMap, $cancelJoinOnUnion, $context, $extensions);
  let processedOperand = $state.inFilter->if(|$operandResult.select.filteringOperation, |$operandResult.select.columns)->toOne();
  let indexResult = $ssa.index->processColumnsInRelationalOperationElements($state, $operandResult, $nodeId, $aggFromMap, $cancelJoinOnUnion, $context, $extensions);
  let processedIndex = $state.inFilter->if(|$indexResult.select.filteringOperation, |$indexResult.select.columns)->toOne();
  let resolved = ^$ssa(operand = $processedOperand, index = $processedIndex);
  let sel = $indexResult.select;
  ^$indexResult(select = $state.inFilter->if(|^$sel(filteringOperation = $resolved), |^$sel(columns = $resolved)));
}

function <<access.private>> meta::relational::functions::pureToSqlQuery::processSemiStructuredRelationalPropertyMapping(origPropertyMappings:SemiStructuredRelationalPropertyMapping[*], property:AbstractProperty<Any>[1], propertyOwnerClass:Class<Any>[1], oldSrcOperation:SelectWithCursor[1], state:State[1], joinType:JoinType[1], nodeId:String[1], aggFromMap:List<ColumnGroup>[1], context:DebugContext[1], extensions:Extension[*]): RelationalOperationElement[1]
{
  assert($origPropertyMappings->size() >= 1, | 'Expected non-empty semi structured property mappings');
  let result = if($origPropertyMappings->forAll(p | $p.owner->toOne()->instanceOf(meta::relational::mapping::SemiStructuredEmbeddedRelationalInstanceSetImplementation)
                                                      || $p.owner->toOne()->instanceOf(meta::pure::mapping::relation::RelationFunctionInstanceSetImplementation)),
    | pair($oldSrcOperation, $origPropertyMappings->at(0).relationalOperationElement->processColumnsInRelationalOperationElements($state, $oldSrcOperation, $nodeId, $aggFromMap, true, $context, $extensions)),
    | let propertyMappings = $origPropertyMappings->map(p|$p->buildPossibleEnumMappingPushDown($state));
      let res = addMissingColumnIfUnion($propertyMappings, $property, $oldSrcOperation, $propertyOwnerClass, $state, $joinType, $nodeId, $aggFromMap, $context, $extensions);
      let propName = $res.first;
      let srcOperation = $res.second;
      pair($srcOperation, processRelationalOperationElementOfPropertyMapping($propertyMappings, $property, $propName, $srcOperation, $propertyOwnerClass, $state, $joinType, $nodeId, $aggFromMap, $context, $extensions));
  );
  let srcOperation = $result.first;
  let finalResult = $result.second;
  $finalResult->validate([], $extensions);
  if ($property.multiplicity->hasToOneUpperBound(),
    | $finalResult,
    | if ($state.disableAutoFlatten == true,
        | // disableAutoFlatten: return raw array column without LATERAL FLATTEN.
          // Also stamp avoidCastIfPrimitive=true on the navigation so the SQL renderer
          // does NOT append a primitive cast (e.g. ::varchar in Snowflake). Array functions
          // such as array_size / array_distinct / array_max need a true ARRAY/VARIANT input,
          // not the stringified JSON that the cast would produce.
          let swc = $finalResult->cast(@SelectWithCursor);
          let sel = $swc.select;
          let stamp = {c:RelationalOperationElement[1] | $c->match([
              s: SemiStructuredObjectNavigation[1] | ^$s(avoidCastIfPrimitive=true),
              a: Any[1] | $c
          ])};
          let updatedSel = if($state.inFilter,
              | ^$sel(filteringOperation = $sel.filteringOperation->map(c | $stamp->eval($c))),
              | ^$sel(columns = $sel.columns->map(c | $stamp->eval($c))));
          ^$swc(select = $updatedSel);,
        |
            // Property is 1->MANY. Need to flatten
          let navigation = if($state.inFilter, | $finalResult->cast(@SelectWithCursor).select.filteringOperation, | $finalResult->cast(@SelectWithCursor).select.columns)->toOne();
          let updatedNavigation = $navigation->match([s:SemiStructuredObjectNavigation[1]|^$s(avoidCastIfPrimitive=true), a:Any[*]|$navigation]);
          let arrayFlattening = ^SemiStructuredArrayFlatten(navigation = $updatedNavigation);
          let leftAlias = $finalResult.currentTreeNode->toOne().alias;
          let rightAlias = ^TableAlias(relationalElement = $arrayFlattening, name = 'arrayFlatten_' + $nodeId);
          let joinName = 'join_arrayFlatten_' + $arrayFlattening->buildUniqueName(false, true, $extensions);
          let join = ^Join(
            name = $joinName,
            target = $rightAlias,
            aliases = [pair($leftAlias, $rightAlias), pair($rightAlias, $leftAlias)],
            operation = ^DynaFunction(name = 'equal', parameters = [^Literal(value = 1), ^Literal(value = 1)]) // True operation
          );
          let lateralJoinNode = ^JoinTreeNode(
            database = ^Database(),
            joinName = $joinName,
            alias = $rightAlias,
            join = $join,
            joinType = $joinType,
            lateral = true
          );
          let joinAppliedNode = applyJoinInTree($finalResult.select.data->toOne(), $finalResult.currentTreeNode->toOne(), $lateralJoinNode, $srcOperation, $nodeId, $joinType, true, true, [], $state, $context, $extensions);
          let joinAppliedNodeSelect = $joinAppliedNode.select;
          let flattenOutput = ^SemiStructuredArrayFlattenOutput(tableAliasColumn = ^TableAliasColumn(alias = $joinAppliedNode.currentTreeNode.alias->toOne(), column = ^Column(name = 'result', type = ^meta::relational::metamodel::datatype::SemiStructured())), returnType  = $property.genericType.rawType);
          let res = ^$joinAppliedNode(
            select = ^$joinAppliedNodeSelect(
                columns = if($state.inFilter,|[],|$flattenOutput),
                filteringOperation = if($state.inFilter,|$flattenOutput,|[])
            )
          );
          $res->validate([], $extensions);
          $res;
      );
  );
}

function meta::relational::functions::pureToSqlQuery::explodeInCurrentJoinOperation(op: RelationalOperationElement[1]):Boolean[1]
{
  $op->match([
    d:DynaFunction[1] | $d.name == meta::relational::functions::sqlQueryToString::DynaFunctionRegistry.explodeSemiStructured.name || $d.parameters->map(p|$p->explodeInCurrentJoinOperation())->contains(true),
    a:Any[1]| false
  ]);
}

function meta::relational::functions::pureToSqlQuery::extractExplodeSemiStructured(op: RelationalOperationElement[1]):RelationalOperationElement[*]
{
  $op->match([
      d:DynaFunction[1] | if($d.name == meta::relational::functions::sqlQueryToString::DynaFunctionRegistry.explodeSemiStructured.name, | $d, | [])->concatenate($d.parameters->map(p|$p->extractExplodeSemiStructured())),
      a:Any[1]| []
    ]);
}

function meta::relational::functions::pureToSqlQuery::explodeReturnType(typeName:String[1]):Type[0..1]
{
    let map = meta::relational::functions::database::sqlTextToRelationalDataTypeMap();
    let func = $map->get($typeName);
    let columnType = if ($func->isEmpty(), | ^meta::relational::metamodel::datatype::SemiStructured(), | $func->toOne()->eval(1000, 1));
    let pureType = if($columnType->instanceOf(meta::relational::metamodel::datatype::SemiStructured), | [], | meta::relational::metamodel::datatype::dataTypeToCompatiblePureType($columnType));
}
