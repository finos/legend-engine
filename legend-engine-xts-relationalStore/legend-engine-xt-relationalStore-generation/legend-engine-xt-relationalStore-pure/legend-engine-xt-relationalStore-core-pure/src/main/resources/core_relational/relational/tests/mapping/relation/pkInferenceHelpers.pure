###Pure
import meta::pure::metamodel::relation::*;
import meta::relational::tests::mapping::relation::*;

// Relation functions for PK auto-inference tests (pkInferenceTests.pure).
// Bodies are never executed; `pkOfFunc()` only walks their expression tree.

// --- A. Single-operator scenarios ----------------------------------------
function meta::relational::tests::mapping::relation::pkTestBare(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
}

function meta::relational::tests::mapping::relation::pkTestFilter(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#->filter(x | $x.AGE > 25)
}

function meta::relational::tests::mapping::relation::pkTestLimit(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#->limit(5)
}

function meta::relational::tests::mapping::relation::pkTestDrop(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#->drop(2)
}

function meta::relational::tests::mapping::relation::pkTestSlice(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#->slice(1, 3)
}

function meta::relational::tests::mapping::relation::pkTestSort(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#->sort(~AGE->ascending())
}

function meta::relational::tests::mapping::relation::pkTestExtend(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#->extend(~DOUBLE_AGE:x | $x.AGE->toOne() * 2)
}

function meta::relational::tests::mapping::relation::pkTestRename(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#->rename(~ID, ~PERSON_ID)
}

function meta::relational::tests::mapping::relation::pkTestSelectKeepingPK(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#->select(~[ID, AGE])
}

function meta::relational::tests::mapping::relation::pkTestSelectDroppingPK(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#->select(~[AGE, FIRMID])
}

function meta::relational::tests::mapping::relation::pkTestSelectNoArgs(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#->select()
}

function meta::relational::tests::mapping::relation::pkTestDistinctNoArgs(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#->distinct()
}

function meta::relational::tests::mapping::relation::pkTestDistinctWithCols(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#->distinct(~[AGE, FIRMID])
}

function meta::relational::tests::mapping::relation::pkTestJoin(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  // Rename firmTable.ID to avoid duplicate column names in the joined row.
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->join(#>{meta::relational::tests::mapping::relation::testDB.firmTable}#->rename(~ID, ~FIRM_ID), JoinKind.INNER, {x, y | $x.FIRMID == $y.FIRM_ID})
}

// --- B. Unsupported / negative scenarios ---------------------------------
function meta::relational::tests::mapping::relation::pkTestConcatenate(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->concatenate(#>{meta::relational::tests::mapping::relation::testDB.personTable}#)
}

function meta::relational::tests::mapping::relation::pkTestAggregate(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->aggregate(~SUM:x | $x.AGE:y | $y->sum())
}

function meta::relational::tests::mapping::relation::pkTestPivot(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->pivot(~FIRMID, ~SUM:x | $x.AGE:y | $y->sum())
}

// --- C. Complex nested chains --------------------------------------------
function meta::relational::tests::mapping::relation::pkTestFilterSortLimit(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->filter(x | $x.AGE > 25)
    ->sort(~AGE->ascending())
    ->limit(5)
}

function meta::relational::tests::mapping::relation::pkTestRenameThenSelectKeepingPK(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->rename(~ID, ~PID)
    ->select(~[PID, AGE])
}

function meta::relational::tests::mapping::relation::pkTestRenameThenSelectDroppingPK(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->rename(~ID, ~PID)
    ->select(~[AGE, FIRMID])
}

function meta::relational::tests::mapping::relation::pkTestDoubleRename(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->rename(~ID, ~X)
    ->rename(~X, ~Y)
}

function meta::relational::tests::mapping::relation::pkTestGroupByThenFilter(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->groupBy(~FIRMID, ~SUM:x | $x.AGE:y | $y->sum())
    ->filter(x | $x.SUM > 10)
}

function meta::relational::tests::mapping::relation::pkTestGroupByThenRename(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->groupBy(~FIRMID, ~SUM:x | $x.AGE:y | $y->sum())
    ->rename(~FIRMID, ~FIRM)
}

function meta::relational::tests::mapping::relation::pkTestJoinThenFilterSort(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->join(#>{meta::relational::tests::mapping::relation::testDB.firmTable}#->rename(~ID, ~FIRM_ID), JoinKind.INNER, {x, y | $x.FIRMID == $y.FIRM_ID})
    ->filter(x | $x.AGE > 25)
    ->sort(~AGE->ascending())
}

function meta::relational::tests::mapping::relation::pkTestDistinctThenFilter(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->distinct(~[AGE, FIRMID])
    ->filter(x | $x.AGE > 25)
}

function meta::relational::tests::mapping::relation::pkTestSelectThenRenameThenFilter(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->select(~[ID, AGE, FIRMID])
    ->rename(~ID, ~PID)
    ->filter(x | $x.AGE > 20)
}

function meta::relational::tests::mapping::relation::pkTestJoinExtendFilterSelect(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->join(#>{meta::relational::tests::mapping::relation::testDB.groupMembershipTable}#, JoinKind.INNER, {x, y | $x.ID == $y.PERSONID})
    ->extend(~DOUBLE_AGE:x | $x.AGE->toOne() * 2)    ->filter(x | $x.AGE > 20)
    ->select(~[ID, GROUPID, AGE])
}

function meta::relational::tests::mapping::relation::pkTestGroupByThenSelectDroppingPK(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->groupBy(~FIRMID, ~SUM:x | $x.AGE:y | $y->sum())
    ->select(~[SUM])
}

function meta::relational::tests::mapping::relation::pkTestExtendThenSelectDroppingPK(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->extend(~DOUBLE_AGE:x | $x.AGE->toOne() * 2)
    ->select(~[AGE, FIRMID, DOUBLE_AGE])
}

function meta::relational::tests::mapping::relation::pkTestFilterThenRename(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->filter(x | $x.AGE > 25)
    ->rename(~ID, ~PID)
}

function meta::relational::tests::mapping::relation::pkTestRenameThenGroupBy(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->rename(~ID, ~PID)
    ->groupBy(~FIRMID, ~SUM:x | $x.AGE:y | $y->sum())
}

function meta::relational::tests::mapping::relation::pkTestJoinThenGroupBy(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->join(#>{meta::relational::tests::mapping::relation::testDB.groupMembershipTable}#, JoinKind.INNER, {x, y | $x.ID == $y.PERSONID})
    ->groupBy(~GROUPID, ~CNT:x | $x.AGE:y | $y->count())
}

function meta::relational::tests::mapping::relation::pkTestFilterExtendDistinct(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->filter(x | $x.AGE > 20)
    ->extend(~DOUBLE_AGE:x | $x.AGE->toOne() * 2)
    ->distinct()
}

function meta::relational::tests::mapping::relation::pkTestGroupByExtendFilterSelect(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->groupBy(~FIRMID, ~SUM:x | $x.AGE:y | $y->sum())
    ->extend(~DOUBLE_SUM:x | $x.SUM->toOne() * 2)
    ->filter(x | $x.SUM > 10)
    ->select(~[FIRMID, SUM, DOUBLE_SUM])
}

function meta::relational::tests::mapping::relation::pkTestSortLimitFilterRename(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#
    ->sort(~AGE->ascending())
    ->limit(100)
    ->filter(x | $x.AGE > 20)
    ->rename(~ID, ~PERSON_ID)
}

// Helpers with concrete RelationType return so callers can type-check column access.
function meta::relational::tests::mapping::relation::pkHelperFilteredPersons(): meta::pure::metamodel::relation::Relation<(ID:Integer, 'FIRST NAME':String, AGE:Integer, FIRMID:Integer, SALARY:Float)>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.personTable}#->filter(x | $x.AGE > 25)
}

function meta::relational::tests::mapping::relation::pkHelperFirms(): meta::pure::metamodel::relation::Relation<(ID:Integer, legalName:String)>[1]
{
  #>{meta::relational::tests::mapping::relation::testDB.firmTable}#->select(~[ID, legalName])
}

function meta::relational::tests::mapping::relation::pkTestComposedFilter(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  meta::relational::tests::mapping::relation::pkHelperFilteredPersons()->filter(x | true)
}

function meta::relational::tests::mapping::relation::pkTestComposedJoin(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  meta::relational::tests::mapping::relation::pkHelperFilteredPersons()
    ->join(meta::relational::tests::mapping::relation::pkHelperFirms()->rename(~ID, ~FIRM_ID), JoinKind.INNER, {x, y | $x.FIRMID == $y.FIRM_ID})
}

function meta::relational::tests::mapping::relation::pkTestComposedGroupBy(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  meta::relational::tests::mapping::relation::pkHelperFilteredPersons()
    ->groupBy(~FIRMID, ~SUM:x | $x.AGE:y | $y->sum())
}


