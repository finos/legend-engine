###Pure
Class test::semiStructuredUnionFlatten::Order
{
  orderId: String[1];
  orderStatus: String[0..1];
}

Class test::semiStructuredUnionFlatten::OrderFulfillment
{
  orderVersion: Integer[1];
  fulfillmentVersion: Integer[1];
  details: test::semiStructuredUnionFlatten::FulfillmentDetails[1];
  itemCategories() {$this.details.lineItems.category}: String[*];
}

Class test::semiStructuredUnionFlatten::FulfillmentDetails
{
  lineItems: test::semiStructuredUnionFlatten::LineItem[*];
}

Class test::semiStructuredUnionFlatten::LineItem
{
  category: String[1];
}

Association test::semiStructuredUnionFlatten::OrderFulfillmentAssociation
{
  order: test::semiStructuredUnionFlatten::Order[1];
  fulfillment: test::semiStructuredUnionFlatten::OrderFulfillment[1];
}

function test::semiStructuredUnionFlatten::testQuery(): meta::pure::tds::TabularDataSet[1]
{
  test::semiStructuredUnionFlatten::Order.all()->filter(
    x|$x.orderId != ''
  )->project(
    [
      x|$x.orderId,
      x|$x.orderStatus,
      x|$x.fulfillment.orderVersion,
      x|$x.fulfillment.fulfillmentVersion,
      x|$x.fulfillment.itemCategories
    ],
    [
      'Order Id',
      'Order Status',
      'Order Version',
      'Fulfillment Version',
      'Item Categories'
    ]
  )
}


###Relational
Database test::semiStructuredUnionFlatten::DB
(
  Schema ORDER_SCHEMA
  (
    Table ORDER_TABLE_A
    (
      ORDER_ID VARCHAR(100) PRIMARY KEY,
      ORDER_VERSION INTEGER PRIMARY KEY,
      ORDER_STATUS VARCHAR(50)
    )
    Table ORDER_TABLE_B
    (
      ORDER_ID VARCHAR(100) PRIMARY KEY,
      ORDER_VERSION INTEGER PRIMARY KEY,
      ORDER_STATUS VARCHAR(50)
    )
  )
  Schema FULFILLMENT_SCHEMA
  (
    Table FULFILLMENT_TABLE_A
    (
      FULFILLMENT_ID VARCHAR(100) PRIMARY KEY,
      FULFILLMENT_VERSION INTEGER PRIMARY KEY,
      ORDER_ID VARCHAR(100),
      ORDER_VERSION INTEGER,
      DETAILS SEMISTRUCTURED
    )
    Table FULFILLMENT_TABLE_B
    (
      FULFILLMENT_ID VARCHAR(100) PRIMARY KEY,
      FULFILLMENT_VERSION INTEGER PRIMARY KEY,
      ORDER_ID VARCHAR(100),
      ORDER_VERSION INTEGER,
      DETAILS SEMISTRUCTURED
    )
  )

  Join order_fulfillment_a(ORDER_SCHEMA.ORDER_TABLE_A.ORDER_ID = FULFILLMENT_SCHEMA.FULFILLMENT_TABLE_A.ORDER_ID and ORDER_SCHEMA.ORDER_TABLE_A.ORDER_VERSION = FULFILLMENT_SCHEMA.FULFILLMENT_TABLE_A.ORDER_VERSION)
  Join order_fulfillment_b(ORDER_SCHEMA.ORDER_TABLE_B.ORDER_ID = FULFILLMENT_SCHEMA.FULFILLMENT_TABLE_B.ORDER_ID and ORDER_SCHEMA.ORDER_TABLE_B.ORDER_VERSION = FULFILLMENT_SCHEMA.FULFILLMENT_TABLE_B.ORDER_VERSION)
)


