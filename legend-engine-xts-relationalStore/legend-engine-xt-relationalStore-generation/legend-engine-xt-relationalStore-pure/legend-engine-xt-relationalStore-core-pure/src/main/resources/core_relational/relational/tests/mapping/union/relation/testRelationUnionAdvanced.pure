// Error: 'Cannot cast a collection of size 0 to multiplicity [1]' (pureToSQLQuery_union.pure:747)
function <<test.ToFix, test.AlloyOnly>> meta::relational::tests::mapping::union::relation::advanced::testUnionOfSubAggregations_ProjectThroughFirm():Boolean[1]
