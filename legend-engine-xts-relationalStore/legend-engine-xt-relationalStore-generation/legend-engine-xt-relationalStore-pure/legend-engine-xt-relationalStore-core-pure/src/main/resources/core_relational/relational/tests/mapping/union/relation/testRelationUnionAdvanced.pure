// =============================================================================
// Sub-aggregation tests: each leg of the union mapping is sourced from a
// Pure Relation that already applies a groupBy aggregation. The mapping then
// unions those pre-aggregated rows. These exercise that the union plan
// correctly threads aggregated subqueries through projections, filters and
// the ModelJoin to Firm.
//
// Underlying per-set sub-aggregations (groupBy FirmID, max(lastName_s*)):
//    PersonSet1 -> (FirmID=1,'Scott'), (FirmID=2,'Roberts')
//    PersonSet2 -> (FirmID=1,'Wright')
// Unioned Person.all() therefore produces three rows.
// =============================================================================

// ToFix: Union of sub-aggregated relation mappings — SQL generation double-quotes FirmID in the GROUP BY clause
// (case-sensitive in H2) while the outer query references it without quotes, causing a SQL syntax error
// Error: 'Column "FirmID" not found' (H2 JdbcSQLSyntaxErrorException).
function <<test.ToFix, test.AlloyOnly>> meta::relational::tests::mapping::union::relation::advanced::testUnionOfSubAggregations_SimpleProject():Boolean[1]
{
   let result = execute(
      |Person.all()->project(~[name:p|$p.lastName]),
      unionOfTwoRelationMappingsWithSubAggregation,
      meta::external::store::relational::tests::testRuntime(myDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        name
        Roberts
        Scott
        Wright
     #->toString(),
     $result.values->at(0)->sort([~name->ascending()])->toString());
}

// ToFix: Union of sub-aggregated relation mappings — filtering from Person.firm through the model join causes
// the SQL query builder to encounter a RelationFunction where a NamedRelation is expected.
// Error: 'Cast exception: RelationFunction cannot be cast to NamedRelation' (pureToSQLQuery.pure:10133).
function <<test.ToFix, test.AlloyOnly>> meta::relational::tests::mapping::union::relation::advanced::testUnionOfSubAggregations_FilterFromFirm():Boolean[1]
{
   let resultFirmX = execute(
      |Person.all()->filter(p|$p.firm.legalName == 'Firm X')->project(~[name:p|$p.lastName]),
      unionOfTwoRelationMappingsWithSubAggregation,
      meta::external::store::relational::tests::testRuntime(myDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        name
        Scott
        Wright
     #->toString(),
     $resultFirmX.values->at(0)->sort([~name->ascending()])->toString());

   let resultFirmA = execute(
      |Person.all()->filter(p|$p.firm.legalName == 'Firm A')->project(~[name:p|$p.lastName]),
      unionOfTwoRelationMappingsWithSubAggregation,
      meta::external::store::relational::tests::testRuntime(myDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        name
        Roberts
     #->toString(),
     $resultFirmA.values->at(0)->sort([~name->ascending()])->toString());
}

// ToFix: Union of sub-aggregated relation mappings — filtering from Firm to Person (reverse model join) causes
// the union SQL generator to fail resolving the join relation, returning an empty collection.
