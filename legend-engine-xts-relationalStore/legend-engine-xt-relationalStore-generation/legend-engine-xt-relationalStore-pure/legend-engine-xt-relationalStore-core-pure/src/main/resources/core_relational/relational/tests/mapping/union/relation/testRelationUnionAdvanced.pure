// ToFix: Union on both sides of model join — filtering Person.firm navigates the model join during SQL generation
// but the SQL query builder expects a NamedRelation and instead finds a RelationFunction.
// Error: 'Cast exception: RelationFunction cannot be cast to NamedRelation' (pureToSQLQuery.pure:10133).
function <<test.ToFix, test.AlloyOnly>> meta::relational::tests::mapping::union::relation::advanced::testUnionTwoRelationMappings_FilterFromFirm():Boolean[1]
{
   let resultFirmX = execute(
      |Person.all()->filter(p|$p.firm.legalName == 'Firm X')->project(~[name:p|$p.lastName]),
      unionOfTwoRelationMappingsWithFirm,
      meta::external::store::relational::tests::testRuntime(myDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        name
        Anand
        Scott
        Taylor
        Wright
     #->toString(),
     $resultFirmX.values->at(0)->sort([~name->ascending()])->toString());

   let resultFirmA = execute(
      |Person.all()->filter(p|$p.firm.legalName == 'Firm A')->project(~[name:p|$p.lastName]),
      unionOfTwoRelationMappingsWithFirm,
      meta::external::store::relational::tests::testRuntime(myDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        name
        Roberts
     #->toString(),
     $resultFirmA.values->at(0)->sort([~name->ascending()])->toString());
}

// ToFix: Union on both sides of model join — filtering from Firm navigating to Person (reverse model join) causes
// the union SQL generator to fail resolving the join relation, returning an empty collection.
// Error: 'Cannot cast a collection of size 0 to multiplicity [1]' (pureToSQLQuery_union.pure:747)
function <<test.ToFix, test.AlloyOnly>> meta::relational::tests::mapping::union::relation::advanced::testUnionTwoRelationMappings_FilterToFirm():Boolean[1]
{
   let resultWright = execute(
      |Firm.all()->filter(f|$f.employees->exists(e|$e.lastName == 'Wright'))->project(~[legalName:f|$f.legalName]),
      unionOfTwoRelationMappingsWithFirm,
      meta::external::store::relational::tests::testRuntime(myDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        legalName
        Firm X
     #->toString(),
     $resultWright.values->at(0)->sort([~legalName->ascending()])->toString());

   let resultRoberts = execute(
      |Firm.all()->filter(f|$f.employees->exists(e|$e.lastName == 'Roberts'))->project(~[legalName:f|$f.legalName]),
      unionOfTwoRelationMappingsWithFirm,
      meta::external::store::relational::tests::testRuntime(myDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        legalName
        Firm A
     #->toString(),
     $resultRoberts.values->at(0)->sort([~legalName->ascending()])->toString());
}

// ToFix: Union on both sides of model join — projecting through Firm.employees (reverse model join) causes
// the union SQL generator to fail resolving the join relation, returning an empty collection.
// Error: 'Cannot cast a collection of size 0 to multiplicity [1]' (pureToSQLQuery_union.pure:747)
function <<test.ToFix, test.AlloyOnly>> meta::relational::tests::mapping::union::relation::advanced::testUnionTwoRelationMappings_ProjectThroughFirm():Boolean[1]
{
   let result = execute(
      |Firm.all()->project(~[legalName:f|$f.legalName, name:f|$f.employees.lastName]),
      unionOfTwoRelationMappingsWithFirm,
      meta::external::store::relational::tests::testRuntime(myDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        legalName, name
        Firm A, Roberts
        Firm X, Anand
        Firm X, Scott
        Firm X, Taylor
        Firm X, Wright
     #->toString(),
     $result.values->at(0)->sort([~legalName->ascending(), ~name->ascending()])->toString());
}

// ToFix: Mixed union (one relation mapping leg + one standard relational/table mapping leg) — filtering from
// Person.firm through the model join causes the SQL composer to encounter a TdsSelectSqlQuery where a NamedRelation
// is required. Error: 'Cast exception: TdsSelectSqlQuery cannot be cast to NamedRelation' (functions.pure:308)
function <<test.ToFix, test.AlloyOnly>> meta::relational::tests::mapping::union::relation::advanced::testUnionRelationAndRelational_FilterFromFirm():Boolean[1]
{
   let resultFirmX = execute(
      |Person.all()->filter(p|$p.firm.legalName == 'Firm X')->project(~[name:p|$p.lastName]),
      unionOfRelationAndRelationalMappingsWithFirm,
      meta::external::store::relational::tests::testRuntime(myDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        name
        Anand
        Scott
        Taylor
        Wright
     #->toString(),
     $resultFirmX.values->at(0)->sort([~name->ascending()])->toString());

   let resultFirmA = execute(
      |Person.all()->filter(p|$p.firm.legalName == 'Firm A')->project(~[name:p|$p.lastName]),
      unionOfRelationAndRelationalMappingsWithFirm,
      meta::external::store::relational::tests::testRuntime(myDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        name
        Roberts
     #->toString(),
     $resultFirmA.values->at(0)->sort([~name->ascending()])->toString());
}

