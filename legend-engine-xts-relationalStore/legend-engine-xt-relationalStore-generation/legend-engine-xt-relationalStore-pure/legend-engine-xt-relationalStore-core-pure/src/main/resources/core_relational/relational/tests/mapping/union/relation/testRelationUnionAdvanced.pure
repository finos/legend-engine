// =============================================================================
// Multi-column sub-aggregation tests: each leg's Relation function emits two
// aggregated columns per group (min and max of lastName, mapped to firstName
// and lastName respectively). Verifies projection, model-join traversal and
// row pairing across multiple aggregate outputs under a relation union.
//
// Underlying per-set sub-aggregations (groupBy FirmID):
//    PersonSet1 -> (FirmID=1,'Anand','Scott'), (FirmID=2,'Roberts','Roberts')
//    PersonSet2 -> (FirmID=1,'Taylor','Wright')
// =============================================================================

// ToFix: Union of multi-column sub-aggregated relation mappings — SQL generation double-quotes FirmID in the
// GROUP BY clause (case-sensitive in H2) while the outer query references it without quotes, causing a SQL
// syntax error. Same root cause as the single-column sub-aggregation SimpleProject variant.
// Error: 'Column "FirmID" not found' (H2 JdbcSQLSyntaxErrorException)
function <<test.ToFix, test.AlloyOnly>> meta::relational::tests::mapping::union::relation::advanced::testUnionOfMultiColumnSubAggregations_SimpleProject():Boolean[1]
{
   let result = execute(
      |Person.all()->project(~[first:p|$p.firstName, last:p|$p.lastName]),
      unionOfTwoRelationMappingsWithMultiColumnSubAggregation,
      meta::external::store::relational::tests::testRuntime(myDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        first, last
        Roberts, Roberts
        Anand, Scott
        Taylor, Wright
     #->toString(),
     $result.values->at(0)->sort([~last->ascending(), ~first->ascending()])->toString());
}

// ToFix: Union of multi-column sub-aggregated relation mappings — projecting through Firm.employees (reverse
// model join) causes the union SQL generator to fail resolving the join relation, returning an empty collection.
// Same root cause as the single-column sub-aggregation ProjectThroughFirm variant.
// Error: 'Cannot cast a collection of size 0 to multiplicity [1]' (pureToSQLQuery_union.pure:747).
function <<test.ToFix, test.AlloyOnly>> meta::relational::tests::mapping::union::relation::advanced::testUnionOfMultiColumnSubAggregations_ProjectThroughFirm():Boolean[1]
{
   let result = execute(
      |Firm.all()->project(~[legalName:f|$f.legalName, first:f|$f.employees.firstName, last:f|$f.employees.lastName]),
      unionOfTwoRelationMappingsWithMultiColumnSubAggregation,
      meta::external::store::relational::tests::testRuntime(myDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        legalName, first, last
        Firm A, Roberts, Roberts
        Firm X, Anand, Scott
        Firm X, Taylor, Wright
     #->toString(),
     $result.values->at(0)->sort([~legalName->ascending(), ~last->ascending(), ~first->ascending()])->toString());
}

// =============================================================================
// testTds helper and testTds-based variants of the tests above, mirroring the
// style used in testRelationUnion.pure.
// =============================================================================

function <<access.private>> meta::relational::tests::mapping::union::relation::advanced::testTds(func: FunctionDefinition<{->TabularDataSet[1]}>[1], mapping: Mapping[1], db: Database[1], expectedRows: String[*]): Boolean[1]
{
   let result = execute(
      $func,
      $mapping,
      meta::external::store::relational::tests::testRuntime($db),
      meta::relational::extension::relationalExtensions()
   ).values->at(0);
   assertSameElements($expectedRows, $result.rows->map(r | $r.values->makeString(' | ')));
}

function meta::relational::tests::mapping::union::relation::advanced::testUnionTwoRelationMappings_FilterFromFirm_Tds():Boolean[1]
{
   meta::relational::tests::mapping::union::relation::advanced::testTds(|Person.all()->filter(p|$p.firm.legalName == 'Firm X')->project(~[name:p|$p.lastName])->cast(@TabularDataSet),
           unionOfTwoRelationMappingsWithFirm,
           myDB,
           ['Anand', 'Scott', 'Taylor', 'Wright']
         );
   meta::relational::tests::mapping::union::relation::advanced::testTds(|Person.all()->filter(p|$p.firm.legalName == 'Firm A')->project(~[name:p|$p.lastName])->cast(@TabularDataSet),
           unionOfTwoRelationMappingsWithFirm,
           myDB,
           ['Roberts']
         );
}

function meta::relational::tests::mapping::union::relation::advanced::testUnionTwoRelationMappings_FilterToFirm_Tds():Boolean[1]
{
   meta::relational::tests::mapping::union::relation::advanced::testTds(|Firm.all()->filter(f|$f.employees->exists(e|$e.lastName == 'Wright'))->project(~[legalName:f|$f.legalName])->cast(@TabularDataSet),
           unionOfTwoRelationMappingsWithFirm,
           myDB,
           ['Firm X']
         );
   meta::relational::tests::mapping::union::relation::advanced::testTds(|Firm.all()->filter(f|$f.employees->exists(e|$e.lastName == 'Roberts'))->project(~[legalName:f|$f.legalName])->cast(@TabularDataSet),
           unionOfTwoRelationMappingsWithFirm,
           myDB,
           ['Firm A']
         );
}

function meta::relational::tests::mapping::union::relation::advanced::testUnionTwoRelationMappings_ProjectThroughFirm_Tds():Boolean[1]
{
   meta::relational::tests::mapping::union::relation::advanced::testTds(|Firm.all()->project(~[legalName:f|$f.legalName, name:f|$f.employees.lastName])->cast(@TabularDataSet),
           unionOfTwoRelationMappingsWithFirm,
           myDB,
           ['Firm A | Roberts', 'Firm X | Anand', 'Firm X | Scott', 'Firm X | Taylor', 'Firm X | Wright']
