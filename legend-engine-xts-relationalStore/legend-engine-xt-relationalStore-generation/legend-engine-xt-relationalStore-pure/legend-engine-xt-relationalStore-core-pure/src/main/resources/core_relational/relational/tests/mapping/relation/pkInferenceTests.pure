###Pure
import meta::pure::metamodel::relation::*;
import meta::relational::tests::mapping::relation::*;

// PK auto-inference tests for Relation Function class mappings.
// Each test runs `inferPrimaryKeyColumnNames` against a function body —
// the same path the Java compiler hits for ~primaryKey resolution.
// Explicit ~primaryKey is tested in Java (TestMappingCompilationFromGrammar,
// TestRelationalCompilationFromGrammar).

function <<access.private>> meta::relational::tests::mapping::relation::pkOfFunc(func:FunctionDefinition<Any>[1]):String[*]
{
  let expr = $func.expressionSequence->evaluateAndDeactivate()->at(0);
  meta::relational::mapping::inferPrimaryKeyColumnNames($expr);
}

// A. Single-operator coverage — one operator after a bare table accessor.

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKFromBareAccessor():Boolean[1]
{
  assertEquals(['ID'], pkOfFunc(
    meta::relational::tests::mapping::relation::pkTestBare__Relation_1_));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughFilter():Boolean[1]
{
  assertEquals(['ID'], pkOfFunc(
    meta::relational::tests::mapping::relation::pkTestFilter__Relation_1_));
}

