// Combined, self-contained store for the relation-mapping coverage tests
// (distinct / filter / groupBy / dates), all localised under mapping/relation.
//
// The columns backing [1] class properties are declared NOT NULL so the relation
// accessor infers them as [1]. This satisfies the relation-mapping multiplicity
// validator (a [1] property cannot be mapped to a [0..1] expression). Columns
// that are surfaced through a LEFT join in a function body still degrade to
// [0..1] at that point, so the classes map those to [0..1] properties.

###Relational
Database meta::relational::tests::mapping::relation::coverage::coverageDB
(
   Table ACCOUNT_INFO
   (
      IF_CODE INTEGER NOT NULL,
      IF_NAME VARCHAR(200) NOT NULL,
      IF_TYPE VARCHAR(20) NOT NULL
   )

   Table IF_OTHER_INFO
   (
      IF_CODE INTEGER PRIMARY KEY,
      IF_OTHER_NAME VARCHAR(20) NOT NULL
   )

   Table orgTable
   (
      id INTEGER PRIMARY KEY,
      filterVal INTEGER NOT NULL,
      parentId INTEGER,
      name VARCHAR(200) NOT NULL
   )

   Table otherTable
   (
      orgTableId INTEGER NOT NULL,
      filterVal INTEGER NOT NULL
   )

   Table TRADE
   (
      TRADE_ID INTEGER PRIMARY KEY,
      ACC_NUM INTEGER NOT NULL,
      GSN VARCHAR(20) NOT NULL,
      PRODUCT_ID INTEGER NOT NULL,
      QTY INTEGER NOT NULL
   )

   Table PRODUCT
   (
      ID INTEGER PRIMARY KEY,
      DESCRIPTION VARCHAR(20) NOT NULL
   )

   Table PRODUCT_EXPLODED
   (
      TRADEABLE_ID INTEGER PRIMARY KEY,
      PRODUCT_ID INTEGER NOT NULL,
      DESCRIPTION VARCHAR(20) NOT NULL,
      ACTIVE INTEGER NOT NULL
   )

   Table tradeTable
   (
      ID INTEGER PRIMARY KEY,
      quantity FLOAT NOT NULL,
      tradeDate DATE NOT NULL,
      settlementDateTime TIMESTAMP
   )
)

###Pure
// A class dedicated to the multi-aggregate groupBy scenario. The reducer columns
// min/max/average are declared [0..1] because a group aggregate can infer as
// either [1] or [0..1]; a [0..1] property subsumes both, so the mapping is safe
// regardless of the exact inferred multiplicity. sum/count always infer as [1].
Class meta::relational::tests::mapping::relation::coverage::PositionStats
{
   acctNum : Integer[1];
   gsn     : String[1];
   total   : Integer[1];
   cnt     : Integer[1];
   minQty  : Integer[0..1];
   maxQty  : Integer[0..1];
   avgQty  : Float[0..1];
}

// Domain class for the date/date-time coverage; no equivalent exists in the
// classic relation model, so it is defined locally.
Class meta::relational::tests::mapping::relation::coverage::Trade
{
   id: Integer[1];
   quantity: Float[1];
   date: StrictDate[1];
   settlementDateTime: DateTime[0..1];
}

###Pure
import meta::relational::metamodel::execute::*;
import meta::relational::functions::toDDL::*;
import meta::relational::tests::mapping::relation::coverage::*;

function <<meta::pure::profiles::test.BeforePackage>> meta::relational::tests::mapping::relation::coverage::setUp():Boolean[1]
{
   meta::relational::tests::mapping::relation::coverage::createTablesAndFillDb();
}

function meta::relational::tests::mapping::relation::coverage::createTablesAndFillDb():Boolean[1]
{
   let connection = meta::external::store::relational::tests::testRuntime(coverageDB).connectionByElement(coverageDB)->cast(@meta::external::store::relational::runtime::TestDatabaseConnection);

   // distinct model
   dropAndCreateTableInDb(coverageDB, 'ACCOUNT_INFO', $connection);
   executeInDb('insert into ACCOUNT_INFO (IF_CODE, IF_NAME, IF_TYPE) values (1001, \'IF 1\', \'Type 1\');', $connection);
   executeInDb('insert into ACCOUNT_INFO (IF_CODE, IF_NAME, IF_TYPE) values (1002, \'IF 2\', \'Type 1\');', $connection);
   executeInDb('insert into ACCOUNT_INFO (IF_CODE, IF_NAME, IF_TYPE) values (1002, \'IF 2\', \'Type 1\');', $connection);
   executeInDb('insert into ACCOUNT_INFO (IF_CODE, IF_NAME, IF_TYPE) values (1022, \'IF 2\', \'Type 1\');', $connection);
   executeInDb('insert into ACCOUNT_INFO (IF_CODE, IF_NAME, IF_TYPE) values (1002, \'IF 2\', \'Type 2\');', $connection);

   dropAndCreateTableInDb(coverageDB, 'IF_OTHER_INFO', $connection);
   executeInDb('insert into IF_OTHER_INFO (IF_CODE, IF_OTHER_NAME) values (1001, \'IfName1\');', $connection);
   executeInDb('insert into IF_OTHER_INFO (IF_CODE, IF_OTHER_NAME) values (1002, \'IfName2\');', $connection);

   // filter model
   dropAndCreateTableInDb(coverageDB, 'orgTable', $connection);
   executeInDb('insert into orgTable (id, filterVal, parentId, name) values (1, 4, -1, \'ROOT\');', $connection);
   executeInDb('insert into orgTable (id, filterVal, parentId, name) values (2, 4, 1, \'Firm X\');', $connection);
   executeInDb('insert into orgTable (id, filterVal, parentId, name) values (3, 4, 1, \'Firm A\');', $connection);
   executeInDb('insert into orgTable (id, filterVal, parentId, name) values (4, 4, 2, \'Securities\');', $connection);
   executeInDb('insert into orgTable (id, filterVal, parentId, name) values (5, 4, 2, \'Banking\');', $connection);
   executeInDb('insert into orgTable (id, filterVal, parentId, name) values (6, 4, 2, \'Federation\');', $connection);
   executeInDb('insert into orgTable (id, filterVal, parentId, name) values (7, 6, 2, \'ShouldNotBeDisplayed\');', $connection);

   dropAndCreateTableInDb(coverageDB, 'otherTable', $connection);
   executeInDb('insert into otherTable (orgTableId, filterVal) values (1, 4);', $connection);
   executeInDb('insert into otherTable (orgTableId, filterVal) values (2, 4);', $connection);
   executeInDb('insert into otherTable (orgTableId, filterVal) values (3, 4);', $connection);
   executeInDb('insert into otherTable (orgTableId, filterVal) values (4, 4);', $connection);
   executeInDb('insert into otherTable (orgTableId, filterVal) values (5, 4);', $connection);
   executeInDb('insert into otherTable (orgTableId, filterVal) values (6, 4);', $connection);
   executeInDb('insert into otherTable (orgTableId, filterVal) values (7, 6);', $connection);

   // groupBy model
   dropAndCreateTableInDb(coverageDB, 'TRADE', $connection);
   executeInDb('insert into TRADE (TRADE_ID, ACC_NUM, GSN, PRODUCT_ID, QTY) values (1, 7900002, \'YU2EF5\', 1, 3);', $connection);
   executeInDb('insert into TRADE (TRADE_ID, ACC_NUM, GSN, PRODUCT_ID, QTY) values (2, 7900002, \'YU2EF5\', 1, 5);', $connection);
   executeInDb('insert into TRADE (TRADE_ID, ACC_NUM, GSN, PRODUCT_ID, QTY) values (3, 7900003, \'EA4GNY\', 2, 100);', $connection);
   executeInDb('insert into TRADE (TRADE_ID, ACC_NUM, GSN, PRODUCT_ID, QTY) values (4, 7900003, \'EA4GNY\', 2, 200);', $connection);

   dropAndCreateTableInDb(coverageDB, 'PRODUCT', $connection);
   executeInDb('insert into PRODUCT (ID, DESCRIPTION) values (1, \'Firm D\');', $connection);
   executeInDb('insert into PRODUCT (ID, DESCRIPTION) values (2, \'Gold\');', $connection);

   dropAndCreateTableInDb(coverageDB, 'PRODUCT_EXPLODED', $connection);
   executeInDb('insert into PRODUCT_EXPLODED (TRADEABLE_ID, PRODUCT_ID, DESCRIPTION, ACTIVE) values (11, 1, \'Firm D\', 1);', $connection);
   executeInDb('insert into PRODUCT_EXPLODED (TRADEABLE_ID, PRODUCT_ID, DESCRIPTION, ACTIVE) values (22, 2, \'Gold\', 0);', $connection);
   executeInDb('insert into PRODUCT_EXPLODED (TRADEABLE_ID, PRODUCT_ID, DESCRIPTION, ACTIVE) values (33, 2, \'Gold\', 0);', $connection);

   // dates model
   dropAndCreateTableInDb(coverageDB, 'tradeTable', $connection);
   executeInDb('insert into tradeTable (ID, quantity, tradeDate, settlementDateTime) values (1, 25, \'2014-12-01\', \'2014-12-02 21:00:00\');', $connection);
   executeInDb('insert into tradeTable (ID, quantity, tradeDate, settlementDateTime) values (2, 320, \'2014-12-01\', \'2014-12-02 21:00:00\');', $connection);
   executeInDb('insert into tradeTable (ID, quantity, tradeDate, settlementDateTime) values (3, 11, \'2014-12-01\', \'2014-12-02 21:00:00\');', $connection);
   executeInDb('insert into tradeTable (ID, quantity, tradeDate, settlementDateTime) values (4, 23, \'2014-12-02\', \'2014-12-03 21:00:00\');', $connection);
   executeInDb('insert into tradeTable (ID, quantity, tradeDate, settlementDateTime) values (5, 32, \'2014-12-02\', \'2014-12-03 21:00:00\');', $connection);
   executeInDb('insert into tradeTable (ID, quantity, tradeDate, settlementDateTime) values (6, 27, \'2014-12-03\', \'2014-12-04 21:00:00\');', $connection);
   executeInDb('insert into tradeTable (ID, quantity, tradeDate, settlementDateTime) values (7, 44, \'2014-12-03\', \'2014-12-04 15:22:23.123456789\');', $connection);
   executeInDb('insert into tradeTable (ID, quantity, tradeDate, settlementDateTime) values (8, 22, \'2014-12-04\', \'2014-12-05 21:00:00\');', $connection);
   executeInDb('insert into tradeTable (ID, quantity, tradeDate, settlementDateTime) values (9, 45, \'2014-12-04\', \'2014-12-05 21:00:00\');', $connection);
   executeInDb('insert into tradeTable (ID, quantity, tradeDate) values (10, 38, \'2014-12-04\');', $connection);
   executeInDb('insert into tradeTable (ID, quantity, tradeDate) values (11, 5, \'2014-12-05\');', $connection);
   executeInDb('insert into tradeTable (ID, quantity, tradeDate, settlementDateTime) values (12, 45, \'2016-02-04\', \'2016-02-05T21:00:00.123456789\');', $connection);
   executeInDb('insert into tradeTable (ID, quantity, tradeDate, settlementDateTime) values (13, 45, \'2016-03-28\', \'2016-03-29T21:00:00.123456789\');', $connection);
   executeInDb('insert into tradeTable (ID, quantity, tradeDate, settlementDateTime) values (14, 45, \'2016-03-28\', \'2016-03-29 21:00:00.123456789\');', $connection);
   executeInDb('insert into tradeTable (ID, quantity, tradeDate, settlementDateTime) values (15, 45, \'2016-02-14\', \'2016-02-15T21:00:00.123456789\');', $connection);

   true;
}
