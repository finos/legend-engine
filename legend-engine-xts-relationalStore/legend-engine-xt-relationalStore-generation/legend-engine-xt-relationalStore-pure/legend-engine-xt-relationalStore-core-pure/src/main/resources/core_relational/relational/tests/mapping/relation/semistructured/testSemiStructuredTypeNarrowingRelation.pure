function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::typenarrowing::testSemiStructuredMatchComplexProperty(conn: Connection[1]): Boolean[1]
{
  typeNarrowingExecute($conn,
    |Order.all()->project(~[
      'Customer Address': x|$x.customer.customerAddress->match([
        s: BillingAddress[1]  | $s.billAddress,
        s: ShippingAddress[1] | $s.shipAddress,
        s: Any[1]             | 'Default Address'
      ])
    ]),
    'Customer Address\n' +
    'B1\n' +
    'B2\n' +
    'B3\n' +
    'Default Address\n' +
    'S2\n' +
    'S1\n' +
    'S3\n' +
    'S4\n' +
    'Default Address\n' +
    'Default Address\n'
  );
}

function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::typenarrowing::testSemiStructuredMatchWithDifferentMultiplicities(conn: Connection[1]): Boolean[1]
{
  typeNarrowingExecute($conn,
    |Order.all()->project(~[
      'Customer Address': x|$x.customer.customerAddress->match([
        s: BillingAddress[1]  | $s.billAddress,
        s: ShippingAddress[1] | $s.shipAddress,
        s: CustomerAddress[1] | $s.defaultAddress,
        s: Any[1]             | []
      ])
    ]),
    'Customer Address\n' +
    'B1\n' +
    'B2\n' +
    'B3\n' +
    '\n' +
    'S2\n' +
    'S1\n' +
    'S3\n' +
    'S4\n' +
    '\n' +
    'Default Customer Address\n'
  );
}

function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::typenarrowing::testSemiStructuredMatchWithMultipleProject(conn: Connection[1]): Boolean[1]
{
  typeNarrowingExecute($conn,
    |Order.all()->project(~[
      'Customer Address': x|$x.customer.customerAddress->match([
        s: BillingAddress[1]  | $s.billAddress,
        s: ShippingAddress[1] | $s.shipAddress
      ]),
      'Order Price'     : x|$x.customer.transactionDetails.payment->match([
        s: CashOnDeliveryPayment[1] | $s.amountToBePaid,
        s: PrepaidPayment[1]        | $s.amountPaid
      ])
    ]),
    'Customer Address,Order Price\n' +
    'B1,200\n' +
    'B2,180\n' +
    'B3,290\n' +
    ',150\n' +
    'S2,120\n' +
    'S1,185\n' +
    'S3,180\n' +
    'S4,160\n' +
    ',150\n' +
    ',150\n'
  );
}

function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::typenarrowing::testSemiStructuredMatchWithComplexFilter(conn: Connection[1]): Boolean[1]
{
  typeNarrowingExecute($conn,
    |Order.all()
      ->filter(x | $x.customer.transactionDetails.payment->match([
          s: CashOnDeliveryPayment[1] | $s.amountToBePaid,
          s: PrepaidPayment[1]        | $s.amountPaid
        ]) < 200)
      ->project(~[
        'Customer Address': x|$x.customer.customerAddress->match([
          s: BillingAddress[1]  | $s.billAddress,
          s: ShippingAddress[1] | $s.shipAddress
        ])
      ]),
    'Customer Address\n' +
    'B2\n' +
    '\n' +
    'S2\n' +
    'S1\n' +
    'S3\n' +
    'S4\n' +
    '\n' +
    '\n'
  );
}

function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::typenarrowing::testSemiStructuredMatchWithVariableAccess(conn: Connection[1]): Boolean[1]
{
  let maxAmount = 200;
  typeNarrowingExecute($conn,
    |Order.all()->project(~[
      'Max Amount Flag': x|$x.customer.transactionDetails.payment->match([
        s: CashOnDeliveryPayment[1] | if($s.amountToBePaid < $maxAmount, |true, |false),
        s: PrepaidPayment[1]        | if($s.amountPaid < $maxAmount, |true, |false)
      ])
    ]),
    'Max Amount Flag\n' +
    'false\n' +
    'true\n' +
    'false\n' +
    'true\n' +
    'true\n' +
    'true\n' +
    'true\n' +
    'true\n' +
    'true\n' +
    'true\n'
  );
}

function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::typenarrowing::testSemiStructuredMatchMultilevel(conn: Connection[1]): Boolean[1]
{
  typeNarrowingExecute($conn,
    |Order.all()->project(~[
      'Amount': x|$x.customer.transactionDetails.payment->match([
        s: PrepaidPayment[1]        | $s->match([
          k: WalletPrepaidPayment[1] | $k.walletTransactionAmount,
          k: CardPrepaidPayment[1]   | $k.cardTransactionAmount,
          k: PrepaidPayment[1]       | $k.amountPaid
        ]),
        s: CashOnDeliveryPayment[1] | $s.amountToBePaid
      ])
    ]),
    'Amount\n' +
    '200\n' +
    '180\n' +
    '290\n' +
    '150\n' +
    '120\n' +
    '185\n' +
    '200\n' +
    '190\n' +
    '150\n' +
    '150\n'
  );
}

function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::typenarrowing::testSemiStructuredMatchWithMultipleProjectUsingCol(conn: Connection[1]): Boolean[1]
{
  typeNarrowingExecute($conn,
    |Order.all()->project(~[
      'Customer Address': x|$x.customer.customerAddress->match([
        s: BillingAddress[1]  | $s.billAddress,
        s: ShippingAddress[1] | $s.shipAddress
      ]),
      'Order Price'     : x|$x.customer.transactionDetails.payment->match([
        s: CashOnDeliveryPayment[1] | $s.amountToBePaid,
        s: PrepaidPayment[1]        | $s.amountPaid
      ])
    ]),
    'Customer Address,Order Price\n' +
    'B1,200\n' +
    'B2,180\n' +
    'B3,290\n' +
    ',150\n' +
    'S2,120\n' +
    'S1,185\n' +
    'S3,180\n' +
    'S4,160\n' +
    ',150\n' +
    ',150\n'
  );
}
