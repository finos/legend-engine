// =========================================================================
// Nested property chain: employees.address.city == firm.city && ...country
// =========================================================================
Mapping meta::relational::tests::mapping::modelJoin::advanced::NestedPropertyChainMapping
(
  *meta::relational::tests::mapping::modelJoin::domain::Person[person]: Relation
  {
    ~func meta::relational::tests::mapping::modelJoin::function::personTable():Relation<Any>[1]
    firstName: FIRSTNAME,
    lastName: LASTNAME,
    age: AGE,
    +id: Integer[1]: ID,
    +firmId: Integer[1]: FIRMID
  }
  *meta::relational::tests::mapping::modelJoin::domain::Firm[firm]: Relation
  {
    ~func meta::relational::tests::mapping::modelJoin::function::firmTable():Relation<Any>[1]
    legalName: LEGALNAME,
    city: CITY,
    country: COUNTRY,
    +id: Integer[1]: ID
  }
  *meta::relational::tests::mapping::modelJoin::domain::Address[address]: Relation
  {
    ~func meta::relational::tests::mapping::modelJoin::function::addressTable():Relation<Any>[1]
    city: CITY,
    country: COUNTRY,
    +personId: Integer[1]: PERSONID
  }

  Person_Address: ModelJoin
  {
    {person: meta::relational::tests::mapping::modelJoin::domain::Person[1], address: meta::relational::tests::mapping::modelJoin::domain::Address[1]|$person.id == $address.personId}
  }

  Person_Firm: ModelJoin
  {
    {employees: meta::relational::tests::mapping::modelJoin::domain::Person[1], firm: meta::relational::tests::mapping::modelJoin::domain::Firm[1]|$employees.address.city == $firm.city && $employees.address.country == $firm.country}
  }
)

