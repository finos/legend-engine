// =========================================================================
// Advanced Nesting & Target Processing Mappings
// Uses the shared Database/domain from modelJoinSimpleSetup.pure
// =========================================================================

###Pure
// =========================================================================
// Complex Relation Function: personTable JOIN addressTable (pre-joined)
// =========================================================================
function meta::relational::tests::mapping::modelJoin::function::personWithAddressJoined(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::modelJoin::store::Db.personTable}#
    ->join(#>{meta::relational::tests::mapping::modelJoin::store::Db.addressTable}#->select(~[PERSONID, CITY, COUNTRY]), meta::pure::functions::relation::JoinKind.LEFT, {p,a | $p.ID == $a.PERSONID})
    ->select(~[ID, FIRSTNAME, LASTNAME, FIRMID, AGE, CITY, COUNTRY])
}

