function showcase::modelJoinTests::advanced::query::firmWithEmployees(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  showcase::modelJoinTests::advanced::domain::Firm.all()->project(
    ~[
       'Legal Name': x|$x.legalName,
       'Employee First Name': x|$x.employees.firstName
     ]
  )
}

function showcase::modelJoinTests::advanced::query::personWithFirm(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  showcase::modelJoinTests::advanced::domain::Person.all()->project(
    ~[
       'First Name': x|$x.firstName,
       'Firm Name': x|$x.firm.legalName
     ]
  )
}

function showcase::modelJoinTests::advanced::query::personWithContract(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  showcase::modelJoinTests::advanced::domain::Person.all()->project(
    ~[
       'First Name': x|$x.firstName,
       'Contract': x|$x.contracts(%2024-01-01).description
     ]
  )
}

function showcase::modelJoinTests::advanced::query::firmWithEmployeesInCity(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  showcase::modelJoinTests::advanced::domain::Firm.all()->project(
    ~[
       'Legal Name': x|$x.legalName,
       'Employee In NYC': x|$x.employeesInCity('NYC').firstName
     ]
  )
}

// Test 21: Target milestoned (Order), source NOT milestoned (Warehouse)
// Nested condition: orders.product.category == warehouse.section.zone
function showcase::modelJoinTests::advanced::query::warehouseWithOrders(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  showcase::modelJoinTests::advanced::domain::Warehouse.all()->project(
    ~[
       'Warehouse': x|$x.name,
       'Order': x|$x.orders(%2024-01-01).description
     ]
  )
}

// Test 22: Source milestoned (Order), target NOT milestoned (Warehouse)
// Same ModelJoin as test 21, inverted: Order.all(%2024-01-01)→warehouse.name
function showcase::modelJoinTests::advanced::query::orderWithWarehouse(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  showcase::modelJoinTests::advanced::domain::Order.all(%2024-01-01)->project(
    ~[
       'Order': x|$x.description,
       'Warehouse': x|$x.warehouse.name
     ]
  )
}

// Test 23: Both milestoned same scheme (Order + Shipment both business temporal)
// Uses DIFFERENT dates: Order at %2024-03-01, Shipment at %2024-07-01
// Nested condition: order_ship.product.code == shipments.trackingRef.prefix
function showcase::modelJoinTests::advanced::query::orderWithShipments(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  showcase::modelJoinTests::advanced::domain::Order.all(%2024-03-01)->project(
    ~[
       'Order': x|$x.description,
       'Carrier': x|$x.shipments(%2024-07-01).carrier
     ]
  )
}

// Test 24: Different schemes (Order=business, AuditEntry=processing)
// Nested condition: order_audit.product.code == auditEntries.entityRef
function showcase::modelJoinTests::advanced::query::orderWithAudit(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  showcase::modelJoinTests::advanced::domain::Order.all(%2024-01-01)->project(
    ~[
       'Order': x|$x.description,
       'Audit': x|$x.auditEntries(%2024-01-01T10:00:00).message
     ]
  )
}

// Test 25: Both milestoned same scheme with milestoned INTERMEDIATES
// Order at %2024-03-01, Shipment at %2024-07-01
// Intermediates (MilestonedProduct, MilestonedTrackingRef) are also business temporal
// Condition traverses through milestoned intermediates:
//   order_ship.milestonedProduct(%2024-03-01).code == shipments.milestonedTrackingRef(%2024-07-01).prefix
function showcase::modelJoinTests::advanced::query::orderWithShipmentsMilestonedIntermediates(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  showcase::modelJoinTests::advanced::domain::Order.all(%2024-03-01)->project(
    ~[
       'Order': x|$x.description,
       'Carrier': x|$x.shipments(%2024-07-01).carrier
     ]
  )
}


