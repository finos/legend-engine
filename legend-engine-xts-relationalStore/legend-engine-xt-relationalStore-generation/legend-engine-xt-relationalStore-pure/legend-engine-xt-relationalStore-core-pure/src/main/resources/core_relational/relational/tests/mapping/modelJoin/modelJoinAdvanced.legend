###Relational
Database showcase::modelJoinTests::advanced::store::Database
(
  Schema default
  (
    Table firmTable
    (
      ID INTEGER PRIMARY KEY,
      LEGALNAME VARCHAR(100),
      CITY VARCHAR(100),
      COUNTRY VARCHAR(100),
      CODE VARCHAR(50)
    )

    Table personTable
    (
      ID INTEGER PRIMARY KEY,
      FIRSTNAME VARCHAR(100),
      LASTNAME VARCHAR(100),
      FIRMID INTEGER,
      AGE INTEGER
    )

    Table addressTable
    (
      ID INTEGER PRIMARY KEY,
      PERSONID INTEGER,
      CITY VARCHAR(100),
      COUNTRY VARCHAR(100)
    )

    Table fullTimeTable
    (
      ID INTEGER PRIMARY KEY,
      FIRSTNAME VARCHAR(100),
      LASTNAME VARCHAR(100),
      FIRMID INTEGER,
      AGE INTEGER
    )

    Table contractTable
    (
      ID INTEGER PRIMARY KEY,
      FIRSTNAME VARCHAR(100),
      LASTNAME VARCHAR(100),
      FIRMID INTEGER,
      AGE INTEGER
    )

    Table firmTableB
    (
      ID INTEGER PRIMARY KEY,
      LEGALNAME VARCHAR(100),
      CITY VARCHAR(100),
      COUNTRY VARCHAR(100),
      CODE VARCHAR(50)
    )

    Table contractLogTable
    (
      milestoning(
        business(BUS_FROM=FROM_Z, BUS_THRU=THRU_Z, INFINITY_DATE=%9999-12-31T00:00:00.0000)
      )
      ID INTEGER PRIMARY KEY,
      PERSONID INTEGER,
      DESCRIPTION VARCHAR(200),
      FROM_Z DATE,
      THRU_Z DATE
    )

    Table orderTable
    (
      milestoning(
        business(BUS_FROM=FROM_Z, BUS_THRU=THRU_Z, INFINITY_DATE=%9999-12-31T00:00:00.0000)
      )
      ID INTEGER PRIMARY KEY,
      PRODUCTID INTEGER,
      DESCRIPTION VARCHAR(200),
      REFCODE VARCHAR(50),
      FROM_Z DATE,
      THRU_Z DATE
    )

    Table productTable
    (
      ID INTEGER PRIMARY KEY,
      ORDERID INTEGER,
      CODE VARCHAR(50),
      CATEGORY VARCHAR(50)
    )

    Table warehouseTable
    (
      ID INTEGER PRIMARY KEY,
      NAME VARCHAR(100),
      SECTIONID INTEGER
    )

    Table sectionTable
    (
      ID INTEGER PRIMARY KEY,
      WAREHOUSEID INTEGER,
      ZONE VARCHAR(50)
    )

    Table shipmentTable
    (
      milestoning(
        business(BUS_FROM=FROM_Z, BUS_THRU=THRU_Z, INFINITY_DATE=%9999-12-31T00:00:00.0000)
      )
      ID INTEGER PRIMARY KEY,
      ORDERID INTEGER,
      CARRIER VARCHAR(100),
      TRACKINGID INTEGER,
      FROM_Z DATE,
      THRU_Z DATE
    )

    Table trackingTable
    (
      ID INTEGER PRIMARY KEY,
      SHIPMENTID INTEGER,
      PREFIX VARCHAR(50)
    )

    Table auditTable
    (
      milestoning(
        processing(PROCESSING_IN=IN_Z, PROCESSING_OUT=OUT_Z, INFINITY_DATE=%9999-12-31T00:00:00.0000)
      )
      ID INTEGER PRIMARY KEY,
      ENTITYREF VARCHAR(50),
      MESSAGE VARCHAR(200),
      IN_Z TIMESTAMP,
      OUT_Z TIMESTAMP
    )

    Table productMilTable
    (
      milestoning(
        business(BUS_FROM=FROM_Z, BUS_THRU=THRU_Z, INFINITY_DATE=%9999-12-31T00:00:00.0000)
      )
      ID INTEGER PRIMARY KEY,
      ORDERID INTEGER,
      CODE VARCHAR(50),
      CATEGORY VARCHAR(50),
      FROM_Z DATE,
      THRU_Z DATE
    )

    Table trackingMilTable
    (
      milestoning(
        business(BUS_FROM=FROM_Z, BUS_THRU=THRU_Z, INFINITY_DATE=%9999-12-31T00:00:00.0000)
      )
      ID INTEGER PRIMARY KEY,
      SHIPMENTID INTEGER,
      PREFIX VARCHAR(50),
      FROM_Z DATE,
      THRU_Z DATE
    )
  )
)

