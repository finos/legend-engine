    'Oliver,Firm B,Firm B\n' +
    'Peter,Firm X,A1\n'
  );
}

function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::arrayscalar::testSemiStructuredArrayFilterFirstWithEnumComparison(conn: Connection[1]):Boolean[1]
{
  arrayScalarExecute(
    $conn,
    |Person.all()->project([
      col(x | $x.firstName, 'First Name'),
      col(x | $x.firm.legalName, 'Firm Name'),
      col(x | $x->meta::relational::tests::mapping::relation::semistructured::arrayscalar::getPrimaryAddressName(), 'Primary Address Name')
    ]),
    'First Name,Firm Name,Primary Address Name\n' +
    'Anthony,Firm X,A4\n' +
    'David,Firm B,A7\n' +
    'Fabrice,Firm A,A5\n' +
    'John,Firm X,A2\n' +
    'John,Firm X,A3\n' +
    'Oliver,Firm B,A6\n' +
    'Peter,Firm X,A1\n'
  );
}

