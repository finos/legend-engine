// =============================================================================
// ModelJoin Lambdas with Variant Navigation — Test Functions
//
// 26 tests across 8 tiers. Every lambda navigates a SS-deserialised subtree
// inside the JOIN condition; all comparator sides are [1] or [0..1].
//
// Expected outputs are first-pass computations based on the test data in
// testVariantInModelJoinLambdaSetup.pure and may need adjustment after the first
// PCT run to match the engine's actual row-ordering and NULL-rendering conventions.
// =============================================================================

###Pure
import meta::pure::test::*;
import meta::core::runtime::*;
import meta::relational::metamodel::execute::tests::*;
import meta::relational::tests::mapping::relation::variant::modelJoin::*;

// =============================================================================
// Tier 0 — Class-navigation baseline (no variant collapse)
// =============================================================================

// T0.1 — scalar nav AND nested 2-hop nav
//   Alice (FirmX, A1) → F1 (FirmX, A1) ✓
//   Bob   (FirmA, A2) → no Firm with LEGALNAME=FirmA AND CODE=A2
//   Carol (FirmB, A3) → F2 (FirmB, A3) ✓
//   Dave  (FirmX, A4) → F3 (FirmX, A4) ✓
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testNavScalarAndNested(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T0_1_Mapping,
    |Person.all()->project(~[
      'Person': x|$x.firstName,
      'FirmId': x|$x.firm.id,
      'Firm':   x|$x.firm.legalName,
      'Code':   x|$x.firm.code
    ]),
    'Person,FirmId,Firm,Code\n' +
    'Alice,1,FirmX,A1\n' +
    'Bob,,,\n' +
    'Carol,2,FirmB,A3\n' +
    'Dave,3,FirmX,A4\n'
  );
}

// T0.2 — optional [0..1] navigation on both sides, OR-combined
//   Alice (Org, S1) → F8 via S1==S1 (street==altCode)
//   Bob   (NULL, NULL) → no
//   Carol (Co, S2)  → F8 via Co==Co (entityType==code)
//   Dave  (NULL, NULL) → no
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testNavOnOptionalProp(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T0_2_Mapping,
    |Person.all()->project(~[
      'Person': x|$x.firstName,
      'FirmId': x|$x.firm.id,
      'Firm':   x|$x.firm.legalName,
      'Code':   x|$x.firm.code
    ]),
    'Person,FirmId,Firm,Code\n' +
    'Alice,8,OptCo,Co\n' +
    'Bob,,,\n' +
    'Carol,8,OptCo,Co\n' +
    'Dave,,,\n'
  );
}

// =============================================================================
// Tier 1 — Variant collapse at the leaf (single-hop nav, OR-form for T1.1)
// =============================================================================

// T1.1 — indexed access OR-form: first || at(1) || last == code
//   Each clause matches independently → per-operator diagnostic value.
//   Alice {O1, O2, O3}: matches F12 (last=O3), F13 (at(1)=O2), F14/F18/F35 (first=O1)
//   Bob   {X1, X2, X2}: matches F4 (first=X1), F34 (at(1)/last=X2)
//   Carol {O5, O6, O6}: matches F5 (first=O5)
//   Dave  {NULL}:       no matches
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testIndexedAccess(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T1_1_Mapping,
    |Person.all()->project(~[
      'Person': x|$x.firstName,
      'FirmId': x|$x.firm.id,
      'Firm':   x|$x.firm.legalName,
      'Code':   x|$x.firm.code
    ]),
    'Person,FirmId,Firm,Code\n' +
    'Alice,12,Last_O3,O3\n' +
    'Alice,13,At1_O2,O2\n' +
    'Alice,14,First_O1,O1\n' +
    'Alice,18,Fil_O1O2,O1\n' +
    'Alice,35,Fan1,O1\n' +
    'Bob,4,FirmA,X1\n' +
    'Bob,34,IfBob,X2\n' +
    'Carol,5,FirmC,O5\n' +
    'Dave,,,\n'
  );
}

// T1.2 — size + distinct.size, ANDed against two Firm columns
//   Alice (size=3, distinct=3) → F1 (3, 3)
//   Bob   (size=2, distinct=1) → F3 (2, 1) AND F4 (2, 1) — fan-out
//   Carol (size=2, distinct=2) → F2 (2, 2)
//   Dave  (size=0, distinct=1) → no Firm with (0, 1)
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testCardinalityAndDistinct(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T1_2_Mapping,
    |Person.all()->project(~[
      'Person': x|$x.firstName,
      'FirmId': x|$x.firm.id,
      'Firm':   x|$x.firm.legalName,
      'Code':   x|$x.firm.code
    ]),
    'Person,FirmId,Firm,Code\n' +
    'Alice,1,FirmX,A1\n' +
    'Bob,3,FirmX,A4\n' +
    'Bob,4,FirmA,X1\n' +
    'Carol,2,FirmB,A3\n' +
    'Dave,,,\n'
  );
}

// T1.3 — indexOf
//   Alice/Carol (indexOf=1) → F6 (expectedCount=1), F10 (expectedCount=1)
//   Bob/Dave   (indexOf=-1) → F7 (expectedCount=-1)
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testMembership(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T1_3_Mapping,
    |Person.all()->project(~[
      'Person': x|$x.firstName,
      'FirmId': x|$x.firm.id,
      'Firm':   x|$x.firm.legalName,
      'Code':   x|$x.firm.code
    ]),
    'Person,FirmId,Firm,Code\n' +
    'Alice,6,UKMatch,UK\n' +
    'Alice,10,NullCode,\n' +
    'Bob,7,NoUKMatch,NoUK\n' +
    'Carol,6,UKMatch,UK\n' +
    'Carol,10,NullCode,\n' +
    'Dave,7,NoUKMatch,NoUK\n'
  );
}

// T1.4 — numeric aggregations (plus + max + min) — the §3 "repetitive" example
//   Alice (350, 200, 50)  → F1
//   Bob   (0, NULL, NULL) → no (NULL==NULL is false in SQL)
//   Carol (500, 500, 500) → F2
//   Dave  (30, 20, 10)    → F3
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testNumericAggregations(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T1_4_Mapping,
    |Person.all()->project(~[
      'Person': x|$x.firstName,
      'FirmId': x|$x.firm.id,
      'Firm':   x|$x.firm.legalName,
      'Code':   x|$x.firm.code
    ]),
    'Person,FirmId,Firm,Code\n' +
    'Alice,1,FirmX,A1\n' +
    'Bob,,,\n' +
    'Carol,2,FirmB,A3\n' +
    'Dave,3,FirmX,A4\n'
  );
}

// T1.5 — fold + take
//   Alice fold='O1O2O3', take(2).size=2 → F15
//   Bob   fold='X1X2',   take(2).size=2 → F16
//   Carol fold='O5O6',   take(2).size=2 → F17
//   Dave  fold='',       take(2).size=0 → no (no Firm with EXPECTED_COUNT=0)
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testFoldAndTake(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T1_5_Mapping,
    |Person.all()->project(~[
      'Person': x|$x.firstName,
      'FirmId': x|$x.firm.id,
      'Firm':   x|$x.firm.legalName,
      'Code':   x|$x.firm.code
    ]),
    'Person,FirmId,Firm,Code\n' +
    'Alice,15,FoldAlice,O1O2O3\n' +
    'Bob,16,FoldBob,X1X2\n' +
    'Carol,17,FoldCarol,O5O6\n' +
    'Dave,,,\n'
  );
}

// =============================================================================
