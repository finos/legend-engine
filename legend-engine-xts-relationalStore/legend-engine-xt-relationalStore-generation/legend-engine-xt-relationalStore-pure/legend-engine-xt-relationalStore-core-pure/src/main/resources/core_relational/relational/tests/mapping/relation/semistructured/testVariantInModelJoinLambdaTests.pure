    ]),
    'Person,FirmId,Firm,Code\n' +
    'Alice,1,FirmX,A1\n' +
    'Bob,,,\n' +
    'Carol,,,\n' +
    'Dave,,,\n'
  );
}

// T4.3 — filter+first.details == filter+first.name on both sides
//   Alice (D1) == F30.contacts.filter(lead).first.name (D1) → F30
//   Others: no contacts with matching lead names
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::variant::modelJoin::testCrossSideDeepFilter(conn: Connection[1]):Boolean[1]
{
