// =============================================================================
// Tier 4 — Cross-side variant (both LHS and RHS do variant work)
// =============================================================================

// T4.1 — legalName==region AND first==aliases.first
//   Alice (FirmX, O1) → F1 (region=FirmX, aliases.first=O1)
//   Bob   (FirmA, X1) → F4 (region=FirmA, aliases.first=X1)
//   Carol (FirmB, O5) → F2 (region=FirmB, aliases.first=O5)
//   Dave  (FirmX, NULL) → NULL second clause → no
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::variant::modelJoin::testCrossSideScalarAndFirst(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T4_1_Mapping,
    |Person.all()->project(~[
      'Person': x|$x.firstName,
      'FirmId': x|$x.firm.id,
      'Firm':   x|$x.firm.legalName,
      'Code':   x|$x.firm.code
    ]),
    'Person,FirmId,Firm,Code\n' +
    'Alice,1,FirmX,A1\n' +
    'Bob,4,FirmA,X1\n' +
    'Carol,2,FirmB,A3\n' +
    'Dave,,,\n'
  );
}

// T4.2 — countries.size==productLines.size AND customer.name==contacts.first.name
//   Alice (3, CustA) → F1 (productLines.size=3, contacts.first.name=CustA)
//   Carol (3, CustC) → no Firm with contacts.first.name=CustC AND productLines.size=3
//   Bob/Dave: NULL customer.name → no
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::variant::modelJoin::testCrossSideSizeAndPostCollapse(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T4_2_Mapping,
