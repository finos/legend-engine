    'Carol,,,\n' +
    'Dave,,,\n'
  );
}

// T2.2 — filter + size
//   All Persons have all-2-letter countries, so filter(length==2).size == countries.size.
//   Alice (size=3) → F1, F11, F32 (all have expectedCount=3)
//   Bob   (size=1) → F6 (expectedCount=1), F10 (expectedCount=1)
//   Carol (size=3) → F1, F11, F32
//   Dave  (size=1) → F6, F10
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testFilterThenCardinality(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T2_2_Mapping,
    |Person.all()->project(~[
      'Person': x|$x.firstName,
      'FirmId': x|$x.firm.id,
      'Firm':   x|$x.firm.legalName,
      'Code':   x|$x.firm.code
    ]),
    'Person,FirmId,Firm,Code\n' +
    'Alice,1,FirmX,A1\n' +
    'Alice,11,Lines,D1\n' +
    'Alice,32,Sum3_X1FR,X1-FR\n' +
    'Bob,6,UKMatch,UK\n' +
    'Bob,10,NullCode,\n' +
    'Carol,1,FirmX,A1\n' +
    'Carol,11,Lines,D1\n' +
    'Carol,32,Sum3_X1FR,X1-FR\n' +
    'Dave,6,UKMatch,UK\n' +
    'Dave,10,NullCode,\n'
  );
}

// T2.3 — filter+plus AND filter+max
//   Alice (200, 200) → F20 (200, 200)
//   Bob   (0, NULL)  → no
//   Carol (500, 500) → F2 (500, 500)
//   Dave  (0, 20)    → F21 (0, 20)
