// =============================================================================
// Tier 5 — Compound expressions inside one comparator side
// =============================================================================

// T5.1 — arithmetic AND concat (each combining two collapses)
//   Alice (6, 'O1-US') → F31
//   Bob   (3, 'X1-FR') → F32
//   Carol (5, 'O5-US') → F33
//   Dave  (1, NULL)    → no (NULL+'-'+'JP' = NULL in SQL)
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testArithmeticAndConcatOfCollapses(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T5_1_Mapping,
    |Person.all()->project(~[
      'Person': x|$x.firstName,
      'FirmId': x|$x.firm.id,
      'Firm':   x|$x.firm.legalName,
      'Code':   x|$x.firm.code
    ]),
    'Person,FirmId,Firm,Code\n' +
    'Alice,31,Sum6_O1US,O1-US\n' +
    'Bob,32,Sum3_X1FR,X1-FR\n' +
    'Carol,33,Sum5_O5US,O5-US\n' +
    'Dave,,,\n'
  );
}

// T5.2 — if/then/else whose branches collapse the same variant array differently
//   Alice contains(UK)=true → first=O1 → matches F14, F18, F35 (all CODE=O1)
//   Bob   contains(UK)=false → last=X2 → F34 (CODE=X2)
//   Carol contains(UK)=true → first=O5 → F5 (CODE=O5)
//   Dave  contains(UK)=false → last=NULL → no
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testIfThenElseOverCollapse(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T5_2_Mapping,
    |Person.all()->project(~[
      'Person': x|$x.firstName,
      'FirmId': x|$x.firm.id,
      'Firm':   x|$x.firm.legalName,
      'Code':   x|$x.firm.code
    ]),
    'Person,FirmId,Firm,Code\n' +
    'Alice,14,First_O1,O1\n' +
    'Alice,18,Fil_O1O2,O1\n' +
    'Alice,35,Fan1,O1\n' +
    'Bob,34,IfBob,X2\n' +
    'Carol,5,FirmC,O5\n' +
    'Dave,,,\n'
  );
}

// =============================================================================
// Tier 6 — Non-equality comparators
// =============================================================================

// T6.1 — lines.size > expectedCount AND revenue.plus >= expectedRevenue
//   Multiple matches possible (fan-out). Computed below:
//   Alice (3, 350) matches F3 (2, 30), F4 (2, 0), F10 (1, 0)
//   Bob   (2, 0)   matches F10 (1, 0)
//   Carol (2, 500) matches F10 (1, 0)
//   Dave  (0, 30)  matches nothing (size=0 can't be > any expectedCount in scope)
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testInequalityGtAndGe(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T6_1_Mapping,
    |Person.all()->project(~[
      'Person': x|$x.firstName,
      'FirmId': x|$x.firm.id,
      'Firm':   x|$x.firm.legalName,
      'Code':   x|$x.firm.code
    ]),
    'Person,FirmId,Firm,Code\n' +
    'Alice,3,FirmX,A4\n' +
    'Alice,4,FirmA,X1\n' +
    'Alice,10,NullCode,\n' +
    'Bob,10,NullCode,\n' +
    'Carol,10,NullCode,\n' +
    'Dave,,,\n'
  );
}

// T6.2 — !=  over [1] AND [0..1], anchored on legalName to limit fan-out.
//   The Legend router emits IS DISTINCT FROM semantics for `!=` (see
//   processNotEqual in sqlQueryToString/dbExtension.pure), matching Pure's
//   classical 2VL `equal` semantics where `[] == 'x'` = FALSE, hence
//   `[] != 'x'` = TRUE. This is verified by the invariant test
//   testConsistencyWithNullsInColumnToColumnComparison in testFilters.pure
//   (size(==) + size(!=) == size(all) requires `!=` to cover the null cases).
//   Alice (FirmX) → F1, F3: O1 != CODE → true for both  → match
//   Bob   (FirmA) → F4: X1 != X1 → false; entityType [] != X2 → TRUE (Pure) → match
//   Carol (FirmB) → F2: O5 != A3 → true → match
//   Dave  (FirmX) → F1, F3: otherNames->first() [] != CODE → TRUE (Pure) → match both
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testInequalityNe(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T6_2_Mapping,
    |Person.all()->project(~[
      'Person': x|$x.firstName,
      'FirmId': x|$x.firm.id,
      'Firm':   x|$x.firm.legalName,
      'Code':   x|$x.firm.code
    ]),
    'Person,FirmId,Firm,Code\n' +
    'Alice,1,FirmX,A1\n' +
    'Alice,3,FirmX,A4\n' +
    'Bob,4,FirmA,X1\n' +
    'Carol,2,FirmB,A3\n' +
    'Dave,1,FirmX,A1\n' +
    'Dave,3,FirmX,A4\n'
  );
}

// =============================================================================
// Tier 7 — Failure modes
// =============================================================================

// T7.1 — empty array on LHS (focused on Dave via filter)
//   Dave.otherNames=[] → ->first() returns [] → comparison fails → no match → NULL row
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testEmptyArrayLhs(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T7_1_Mapping,
    |Person.all()->filter(p | $p.firstName == 'Dave')->project(~[
      'Person': x|$x.firstName,
      'FirmId': x|$x.firm.id,
      'Firm':   x|$x.firm.legalName,
      'Code':   x|$x.firm.code
    ]),
    'Person,FirmId,Firm,Code\n' +
    'Dave,,,\n'
  );
}

// T7.2 — missing JSON key (entityType absent for Bob and Dave)
//   Alice (Org)  → no Firm with CODE='Org'  → empty
//   Bob   (NULL) → NULL==anything is NULL  → empty
//   Carol (Co)   → F8 (CODE=Co) ✓
//   Dave  (NULL) → empty
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testMissingJsonKey(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T7_2_Mapping,
    |Person.all()->project(~[
      'Person': x|$x.firstName,
      'FirmId': x|$x.firm.id,
      'Firm':   x|$x.firm.legalName,
      'Code':   x|$x.firm.code
    ]),
    'Person,FirmId,Firm,Code\n' +
    'Alice,,,\n' +
    'Bob,,,\n' +
    'Carol,8,OptCo,Co\n' +
    'Dave,,,\n'
  );
}

// T7.3 — NULL on Firm side (F10 has CODE=NULL).
//   Lambda compares firmInfo.legalName == code->toOne(). No Firm has CODE matching
//   FirmX / FirmA / FirmB, so all rows are NULL. The test asserts the query
//   completes without raising on F10's NULL code (the engine should treat
//   NULL == 'FirmX' as NULL/false in SQL, not throw a PureException).
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testNullOnFirmSide(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T7_3_Mapping,
    |Person.all()->project(~[
      'Person': x|$x.firstName,
      'FirmId': x|$x.firm.id,
      'Firm':   x|$x.firm.legalName,
      'Code':   x|$x.firm.code
    ]),
    'Person,FirmId,Firm,Code\n' +
    'Alice,,,\n' +
    'Bob,,,\n' +
    'Carol,,,\n' +
    'Dave,,,\n'
  );
}

// T7.4 — fan-out: Alice's first()=O1 matches F14, F18, F35 (all CODE=O1)
//   Asserts the full output to verify cardinality fan-out is preserved.
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testFanOutOneToMany(conn: Connection[1]):Boolean[1]
{
  variantInMJExecute($conn, T7_4_Mapping,
    |Person.all()->project(~[
      'Person': x|$x.firstName,
      'FirmId': x|$x.firm.id,
      'Firm':   x|$x.firm.legalName,
      'Code':   x|$x.firm.code
    ]),
    'Person,FirmId,Firm,Code\n' +
    'Alice,14,First_O1,O1\n' +
    'Alice,18,Fil_O1O2,O1\n' +
    'Alice,35,Fan1,O1\n' +
    'Bob,4,FirmA,X1\n' +
    'Carol,5,FirmC,O5\n' +
    'Dave,,,\n'
  );
}

// =============================================================================
// QUERY-FEATURE TESTS (Q1–Q10) — complex query combinators applied to the
// variant-mapping infrastructure. All use VariantInMJ_BaseMappingWithDept via
// the variantInMJExecuteWithDept helper, which also loads departmentCsv().
//
// These tests exercise the INTERACTION between query-level features
// (filter, exists, sortBy, groupBy, complex projections, nav through ModelJoin)
// and the variant-deserialised subtree exposed in the class mappings.
// =============================================================================

// Q1 — model-level ->filter() using a variant collapse operator
//   Filter: $p.firmInfo.address.lines->size() > 2
//   Alice (3 lines) ✓; Bob (2), Carol (2), Dave (0) all fail
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testFilterByVariantSize(conn: Connection[1]):Boolean[1]
{
  variantInMJExecuteWithDept($conn,
    |Person.all()
      ->filter(p | $p.firmInfo.address.lines->size() > 2)
      ->project(~[
        'Person':   x|$x.firstName,
        'AddrName': x|$x.firmInfo.address.name
      ]),
    'Person,AddrName\n' +
    'Alice,A1\n'
  );
}

// Q2 — ->filter(p | $p.X->exists(...)) over a variant class array
//   Filter: orders->exists(o | $o.side == 'BUY')
//   Alice (BUY ORD-A) ✓; Bob (empty); Carol (BUY ORD-C) ✓; Dave (empty)
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::variant::modelJoin::testFilterWithExistsOnVariantArray(conn: Connection[1]):Boolean[1]
{
  variantInMJExecuteWithDept($conn,
    |Person.all()
      ->filter(p | $p.firmInfo.orders->exists(o | $o.side == 'BUY'))
      ->project(~[
        'Person':    x|$x.firstName,
        'NumOrders': x|$x.firmInfo.orders->size()
      ]),
    'Person,NumOrders\n' +
    'Alice,2\n' +
    'Carol,1\n'
  );
}

// Q3 — model-level filter using property reached THROUGH the variant ModelJoin
//   Filter: $p.firm.legalName == 'FirmX' (where firm is reached via T0.1's
//   Person_Firm join: legalName + address.name match)
//   T0.1 matches: Alice→F1 (FirmX), Carol→F2 (FirmB), Dave→F3 (FirmX), Bob→none
//   After filter ==FirmX: Alice, Dave
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testFilterByCrossMappedFirm(conn: Connection[1]):Boolean[1]
{
  variantInMJExecuteWithDept($conn,
    |Person.all()
      ->filter(p | $p.firm.legalName == 'FirmX')
      ->project(~[
        'Person': x|$x.firstName,
        'FirmId': x|$x.firm.id,
        'Firm':   x|$x.firm.legalName
      ]),
    'Person,FirmId,Firm\n' +
    'Alice,1,FirmX\n' +
    'Dave,3,FirmX\n'
  );
}

// Q4 — TDS ->sort() over a column populated by a variant aggregation
//   Project total revenue (sum of revenueHistory), then sort TDS ascending.
//   Bob (empty → 0), Dave (30), Alice (350), Carol (500)
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testSortByVariantAggregation(conn: Connection[1]):Boolean[1]
{
  variantInMJExecuteWithDept($conn,
    |Person.all()
      ->project(~[
        'Person':   x|$x.firstName,
        'TotalRev': x|$x.firmInfo.revenueHistory->plus()
      ])
      ->sort([~'TotalRev'->ascending()]),
    'Person,TotalRev\n' +
    'Bob,0.0\n' +
    'Dave,30.0\n' +
    'Alice,350.0\n' +
    'Carol,500.0\n'
  );
}

// Q5 — model-level ->groupBy() grouping AND aggregating on variant-derived
//   properties.
//   Group by firmInfo.legalName; sum(firmInfo.employeeCount).
//   FirmA: Bob=1            → 1
//   FirmB: Carol=2          → 2
//   FirmX: Alice=4 + Dave=4 → 8
// function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testGroupByVariantProperty(conn: Connection[1]):Boolean[1]
// {
//   variantInMJExecuteWithDept($conn,
//     |Person.all()
//       ->groupBy(
//           [x|$x.firmInfo.legalName],
//           [agg(x|$x.firmInfo.employeeCount, y|$y->sum())],
//           ['LegalName', 'TotalEmp']
//         )
//       ->sort([~'LegalName'->ascending()]),
//     'LegalName,TotalEmp\n' +
//     'FirmA,1\n' +
//     'FirmB,2\n' +
//     'FirmX,8\n'
//   );
// }

// Q6 — complex projection with multiple function calls on variant outputs
//   Per Person: firstName, FirstCtry (countries.first().toUpper),
//               CtrySize (countries.size), RevOrZero (if-isEmpty guard)
//   Alice ('US', 3, 350.0); Bob ('FR', 1, 0.0); Carol ('US', 3, 500.0); Dave ('JP', 1, 30.0)
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testComplexProjectionWithFnCalls(conn: Connection[1]):Boolean[1]
{
  variantInMJExecuteWithDept($conn,
    |Person.all()
      ->project(~[
        'Person':    x|$x.firstName,
        'FirstCtry': x|$x.firmInfo.countries->first()->toOne()->toUpper(),
        'CtrySize':  x|$x.firmInfo.countries->size(),
        'RevOrZero': x|if($x.firmInfo.revenueHistory->isEmpty(),
                          |0.0,
                          |$x.firmInfo.revenueHistory->plus())
      ]),
    'Person,FirstCtry,CtrySize,RevOrZero\n' +
    'Alice,US,3,350.0\n' +
    'Bob,FR,1,0.0\n' +
    'Carol,US,3,500.0\n' +
    'Dave,JP,1,30.0\n'
  );
}

// Q7 — navigation through TWO ModelJoins of different kinds:
//   Person -(variant Person_Firm)→ Firm -(plain Firm_Department)→ Department[*]
//   Project firmDept.size() — exercises plain FK ModelJoin off a Firm that was
//   itself reached via a variant-in-lambda ModelJoin.
//   T0.1 matches → F1 (3 depts), F2 (2), F3 (1). Bob no match → 0 depts.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::variant::modelJoin::testDepartmentNavThroughFirm(conn: Connection[1]):Boolean[1]
{
  variantInMJExecuteWithDept($conn,
    |Person.all()
      ->project(~[
        'Person':    x|$x.firstName,
        'FirmId':    x|$x.firm.id,
        'Firm':      x|$x.firm.legalName,
        'DeptCount': x|$x.firm.firmDept->size()
      ]),
    'Person,FirmId,Firm,DeptCount\n' +
    'Alice,1,FirmX,3\n' +
    'Bob,,,0\n' +
    'Carol,2,FirmB,2\n' +
    'Dave,3,FirmX,1\n'
  );
}

// Q8 — filter on Firm with exists over departments (no Person involvement)
//   Filter: firmDept->exists(d | $d.budget > 500000.0)
//   F1 (Eng 1M ✓), F2 (Research 800k ✓), F4 (Trading 2M ✓).
//   F3 has only IT 100k (no); F5-F35 have no depts (no).
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testFilterOnFirmWithDeptExists(conn: Connection[1]):Boolean[1]
{
  variantInMJExecuteWithDept($conn,
    |Firm.all()
      ->filter(f | $f.firmDept->exists(d | $d.budget > 500000.0))
      ->project(~[
        'FirmId': x|$x.id,
        'Firm':   x|$x.legalName
      ])
      ->sort([~'FirmId'->ascending()]),
    'FirmId,Firm\n' +
    '1,FirmX\n' +
    '2,FirmB\n' +
    '4,FirmA\n'
  );
}

// Q9 — groupBy on a property reached through the variant ModelJoin, aggregating
//   on a variant-derived value.
//   Group by $p.firm.legalName (Person→Firm via T0.1), sum($p.firmInfo.revenueHistory->plus())
//   Pre-filter to exclude Bob (no firm) so the output is fully deterministic
//   (no NULL group with engine-dependent sort placement).
//   FirmX: Alice(350) + Dave(30) → 380.0
//   FirmB: Carol(500)            → 500.0
// function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::modelJoin::testGroupByCrossMappedAggregatingVariant(conn: Connection[1]):Boolean[1]
// {
//   variantInMJExecuteWithDept($conn,
//     |Person.all()
//       ->filter(p | $p.firm.legalName->isNotEmpty())
//       ->groupBy(
//           [x|$x.firm.legalName],
//           [agg(x|$x.firmInfo.revenueHistory->plus(), y|$y->sum())],
//           ['Firm', 'TotalRev']
//         )
//       ->sort([~'Firm'->ascending()]),
//     'Firm,TotalRev\n' +
//     'FirmB,500.0\n' +
//     'FirmX,380.0\n'
//   );
// }

// Q10 — compound filter (OR of two variant ops) + nested filter+collapse in projection
//   Filter: $p.firmInfo.countries->contains('UK') || $p.firmInfo.revenueHistory->plus() > 100.0
//     Alice (contains UK true)  ✓
//     Bob   (no UK, plus 0)     ✗
//     Carol (contains UK true)  ✓
//     Dave  (no UK, plus 30)    ✗
//   Project: $p.firstName, $p.firmInfo.otherNames->filter(starts with 'O')->first()
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::variant::modelJoin::testCompoundFilterAndNestedProject(conn: Connection[1]):Boolean[1]
{
  variantInMJExecuteWithDept($conn,
    |Person.all()
      ->filter(p | $p.firmInfo.countries->contains('UK') ||
                   ($p.firmInfo.revenueHistory->plus() > 100.0))
      ->project(~[
        'Person':       x|$x.firstName,
        'FilteredName': x|$x.firmInfo.otherNames->filter(n | $n->startsWith('O'))->first()
      ]),
    'Person,FilteredName\n' +
    'Alice,"O1"\n' +
    'Carol,"O5"\n'
  );
}
