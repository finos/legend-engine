function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testGroupByMappingProjectWithJoinAndTableFilter():Boolean[1]
{
   let result = execute(
      |Position.all()->project(~[gsn:p|$p.gsn, description:p|$p.product.description]),
