function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testGroupByMappingProjectWithGroupByInJoin():Boolean[1]
{
   let result = execute(
      |Product.all()->project(~[gsn:pr|$pr.positions.gsn, description:pr|$pr.description]),
      groupByRelationMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions());
   assertEquals(
     #TDS
        gsn, description
        EA4GNY, Gold
        YU2EF5, Firm D
     #->toString(),
     $result.values->at(0)->sort([~gsn->ascending()])->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testGroupByMappingProjectAggregateWithGroupByInJoin():Boolean[1]
{
   let result = execute(
      |Product.all()->project(~[quantity:pr|$pr.positions.quantity, description:pr|$pr.description]),
      groupByRelationMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions());
   assertEquals(
     #TDS
        quantity, description
        8, Firm D
        300, Gold
     #->toString(),
     $result.values->at(0)->sort([~description->ascending()])->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testGroupByMappingProjectWithMultipleGroupBys():Boolean[1]
{
   let result = execute(
      |Position.all()->project(~[gsn:p|$p.gsn, description:p|$p.product.description]),
      groupByRelationMappingWithTwoGroupBys,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions());
   assertEquals(
     #TDS
        gsn, description
        YU2EF5, Firm D
     #->toString(),
     $result.values->at(0)->toString());
}

