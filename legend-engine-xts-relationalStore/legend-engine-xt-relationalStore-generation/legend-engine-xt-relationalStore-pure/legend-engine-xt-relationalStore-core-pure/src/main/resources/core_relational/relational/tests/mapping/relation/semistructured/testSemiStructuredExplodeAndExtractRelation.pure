    'p2,2\n' +
    'p3,3\n' +
    'p1,4\n' +
    'p1,5\n' +
    'p1,5\n' +
    ',6\n'
  );
}

// Ignored because explode-driven joins from BLOCKDATA.relatedEntities to physical Trades/Orders have no RFPM-lift analogue.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::testJoinChainMultipleJoinsMultipleExplode(conn: Connection[1]):Boolean[1]
{
