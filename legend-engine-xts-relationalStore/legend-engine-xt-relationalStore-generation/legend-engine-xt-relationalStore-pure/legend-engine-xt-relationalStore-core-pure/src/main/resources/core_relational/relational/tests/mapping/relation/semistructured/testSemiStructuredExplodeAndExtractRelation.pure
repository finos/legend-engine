// =============================================================================
// Translation of tests/semistructured/testExplodeSemiStructuredMapping.pure
// and tests/semistructured/testExtractFromSemiStructuredMappingSimple.pure
// into the RFPM variant-lift form.
//
// Two distinct source models — separated by sub-package:
//
// EXPLODE sub-package
//   …::explodeextract::explode::*
//   Sources: testExplodeSemiStructuredMapping (15 tests, 3 source mappings —
//            simple, view, extractAndExplode).
//   Status:  All 15 tests marked <<paramTest.Ignore>>. Source mapping uses
//            `Join Block_Order(extractFromSemiStructured(explodeSemiStructured(
//            BLOCKDATA, 'relatedEntities', 'SEMISTRUCTURED'), 'tagId', 'VARCHAR')
//            = Orders.ID)` — i.e. array-explode-driven cross-table joins. RFPM
//            lift handles composition embedding (Block.orders as array of
//            embedded JSON), NOT array-explode joins back to separate physical
//            tables. No clean lift analogue; would need lift-router extension.
//
// EXTRACTSIMPLE sub-package
//   …::explodeextract::extractsimple::*
//   Sources: testExtractFromSemiStructuredMappingSimple (4 tests, 1 mapping,
//            includes enum EntityType).
//   Status:  3 tests <<paramTest.Test>>, 1 test <<paramTest.Ignore>>
//            (testExtractEnumProperty — lift-router rejects enum-typed
//            top-level RFPMs per R-2).
// =============================================================================


###Relational
Database meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::H2DB
(
  Schema Semistructured
  (
    Table Blocks
    (
      ID VARCHAR(100) PRIMARY KEY,
      ACCOUNT VARCHAR(100) NOT NULL,
      BLOCKDATA SEMISTRUCTURED
    )
    Table Trades
    (
      ID VARCHAR(100) PRIMARY KEY,
      STATUS VARCHAR(100) NOT NULL,
      TRADESUMMARY SEMISTRUCTURED
    )
    Table Orders
    (
      ID VARCHAR(100) PRIMARY KEY,
      IDENTIFIER VARCHAR(100) NOT NULL,
      QUANTITY INTEGER NOT NULL,
      SIDE VARCHAR(100) NOT NULL,
      PRICE DOUBLE NOT NULL
    )
    Table Product
    (
      IDENTIFIER VARCHAR(100) PRIMARY KEY,
      VERSION VARCHAR(100) PRIMARY KEY,
      PRODUCT VARCHAR(100) NOT NULL
    )
  )
)


###Relational
Database meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::H2DB
(
  Schema FIRM_SCHEMA
  (
    Table FIRM_TABLE
    (
      ID INTEGER PRIMARY KEY,
      FIRM_DETAILS SEMISTRUCTURED
    )
  )
)


###Pure
import meta::pure::functions::variant::convert::*;
import meta::pure::functions::variant::navigation::*;
import meta::pure::metamodel::variant::*;

// =============================================================================
// EXPLODE domain — Block / Trade / Order / Product / BlockData / RelatedEntity
// =============================================================================
Class meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::RelatedEntity
{
  tag  : String[1];
  tagId: String[1];
}

Class meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::BlockData
{
  status         : String[1];
  relatedEntities: meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::RelatedEntity[1..*];
}

Class meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::TradeSummary
{
  identifier  : String[1];
  execQuantity: Integer[1];
  price       : String[1];
  side        : String[1];
  orderId     : String[1];
}

Class meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Product
{
  product   : String[1];
  identifier: String[1];
  version   : String[1];
}

Class meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Block
{
  id       : String[1];
  account  : String[1];
  blockData: meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::BlockData[1];
  trades   : meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Trade[*];
  orders   : meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Order[*];
  products : String[*];
}

Class meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Order
{
  id        : String[1];
  identifier: String[1];
  quantity  : Integer[1];
  side      : String[1];
  price     : Float[1];
  account   : String[1];
  tradeId   : String[1];
  product   : meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Product[1];
  block     : meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Block[1];
}

Class meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Trade
{
  id          : String[1];
  status      : String[1];
  tradeSummary: meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::TradeSummary[1];
  block       : meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Block[1];
}

// =============================================================================
// EXTRACTSIMPLE domain — Firm / EntityType
// =============================================================================
Enum meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::EntityType
{
  Organization,
  Company
}

Class meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::Firm
{
  ID                 : Integer[1];
  legalName          : String[1];
  employeeCount      : Integer[1];
  revenue            : Float[1];
  mnc                : Boolean[1];
  estDate            : StrictDate[1];
  lastUpdate         : DateTime[1];
  entityType         : meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::EntityType[1];
  secondLineOfAddress: String[0..1];
}

// =============================================================================
// Relation functions
// =============================================================================
function meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::blockFunction(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::H2DB.Semistructured.Blocks}#
    ->select(~[ID, ACCOUNT, BLOCKDATA])
}

function meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::tradeFunction(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::H2DB.Semistructured.Trades}#
    ->select(~[ID, STATUS, TRADESUMMARY])
}

function meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::orderFunction(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::H2DB.Semistructured.Orders}#
    ->select(~[ID, IDENTIFIER, QUANTITY, SIDE, PRICE])
}

function meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::productFunction(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::H2DB.Semistructured.Product}#
    ->select(~[IDENTIFIER, VERSION, PRODUCT])
}

function meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::firmFunction(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::H2DB.FIRM_SCHEMA.FIRM_TABLE}#
    ->select(~[ID, FIRM_DETAILS])
}


###Mapping
import meta::pure::functions::variant::convert::*;
import meta::pure::functions::variant::navigation::*;

// =============================================================================
// EXPLODE lift mapping — best-effort. Composition (blockData / trades / orders)
// is expressed as embedded JSON; the original source's explode-driven joins to
// physical Orders/Trades/Product tables are NOT preserved because the lift
// router has no analogue. All 15 explode tests marked <<paramTest.Ignore>>.
// =============================================================================
Mapping meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::ExplodeSemiStructuredMapping
(
  *meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Block[block]: Relation
  {
    ~func meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::blockFunction():Relation<Any>[1]
    id       : ID,
    account  : ACCOUNT,
    blockData: $src.BLOCKDATA->to(@meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::BlockData)->toOne()
  }

  *meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Trade[trade]: Relation
  {
    ~func meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::tradeFunction():Relation<Any>[1]
    id          : ID,
    status      : STATUS,
    tradeSummary: $src.TRADESUMMARY->to(@meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::TradeSummary)->toOne()
  }

  *meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Order[order]: Relation
  {
    ~func meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::orderFunction():Relation<Any>[1]
    id        : ID,
    identifier: IDENTIFIER,
    quantity  : QUANTITY,
    side      : SIDE,
    price     : PRICE
  }

  *meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Product[product]: Relation
  {
    ~func meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::productFunction():Relation<Any>[1]
    identifier: IDENTIFIER,
    version   : VERSION,
    product   : PRODUCT
  }
)

// =============================================================================
// EXTRACTSIMPLE lift mapping — direct translation of binding-based H2Mapping.
// Firm fields extracted from FIRM_DETAILS JSON via variant navigation.
// =============================================================================
Mapping meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::ExtractSimpleSemiStructuredMapping
(
  *meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::Firm[firm]: Relation
  {
    ~func meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::firmFunction():Relation<Any>[1]
    ID                 : ID,
    legalName          : $src.FIRM_DETAILS->get('legalName')->to(@String)->toOne(),
    employeeCount      : $src.FIRM_DETAILS->get('employeeCount')->to(@Integer)->toOne(),
    revenue            : $src.FIRM_DETAILS->get('revenue')->to(@Float)->toOne(),
    mnc                : $src.FIRM_DETAILS->get('mnc')->to(@Boolean)->toOne(),
    estDate            : $src.FIRM_DETAILS->get('dates')->get('estDate')->to(@StrictDate)->toOne(),
    lastUpdate         : $src.FIRM_DETAILS->get('dates')->get('last Update')->to(@DateTime)->toOne(),
    // entityType         : EnumerationMapping meta_relational_tests_mapping_relation_semistructured_explodeextract_extractsimple_EntityType: $src.FIRM_DETAILS->get('entity')->get('entityType')->to(@String)->toOne(),
    secondLineOfAddress: $src.FIRM_DETAILS->get('address')->get('lines')->get(1)->get('details')->to(@String)
  }

  meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::EntityType: EnumerationMapping
  {
    Organization: ['O'],
    Company     : ['C']
  }
)


