    'o3,t4\n' +
    'o4,t5\n' +
    'o4,t6\n' +
    'o5,t7\n' +
    'o6,t7\n'
  );
}


// =============================================================================
// ====== EXTRACTSIMPLE — CSV + execute helper ======
// =============================================================================
function <<access.private>> meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::firmCsv(): String[1]
{
  'FIRM_SCHEMA\n' +
  'FIRM_TABLE\n' +
  'ID,FIRM_DETAILS\n' +
  '1,"{""legalName"": ""Firm X"", ""employeeCount"": 4, ""revenue"": 5.0, ""mnc"": true, ""dates"": {""estDate"": ""2010-03-04"", ""last Update"": ""2022-01-16T01:00:00""}, ""entity"": {""entityType"":""O""}, ""otherNames"": [""O1"", ""O2""], ""address"": {""name"": ""A1"", ""street"": ""S1"", ""lines"": [{""details"": ""D1""}, {""details"": ""D2""}, {""details"": ""D3""}]}}"\n' +
  '2,"{""legalName"": ""Firm A"", ""employeeCount"": 1, ""revenue"": 2000.5, ""mnc"": false, ""dates"": {""estDate"": ""2012-11-13"", ""last Update"": ""2022-02-14T03:00:00""}, ""entity"": {""entityType"":""O""}, ""otherNames"": [""O3"", ""O4""], ""address"": {""name"": ""A2"", ""lines"": [{""details"": ""D4""}, {""details"": ""D5""}]}}"\n' +
  '3,"{""legalName"": ""Firm B"", ""employeeCount"": 2, ""revenue"": 0.1, ""mnc"": true, ""dates"": {""estDate"": ""2017-7-7"", ""last Update"": ""2022-9-01T06:00:00""}, ""entity"": {""entityType"":""C""}, ""otherNames"": [""O5"", ""O6""], ""address"": {""name"": ""A3"", ""lines"": [{""details"": ""D5""},{""details"": ""D6""}]}}"\n'
}

function <<access.private>> meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::extractSimpleExecute(conn: Connection[1], func: FunctionDefinition<Any>[1], expected: String[1]):Boolean[1]
{
  executeLegendFunction(
    $func,
    meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::ExtractSimpleSemiStructuredMapping,
    meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::H2DB,
    $conn,
    [firmCsv()],
    $expected,
    false
  );
}

// =============================================================================
// ====== EXTRACTSIMPLE — tests ======
// =============================================================================

function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::testDotAndBracketNotationAccess(conn: Connection[1]):Boolean[1]
{
  extractSimpleExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::Firm.all()
      ->project(~[
        'Id'           : x | $x.ID,
        'Dot Only'     : x | $x.estDate,
        'Bracket Only' : x | $x.lastUpdate,
        'Dot & Bracket': x | $x.secondLineOfAddress
      ]),
    'Id,Dot Only,Bracket Only,Dot & Bracket\n' +
    '1,2010-03-04,2022-01-16 01:00:00.0,D2\n' +
    '2,2012-11-13,2022-02-14 03:00:00.0,D5\n' +
    '3,2017-07-07,2022-09-01 06:00:00.0,D6\n'
  );
}

function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::testArrayElementNoFlattenAccess(conn: Connection[1]):Boolean[1]
{
  extractSimpleExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::Firm.all()
      ->project(~[
        'Id'                    : x | $x.ID,
        'Second Line of Address': x | $x.secondLineOfAddress
      ]),
    'Id,Second Line of Address\n' +
    '1,D2\n' +
    '2,D5\n' +
    '3,D6\n'
  );
}

function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::testAllDataTypesAccess(conn: Connection[1]):Boolean[1]
{
  extractSimpleExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::Firm.all()
      ->project(~[
        'Id'            : x | $x.ID,
        'Legal Name'    : x | $x.legalName,
        'Est Date'      : x | $x.estDate,
        'Mnc'           : x | $x.mnc,
        'Employee Count': x | $x.employeeCount,
        'Revenue'       : x | $x.revenue,
        'Last Update'   : x | $x.lastUpdate
      ]),
    'Id,Legal Name,Est Date,Mnc,Employee Count,Revenue,Last Update\n' +
    '1,Firm X,2010-03-04,true,4,5.0,2022-01-16 01:00:00.0\n' +
    '2,Firm A,2012-11-13,false,1,2000.5,2022-02-14 03:00:00.0\n' +
    '3,Firm B,2017-07-07,true,2,0.1,2022-09-01 06:00:00.0\n'
  );
}

// Ignored because lift router rejects enum-typed top-level RFPMs (per R-2 in playbook).
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::testExtractEnumProperty(conn: Connection[1]):Boolean[1]
{
  extractSimpleExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::explodeextract::extractsimple::Firm.all()
      ->project(~[
        'Id'         : x | $x.ID,
        'Entity Type': x | $x.entityType
      ]),
    'Id,Entity Type\n' +
    '1,O\n' +
    '2,O\n' +
    '3,C\n'
  );
}
