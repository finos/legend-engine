// =============================================================================
// ====== EXPLODE — CSV + execute helper ======
// =============================================================================
function <<access.private>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::blockCsv(): String[1]
{
  'Semistructured\n' +
  'Blocks\n' +
  'id,account,blockData\n' +
  '1,a1,"{""status"": ""fulfilled"", ""relatedEntities"": [{""tag"": ""trade"", ""tagId"": ""t1""}, {""tag"": ""order"", ""tagId"": ""o1""}]}"\n' +
  '2,a1,"{""status"": ""cancelled"", ""relatedEntities"": [{""tag"": ""trade"", ""tagId"": ""t2""}, {""tag"": ""order"", ""tagId"": ""o2""}, {""tag"": ""order"", ""tagId"": ""o1""}]}"\n' +
  '3,a2,"{""status"": ""fulfilled"", ""relatedEntities"": [{""tag"": ""trade"", ""tagId"": ""t3""}, {""tag"": ""trade"", ""tagId"": ""t4""}, {""tag"": ""order"", ""tagId"": ""o3""}]}"\n' +
  '4,a2,"{""status"": ""accepted"", ""relatedEntities"": [{""tag"": ""trade"", ""tagId"": ""t5""}, {""tag"": ""trade"", ""tagId"": ""t6""}, {""tag"": ""order"", ""tagId"": ""o4""}]}"\n' +
  '5,a1,"{""status"": ""fulfilled"", ""relatedEntities"": [{""tag"": ""trade"", ""tagId"": ""t7""}, {""tag"": ""order"", ""tagId"": ""o5""}, {""tag"": ""order"", ""tagId"": ""o6""}]}"\n' +
  '6,a3,"{""status"": ""rejected"", ""relatedEntities"": []}"\n'
}

function <<access.private>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::tradeCsv(): String[1]
{
  'Semistructured\n' +
  'Trades\n' +
  'id,status,tradeSummary\n' +
  't1,accepted,"{""identifier"": ""i1"", ""execQuantity"": 100, ""execPrice"": 100, ""side"": ""SELL""}"\n' +
  't2,rejected,"{""identifier"": ""i2"", ""execQuantity"": 100, ""execPrice"": 10, ""side"": ""BUY""}"\n' +
  't3,accepted,"{""identifier"": ""i3"", ""execQuantity"": 100, ""execPrice"": 100, ""side"": ""BUY""}"\n' +
  't4,accepted,"{""identifier"": ""i3"", ""execQuantity"": 100, ""execPrice"": 105, ""side"": ""BUY""}"\n' +
  't5,accepted,"{""identifier"": ""i1"", ""execQuantity"": 70, ""execPrice"": 100, ""side"": ""SELL""}"\n' +
  't6,rejected,"{""identifier"": ""i1"", ""execQuantity"": 80, ""execPrice"": 90, ""side"": ""SELL""}"\n' +
  't7,accepted,"{""identifier"": ""i4"", ""execQuantity"": 60, ""execPrice"": 50, ""side"": ""SELL""}"\n' +
  't8,invalid,"{""identifier"": ""i4"", ""execQuantity"": 60, ""execPrice"": 50, ""side"": ""SELL""}"\n'
}

function <<access.private>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::orderCsv(): String[1]
{
  'Semistructured\n' +
  'Orders\n' +
  'id,identifier,quantity,side,price\n' +
  'o1,i1,100,SELL,100\n' +
  'o2,i2,100,BUY,10\n' +
  'o3,i3,200,BUY,100\n' +
  'o4,i1,150,SELL,100\n' +
  'o5,i4,60,SELL,50\n' +
  'o6,i4,60,SELL,50\n'
}

function <<access.private>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::productCsv(): String[1]
{
  'Semistructured\n' +
  'Product\n' +
  'product,identifier,version\n' +
  'p1,i1,v1\n' +
  'p2,i2,v1\n' +
  'p3,i3,v1\n' +
  'p1,i4,v1\n'
}

function <<access.private>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::explodeExecute(conn: Connection[1], func: FunctionDefinition<Any>[1], expected: String[1]):Boolean[1]
{
  executeLegendFunction(
    $func,
    meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::ExplodeSemiStructuredMapping,
    meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::H2DB,
    $conn,
    [blockCsv(), tradeCsv(), orderCsv(), productCsv()],
    $expected,
    false
  );
}

// =============================================================================
// ====== EXPLODE — tests (all 15 ignored: explode-driven joins have no
// ====== RFPM-lift analogue — would require lift-router extension)
// =============================================================================

// Ignored because explode-driven joins from BLOCKDATA.relatedEntities to physical Trades/Orders have no RFPM-lift analogue.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::testCanProperlyMixExtractAndExplode(conn: Connection[1]):Boolean[1]
{
  explodeExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Block.all()
      ->project(~[
        'Id'           : x | $x.id,
        'Trades/Status': x | $x.trades.status
      ]),
    'Id,Trades/Status\n' +
    '1,\n' +
    '2,\n' +
    '4,\n' +
    '3,\n' +
    '5,\n' +
    '6,\n'
  );
}

// Ignored because explode-driven joins from BLOCKDATA.relatedEntities to physical Trades/Orders have no RFPM-lift analogue.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::testSimplePrimitivePropertiesProjectExplodeSource(conn: Connection[1]):Boolean[1]
{
  explodeExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Block.all()
      ->project(~[
        'Id'               : x | $x.id,
        'Account'          : x | $x.account,
        'Orders/Id'        : x | $x.orders.id,
        'Orders/Identifier': x | $x.orders.identifier,
        'Orders/Price'     : x | $x.orders.price
      ]),
    'Id,Account,Orders/Id,Orders/Identifier,Orders/Price\n' +
    '1,a1,o1,i1,100.0\n' +
    '2,a1,o1,i1,100.0\n' +
    '2,a1,o2,i2,10.0\n' +
    '3,a2,o3,i3,100.0\n' +
    '4,a2,o4,i1,100.0\n' +
    '5,a1,o5,i4,50.0\n' +
    '5,a1,o6,i4,50.0\n' +
    '6,a3,,,\n'
  );
}

// Ignored because explode-driven joins from BLOCKDATA.relatedEntities to physical Trades/Orders have no RFPM-lift analogue.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::testSimplePrimitivePropertiesProjectExplodeTarget(conn: Connection[1]):Boolean[1]
{
  explodeExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Trade.all()
      ->project(~[
        'Id'           : x | $x.id,
        'Status'       : x | $x.status,
        'Block/Id'     : x | $x.block.id,
        'Block/Account': x | $x.block.account
      ]),
    'Id,Status,Block/Id,Block/Account\n' +
    't1,accepted,1,a1\n' +
    't2,rejected,2,a1\n' +
    't3,accepted,3,a2\n' +
    't4,accepted,3,a2\n' +
    't5,accepted,4,a2\n' +
    't6,rejected,4,a2\n' +
    't7,accepted,5,a1\n' +
    't8,invalid,,\n'
  );
}

// Ignored because explode-driven joins from BLOCKDATA.relatedEntities to physical Trades/Orders have no RFPM-lift analogue.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::testComplexProjectFlattenedAndExplodedPropertiesInProject(conn: Connection[1]):Boolean[1]
{
  explodeExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Block.all()
      ->project(~[
        'Id'           : x | $x.id,
        'Entity Tag'   : x | $x.blockData.relatedEntities.tag,
        'Entity Tag Id': x | $x.blockData.relatedEntities.tagId,
        'Orders/Id'    : x | $x.orders.id
      ]),
    'Id,Entity Tag,Entity Tag Id,Orders/Id\n' +
    '1,trade,t1,o1\n' +
    '1,order,o1,o1\n' +
    '2,trade,t2,o1\n' +
    '2,trade,t2,o2\n' +
    '2,order,o2,o1\n' +
    '2,order,o2,o2\n' +
    '2,order,o1,o2\n' +
    '2,order,o1,o1\n' +
    '3,trade,t3,o3\n' +
    '3,trade,t4,o3\n' +
    '3,order,o3,o3\n' +
    '4,trade,t5,o4\n' +
    '4,trade,t6,o4\n' +
    '4,order,o4,o4\n' +
    '5,trade,t7,o5\n' +
    '5,trade,t7,o6\n' +
    '5,order,o5,o5\n' +
    '5,order,o5,o6\n' +
    '5,order,o6,o5\n' +
    '5,order,o6,o6\n' +
    '6,,,\n'
  );
}

// Ignored because explode-driven joins from BLOCKDATA.relatedEntities to physical Trades/Orders have no RFPM-lift analogue.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::testComplexProjectMultiplePropertiesToExplodeInProject(conn: Connection[1]):Boolean[1]
{
  explodeExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Block.all()
      ->project(~[
        'Id'               : x | $x.id,
        'Account'          : x | $x.account,
        'Orders/Id'        : x | $x.orders.id,
        'Orders/Identifier': x | $x.orders.identifier,
        'Trades/Id'        : x | $x.trades.id,
        'Trades/Status'    : x | $x.trades.status
      ]),
    'Id,Account,Orders/Id,Orders/Identifier,Trades/Id,Trades/Status\n' +
    '1,a1,o1,i1,t1,accepted\n' +
    '2,a1,o1,i1,t2,rejected\n' +
    '2,a1,o2,i2,t2,rejected\n' +
    '3,a2,o3,i3,t3,accepted\n' +
    '3,a2,o3,i3,t4,accepted\n' +
    '4,a2,o4,i1,t5,accepted\n' +
    '4,a2,o4,i1,t6,rejected\n' +
    '5,a1,o5,i4,t7,accepted\n' +
    '5,a1,o6,i4,t7,accepted\n' +
    '6,a3,,,,\n'
  );
}

// Ignored because explode-driven joins from BLOCKDATA.relatedEntities to physical Trades/Orders have no RFPM-lift analogue.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::testSimplePrimitivePropertiesProjectWithFilterOnSource(conn: Connection[1]):Boolean[1]
{
  explodeExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Block.all()
      ->filter(x | !($x.blockData.status == 'cancelled'))
      ->project(~[
        'Id'           : x | $x.id,
        'Account'      : x | $x.account,
        'Trades/Id'    : x | $x.trades.id,
        'Trades/Status': x | $x.trades.status
      ]),
    'Id,Account,Trades/Id,Trades/Status\n' +
    '1,a1,t1,accepted\n' +
    '3,a2,t3,accepted\n' +
    '3,a2,t4,accepted\n' +
    '4,a2,t5,accepted\n' +
    '4,a2,t6,rejected\n' +
    '5,a1,t7,accepted\n' +
    '6,a3,,\n'
  );
}

// Ignored because explode-driven joins from BLOCKDATA.relatedEntities to physical Trades/Orders have no RFPM-lift analogue.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::testSimplePrimitivePropertiesProjectWithFilterOnTarget(conn: Connection[1]):Boolean[1]
{
  explodeExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Trade.all()
      ->filter(x | !($x.block.blockData.status == 'cancelled'))
      ->project(~[
        'Id'           : x | $x.id,
        'Status'       : x | $x.status,
        'Block/Id'     : x | $x.block.id,
        'Block/Account': x | $x.block.account
      ]),
    'Id,Status,Block/Id,Block/Account\n' +
    't1,accepted,1,a1\n' +
    't3,accepted,3,a2\n' +
    't4,accepted,3,a2\n' +
    't5,accepted,4,a2\n' +
    't6,rejected,4,a2\n' +
    't7,accepted,5,a1\n' +
    't8,invalid,,\n'
  );
}

// Ignored because explode-driven joins from BLOCKDATA.relatedEntities to physical Trades/Orders have no RFPM-lift analogue.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::testProjectWithExplodedPropertyAccessOnlyInFilter(conn: Connection[1]):Boolean[1]
{
  explodeExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Trade.all()
      ->filter(x | !($x.block.blockData.status == 'cancelled'))
      ->project(~[
        'Id'    : x | $x.id,
        'Status': x | $x.status
      ]),
    'Id,Status\n' +
    't1,accepted\n' +
    't3,accepted\n' +
    't4,accepted\n' +
    't5,accepted\n' +
    't6,rejected\n' +
    't7,accepted\n' +
    't8,invalid\n'
  );
}

// Ignored because explode-driven joins from BLOCKDATA.relatedEntities to physical Trades/Orders have no RFPM-lift analogue.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::testFilterOnExplodedPropertyFilteringInsideProject(conn: Connection[1]):Boolean[1]
{
  explodeExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Block.all()
      ->project(~[
        'Block/Id'     : x | $x.id,
        'Block/Account': x | $x.account,
        'Big Buy Orders': x | $x.orders->filter(x_1 | ($x_1.quantity >= 100) && ($x_1.side == 'BUY')).id,
        'Orders/Id'    : x | $x.orders.id
      ]),
    'Block/Id,Block/Account,Big Buy Orders,Orders/Id\n' +
    '1,a1,,o1\n' +
    '2,a1,o2,o1\n' +
    '2,a1,o2,o2\n' +
    '3,a2,o3,o3\n' +
    '4,a2,,o4\n' +
    '5,a1,,o5\n' +
    '5,a1,,o6\n' +
    '6,a3,,\n'
  );
}

// Ignored because explode-driven joins from BLOCKDATA.relatedEntities to physical Trades/Orders have no RFPM-lift analogue.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::testAggregationAggregateExplodedPropertyUsingGroupBy(conn: Connection[1]):Boolean[1]
{
  explodeExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Block.all()
      ->groupBy(
        [x | $x.id, x | $x.account],
        [agg(x | $x.trades.tradeSummary.execQuantity, x | $x->sum())],
        ['Id', 'Account', 'quantity']
      ),
    'Id,Account,quantity\n' +
    '1,a1,100\n' +
    '2,a1,100\n' +
    '3,a2,200\n' +
    '4,a2,150\n' +
    '5,a1,60\n' +
    '6,a3,\n'
  );
}

// Ignored because explode-driven joins from BLOCKDATA.relatedEntities to physical Trades/Orders have no RFPM-lift analogue.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::testAggregationAggregateExplodedPropertyInsideProject(conn: Connection[1]):Boolean[1]
{
  explodeExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Block.all()
      ->project(~[
        'Id'       : x | $x.id,
        'Account'  : x | $x.account,
        'Buy Order': x | $x.orders->filter(x_1 | $x_1.side == 'BUY').quantity->sum()
      ]),
    'Id,Account,Buy Order\n' +
    '1,a1,\n' +
    '2,a1,100\n' +
    '3,a2,200\n' +
    '4,a2,\n' +
    '5,a1,\n' +
    '6,a3,\n'
  );
}

// Ignored because explode-driven joins from BLOCKDATA.relatedEntities to physical Trades/Orders have no RFPM-lift analogue.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::testSimpleJoinChainOneJoin(conn: Connection[1]):Boolean[1]
{
  explodeExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Order.all()
      ->project(~[
        'Id'      : x | $x.id,
        'Account' : x | $x.account,
