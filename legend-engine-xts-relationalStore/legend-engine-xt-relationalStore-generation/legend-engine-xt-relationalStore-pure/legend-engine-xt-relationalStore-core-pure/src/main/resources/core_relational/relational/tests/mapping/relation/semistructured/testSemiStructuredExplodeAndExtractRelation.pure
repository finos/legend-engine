    'o2,a1,2\n' +
    'o3,a2,3\n' +
    'o4,a2,4\n' +
    'o5,a1,5\n' +
    'o6,a1,5\n'
  );
}

// Ignored because explode-driven joins from BLOCKDATA.relatedEntities to physical Trades/Orders have no RFPM-lift analogue.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::testJoinChainMultipleJoinsSingleExplode(conn: Connection[1]):Boolean[1]
{
  explodeExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::explodeextract::explode::Block.all()
      ->project(~[
        'Product': x | $x.products,
        'Id'     : x | $x.id
