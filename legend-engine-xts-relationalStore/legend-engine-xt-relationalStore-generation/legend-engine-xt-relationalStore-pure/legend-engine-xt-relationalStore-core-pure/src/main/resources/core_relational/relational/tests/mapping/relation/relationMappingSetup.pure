  {
    ~func meta::relational::tests::mapping::relation::personFunctionWithAddress():Relation<Any>[1]
    firstName: FIRSTNAME,
    age: AGE,
    +firmId: Integer[1]: FIRMID,
    address () Inline [addressSet]
  }

  *Address[addressSet]: Relation
  {
    ~func meta::relational::tests::mapping::relation::personFunctionWithAddress():Relation<Any>[1]
    street: STREET,
    city: CITY
  }

  *Firm[firm]: Relation
  {
    ~func meta::relational::tests::mapping::relation::firmFunction__Relation_1_
    legalName: legalName,
    +id: Integer[1]: ID
  }

  PersonWithAddressAndFirm_Firm: XStore
  {
    employeesWithAddr[firm, personAddr]: $this.id == $that.firmId,
    firmOfAddr[personAddr, firm]: $this.firmId == $that.id
  }
)

Mapping meta::relational::tests::mapping::relation::MixedCaseAssociationChainMapping
(
  *Group[group]: Relational
  {
    ~primaryKey
    (
      [meta::relational::tests::mapping::relation::testDB]groupMembershipTable.GROUPID,
      [meta::relational::tests::mapping::relation::testDB]groupMembershipTable.PERSONID
    )
    ~mainTable [meta::relational::tests::mapping::relation::testDB]groupMembershipTable
    groupId  : [meta::relational::tests::mapping::relation::testDB]groupMembershipTable.GROUPID,
    groupName: [meta::relational::tests::mapping::relation::testDB]groupMembershipTable.GROUPNAME
  }

  *Person[person]: Relational
  {
    ~primaryKey ([meta::relational::tests::mapping::relation::testDB]personTable.ID)
    ~mainTable [meta::relational::tests::mapping::relation::testDB]personTable
    firstName: [meta::relational::tests::mapping::relation::testDB]personTable."FIRST NAME",
    age: [meta::relational::tests::mapping::relation::testDB]personTable.AGE,
    +firmId: Integer[1]: [meta::relational::tests::mapping::relation::testDB]personTable.FIRMID
  }

  *Firm[firm]: Relation
  {
    ~func meta::relational::tests::mapping::relation::firmFunctionMixedCase__Relation_1_
    legalName: legalName,
    +id: Integer[1]: firmId
  }

  Person_Group: Relational
  {
    AssociationMapping
    (
      members[group, person]: [meta::relational::tests::mapping::relation::testDB]@GroupMembership_Person,
      group[person, group]: [meta::relational::tests::mapping::relation::testDB]@GroupMembership_Person
    )
  }

  Person_Firm: XStore
  {
    employees[firm, person]: $this.id == $that.firmId,
    firm[person, firm]:      $this.firmId == $that.id
  }

  // Person_Firm: ModelJoin
  // {
  //   {employees:Person[1], firm:Firm[1]|$firm.id == $employees.firmId}
  // }
)

Mapping meta::relational::tests::mapping::relation::tradeRelationMapping
(
   *Trade: Relation
   {
      ~func meta::relational::tests::mapping::relation::tradeFunction__Relation_1_
      id: ID,
      quantity: quantity,
      date: tradeDate,
      settlementDateTime: settlementDateTime
   }
)

Mapping meta::relational::tests::mapping::relation::filterJoinMapping
(
   *Person: Relation
   {
      ~func meta::relational::tests::mapping::relation::personFunctionWithJoinFilter__Relation_1_
      firstName: 'FIRST NAME',
      age: AGE
   }
)

Mapping meta::relational::tests::mapping::relation::distinctFirmMapping
(
   *Firm: Relation
   {
      ~func meta::relational::tests::mapping::relation::distinctFirmFunc__Relation_1_
      legalName: LEGALNAME,
      +id: Integer[1]: ID
   }
)

Mapping meta::relational::tests::mapping::relation::GroupByAssociationMapping
(
   *GroupByClass[groupByClass]: Relation
   {
      ~func meta::relational::tests::mapping::relation::personFunctionWithGroupBy__Relation_1_
      firmId: FIRMID,
      sum: SUM
   }

   *Firm[firm]: Relation
   {
      ~func meta::relational::tests::mapping::relation::firmFunction__Relation_1_
      legalName: legalName,
      +id: Integer[1]: ID
   }

   GroupByClass_Firm: ModelJoin
   {
      {groupByClass: GroupByClass[1], firm: Firm[1] | $groupByClass.firmId == $firm.id}
   }
)

