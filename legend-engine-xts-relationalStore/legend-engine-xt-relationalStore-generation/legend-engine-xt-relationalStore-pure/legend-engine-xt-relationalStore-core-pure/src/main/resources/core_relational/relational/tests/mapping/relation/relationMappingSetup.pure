  executeInDb('insert into PERSON_TABLE_PROCESSING_TEMPORAL(ID, FIRSTNAME, SALARY, FIRMID, IN_Z, OUT_Z) values (3, \'Jane\',    23,  2, \'2024-11-01\', \'2025-01-02\');', $connection);
