###Relational
Database meta::relational::tests::mapping::relation::testDB
(
  // Most columns are NOT NULL so they map cleanly to [1] properties under the
  // strict multiplicity check. SALARY is intentionally left nullable so we can
  // exercise the [0..1]-column → [0..1]-property path in NullableSalaryMapping.
  Table personTable
  (
    ID INTEGER PRIMARY KEY,
    "FIRST NAME" VARCHAR(100) NOT NULL,
    AGE INTEGER NOT NULL,
    FIRMID INTEGER NOT NULL,
    EMPLOYEE_TYPE VARCHAR(20) NOT NULL,
    IS_MALE INTEGER NOT NULL,
    SALARY FLOAT
  )

  Table firmTable
  (
    ID INTEGER PRIMARY KEY,
    legalName VARCHAR(100) NOT NULL
  )

  Table groupMembershipTable
  (
    GROUPID INTEGER PRIMARY KEY,
    PERSONID INTEGER NOT NULL,
    GROUPNAME VARCHAR(30) NOT NULL
  )

  // Source for RFPM-lift variant tests. PAYLOAD holds JSON-encoded data that
  // the lift router extracts via $src.PAYLOAD->get(...) chains.
  Table personPayloadTable
  (
    ID INTEGER PRIMARY KEY,
    PAYLOAD SEMISTRUCTURED
  )

  Table personWithAddressTable
  (
    ID INTEGER PRIMARY KEY,
    FIRSTNAME VARCHAR(100) NOT NULL,
    AGE INTEGER NOT NULL,
    STREET VARCHAR(100) NOT NULL,
    CITY VARCHAR(100) NOT NULL,
    FIRMID INTEGER NOT NULL
  )

  Join GroupMembership_Person(groupMembershipTable.PERSONID = personTable.ID)
)

###Relational
Database meta::relational::tests::mapping::relation::MilestonedDB
(
  // Same NOT NULL strategy as testDB: columns mapped to [1] properties and
  // milestoning marker columns are NOT NULL; SALARY remains nullable since
  // it is not property-mapped in any of these tests.
  Table PERSON_TABLE_PROCESSING_SNAPSHOT
  (
    milestoning
    (
      processing(PROCESSING_SNAPSHOT_DATE = SNAPSHOTDATE)
    )
    ID INTEGER PRIMARY KEY,
    FIRSTNAME VARCHAR(100) NOT NULL,
    SALARY INTEGER,
    FIRMID INTEGER NOT NULL,
    SNAPSHOTDATE DATE NOT NULL
  )

  Table PERSON_TABLE_BUSINESS_SNAPSHOT
  (
    milestoning
    (
      business(BUS_SNAPSHOT_DATE = SNAPSHOTDATE)
    )
    ID INTEGER PRIMARY KEY,
    FIRSTNAME VARCHAR(100) NOT NULL,
    SALARY INTEGER,
    FIRMID INTEGER NOT NULL,
    SNAPSHOTDATE DATE NOT NULL
  )

  Table PERSON_TABLE_PROCESSING_TEMPORAL
  (
    milestoning
    (
      processing(PROCESSING_IN = IN_Z, PROCESSING_OUT = OUT_Z)
    )
    ID INTEGER PRIMARY KEY,
    FIRSTNAME VARCHAR(100) NOT NULL,
    SALARY INTEGER,
    FIRMID INTEGER NOT NULL,
    IN_Z DATE NOT NULL,
    OUT_Z DATE NOT NULL
  )

  Table PERSON_TABLE_BUSINESS_TEMPORAL
  (
    milestoning
    (
      business(BUS_FROM = FROM_Z, BUS_THRU = THRU_Z)
    )
    ID INTEGER PRIMARY KEY,
    FIRSTNAME VARCHAR(100) NOT NULL,
    SALARY INTEGER,
    FIRMID INTEGER NOT NULL,
    FROM_Z DATE NOT NULL,
    THRU_Z DATE NOT NULL
  )

  Table PERSON_TABLE_BITEMPORAL
  (
    milestoning
    (
      processing(PROCESSING_IN = IN_Z, PROCESSING_OUT = OUT_Z),
      business(BUS_FROM = FROM_Z, BUS_THRU = THRU_Z)
    )
    ID INTEGER PRIMARY KEY,
    FIRSTNAME VARCHAR(100) NOT NULL,
    SALARY INTEGER,
    FIRMID INTEGER NOT NULL,
    IN_Z DATE NOT NULL,
    OUT_Z DATE NOT NULL,
    FROM_Z DATE NOT NULL,
    THRU_Z DATE NOT NULL
  )

  Table FIRM_TABLE_PROCESSING_SNAPSHOT
  (
    milestoning
    (
      processing(PROCESSING_SNAPSHOT_DATE = SNAPSHOTDATE)
    )
    ID INTEGER PRIMARY KEY,
    LEGALNAME VARCHAR(100) NOT NULL,
    SNAPSHOTDATE DATE NOT NULL
  )

  Table FIRM_TABLE_BUSINESS_SNAPSHOT
  (
    milestoning
    (
      business(BUS_SNAPSHOT_DATE = SNAPSHOTDATE)
    )
    ID INTEGER PRIMARY KEY,
    LEGALNAME VARCHAR(100) NOT NULL,
    SNAPSHOTDATE DATE NOT NULL
  )

  Table FIRM_TABLE_PROCESSING_TEMPORAL
  (
    milestoning
    (
      processing(PROCESSING_IN = IN_Z, PROCESSING_OUT = OUT_Z)
    )
    ID INTEGER PRIMARY KEY,
    LEGALNAME VARCHAR(100) NOT NULL,
    IN_Z DATE NOT NULL,
    OUT_Z DATE NOT NULL
  )

  Table FIRM_TABLE_BUSINESS_TEMPORAL
  (
    milestoning
    (
      business(BUS_FROM = FROM_Z, BUS_THRU = THRU_Z)
    )
    ID INTEGER PRIMARY KEY,
    LEGALNAME VARCHAR(100) NOT NULL,
    FROM_Z DATE NOT NULL,
    THRU_Z DATE NOT NULL
  )

  Table FIRM_TABLE_BITEMPORAL
  (
    milestoning
    (
      processing(PROCESSING_IN = IN_Z, PROCESSING_OUT = OUT_Z),
      business(BUS_FROM = FROM_Z, BUS_THRU = THRU_Z)
    )
    ID INTEGER PRIMARY KEY,
    LEGALNAME VARCHAR(100) NOT NULL,
    IN_Z DATE NOT NULL,
    OUT_Z DATE NOT NULL,
    FROM_Z DATE NOT NULL,
    THRU_Z DATE NOT NULL,
    SNAPSHOTDATE DATE NOT NULL
  )
)

###Relational
Database meta::relational::tests::mapping::relation::coverageDB
(
   Table ACCOUNT_INFO
   (
      IF_CODE INTEGER NOT NULL,
      IF_NAME VARCHAR(200) NOT NULL,
      IF_TYPE VARCHAR(20) NOT NULL
   )

   Table IF_OTHER_INFO
   (
      IF_CODE INTEGER PRIMARY KEY,
      IF_OTHER_NAME VARCHAR(20) NOT NULL
   )

   Table orgTable
   (
      id INTEGER PRIMARY KEY,
      filterVal INTEGER NOT NULL,
      parentId INTEGER,
      name VARCHAR(200) NOT NULL
   )

   Table otherTable
   (
      orgTableId INTEGER NOT NULL,
      filterVal INTEGER NOT NULL
   )

   Table TRADE
   (
      TRADE_ID INTEGER PRIMARY KEY,
      ACC_NUM INTEGER NOT NULL,
      GSN VARCHAR(20) NOT NULL,
      PRODUCT_ID INTEGER NOT NULL,
      QTY INTEGER NOT NULL
   )

   Table PRODUCT
   (
      ID INTEGER PRIMARY KEY,
      DESCRIPTION VARCHAR(20) NOT NULL
   )

   Table PRODUCT_EXPLODED
   (
      TRADEABLE_ID INTEGER PRIMARY KEY,
      PRODUCT_ID INTEGER NOT NULL,
      DESCRIPTION VARCHAR(20) NOT NULL,
      ACTIVE INTEGER NOT NULL
   )

   Table cvTradeTable
   (
      ID INTEGER PRIMARY KEY,
      quantity FLOAT NOT NULL,
      tradeDate DATE NOT NULL,
      settlementDateTime TIMESTAMP
   )
)

