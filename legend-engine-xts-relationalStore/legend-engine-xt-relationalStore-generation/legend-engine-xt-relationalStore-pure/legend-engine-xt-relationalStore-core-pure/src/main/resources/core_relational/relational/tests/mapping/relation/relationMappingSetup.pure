Mapping meta::relational::tests::mapping::relation::EmbeddedRelationMapping
(
  *PersonWithAddress: Relation
  {
    ~func meta::relational::tests::mapping::relation::personFunctionWithAddress():Relation<Any>[1]
    firstName: FIRSTNAME,
    age: AGE,
    address
    (
