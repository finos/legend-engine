  executeInDb('insert into PERSON_TABLE_PROCESSING_TEMPORAL(ID, FIRSTNAME, SALARY, FIRMID, IN_Z, OUT_Z) values (5, \'Fabrice\', 45,  4, \'2024-11-01\', \'2025-01-01\');', $connection);
