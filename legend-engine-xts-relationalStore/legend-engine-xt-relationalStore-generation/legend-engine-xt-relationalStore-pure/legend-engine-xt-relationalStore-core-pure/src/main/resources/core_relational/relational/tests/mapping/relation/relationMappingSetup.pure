  true;
}

function meta::relational::tests::mapping::relation::createCoverageTablesAndFillDb():Boolean[1]
{
   let connection = meta::external::store::relational::tests::testRuntime(coverageDB).connectionByElement(coverageDB)->cast(@meta::external::store::relational::runtime::TestDatabaseConnection);

   // distinct model
   executeInDb('Drop table if exists ACCOUNT_INFO;', $connection);
   executeInDb('Create Table ACCOUNT_INFO(IF_CODE INTEGER NOT NULL, IF_NAME VARCHAR(200) NOT NULL, IF_TYPE VARCHAR(20) NOT NULL);', $connection);
   executeInDb('insert into ACCOUNT_INFO (IF_CODE, IF_NAME, IF_TYPE) values (1001, \'IF 1\', \'Type 1\');', $connection);
   executeInDb('insert into ACCOUNT_INFO (IF_CODE, IF_NAME, IF_TYPE) values (1002, \'IF 2\', \'Type 1\');', $connection);
   executeInDb('insert into ACCOUNT_INFO (IF_CODE, IF_NAME, IF_TYPE) values (1002, \'IF 2\', \'Type 1\');', $connection);
   executeInDb('insert into ACCOUNT_INFO (IF_CODE, IF_NAME, IF_TYPE) values (1022, \'IF 2\', \'Type 1\');', $connection);
   executeInDb('insert into ACCOUNT_INFO (IF_CODE, IF_NAME, IF_TYPE) values (1002, \'IF 2\', \'Type 2\');', $connection);

   executeInDb('Drop table if exists IF_OTHER_INFO;', $connection);
   executeInDb('Create Table IF_OTHER_INFO(IF_CODE INTEGER PRIMARY KEY, IF_OTHER_NAME VARCHAR(20) NOT NULL);', $connection);
   executeInDb('insert into IF_OTHER_INFO (IF_CODE, IF_OTHER_NAME) values (1001, \'IfName1\');', $connection);
   executeInDb('insert into IF_OTHER_INFO (IF_CODE, IF_OTHER_NAME) values (1002, \'IfName2\');', $connection);

   // filter model
   executeInDb('Drop table if exists orgTable;', $connection);
   executeInDb('Create Table orgTable(id INTEGER PRIMARY KEY, filterVal INTEGER NOT NULL, parentId INTEGER, name VARCHAR(200) NOT NULL);', $connection);
   executeInDb('insert into orgTable (id, filterVal, parentId, name) values (1, 4, -1, \'ROOT\');', $connection);
   executeInDb('insert into orgTable (id, filterVal, parentId, name) values (2, 4, 1, \'Firm X\');', $connection);
   executeInDb('insert into orgTable (id, filterVal, parentId, name) values (3, 4, 1, \'Firm A\');', $connection);
   executeInDb('insert into orgTable (id, filterVal, parentId, name) values (4, 4, 2, \'Securities\');', $connection);
   executeInDb('insert into orgTable (id, filterVal, parentId, name) values (5, 4, 2, \'Banking\');', $connection);
   executeInDb('insert into orgTable (id, filterVal, parentId, name) values (6, 4, 2, \'Federation\');', $connection);
   executeInDb('insert into orgTable (id, filterVal, parentId, name) values (7, 6, 2, \'ShouldNotBeDisplayed\');', $connection);

   executeInDb('Drop table if exists otherTable;', $connection);
   executeInDb('Create Table otherTable(orgTableId INTEGER NOT NULL, filterVal INTEGER NOT NULL);', $connection);
   executeInDb('insert into otherTable (orgTableId, filterVal) values (1, 4);', $connection);
   executeInDb('insert into otherTable (orgTableId, filterVal) values (2, 4);', $connection);
   executeInDb('insert into otherTable (orgTableId, filterVal) values (3, 4);', $connection);
   executeInDb('insert into otherTable (orgTableId, filterVal) values (4, 4);', $connection);
   executeInDb('insert into otherTable (orgTableId, filterVal) values (5, 4);', $connection);
   executeInDb('insert into otherTable (orgTableId, filterVal) values (6, 4);', $connection);
   executeInDb('insert into otherTable (orgTableId, filterVal) values (7, 6);', $connection);

   // groupBy model
   executeInDb('Drop table if exists TRADE;', $connection);
   executeInDb('Create Table TRADE(TRADE_ID INTEGER PRIMARY KEY, ACC_NUM INTEGER NOT NULL, GSN VARCHAR(20) NOT NULL, PRODUCT_ID INTEGER NOT NULL, QTY INTEGER NOT NULL);', $connection);
   executeInDb('insert into TRADE (TRADE_ID, ACC_NUM, GSN, PRODUCT_ID, QTY) values (1, 7900002, \'YU2EF5\', 1, 3);', $connection);
   executeInDb('insert into TRADE (TRADE_ID, ACC_NUM, GSN, PRODUCT_ID, QTY) values (2, 7900002, \'YU2EF5\', 1, 5);', $connection);
   executeInDb('insert into TRADE (TRADE_ID, ACC_NUM, GSN, PRODUCT_ID, QTY) values (3, 7900003, \'EA4GNY\', 2, 100);', $connection);
   executeInDb('insert into TRADE (TRADE_ID, ACC_NUM, GSN, PRODUCT_ID, QTY) values (4, 7900003, \'EA4GNY\', 2, 200);', $connection);

   executeInDb('Drop table if exists PRODUCT;', $connection);
   executeInDb('Create Table PRODUCT(ID INTEGER PRIMARY KEY, DESCRIPTION VARCHAR(20) NOT NULL);', $connection);
   executeInDb('insert into PRODUCT (ID, DESCRIPTION) values (1, \'Firm D\');', $connection);
   executeInDb('insert into PRODUCT (ID, DESCRIPTION) values (2, \'Gold\');', $connection);

   executeInDb('Drop table if exists PRODUCT_EXPLODED;', $connection);
   executeInDb('Create Table PRODUCT_EXPLODED(TRADEABLE_ID INTEGER PRIMARY KEY, PRODUCT_ID INTEGER NOT NULL, DESCRIPTION VARCHAR(20) NOT NULL, ACTIVE INTEGER NOT NULL);', $connection);
   executeInDb('insert into PRODUCT_EXPLODED (TRADEABLE_ID, PRODUCT_ID, DESCRIPTION, ACTIVE) values (11, 1, \'Firm D\', 1);', $connection);
   executeInDb('insert into PRODUCT_EXPLODED (TRADEABLE_ID, PRODUCT_ID, DESCRIPTION, ACTIVE) values (22, 2, \'Gold\', 0);', $connection);
   executeInDb('insert into PRODUCT_EXPLODED (TRADEABLE_ID, PRODUCT_ID, DESCRIPTION, ACTIVE) values (33, 2, \'Gold\', 0);', $connection);

   // dates model - TIMESTAMP(9) for nanosecond precision
   executeInDb('Drop table if exists cvTradeTable;', $connection);
   executeInDb('Create Table cvTradeTable(ID INT PRIMARY KEY, quantity FLOAT NOT NULL, tradeDate DATE NOT NULL, settlementDateTime TIMESTAMP(9));', $connection);
   executeInDb('insert into cvTradeTable (ID, quantity, tradeDate, settlementDateTime) values (1, 25, \'2014-12-01\', \'2014-12-02 21:00:00\');', $connection);
   executeInDb('insert into cvTradeTable (ID, quantity, tradeDate, settlementDateTime) values (2, 320, \'2014-12-01\', \'2014-12-02 21:00:00\');', $connection);
   executeInDb('insert into cvTradeTable (ID, quantity, tradeDate, settlementDateTime) values (3, 11, \'2014-12-01\', \'2014-12-02 21:00:00\');', $connection);
   executeInDb('insert into cvTradeTable (ID, quantity, tradeDate, settlementDateTime) values (4, 23, \'2014-12-02\', \'2014-12-03 21:00:00\');', $connection);
   executeInDb('insert into cvTradeTable (ID, quantity, tradeDate, settlementDateTime) values (5, 32, \'2014-12-02\', \'2014-12-03 21:00:00\');', $connection);
   executeInDb('insert into cvTradeTable (ID, quantity, tradeDate, settlementDateTime) values (6, 27, \'2014-12-03\', \'2014-12-04 21:00:00\');', $connection);
   executeInDb('insert into cvTradeTable (ID, quantity, tradeDate, settlementDateTime) values (7, 44, \'2014-12-03\', \'2014-12-04 15:22:23.123\');', $connection);
   executeInDb('insert into cvTradeTable (ID, quantity, tradeDate, settlementDateTime) values (8, 22, \'2014-12-04\', \'2014-12-05 21:00:00\');', $connection);
   executeInDb('insert into cvTradeTable (ID, quantity, tradeDate, settlementDateTime) values (9, 45, \'2014-12-04\', \'2014-12-05 21:00:00\');', $connection);
   executeInDb('insert into cvTradeTable (ID, quantity, tradeDate) values (10, 38, \'2014-12-04\');', $connection);
   executeInDb('insert into cvTradeTable (ID, quantity, tradeDate) values (11, 5, \'2014-12-05\');', $connection);
   executeInDb('insert into cvTradeTable (ID, quantity, tradeDate, settlementDateTime) values (12, 45, \'2016-02-04\', \'2016-02-05T21:00:00.123456789\');', $connection);
   executeInDb('insert into cvTradeTable (ID, quantity, tradeDate, settlementDateTime) values (13, 45, \'2016-03-28\', \'2016-03-29T21:00:00.123456789\');', $connection);
   executeInDb('insert into cvTradeTable (ID, quantity, tradeDate, settlementDateTime) values (14, 45, \'2016-03-28\', \'2016-03-29 21:00:00.123456789\');', $connection);
   executeInDb('insert into cvTradeTable (ID, quantity, tradeDate, settlementDateTime) values (15, 45, \'2016-02-14\', \'2016-02-15T21:00:00.123456789\');', $connection);

   true;
}

// ============================================================================
// Coverage relation functions migrated from the former relationCoverage{Dates,
// Filter,GroupBy,Distinct}.pure files. These reuse the coverageDB store and the
// createCoverageTablesAndFillDb() seed above; each is the relation-mapping
// equivalent of a classic ~filter / ~groupBy / ~distinct / dates mapping test,
// with the operation performed inside the backing ~func.
// ============================================================================

###Pure
import meta::pure::functions::relation::*;
import meta::pure::metamodel::relation::*;
import meta::relational::tests::mapping::relation::*;

// --- Dates: DATE / TIMESTAMP typed columns mapped to StrictDate / DateTime ------
function meta::relational::tests::mapping::relation::tradeFunction():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.cvTradeTable}#
      ->select(~[ID, tradeDate, quantity, settlementDateTime]);
}

// --- Filter: ->filter(...) inside the backing ~func -----------------------------
function meta::relational::tests::mapping::relation::orgRelationFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.orgTable}#
      ->filter(x | $x.filterVal <= 4)
      ->select(~[id, name, parentId]);
}

function meta::relational::tests::mapping::relation::orgRelationWithJoinFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.orgTable}#
      ->select(~[id, name, parentId])
      ->join(
         #>{meta::relational::tests::mapping::relation::coverageDB.otherTable}#->project(~[joinOrgId:t|$t.orgTableId, otherFilterVal:t|$t.filterVal]),
         JoinKind.INNER,
         {o, t | $o.id == $t.joinOrgId}
       )
      ->filter(x | $x.otherFilterVal <= 4)
      ->select(~[id, name, parentId]);
}

function meta::relational::tests::mapping::relation::orgRelationWithParentNameFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.orgTable}#
      ->filter(x | $x.filterVal <= 4)
      ->select(~[id, name, parentId])
      ->join(
         #>{meta::relational::tests::mapping::relation::coverageDB.orgTable}#->project(~[pId:p|$p.id, pParentId:p|$p.parentId]),
         JoinKind.LEFT,
         {r, p | $r.parentId == $p.pId}
       )
      ->join(
         #>{meta::relational::tests::mapping::relation::coverageDB.orgTable}#->project(~[gpId:g|$g.id, parentName:g|$g.name]),
         JoinKind.LEFT,
         {r, g | $r.pParentId == $g.gpId}
       )
      ->select(~[id, name, parentName]);
}

// --- GroupBy: ->groupBy(...) inside the backing ~func ---------------------------
// ~groupBy(ACC_NUM, PRODUCT_ID, GSN), quantity = sum(QTY)
function meta::relational::tests::mapping::relation::positionGroupByFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.TRADE}#
      ->groupBy(~[ACC_NUM, PRODUCT_ID, GSN], ~quantity : x | $x.QTY : y | $y->sum());
}

// ~filter (PRODUCT_ID = 1) then the same groupBy.
function meta::relational::tests::mapping::relation::positionGroupByFilteredFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.TRADE}#
      ->filter(x | $x.PRODUCT_ID == 1)
      ->groupBy(~[ACC_NUM, PRODUCT_ID, GSN], ~quantity : x | $x.QTY : y | $y->sum());
}

// Plain PRODUCT table.
function meta::relational::tests::mapping::relation::productFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.PRODUCT}#
      ->select(~[ID, DESCRIPTION]);
}

// ~filter (ACTIVE = 1) then a keys-only groupBy (no aggregate = distinct).
function meta::relational::tests::mapping::relation::productExplodedFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.PRODUCT_EXPLODED}#
      ->filter(x | $x.ACTIVE == 1)
      ->select(~[PRODUCT_ID, DESCRIPTION])
      ->distinct();
}

// --- Distinct: ->distinct() inside the backing ~func ----------------------------
function meta::relational::tests::mapping::relation::incomeFunctionFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.ACCOUNT_INFO}#
      ->select(~[IF_CODE, IF_NAME])
      ->distinct();
}

// Discriminating filter: only the single 'Type 2' row survives, so after distinct the
// mapped class has one row. The unfiltered mapping yields 3 distinct rows, making the
// func-body filter's effect observable in the asserted TDS.
function meta::relational::tests::mapping::relation::incomeFunctionWithFilterFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.ACCOUNT_INFO}#
      ->filter(r | $r.IF_TYPE == 'Type 2')
      ->select(~[IF_CODE, IF_NAME])
      ->distinct();
}

function meta::relational::tests::mapping::relation::incomeFunctionWithOtherInfoFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.ACCOUNT_INFO}#
      ->join(
         #>{meta::relational::tests::mapping::relation::coverageDB.IF_OTHER_INFO}#
            ->extend(~joinIfCode:r | $r.IF_CODE)
            ->select(~[joinIfCode, IF_OTHER_NAME]),
         JoinKind.LEFT,
         {a, o | $a.IF_CODE == $o.joinIfCode}
      )
      ->select(~[IF_CODE, IF_NAME, IF_OTHER_NAME])
      ->distinct();
}

function meta::relational::tests::mapping::relation::classificationFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.IF_OTHER_INFO}#
      ->select(~[IF_CODE, IF_OTHER_NAME]);
}

function meta::relational::tests::mapping::relation::incomeFunctionWithOtherInfo2Func():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.ACCOUNT_INFO}#
      ->join(
         #>{meta::relational::tests::mapping::relation::coverageDB.IF_OTHER_INFO}#
            ->extend(~joinIfCode:r | $r.IF_CODE)
            ->select(~[joinIfCode, IF_OTHER_NAME]),
         JoinKind.LEFT,
         {a, o | $a.IF_CODE == $o.joinIfCode && $a.IF_CODE->isNotEmpty()}
      )
      ->select(~[IF_CODE, IF_NAME, IF_OTHER_NAME])
      ->distinct();
}

function meta::relational::tests::mapping::relation::incomeFunctionWithCaseFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.ACCOUNT_INFO}#
      ->extend(~name:r | if($r.IF_NAME->isEmpty(), | 'C', | $r.IF_NAME->toOne()))
      ->select(~[IF_CODE, name])
      ->distinct();
}

function meta::relational::tests::mapping::relation::classificationWithCaseFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverageDB.IF_OTHER_INFO}#
      ->extend(~name:r | if($r.IF_OTHER_NAME->isEmpty(), | 'Unknown', | $r.IF_OTHER_NAME->toOne()))
      ->select(~[IF_CODE, name]);
}

// --- Dates mapping (Trade class already declared above) -------------------------
###Mapping
import meta::relational::tests::mapping::relation::*;

Mapping meta::relational::tests::mapping::relation::tradeRelationMapping
(
   *Trade: Relation
   {
      ~func meta::relational::tests::mapping::relation::tradeFunction():Relation<Any>[1]
      id: ID,
      quantity: quantity,
      date: tradeDate,
      settlementDateTime: settlementDateTime
   }
)

// --- Filter mappings (classic filter Org domain) --------------------------------
###Mapping
import meta::relational::tests::mapping::filter::model::domain::*;
import meta::relational::tests::mapping::relation::*;

Mapping meta::relational::tests::mapping::relation::orgRelationMapping
(
   *Org: Relation
   {
      ~func meta::relational::tests::mapping::relation::orgRelationFunc():Relation<Any>[1]
      name: name
   }
)

Mapping meta::relational::tests::mapping::relation::orgRelationMappingWithJoin
(
   *Org: Relation
   {
      ~func meta::relational::tests::mapping::relation::orgRelationWithJoinFunc():Relation<Any>[1]
      name: name
   }
)

Mapping meta::relational::tests::mapping::relation::orgRelationMappingWithParentName
(
   *Org: Relation
   {
      ~func meta::relational::tests::mapping::relation::orgRelationWithParentNameFunc():Relation<Any>[1]
      name: name,
      parentName: parentName
   }
