###Mapping
import meta::pure::functions::variant::convert::*;
import meta::relational::tests::mapping::relation::*;
import meta::pure::functions::variant::navigation::*;

Mapping meta::relational::tests::mapping::relation::SimpleMapping
(
  *Person[person]: Relation
  {
    ~func meta::relational::tests::mapping::relation::personFunction__Relation_1_
    firstName: 'FIRST NAME',
    age: AGE,
    +firmId: Integer[1]: FIRMID
  }

  *Firm[firm]: Relation
  {
    ~func meta::relational::tests::mapping::relation::firmFunction__Relation_1_
    legalName: legalName,
    +id: Integer[1]: ID
  }

  Person_Firm: XStore
  {
    employees[firm, person]: $this.id == $that.firmId,
    firm[person, firm]: $this.firmId == $that.id
  }
)

// Same shape as SimpleMapping, but every property mapping is written in
// the explicit `$src.<col>` form rather than the bare-column sugar.
// Exercises the lambda-body code path for the trivial single-column case
// and asserts equivalence with the bare form.
Mapping meta::relational::tests::mapping::relation::ExplicitSrcMapping
(
  *Person[person]: Relation
  {
    ~func meta::relational::tests::mapping::relation::personFunction__Relation_1_
    firstName: $src.'FIRST NAME',
    age: $src.AGE,
    +firmId: Integer[1]: $src.FIRMID
  }

  *Firm[firm]: Relation
  {
    ~func meta::relational::tests::mapping::relation::firmFunction__Relation_1_
    legalName: $src.legalName,
    +id: Integer[1]: $src.ID
  }

  Person_Firm: XStore
  {
    employees[firm, person]: $this.id == $that.firmId,
    firm[person, firm]: $this.firmId == $that.id
  }
)

// Uses a Pure expression (arithmetic) on the property RHS.
Mapping meta::relational::tests::mapping::relation::ExpressionMapping
(
  *Person[person]: Relation
  {
    ~func meta::relational::tests::mapping::relation::personFunction__Relation_1_
    firstName: $src.'FIRST NAME',
    age: $src.AGE + 5,
    +firmId: Integer[1]: $src.FIRMID
  }
)

// Demonstrates the [0..1]-column → [0..1]-property mapping path under the
// strict multiplicity check.
Mapping meta::relational::tests::mapping::relation::NullableSalaryMapping
(
  *PersonWithOptionalSalary[personWithSalary]: Relation
  {
    ~func meta::relational::tests::mapping::relation::personFunction__Relation_1_
    firstName: 'FIRST NAME',
    age: AGE,
    salary: SALARY
  }
)

// Non-variant DynaFunction (string concat). Lift detects no variants,
// synthesises RelationalPropertyMapping with the concat relop. Runs on H2.
Mapping meta::relational::tests::mapping::relation::LiftedConcatMapping
(
  *PersonLiftedConcat[personLiftedConcat]: Relation
  {
    ~src meta::relational::tests::mapping::relation::personFunctionTyped()
    greeting: 'Hello ' + $src.'FIRST NAME'
  }
)

Mapping meta::relational::tests::mapping::relation::MixedMapping
(
  *Person[person]: Relation
  {
    ~func meta::relational::tests::mapping::relation::personFunctionWithProject__Relation_1_
    firstName: 'FIRST NAME',
    age: AGE,
    +firmId: Integer[1]: FIRMID
  }

  *PersonWithFirmId: Relational
  {
    firstName: [meta::relational::tests::mapping::relation::testDB]personTable."FIRST NAME",
    age: [meta::relational::tests::mapping::relation::testDB]personTable.AGE,
    firmId: [meta::relational::tests::mapping::relation::testDB]personTable.FIRMID
  }

  *Firm[firm]: Relational
  {
    +id: Integer[1]: [meta::relational::tests::mapping::relation::testDB]firmTable.ID,
    legalName: [meta::relational::tests::mapping::relation::testDB]firmTable.legalName
  }

  Person_Firm: XStore
  {
    employees[firm, person]: $this.id == $that.firmId,
    firm[person, firm]: $this.firmId == $that.id
  }
)

