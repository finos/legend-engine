// Demonstrates the nullable-column → [0..1]-property mapping path.
// `salary` is Float[0..1] and the underlying column SALARY is the only
// nullable column in personTable, so the multiplicities line up exactly.
Class meta::relational::tests::mapping::relation::PersonWithOptionalSalary extends meta::relational::tests::mapping::relation::Person
{
  salary: Float[0..1];
}

// --- Classes for RFPM-lift variant tests ---------------------------------------
// These exercise the processRelationFunctionPropertyMapping router, which evaluates
// each PM's `valueFn` lambda body against the materialised RF cursor and synthesises
// the appropriate wrapper (RelationalPropertyMapping /
// SemiStructuredRelationalPropertyMapping /
// SemiStructuredEmbeddedRelationalInstanceSetImplementation).

// Non-variant DynaFunction case: string concat over two regular columns.
// Exercises the lift router's RelationalPropertyMapping (non-SS) wrapper path.
Class meta::relational::tests::mapping::relation::PersonLiftedConcat
{
  greeting: String[1];
}

// Type-rejection case: `attributes` is Map<String,Variant>[1], a
// structural container that the router must reject at plan time. Map is a
// Class instance (passes instanceOf(Class)) but is explicitly excluded by
// the isStructuralContainer check at pureToSQLQuery.pure:1944.
Class meta::relational::tests::mapping::relation::PersonLiftedUnsupported
{
  attributes: meta::pure::functions::collection::Map<String, meta::pure::metamodel::variant::Variant>[1];
}

