Mapping meta::relational::tests::mapping::relation::EmbeddedWithAssociationRelationMapping
(
  *PersonWithAddressAndFirm[personAddr]: Relation
  {
    ~func meta::relational::tests::mapping::relation::personFunctionWithAddress():Relation<Any>[1]
    firstName: FIRSTNAME,
    age: AGE,
