    city: CITY,
    +id: Integer[1]: ID,
    +deptId: Integer[1]: DEPTID
  }

  showcase::modelJoinTests::domain::Department_Project: ModelJoin
  {
    department.id == projects.deptId
  }

  showcase::modelJoinTests::domain::Firm_Department: ModelJoin
  {
    firm_dept.id == departments.firmId
  }
)

