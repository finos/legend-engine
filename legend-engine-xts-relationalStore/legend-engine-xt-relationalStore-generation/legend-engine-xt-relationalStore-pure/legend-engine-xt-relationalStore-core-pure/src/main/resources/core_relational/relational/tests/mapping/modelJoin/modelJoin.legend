// =========================================================================
// Mapping 7: Chained two-hop model joins — Firm→Department→Project
//   Two consecutive model joins: Firm→Department (firm.id == dept.firmId)
//   then Department→Project (dept.id == project.deptId).
// =========================================================================
Mapping showcase::modelJoinTests::mapping::ChainedTwoHopsMapping
(
  *showcase::modelJoinTests::domain::Firm[firm]: Relation
  {
    ~func showcase::modelJoinTests::function::firmTable():Relation<Any>[1]
    legalName: LEGALNAME,
    +id: Integer[1]: ID,
    +city: String[0..1]: CITY
  }
