// =========================================================================
// Mapping 1: Simple equality - employees.firmId == firm.id
// =========================================================================
Mapping showcase::modelJoinTests::mapping::SimpleEqualityMapping
(
  *showcase::modelJoinTests::domain::Person[person]: Relation
  {
    ~func showcase::modelJoinTests::function::personTable():Relation<Any>[1]
    firstName: FIRSTNAME,
    lastName: LASTNAME,
    age: AGE,
    +firmId: Integer[1]: FIRMID,
    +id: Integer[1]: ID
  }
  *showcase::modelJoinTests::domain::Firm[firm]: Relation
  {
    ~func showcase::modelJoinTests::function::firmTable():Relation<Any>[1]
    legalName: LEGALNAME,
    +id: Integer[1]: ID,
    +code: String[0..1]: CODE
  }

  *showcase::modelJoinTests::domain::Person_Firm: ModelJoin
  {
    employees.firmId == firm.id
  }
)

