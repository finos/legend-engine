// =========================================================================
// Mapping 10: Nested model join where the INNER model join condition itself
//   traverses a multi-depth property path (triggering another model join).
//
//   Outer: employees.address.city == firm.headquarters.city
//   Inner Person_Address: person.profile.rank == address.country && person.id == address.personId
//   Innermost Person_Profile: person_prof.id == profile.personId
//
//   This creates 3 levels of model join nesting:
//     Firm→Person (outer) → Person→Address (middle, condition uses person.profile.rank)
//       → Person→Profile (innermost, triggered by person.profile in middle condition)
// =========================================================================
Mapping showcase::modelJoinTests::mapping::NestedModelJoinWithPropertyAccess
(
  *showcase::modelJoinTests::domain::Person[person]: Relation
  {
    ~func showcase::modelJoinTests::function::personTable():Relation<Any>[1]
    firstName: FIRSTNAME,
    lastName: LASTNAME,
    age: AGE,
    +id: Integer[1]: ID,
    +firmId: Integer[1]: FIRMID
  }
  *showcase::modelJoinTests::domain::Firm[firm]: Relation
  {
    ~func showcase::modelJoinTests::function::firmTable():Relation<Any>[1]
    legalName: LEGALNAME,
    +id: Integer[1]: ID
  }
  *showcase::modelJoinTests::domain::Address[address]: Relation
  {
    ~func showcase::modelJoinTests::function::addressTable():Relation<Any>[1]
    city: CITY,
    country: COUNTRY,
    +personId: Integer[1]: PERSONID,
    +id: Integer[1]: ID
  }
  *showcase::modelJoinTests::domain::Headquarters[hq]: Relation
  {
    ~func showcase::modelJoinTests::function::headquartersTable():Relation<Any>[1]
    city: CITY,
    country: COUNTRY,
    +firmId: Integer[1]: FIRMID
  }
  *showcase::modelJoinTests::domain::Profile[profile]: Relation
  {
    ~func showcase::modelJoinTests::function::profileTable():Relation<Any>[1]
    rank: RANK,
    +personId: Integer[1]: PERSONID
  }

  showcase::modelJoinTests::domain::Person_Profile: ModelJoin
  {
    person_prof.id == profile.personId
  }

  showcase::modelJoinTests::domain::Person_Address: ModelJoin
  {
    person.profile.rank == address.country && person.id == address.personId
  }

  showcase::modelJoinTests::domain::Firm_Headquarters: ModelJoin
  {
    firm_hq.id == headquarters.firmId
  }

  showcase::modelJoinTests::domain::Person_Firm: ModelJoin
  {
    employees.address.city == firm.headquarters.city
  }
)

