###Relational
Database showcase::modelJoinTests::store::Database
(
  Schema default
  (
    Table firmTable
    (
      ID INTEGER PRIMARY KEY,
      LEGALNAME VARCHAR(100),
      CITY VARCHAR(100),
      COUNTRY VARCHAR(100),
      CODE VARCHAR(50)
    )

    Table personTable
    (
      ID INTEGER PRIMARY KEY,
      FIRSTNAME VARCHAR(100),
      LASTNAME VARCHAR(100),
      FIRMID INTEGER,
      AGE INTEGER
    )

    Table addressTable
    (
      ID INTEGER PRIMARY KEY,
      PERSONID INTEGER,
      CITY VARCHAR(100),
      COUNTRY VARCHAR(100)
    )

    Table headquartersTable
    (
      ID INTEGER PRIMARY KEY,
      FIRMID INTEGER,
      CITY VARCHAR(100),
      COUNTRY VARCHAR(100)
    )

    Table departmentTable
    (
      ID INTEGER PRIMARY KEY,
      FIRMID INTEGER,
      NAME VARCHAR(100),
      CODE VARCHAR(50)
    )

    Table projectTable
    (
      ID INTEGER PRIMARY KEY,
      DEPTID INTEGER,
      NAME VARCHAR(100),
      CITY VARCHAR(100)
    )

    Table profileTable
    (
      ID INTEGER PRIMARY KEY,
      PERSONID INTEGER,
      RANK VARCHAR(50)
    )
  )

  Filter ActivePersonFilter(default.personTable.AGE > 25)
  Filter ProfileRankFilter(default.profileTable.RANK = 'US')

  Join PersonAddress(default.personTable.ID = default.addressTable.PERSONID)
  Join PersonProfile(default.personTable.ID = default.profileTable.PERSONID)
)

###Pure
Class showcase::modelJoinTests::domain::Firm
{
  legalName: String[1];
  city: String[0..1];
  country: String[0..1];
  code: String[0..1];
}

Class showcase::modelJoinTests::domain::Person
{
  firstName: String[1];
  lastName: String[1];
  age: Integer[1];
  fullName() { $this.firstName + ' ' + $this.lastName }: String[1];
}

Class showcase::modelJoinTests::domain::Address
{
  city: String[1];
  country: String[1];
}

Class showcase::modelJoinTests::domain::Headquarters
{
  city: String[1];
  country: String[1];
}

Class showcase::modelJoinTests::domain::Department
{
  name: String[1];
  code: String[0..1];
}

Class showcase::modelJoinTests::domain::Project
{
  name: String[1];
  city: String[0..1];
}

Class showcase::modelJoinTests::domain::Profile
{
  rank: String[1];
}

Association showcase::modelJoinTests::domain::Person_Firm
{
  employees: showcase::modelJoinTests::domain::Person[*];
  firm: showcase::modelJoinTests::domain::Firm[1];
}

Association showcase::modelJoinTests::domain::Person_Address
{
  person: showcase::modelJoinTests::domain::Person[1];
  address: showcase::modelJoinTests::domain::Address[0..1];
}

Association showcase::modelJoinTests::domain::Firm_Headquarters
{
  firm_hq: showcase::modelJoinTests::domain::Firm[1];
  headquarters: showcase::modelJoinTests::domain::Headquarters[0..1];
}

Association showcase::modelJoinTests::domain::Firm_Department
{
  firm_dept: showcase::modelJoinTests::domain::Firm[1];
  departments: showcase::modelJoinTests::domain::Department[*];
}

Association showcase::modelJoinTests::domain::Department_Project
{
  department: showcase::modelJoinTests::domain::Department[1];
  projects: showcase::modelJoinTests::domain::Project[*];
}

Association showcase::modelJoinTests::domain::Person_Profile
{
  person_prof: showcase::modelJoinTests::domain::Person[1];
  profile: showcase::modelJoinTests::domain::Profile[0..1];
}

// =========================================================================
// Shared query functions
// =========================================================================
function showcase::modelJoinTests::query::firmWithEmployees(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  showcase::modelJoinTests::domain::Firm.all()->project(
    ~[
       'Legal Name': x|$x.legalName,
       'Employee First Name': x|$x.employees.firstName
     ]
  )
}

function showcase::modelJoinTests::query::personWithFirm(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  showcase::modelJoinTests::domain::Person.all()->project(
    ~[
       'First Name': x|$x.firstName,
       'Firm Name': x|$x.firm.legalName
     ]
  )
}

function showcase::modelJoinTests::query::firmWithDeptProjects(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  showcase::modelJoinTests::domain::Firm.all()->project(
    ~[
       'Legal Name': x|$x.legalName,
       'Project Name': x|$x.departments.projects.name
     ]
  )
}

function showcase::modelJoinTests::query::personWithAddress(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  showcase::modelJoinTests::domain::Person.all()->project(
    ~[
       'First Name': x|$x.firstName,
       'City': x|$x.address.city
     ]
  )
}

// Sub-filter within project: firm employees filtered by address city
function showcase::modelJoinTests::query::firmWithFilteredEmployees(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  showcase::modelJoinTests::domain::Firm.all()->project(
    ~[
       'Legal Name': x|$x.legalName,
       'NYC Employee': x|$x.employees->filter(e | $e.address.city == 'NYC').firstName
     ]
  )
}

// Sub-aggregation within project: count of employees per firm (inline agg)
function showcase::modelJoinTests::query::firmWithEmployeeCount(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  showcase::modelJoinTests::domain::Firm.all()->project(
    ~[
       'Legal Name': x|$x.legalName,
       'Employee Count': x|$x.employees->count()
     ]
  )
}

// Filter + project: firms that have HQ in NYC
function showcase::modelJoinTests::query::firmsInNYC(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  showcase::modelJoinTests::domain::Firm.all()
    ->filter(f | $f.headquarters.city == 'NYC')
    ->project(~['Legal Name': x|$x.legalName])
}

