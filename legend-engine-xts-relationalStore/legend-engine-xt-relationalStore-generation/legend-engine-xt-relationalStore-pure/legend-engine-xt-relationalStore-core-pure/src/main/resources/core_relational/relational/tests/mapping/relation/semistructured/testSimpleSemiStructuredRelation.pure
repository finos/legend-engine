// -----------------------------------------------------------------------------
// #23 — Filter on enum property with nested if-else logic
// -----------------------------------------------------------------------------
function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::simple::testFilterOnEnumPropertyWithIfElseLogicEnum(conn: Connection[1]):Boolean[1]
{
  semiStructuredExecute(
    $conn,
    |Person.all()
      ->filter(x|if($x.firstName == 'John', |$x.firm.entityType, |$x.firm.entityType) == 'Organization')
      ->project(~['First Name': x|$x.firstName]),
    'First Name\n' +
    'Peter\n' +
    'John\n' +
    'John\n' +
    'Anthony\n'
  );
}

// -----------------------------------------------------------------------------
// #24 — GroupBy on enum property (firm.entityType as group key)
// -----------------------------------------------------------------------------
function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::simple::testGroupByOnEnumProperty(conn: Connection[1]):Boolean[1]
{
  semiStructuredExecute(
    $conn,
    |Person.all()->groupBy(
       [x|$x.firm.entityType],
       [agg(x|$x.firstName, y|$y->joinStrings(';'))],
       ['Address', 'Names']
     ),
    'Address,Names\n' +
    ',Fabrice\n' +
    'Company,Oliver;David\n' +
    'Organization,Peter;John;John;Anthony\n'
  );
}

// -----------------------------------------------------------------------------
// #25 — SortBy on enum property (firm.entityType as sort key)
// Source marks `<<paramTest.Test>>` on relationFunctionMapping path
// ("TODO: fix currentTreeNode handling in Pure2Sql"); same path as #11.
// -----------------------------------------------------------------------------
function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::simple::testSortByOnEnumProperty(conn: Connection[1]):Boolean[1]
{
  semiStructuredExecute(
    $conn,
    |Person.all()
      ->sortBy(#/Person/firm/entityType!entityType#)
      ->project(~['First Name': x|$x.firstName]),
    'First Name\n' +
    'Fabrice\n' +
    'Oliver\n' +
    'David\n' +
    'Peter\n' +
    'John\n' +
    'John\n' +
    'Anthony\n'
  );
}

