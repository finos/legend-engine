}

Class meta::relational::tests::mapping::relation::semistructured::misc::composition::Alias
{
  name: String[1];
}

Class meta::relational::tests::mapping::relation::semistructured::misc::composition::Entity
{
  id     : Integer[1];
  name   : String[0..1];
  aliases: meta::relational::tests::mapping::relation::semistructured::misc::composition::Alias[*];
  displayName()
  {
    if($this.aliases.name->isNotEmpty(),
      |$this.aliases.name->first(),
      |$this.name
    )->first()
  }: String[0..1];
}

Class meta::relational::tests::mapping::relation::semistructured::misc::composition::Trade
{
  id             : Integer[1];
  uniqueRef      : String[0..1];
  instanceContent: meta::relational::tests::mapping::relation::semistructured::misc::composition::InstanceContent[0..1];
  tradeContent   : meta::relational::tests::mapping::relation::semistructured::misc::composition::TradeContent[0..1];
}

Association meta::relational::tests::mapping::relation::semistructured::misc::composition::Trade_Entity
{
  trades:  meta::relational::tests::mapping::relation::semistructured::misc::composition::Trade[*];
  entity: meta::relational::tests::mapping::relation::semistructured::misc::composition::Entity[1];
}

Association meta::relational::tests::mapping::relation::semistructured::misc::composition::Entity_Alias
{
  entity_for_alias: meta::relational::tests::mapping::relation::semistructured::misc::composition::Entity[0..1];
  aliasesAssoc    : meta::relational::tests::mapping::relation::semistructured::misc::composition::Alias[*];
}

function meta::relational::tests::mapping::relation::semistructured::misc::composition::tradeFunction(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::relation::semistructured::misc::composition::DB.S.TRADE}#
    ->select(~[ID, UNIQUE_REF, ENTITY_ID, TRADE_CONTENT])
}

function meta::relational::tests::mapping::relation::semistructured::misc::composition::entityFunction(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::relation::semistructured::misc::composition::DB.S.ENTITY}#
    ->select(~[ID, NAME])
}


// =============================================================================
// Mappings
// =============================================================================
###Mapping
import meta::pure::functions::variant::convert::*;
import meta::pure::functions::variant::navigation::*;
import meta::pure::metamodel::variant::*;

// -----------------------------------------------------------------------------
// multibinding — single lift mapping covering Person, Employee and
// EmployeeWithManager. The source's two mappings (`mapping::H2Mapping` +
// `relationFunctionMapping::H2Mapping`) collapse into one. The cross-table
// `manager` join becomes a self-ModelJoin on PERSON_TABLE.
// -----------------------------------------------------------------------------
Mapping meta::relational::tests::mapping::relation::semistructured::misc::multibinding::MultiBindingSemiStructuredMapping
(
  *meta::relational::tests::mapping::relation::semistructured::misc::multibinding::Person[person]: Relation
  {
    ~func meta::relational::tests::mapping::relation::semistructured::misc::multibinding::personFunction():Relation<Any>[1]
    firstName: FIRSTNAME,
    lastName : LASTNAME,
    address  : $src.ADDRESS_DETAILS->to(@meta::relational::tests::mapping::relation::semistructured::misc::multibinding::Address)->toOne()
  }

  *meta::relational::tests::mapping::relation::semistructured::misc::multibinding::Employee[employee]: Relation
  {
    ~func meta::relational::tests::mapping::relation::semistructured::misc::multibinding::personFunction():Relation<Any>[1]
    firstName: FIRSTNAME,
    lastName : LASTNAME,
    firm     : $src.FIRM_DETAILS->to(@meta::relational::tests::mapping::relation::semistructured::misc::multibinding::Firm)->toOne(),
    address  : $src.ADDRESS_DETAILS->to(@meta::relational::tests::mapping::relation::semistructured::misc::multibinding::Address)->toOne()
  }

  *meta::relational::tests::mapping::relation::semistructured::misc::multibinding::EmployeeWithManager[employeeWithManager]: Relation
  {
    ~func meta::relational::tests::mapping::relation::semistructured::misc::multibinding::personFunction():Relation<Any>[1]
    firstName: FIRSTNAME,
    lastName : LASTNAME,
    firm     : $src.FIRM_DETAILS->to(@meta::relational::tests::mapping::relation::semistructured::misc::multibinding::Firm)->toOne(),
    address  : $src.ADDRESS_DETAILS->to(@meta::relational::tests::mapping::relation::semistructured::misc::multibinding::Address)->toOne(),
    +id       : Integer[1]   : ID,
    +managerId: Integer[0..1]: MANAGERID
  }

  *meta::relational::tests::mapping::relation::semistructured::misc::multibinding::EmployeeWithManager_Manager: ModelJoin
  {
    {manager: meta::relational::tests::mapping::relation::semistructured::misc::multibinding::EmployeeWithManager[1], reports: meta::relational::tests::mapping::relation::semistructured::misc::multibinding::EmployeeWithManager[1]
      | $reports.managerId == $manager.id}
  }
)


// -----------------------------------------------------------------------------
// parsejson — single lift mapping. The source's binding mapping uses
// `parseJson(VARCHAR_COL)` to coerce the column into JSON before binding. The
// closest lift form is `$src.FIRM_DETAILS->parseJson()->to(@Firm)`. Router
// support for parseJson-wrapped variant lifts is unverified — the one test in
// this group is marked Ignore (see test block).
// -----------------------------------------------------------------------------
Mapping meta::relational::tests::mapping::relation::semistructured::misc::parsejson::ParseJsonSemiStructuredMapping
(
  *meta::relational::tests::mapping::relation::semistructured::misc::parsejson::Person[person]: Relation
  {
    ~func meta::relational::tests::mapping::relation::semistructured::misc::parsejson::personFunction():Relation<Any>[1]
    firstName: FIRSTNAME,
    lastName : LASTNAME,
    firm     : $src.FIRM_DETAILS->cast(@String)->toOne()->fromJson()->to(@meta::relational::tests::mapping::relation::semistructured::misc::parsejson::Firm),
    +id       : Integer[1]   : ID,
    +managerId: Integer[0..1]: MANAGERID
  }

  *meta::relational::tests::mapping::relation::semistructured::misc::parsejson::Person_Manager: ModelJoin
  {
    {manager: meta::relational::tests::mapping::relation::semistructured::misc::parsejson::Person[1], reports: meta::relational::tests::mapping::relation::semistructured::misc::parsejson::Person[1]
      | $reports.managerId == $manager.id}
  }
)


// -----------------------------------------------------------------------------
// extractjoin — single lift mapping. The source's DB-level Joins use
// `extractFromSemiStructured` and `explodeSemiStructured` to bridge cross-table
// references through SS payloads. There is no equivalent RFPM lift form — both
// tests in this group are marked Ignore. The mapping is included so the file
// compiles and the model is reachable for future router work.
// -----------------------------------------------------------------------------
Mapping meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::ExtractJoinSemiStructuredMapping
(
  *meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::Person[person]: Relation
  {
    ~func meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::personFunction():Relation<Any>[1]
    firstName: FIRSTNAME,
    lastName : LASTNAME,
    firm     : $src.FIRM->to(@meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::Firm)->toOne()
  }
)


// -----------------------------------------------------------------------------
// composition — single lift mapping with TWO root entries (Trade, Entity)
// joined through a ModelJoin. The source's binding-via-Join into the
// EXTENSION_TABLE for `uniqueRef`/`instanceContent` has no clean RFPM lift
// equivalent (cross-table SS composition); both tests in this group are
// marked Ignore.
// -----------------------------------------------------------------------------
Mapping meta::relational::tests::mapping::relation::semistructured::misc::composition::CompositionSemiStructuredMapping
(
  *meta::relational::tests::mapping::relation::semistructured::misc::composition::Trade[trade]: Relation
  {
    ~func meta::relational::tests::mapping::relation::semistructured::misc::composition::tradeFunction():Relation<Any>[1]
    id          : ID,
    uniqueRef   : UNIQUE_REF,
    tradeContent: $src.TRADE_CONTENT->to(@meta::relational::tests::mapping::relation::semistructured::misc::composition::TradeContent),
    +entityId    : Integer[0..1]: ENTITY_ID
  }

  *meta::relational::tests::mapping::relation::semistructured::misc::composition::Entity[entity]: Relation
  {
    ~func meta::relational::tests::mapping::relation::semistructured::misc::composition::entityFunction():Relation<Any>[1]
    id  : ID,
    name: NAME
  }

  *meta::relational::tests::mapping::relation::semistructured::misc::composition::Trade_Entity: ModelJoin
  {
    {entity: meta::relational::tests::mapping::relation::semistructured::misc::composition::Entity[1], trades: meta::relational::tests::mapping::relation::semistructured::misc::composition::Trade[1]
      | $trades.entityId == $entity.id}
  }
)


