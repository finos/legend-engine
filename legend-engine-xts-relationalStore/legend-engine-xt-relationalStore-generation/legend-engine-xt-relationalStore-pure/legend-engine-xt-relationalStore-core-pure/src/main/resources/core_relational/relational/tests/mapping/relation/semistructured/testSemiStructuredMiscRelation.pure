// Source root-only test — no rfpm variant. Single Binding (AddressBinding) → lift on ADDRESS_DETAILS.
function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::misc::multibinding::testSemiStructuredPropertyAccessFromSingleBindingMapping(conn: Connection[1]):Boolean[1]
{
  meta::relational::tests::mapping::relation::semistructured::misc::multibinding::multibindingExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::misc::multibinding::Person.all()->project(~[
      'First Name'  : x|$x.firstName,
      'Address Name': x|$x.address.name
    ]),
    'First Name,Address Name\n' +
    'Peter,A4\n' +
    'John,A5\n' +
    'John,A6\n' +
    'Anthony,A7\n' +
    'Fabrice,A8\n' +
    'Oliver,A9\n' +
    'David,A10\n'
  );
}

