// -----------------------------------------------------------------------------
// extractjoin domain — Person + Firm + Location across 3 tables, where the
// source's Joins use extractSemiStructured/explodeSemiStructured. Cross-table
// SS-extract joins have no clean RFPM lift equivalent (no test runs by
// default — see Ignore comments below).
// -----------------------------------------------------------------------------
Class meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::Firm
{
  ID        : Integer[1];
  legalName : String[1];
  otherNames: String[1];
}

Class meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::LocationIdentifier
{
  length: Integer[1];
  name  : String[1];
}

Class meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::Location
{
  identifier: meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::LocationIdentifier[*];
}

Class meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::Person
{
  firstName: String[1];
  lastName : String[1];
  firm     : meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::Firm[1];
  location : meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::Location[1];
  countryCode() {$this.location.identifier->filter(i|$i.length == 2)->first().name}: String[0..1];
}

function meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::personFunction(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::H2DB.PERSON_SCHEMA.PERSON_TABLE}#
    ->select(~[ID, FIRSTNAME, LASTNAME, FIRM])
}

