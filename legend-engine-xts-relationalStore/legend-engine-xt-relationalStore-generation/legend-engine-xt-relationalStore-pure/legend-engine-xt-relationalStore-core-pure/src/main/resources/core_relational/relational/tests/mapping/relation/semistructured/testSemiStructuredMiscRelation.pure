  managerFirm()             {$this.manager.firm}                              : meta::relational::tests::mapping::relation::semistructured::misc::parsejson::Firm[0..1];
  managerManagerFirm()      {$this.manager.manager.firm}                      : meta::relational::tests::mapping::relation::semistructured::misc::parsejson::Firm[0..1];
  managerManagerFirmDup1()  {$this.manager.manager.firm}                      : meta::relational::tests::mapping::relation::semistructured::misc::parsejson::Firm[0..1];
  managerManagerFirmDup2()  {$this.manager.manager.firm}                      : meta::relational::tests::mapping::relation::semistructured::misc::parsejson::Firm[0..1];
