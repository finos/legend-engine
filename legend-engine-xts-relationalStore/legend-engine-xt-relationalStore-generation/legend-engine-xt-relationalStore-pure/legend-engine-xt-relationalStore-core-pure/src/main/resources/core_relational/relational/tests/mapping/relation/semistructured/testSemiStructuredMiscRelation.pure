// =============================================================================
// ====== parsejson ======
// =============================================================================
function <<access.private>> meta::relational::tests::mapping::relation::semistructured::misc::parsejson::parsejsonCsv(): String[1]
{
  'PERSON_SCHEMA\n' +
  'PERSON_TABLE_VARCHAR\n' +
  'ID, FIRSTNAME, LASTNAME, FIRM_DETAILS, MANAGERID\n' +
  '1,Peter,Smith,"{""legalName"": ""Firm X"", ""address"": {""name"": ""A1"", ""lines"": [{""lineno"": 1, ""street"": ""s1""}, {""lineno"": 2, ""city"": ""c1""}, {""lineno"": 3, ""state"": ""s1""}]}}",2\n' +
  '2,John,Johnson,"{""legalName"": ""Firm X"", ""address"": {""name"": ""A1"", ""lines"": [{""lineno"": 1, ""street"": ""s1""}, {""lineno"": 2, ""city"": ""c1""}, {""lineno"": 3, ""state"": ""s1""}]}}",4\n' +
  '3,John,Hill,"{""legalName"": ""Firm X"", ""address"": {""name"": ""A1"", ""lines"": [{""lineno"": 1, ""street"": ""s1""}, {""lineno"": 2, ""city"": ""c1""}, {""lineno"": 3, ""state"": ""s1""}]}}",2\n' +
  '4,Anthony,Allen,"{""legalName"": ""Firm X"", ""address"": {""name"": ""A1"", ""lines"": [{""lineno"": 1, ""street"": ""s1""}, {""lineno"": 2, ""city"": ""c1""}, {""lineno"": 3, ""state"": ""s1""}]}}",null\n' +
  '5,Fabrice,Roberts,"{""legalName"": ""Firm A"", ""address"": {""name"": ""A2"", ""lines"": [{""lineno"": 1, ""street"": ""s2""}, {""lineno"": 2, ""city"": ""c2""}]}}",null\n' +
  '6,Oliver,Hill,"{""legalName"": ""Firm B"", ""address"": {""name"": ""A3"", ""lines"": [{""lineno"": 1, ""street"": ""s3""}]}}",7\n' +
  '7,David,Harris,"{""legalName"": ""Firm B"", ""address"": {""name"": ""A3"", ""lines"": [{""lineno"": 1, ""street"": ""s3""}]}}",null\n' +
  '8,UNKNOWN,UNKNOWN,,\n'
}

function <<access.private>> meta::relational::tests::mapping::relation::semistructured::misc::parsejson::parsejsonExecute(conn: Connection[1], func: FunctionDefinition<Any>[1], expected: String[1]):Boolean[1]
{
  executeLegendFunction($func, meta::relational::tests::mapping::relation::semistructured::misc::parsejson::ParseJsonSemiStructuredMapping, meta::relational::tests::mapping::relation::semistructured::misc::parsejson::SnowflakeDB, $conn, [meta::relational::tests::mapping::relation::semistructured::misc::parsejson::parsejsonCsv()], $expected, false);
}

// Ignored: combines parseJson()-wrapped variant lift over a VARCHAR column with multi-hop
// self-ModelJoin chains (manager.manager.firm) — both patterns currently unsupported in the
// lift router (per playbook R-9: "Multi-hop self-ModelJoin chains" + parseJson lift form unverified).
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::misc::parsejson::testParseJsonInMapping(conn: Connection[1]):Boolean[1]
{
  meta::relational::tests::mapping::relation::semistructured::misc::parsejson::parsejsonExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::misc::parsejson::Person.all()->project(~[
      'First Name'                          : x|$x.firstName,
      'Firm Name'                           : x|$x.firm.legalName,
      'Manager Firm Legal Name'             : x|$x.managerFirm.legalName,
      'Manager Manager Firm Legal Name'     : x|$x.managerManagerFirm.legalName,
      'Manager Manager Firm Legal Name Dup1': x|$x.managerManagerFirmDup1.legalName,
      'Manager Manager Firm Legal Name Dup2': x|$x.managerManagerFirmDup2.legalName
    ]),
    'First Name,Firm Name,Manager Firm Legal Name,Manager Manager Firm Legal Name,Manager Manager Firm Legal Name Dup1,Manager Manager Firm Legal Name Dup2\n' +
    'Peter,Firm X,Firm X,Firm X,Firm X,Firm X\n' +
    'John,Firm X,Firm X,,,\n' +
    'John,Firm X,Firm X,Firm X,Firm X,Firm X\n' +
    'Anthony,Firm X,,,,\n' +
    'Fabrice,Firm A,,,,\n' +
    'Oliver,Firm B,Firm B,,,\n' +
    'David,Firm B,,,,\n' +
    'UNKNOWN,,,,,\n'
  );
}


