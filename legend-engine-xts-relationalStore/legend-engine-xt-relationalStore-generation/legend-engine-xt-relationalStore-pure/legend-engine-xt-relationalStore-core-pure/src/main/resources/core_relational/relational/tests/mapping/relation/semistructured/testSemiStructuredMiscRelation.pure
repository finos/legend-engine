// =============================================================================
// Translation of four unrelated semi-structured sources into the RFPM
// variant-lift form. Each source's model/mapping lives in its own sub-package
// to avoid name collisions; tests/CSV/execute helpers are kept per-source.
//
//   testSemiStructuredMultiBindingMapping
//     -> meta::relational::tests::mapping::relation::semistructured::misc::multibinding::*
//        MultiBindingSemiStructuredMapping (1 mapping; Person/Employee/EmployeeWithManager
//        over PERSON_TABLE with FIRM_DETAILS + ADDRESS_DETAILS SS cols).
//
//   testSemiStructuredParseJsonMapping
//     -> meta::relational::tests::mapping::relation::semistructured::misc::parsejson::*
//        ParseJsonSemiStructuredMapping (1 mapping; Person with self-ref manager
//        chain over VARCHAR FIRM_DETAILS — uses parseJson()).
//
//   testExtractFromSemiStructuredJoin
//     -> meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::*
//        ExtractJoinSemiStructuredMapping (1 mapping; Person+Firm+Location across
//        3 tables with explode/extract in source's DB-level Joins).
//
//   testSemiStructuredCompositionMapping
//     -> meta::relational::tests::mapping::relation::semistructured::misc::composition::*
//        CompositionSemiStructuredMapping (1 mapping containing Trade + Entity
//        root mappings; SS composition on two different tables).
//
// 13 total tests (4 + 1 + 2 + 2 mirrored from sources + 4 multibinding tests).
// =============================================================================


// =============================================================================
// === multibinding === Database
// =============================================================================
###Relational
Database meta::relational::tests::mapping::relation::semistructured::misc::multibinding::H2DB
(
  Schema PERSON_SCHEMA
  (
    Table PERSON_TABLE
    (
      ID INTEGER PRIMARY KEY,
      FIRSTNAME VARCHAR(100) NOT NULL,
      LASTNAME VARCHAR(100) NOT NULL,
      FIRM_DETAILS SEMISTRUCTURED,
      ADDRESS_DETAILS SEMISTRUCTURED,
      MANAGERID INTEGER
    )
  )
)


// =============================================================================
// === parsejson === Database
// =============================================================================
###Relational
Database meta::relational::tests::mapping::relation::semistructured::misc::parsejson::SnowflakeDB
(
  Schema PERSON_SCHEMA
  (
    Table PERSON_TABLE_VARCHAR
    (
      ID INTEGER PRIMARY KEY,
      FIRSTNAME VARCHAR(100) NOT NULL,
      LASTNAME VARCHAR(100) NOT NULL,
      FIRM_DETAILS VARCHAR(1000),
      MANAGERID INTEGER
    )
  )
)


// =============================================================================
// === extractjoin === Database
// =============================================================================
###Relational
Database meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::H2DB
(
  Schema PERSON_SCHEMA
  (
    Table PERSON_TABLE
    (
      ID INTEGER PRIMARY KEY,
      FIRSTNAME VARCHAR(100) NOT NULL,
      LASTNAME VARCHAR(100) NOT NULL,
      FIRM SEMISTRUCTURED
    )
  )
  Schema FIRM_SCHEMA
  (
    Table FIRM_TABLE
    (
      FIRM_DETAILS SEMISTRUCTURED PRIMARY KEY
    )
  )
  Schema LOCATION_SCHEMA
  (
    Table LOCATION_TABLE
    (
      ID INTEGER PRIMARY KEY,
      LOCATION_DETAILS SEMISTRUCTURED NOT NULL
    )
  )
)


// =============================================================================
// === composition === Database
// =============================================================================
###Relational
Database meta::relational::tests::mapping::relation::semistructured::misc::composition::DB
(
  Schema S
  (
    Table TRADE
    (
      ID INTEGER PRIMARY KEY,
      UNIQUE_REF VARCHAR(36),
      ENTITY_ID INTEGER,
      TRADE_CONTENT SEMISTRUCTURED
    )
    Table ENTITY
    (
      ID INTEGER PRIMARY KEY,
      NAME VARCHAR(50)
    )
    Table ENTITY_ALIAS
    (
      ENTITY_ID INTEGER,
      ALIAS_NAME VARCHAR(50)
    )
    Table EXTENSION_TABLE
    (
      UNIQUE_REF VARCHAR(36) PRIMARY KEY,
      INSTANCE_CONTENT SEMISTRUCTURED
    )
  )
)


