{
  name  : String[1];
  lines : meta::relational::tests::mapping::relation::semistructured::misc::multibinding::AddressLine[*];
  street: String[0..1];
}

Class meta::relational::tests::mapping::relation::semistructured::misc::multibinding::Firm
{
  legalName    : String[1];
  address      : meta::relational::tests::mapping::relation::semistructured::misc::multibinding::Address[1];
  employeeCount: Integer[1];
  mnc          : Boolean[1];
  estDate      : StrictDate[1];
  lastUpdate   : DateTime[1];
  otherNames   : String[*];
  entityType   : meta::relational::tests::mapping::relation::semistructured::misc::multibinding::EntityType[1];
}

Class meta::relational::tests::mapping::relation::semistructured::misc::multibinding::Person
{
  firstName: String[1];
  lastName : String[1];
  address  : meta::relational::tests::mapping::relation::semistructured::misc::multibinding::Address[1];
}

Class meta::relational::tests::mapping::relation::semistructured::misc::multibinding::Employee
{
  firstName: String[1];
  lastName : String[1];
  firm     : meta::relational::tests::mapping::relation::semistructured::misc::multibinding::Firm[1];
  address  : meta::relational::tests::mapping::relation::semistructured::misc::multibinding::Address[1];
}

Class meta::relational::tests::mapping::relation::semistructured::misc::multibinding::EmployeeWithManager extends meta::relational::tests::mapping::relation::semistructured::misc::multibinding::Employee
{
  // managerFirm is a derived property (replaces source's binding-via-Join property) so the test
  // can navigate manager.firm without an additional binding-level mapping.
  managerFirm() {$this.manager.firm}: meta::relational::tests::mapping::relation::semistructured::misc::multibinding::Firm[0..1];
}

Association meta::relational::tests::mapping::relation::semistructured::misc::multibinding::EmployeeWithManager_Manager
{
  manager: meta::relational::tests::mapping::relation::semistructured::misc::multibinding::EmployeeWithManager[0..1];
  reports: meta::relational::tests::mapping::relation::semistructured::misc::multibinding::EmployeeWithManager[*];
}

function meta::relational::tests::mapping::relation::semistructured::misc::multibinding::personFunction(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::relation::semistructured::misc::multibinding::H2DB.PERSON_SCHEMA.PERSON_TABLE}#
    ->select(~[ID, FIRSTNAME, LASTNAME, FIRM_DETAILS, ADDRESS_DETAILS, MANAGERID])
}

