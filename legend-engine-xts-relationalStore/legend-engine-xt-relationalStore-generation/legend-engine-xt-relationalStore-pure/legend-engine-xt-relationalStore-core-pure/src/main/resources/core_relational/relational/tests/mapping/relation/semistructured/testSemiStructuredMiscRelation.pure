// Ignored: source's DB-level Join uses extractFromSemiStructured to bridge PERSON_TABLE.FIRM
// (SS) to FIRM_TABLE.FIRM_DETAILS (SS) by JSON ID — no equivalent RFPM lift form, as the lift
// router does not support SS-extract-keyed cross-table ModelJoins.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::testJoinOnSemiStructuredProperty(conn: Connection[1]):Boolean[1]
{
  meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::extractjoinExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::misc::extractjoin::Person.all()->project(~[
      'First Name'     : x|$x.firstName,
      'Last Name'      : x|$x.lastName,
      'Firm/Legal Name': x|$x.firm.legalName
    ]),
    'First Name,Last Name,Firm/Legal Name\n' +
    'Peter,Smith,Firm X\n' +
    'John,Johnson,Firm X\n' +
    'John,Hill,Firm X\n' +
    'Anthony,Allen,Firm X\n' +
    'Fabrice,Roberts,Firm A\n' +
    'Oliver,Hill,Firm B\n' +
    'David,Harris,Firm B\n'
  );
}

// Ignored: source's DB-level Join uses explodeSemiStructured(LOCATION_DETAILS, 'residents', ...)
