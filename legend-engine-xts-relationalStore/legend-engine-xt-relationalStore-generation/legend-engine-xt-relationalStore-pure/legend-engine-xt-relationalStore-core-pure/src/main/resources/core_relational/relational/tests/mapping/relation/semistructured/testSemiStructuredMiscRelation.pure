// Ignored: relies on cross-table embedded-mapping for `entity.aliases` (ENTITY → ENTITY_ALIAS),
// plus `uniqueRef` which the source resolves through @trade_extension into EXTENSION_TABLE.
// The Alias class mapping and the Trade-side `uniqueRef` cross-table resolution are not
// represented in the current lift mapping — pure-translation only; runtime triage pending.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::misc::composition::testSemiStructuredThenDerivedPrimitivePropertyAccess(conn: Connection[1]):Boolean[1]
{
  meta::relational::tests::mapping::relation::semistructured::misc::composition::compositionExecute($conn,
    |meta::relational::tests::mapping::relation::semistructured::misc::composition::Trade.all()->project(~[
      'Id'          : x|$x.id,
      'Trade Name'  : x|$x.tradeContent.tradeName,
      'Unique Ref'  : x|$x.uniqueRef,
      'Display Name': x|$x.entity.displayName()
    ]),
    'Id,Trade Name,Unique Ref,Display Name\n' +
    '1,trade1,A,Alias A1\n' +
    '2,trade2,B,Entity Two\n' +
    '3,trade3,C,Entity Three'
  );
}

// Ignored: source resolves `instanceContent` through @trade_extension into EXTENSION_TABLE
