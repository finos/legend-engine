// composition domain — Trade/Entity with two SEMISTRUCTURED columns on
// different tables (TRADE.TRADE_CONTENT and EXTENSION_TABLE.INSTANCE_CONTENT).
// -----------------------------------------------------------------------------
Class meta::relational::tests::mapping::relation::semistructured::misc::composition::RawData
{
  instanceId  : String[0..1];
  instanceName: String[0..1];
}

Class meta::relational::tests::mapping::relation::semistructured::misc::composition::InstanceContent
{
  rawData: meta::relational::tests::mapping::relation::semistructured::misc::composition::RawData[0..1];
}

Class meta::relational::tests::mapping::relation::semistructured::misc::composition::TradeContent
{
