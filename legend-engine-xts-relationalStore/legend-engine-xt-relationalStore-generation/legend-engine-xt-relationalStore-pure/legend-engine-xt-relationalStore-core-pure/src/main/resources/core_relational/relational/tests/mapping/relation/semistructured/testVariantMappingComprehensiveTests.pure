// =============================================================================
// Test 22 â€” fromJson nested navigation + computed properties (Â§2.4 + Â§2.3)
// Mapping ops: fromJson()â†’get('header')â†’get('source')â†’to(@String),
//              to(@Float) * to(@Float), to(@String) + ':' + to(@String)
