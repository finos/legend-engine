// =============================================================================
// =============================================================================
//                     toMany TESTS (Â§D â€” direct array flatten)
// =============================================================================
// =============================================================================

// =============================================================================
// Test 61 â€” toMany primitive project (Â§D)
// Mapping ops: toMany(@String) â€” direct projection flattens array to rows
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testToManyPrimitiveProject(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()
      ->filter(x | $x.firstName == 'Fabrice')
      ->project(~[
        'First Name'        : x|$x.firstName,
        'Other Names Direct': x|$x.otherNamesDirect
      ]),
    'First Name,Other Names Direct\n' +
    'Fabrice,O3\n' +
    'Fabrice,O4\n'
  );
}

function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::variant::comprehensive::testToManyPrimitiveFilterInProject(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()
      ->filter(x | $x.firstName == 'Fabrice')
      ->project(~[
        'First Name'         : x|$x.firstName,
        'Other Names Direct1': x|$x.otherNamesDirect->filter(n|$n->startsWith('O3')),
        'Other Names Direct2': x|$x.otherNamesDirect->distinct(),
        'Other Names Direct3': x|$x.otherNamesDirect->sort()
      ]),
    'First Name,Other Names Direct\n' +
    'Fabrice,O3\n' +
    'Fabrice,O4\n'
  );
}

// =============================================================================
// Test 62 â€” toMany primitive filter (Â§D)
// Query: filter on flattened array value
// =============================================================================
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::variant::comprehensive::testToManyPrimitiveFilter(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()
      ->filter(x | $x.otherNamesDirect->exists(n | $n == 'O3'))
      ->project(~[
        'First Name': x|$x.firstName
      ]),
    'First Name\n' +
    'Fabrice\n'
  );
}

