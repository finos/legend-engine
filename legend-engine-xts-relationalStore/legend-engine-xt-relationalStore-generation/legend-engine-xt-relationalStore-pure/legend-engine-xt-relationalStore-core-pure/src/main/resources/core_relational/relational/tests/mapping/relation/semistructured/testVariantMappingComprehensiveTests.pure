// =============================================================================
// Test 56 â€” Map get() via to(@Map<String,String>) (Â§B)
// Mapping ops: ->to(@Map<String,String>)->get('role'), ->get('dept')
// =============================================================================
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::variant::comprehensive::testMapGet(conn: Connection[1]):Boolean[1]
{
  mapExecute($conn,
    |MapPerson.all()->project(~[
      'Name'     : x|$x.name,
      'Tag Role' : x|$x.tagRole,
      'Tag Dept' : x|$x.tagDept
    ]),
    'Name,Tag Role,Tag Dept\n' +
    'Alice,admin,eng\n' +
    'Bob,user,sales\n' +
    'Carol,admin,ops\n'
  );
}

