    'David,O5,O6,D5\n' +
    'Fabrice,O3,O4,D4\n' +
    'John,O1,O2,D1\n' +
    'John,O1,O2,D1\n' +
    'Oliver,O5,O6,D5\n' +
    'Peter,O1,O2,D1\n'
  );
}

// =============================================================================
// Test 5 â€” Array distinct / contains / indexOf / concatenate (Â§2.20)
// Mapping ops: toManyâ†’distinct()â†’size(), toManyâ†’contains(), toManyâ†’indexOf(),
//              toManyâ†’concatenate(toMany)â†’size()
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testArrayDistinctContainsIndexOf(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()->project(~[
      'First Name'        : x|$x.firstName,
      'Firm'              : x|$x.firmName,
      'Distinct Countries': x|$x.distinctCtryCount,
      'Has UK'            : x|$x.hasUkOffice,
      'UK Index'          : x|$x.ukIndex,
      'All Names Count'   : x|$x.allNameCount
    ]),
    'First Name,Firm,Distinct Countries,Has UK,UK Index,All Names Count\n' +
    'Anthony,Firm X,3,true,1,5\n' +
    'David,Firm B,2,true,1,5\n' +
    'Fabrice,Firm A,1,false,-1,3\n' +
    'John,Firm X,3,true,1,5\n' +
    'John,Firm X,3,true,1,5\n' +
    'Oliver,Firm B,2,true,1,5\n' +
    'Peter,Firm X,3,true,1,5\n'
  );
}

// =============================================================================
// Test 6 â€” Numeric array aggregations (Â§2.17)
// Mapping ops: toMany(@Float)â†’plus() (sum), toMany(@Float)â†’max(), min()
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testNumericAggregations(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()->project(~[
      'First Name'    : x|$x.firstName,
      'Total Revenue' : x|$x.totalRevenue,
      'Max Revenue'   : x|$x.maxRevenue,
      'Min Revenue'   : x|$x.minRevenue,
      'Has Rev History': x|$x.hasRevHistory
    ]),
    'First Name,Total Revenue,Max Revenue,Min Revenue,Has Rev History\n' +
    'Anthony,350.75,200.0,50.25,true\n' +
    'David,500.0,500.0,500.0,true\n' +
    'Fabrice,0.0,,,false\n' +
    'John,350.75,200.0,50.25,true\n' +
    'John,350.75,200.0,50.25,true\n' +
    'Oliver,500.0,500.0,500.0,true\n' +
    'Peter,350.75,200.0,50.25,true\n'
  );
}

// =============================================================================
// Test 7 â€” fold / take / drop (Â§2.19)
// Mapping ops: toManyâ†’fold({r,acc|...},''), toManyâ†’take(2)â†’size(),
//              toManyâ†’drop(1)â†’size()
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testFoldTakeDrop(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()->project(~[
      'First Name'    : x|$x.firstName,
      'Ratings Folded': x|$x.ratingsFolded,
      'Top Two Count' : x|$x.topTwoRatCt,
      'Tail Count'    : x|$x.tailRatCt
    ]),
    'First Name,Ratings Folded,Top Two Count,Tail Count\n' +
    'Anthony,",A,B,A,C",2,3\n' +
    'David,",A,A,B",2,2\n' +
    'Fabrice,",B",1,0\n' +
    'John,",A,B,A,C",2,3\n' +
    'John,",A,B,A,C",2,3\n' +
    'Oliver,",A,A,B",2,2\n' +
    'Peter,",A,B,A,C",2,3\n'
  );
}

// =============================================================================
// Test 8 â€” Computed leaves: arithmetic + string assembly (Â§2.3)
// Mapping ops: to(@String) + '(' + FIRSTNAME + ')', to(@Float) * to(@Float)
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testComputedArithmetic(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()->project(~[
      'First Name'  : x|$x.firstName,
      'Display Name': x|$x.displayName,
      'FTE Equiv'   : x|$x.fteEquiv
    ]),
    'First Name,Display Name,FTE Equiv\n' +
    'Anthony,Firm X (Anthony),22222.0\n' +
    'David,Firm B (David),111.0\n' +
    'Fabrice,Firm A (Fabrice),0.5\n' +
    'John,Firm X (John),22.0\n' +
    'John,Firm X (John),222.0\n' +
    'Oliver,Firm B (Oliver),11.0\n' +
    'Peter,Firm X (Peter),2.0\n'
  );
}

// =============================================================================
// Test 9 â€” Computed leaves: conditional + boolean logic (Â§2.3)
// Mapping ops: if(isNotEmpty, |to(@String), |'N/A'), to(@Boolean) && (to(@Integer) > 2)
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testComputedConditional(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()->project(~[
      'First Name'  : x|$x.firstName,
      'Contact Name': x|$x.contactName,
      'Is Large MNC': x|$x.isLargeMnc
    ]),
    'First Name,Contact Name,Is Large MNC\n' +
    'Anthony,S1,true\n' +
    'David,N/A,false\n' +
    'Fabrice,N/A,false\n' +
    'John,S1,true\n' +
    'John,S1,true\n' +
    'Oliver,S2,false\n' +
    'Peter,S1,true\n'
  );
}

// =============================================================================
// Test 10 â€” exists() on variant array (Â§2.5)
// Mapping ops: toMany(@String)â†’exists(n| $n == 'O3')
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testExistsOnArray(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()->project(~[
      'First Name': x|$x.firstName,
      'Firm'      : x|$x.firmName,
      'Exists O3' : x|$x.existsO3
    ]),
    'First Name,Firm,Exists O3\n' +
    'Anthony,Firm X,false\n' +
    'David,Firm B,false\n' +
    'Fabrice,Firm A,true\n' +
    'John,Firm X,false\n' +
    'John,Firm X,false\n' +
    'Oliver,Firm B,false\n' +
    'Peter,Firm X,false\n'
  );
}

// =============================================================================
