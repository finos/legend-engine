// Mapping ops: toMany(@String)â†’filter(n| $nâ†’startsWith('O1'))â†’size()
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testFilterOnArrayAtMapping(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()->project(~[
