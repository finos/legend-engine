    'Fabrice,Firm A,0\n' +
    'John,Firm X,1\n' +
    'John,Firm X,1\n' +
    'Oliver,Firm B,0\n' +
    'Peter,Firm X,1\n'
  );
}

// =============================================================================
// Test 12 â€” Whole subtree deserialization (Â§2.7)
// Mapping ops: to(@Firm)â†’toOne() â€” downstream property navigation
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testWholeSubtreeDeserialize(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()->project(~[
      'First Name'        : x|$x.firstName,
      'Firm Legal Name'   : x|$x.firm.legalName,
      'Firm Address Name' : x|$x.firm.address.name,
      'Firm Employee Ct'  : x|$x.firm.employeeCount
    ]),
    'First Name,Firm Legal Name,Firm Address Name,Firm Employee Ct\n' +
    'Anthony,Firm X,A1,4\n' +
    'David,Firm B,A3,2\n' +
    'Fabrice,Firm A,A2,1\n' +
    'John,Firm X,A1,4\n' +
    'John,Firm X,A1,4\n' +
    'Oliver,Firm B,A3,2\n' +
    'Peter,Firm X,A1,4\n'
  );
}

// =============================================================================
// Test 13 â€” Filter on mapped Boolean property
// Query: filter(isMnc == true) + project
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testFilterOnBoolean(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()
      ->filter(x | $x.isMnc == true)
      ->project(~[
        'First Name': x|$x.firstName,
        'Firm'      : x|$x.firmName,
        'Revenue'   : x|$x.revenue
      ]),
    'First Name,Firm,Revenue\n' +
    'Anthony,Firm X,5555.5\n' +
    'David,Firm B,55.5\n' +
    'John,Firm X,5.5\n' +
    'John,Firm X,55.5\n' +
    'Oliver,Firm B,5.5\n' +
    'Peter,Firm X,0.5\n'
  );
}

// =============================================================================
// Test 14 â€” Filter on mapped Integer property
// Query: filter(employeeCount > 2) + project
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testFilterOnInteger(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()
      ->filter(x | $x.employeeCount > 2)
      ->project(~[
        'First Name': x|$x.firstName,
        'Firm'      : x|$x.firmName
      ]),
    'First Name,Firm\n' +
    'Anthony,Firm X\n' +
    'John,Firm X\n' +
    'John,Firm X\n' +
    'Peter,Firm X\n'
  );
}

// =============================================================================
// Test 15 â€” Filter on mapped String property
// Query: filter(firmName == 'Firm X') + project
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testFilterOnString(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()
      ->filter(x | $x.firmName == 'Firm X')
      ->project(~[
        'First Name': x|$x.firstName,
        'Last Name' : x|$x.lastName
      ]),
    'First Name,Last Name\n' +
    'Anthony,Allen\n' +
    'John,Hill\n' +
    'John,Johnson\n' +
    'Peter,Smith\n'
  );
}

// =============================================================================
// Test 16 â€” Compound filter on computed Boolean properties
// Query: filter(isLargeMnc == true && hasRevHistory == true) + project
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testFilterCompound(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()
      ->filter(x | ($x.isLargeMnc == true) && ($x.hasRevHistory == true))
      ->project(~[
        'First Name'   : x|$x.firstName,
        'Total Revenue': x|$x.totalRevenue
      ]),
    'First Name,Total Revenue\n' +
    'Anthony,350.75\n' +
    'John,350.75\n' +
    'John,350.75\n' +
    'Peter,350.75\n'
  );
}

// =============================================================================
// Test 17 â€” Filter on mapping-level contains() result
// Query: filter(hasUkOffice == true) + project multiple cols
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testFilterOnContains(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()
      ->filter(x | $x.hasUkOffice == true)
      ->project(~[
        'First Name'        : x|$x.firstName,
        'Firm'              : x|$x.firmName,
        'Distinct Countries': x|$x.distinctCtryCount,
        'UK Index'          : x|$x.ukIndex
      ]),
    'First Name,Firm,Distinct Countries,UK Index\n' +
    'Anthony,Firm X,3,1\n' +
    'David,Firm B,2,1\n' +
    'John,Firm X,3,1\n' +
    'John,Firm X,3,1\n' +
    'Oliver,Firm B,2,1\n' +
    'Peter,Firm X,3,1\n'
  );
}

// =============================================================================
// Test 18 â€” GroupBy on mapped String property with aggregations
// Query: groupBy([firmName], [agg sum revenue, agg count])
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testGroupByFirmName(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()->groupBy(
      [x|$x.firmName],
      [agg(x|$x.revenue, y|$y->sum()), agg(x|$x.firstName, y|$y->count())],
      ['Firm', 'Total Revenue', 'Count']
    ),
    'Firm,Total Revenue,Count\n' +
    'Firm A,0.5,1\n' +
    'Firm B,61.0,2\n' +
    'Firm X,5617.0,4\n'
  );
}

// =============================================================================
// Test 19 â€” GroupBy on mapped entity type (enum-string Â§2.2)
// Query: groupBy([entityType], [agg count])
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testGroupByEntityType(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()->groupBy(
      [x|$x.entityType],
      [agg(x|$x.firstName, y|$y->count())],
      ['Entity Type', 'Count']
    ),
    'Entity Type,Count\n' +
    ',1\n' +
    'Company,2\n' +
    'Organization,4\n'
  );
}

// =============================================================================
// Test 20 â€” Filter then multi-column project
// Query: filter(hasRevHistory==true) + project 5 mapped properties
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testFilterThenProjectMany(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()
      ->filter(x | $x.hasRevHistory == true)
      ->project(~[
        'First Name'    : x|$x.firstName,
        'Total Revenue' : x|$x.totalRevenue,
        'Max Revenue'   : x|$x.maxRevenue,
        'Min Revenue'   : x|$x.minRevenue,
        'Ratings Folded': x|$x.ratingsFolded
      ]),
    'First Name,Total Revenue,Max Revenue,Min Revenue,Ratings Folded\n' +
    'Anthony,350.75,200.0,50.25,",A,B,A,C"\n' +
    'David,500.0,500.0,500.0,",A,A,B"\n' +
    'John,350.75,200.0,50.25,",A,B,A,C"\n' +
    'John,350.75,200.0,50.25,",A,B,A,C"\n' +
    'Oliver,500.0,500.0,500.0,",A,A,B"\n' +
    'Peter,350.75,200.0,50.25,",A,B,A,C"\n'
  );
}

// =============================================================================
// Test 35 â€” Cross-feature mix: filter on mapping-level ops + project aggregates
// Query: filter(filteredNameCt > 0 && totalRevenue > 100) + project 4 cols
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testCrossFeatureMix1(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()
      ->filter(x | ($x.filteredNameCt > 0) && ($x.totalRevenue > 100.0))
      ->project(~[
        'First Name'        : x|$x.firstName,
        'Total Revenue'     : x|$x.totalRevenue,
        'Distinct Countries': x|$x.distinctCtryCount,
        'Ratings Folded'    : x|$x.ratingsFolded
      ]),
    'First Name,Total Revenue,Distinct Countries,Ratings Folded\n' +
    'Anthony,350.75,3,",A,B,A,C"\n' +
    'John,350.75,3,",A,B,A,C"\n' +
    'John,350.75,3,",A,B,A,C"\n' +
    'Peter,350.75,3,",A,B,A,C"\n'
  );
}

// =============================================================================
// Test 36 â€” Cross-feature mix: filter on mapping filter+size result
// Query: filter(filteredNameCt > 0) + project 4 mixed cols
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testCrossFeatureMix2(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()
      ->filter(x | $x.filteredNameCt > 0)
      ->project(~[
        'First Name'      : x|$x.firstName,
        'Firm'            : x|$x.firmName,
        'First Other Name': x|$x.firstOtherName,
        'Address Name'    : x|$x.addressName
      ]),
    'First Name,Firm,First Other Name,Address Name\n' +
    'Anthony,Firm X,O1,A1\n' +
    'John,Firm X,O1,A1\n' +
    'John,Firm X,O1,A1\n' +
    'Peter,Firm X,O1,A1\n'
  );
}

// =============================================================================
// Test 38 â€” GroupBy with multiple aggregation functions
// Query: groupBy([entityType], [sum totalRevenue, max revenue, count])
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testGroupByMultipleAggs(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()->groupBy(
      [x|$x.entityType],
      [agg(x|$x.totalRevenue, y|$y->sum()), agg(x|$x.revenue, y|$y->max()), agg(x|$x.firstName, y|$y->count())],
      ['Entity Type', 'Sum Total Revenue', 'Max Revenue', 'Count']
    ),
    'Entity Type,Sum Total Revenue,Max Revenue,Count\n' +
    ',0.0,0.5,1\n' +
    'Company,1000.0,55.5,2\n' +
    'Organization,1403.0,5555.5,4\n'
  );
}

// =============================================================================
// Test 39 â€” SortBy on mapped variant-extracted property
// Query: sortBy(firmName) + project â€” sortCsv normalizes so just tests compilation
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testSortByMappedProp(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()
      ->sortBy(#/Person/firmName!firmName#)
      ->project(~[
        'First Name': x|$x.firstName,
        'Firm'      : x|$x.firmName
      ]),
    'First Name,Firm\n' +
    'Anthony,Firm X\n' +
    'David,Firm B\n' +
    'Fabrice,Firm A\n' +
    'John,Firm X\n' +
    'John,Firm X\n' +
    'Oliver,Firm B\n' +
    'Peter,Firm X\n'
  );
}

// =============================================================================
// Test 40 â€” distinct() on projected TDS
// Query: project(firmName, entityType) â†’ distinct()
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testDistinctOnProjection(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()
      ->project(~[
        'Firm'       : x|$x.firmName,
        'Entity Type': x|$x.entityType
      ])
      ->distinct(),
    'Firm,Entity Type\n' +
    'Firm A,\n' +
    'Firm B,Company\n' +
    'Firm X,Organization\n'
  );
}

// =============================================================================
// Test 41 â€” Filter + project + limit (pagination)
// Query: filter(firmName == 'Firm B') + project + limit(5)
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testLimitAfterFilter(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()
      ->filter(x | $x.firmName == 'Firm B')
      ->project(~[
        'First Name': x|$x.firstName,
        'Firm'      : x|$x.firmName,
        'Revenue'   : x|$x.revenue
      ])
      ->limit(5),
    'First Name,Firm,Revenue\n' +
    'David,Firm B,55.5\n' +
    'Oliver,Firm B,5.5\n'
  );
}

// =============================================================================
// Test 42 â€” Inline computation in projection lambda (if/else)
// Query: project with if(revenue > 10.0, 'HIGH', 'LOW')
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testInlineComputationInProject(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()->project(~[
      'First Name'      : x|$x.firstName,
      'Revenue Category': x|if($x.revenue > 10.0, |'HIGH', |'LOW')
    ]),
    'First Name,Revenue Category\n' +
    'Anthony,HIGH\n' +
    'David,HIGH\n' +
    'Fabrice,LOW\n' +
    'John,LOW\n' +
    'John,HIGH\n' +
    'Oliver,LOW\n' +
    'Peter,LOW\n'
  );
}

// =============================================================================
// Test 43 â€” Sub-expression (if/isEmpty) in projection on mapped optional prop
// Query: project with if(addressStreetâ†’isEmpty, 'none', addressStreet)
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testSubExprInProject(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()->project(~[
