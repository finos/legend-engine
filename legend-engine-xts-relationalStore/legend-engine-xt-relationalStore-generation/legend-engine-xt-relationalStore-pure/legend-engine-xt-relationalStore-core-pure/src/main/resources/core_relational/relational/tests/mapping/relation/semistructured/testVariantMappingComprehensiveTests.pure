function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testFromJsonGroupBy(conn: Connection[1]):Boolean[1]
{
  orderExecute($conn,
    |Order.all()->groupBy(
      [x|$x.side],
