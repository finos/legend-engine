###Pure
import meta::pure::test::*;
import meta::core::runtime::*;
import meta::relational::metamodel::execute::tests::*;
import meta::relational::tests::mapping::relation::variant::comprehensive::*;

// =============================================================================
// Test 1 â€” All primitive type extraction (Â§2.1)
// Mapping ops: getâ†’to(@String), getâ†’to(@Integer), getâ†’to(@Float),
//              getâ†’to(@Boolean), getâ†’to(@StrictDate), getâ†’to(@DateTime)
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testAllPrimitiveTypes(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()->project(~[
      'First Name'    : x|$x.firstName,
      'Firm Name'     : x|$x.firmName,
      'Employee Count': x|$x.employeeCount,
      'Revenue'       : x|$x.revenue,
      'Is MNC'        : x|$x.isMnc,
      'Est Date'      : x|$x.estDate,
      'Last Update'   : x|$x.lastUpdate
    ]),
    'First Name,Firm Name,Employee Count,Revenue,Is MNC,Est Date,Last Update\n' +
    'Anthony,Firm X,4,5555.5,true,2010-03-04,2022-01-16 01:00:00.0\n' +
    'David,Firm B,2,55.5,true,2017-07-07,2022-09-01 06:00:00.0\n' +
    'Fabrice,Firm A,1,0.5,false,2012-11-13,2022-02-14 03:00:00.0\n' +
    'John,Firm X,4,5.5,true,2010-03-04,2022-01-16 01:00:00.0\n' +
    'John,Firm X,4,55.5,true,2010-03-04,2022-01-16 01:00:00.0\n' +
    'Oliver,Firm B,2,5.5,true,2017-07-07,2022-09-01 06:00:00.0\n' +
    'Peter,Firm X,4,0.5,true,2010-03-04,2022-01-16 01:00:00.0\n'
  );
}

// =============================================================================
// Test 2 â€” Nested object navigation (Â§2.9)
// Mapping ops: get('address')â†’get('name')â†’to, getâ†’getâ†’at(N)â†’getâ†’to
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testNestedObjectNavigation(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()->project(~[
      'First Name'      : x|$x.firstName,
      'Address Name'    : x|$x.addressName,
      'Address Street'  : x|$x.addressStreet,
      'First Addr Line' : x|$x.firstAddrLine,
      'Second Addr Line': x|$x.secondAddrLine
    ]),
    'First Name,Address Name,Address Street,First Addr Line,Second Addr Line\n' +
    'Anthony,A1,S1,D1,D2\n' +
    'David,A3,,D5,D6\n' +
    'Fabrice,A2,,D4,D5\n' +
    'John,A1,S1,D1,D2\n' +
    'John,A1,S1,D1,D2\n' +
    'Oliver,A3,S2,D5,D6\n' +
    'Peter,A1,S1,D1,D2\n'
  );
}

// =============================================================================
// Test 3 â€” Array size / isEmpty / isNotEmpty (Â§2.15)
// Mapping ops: toManyâ†’size(), isNotEmpty(), isEmpty(), getâ†’getâ†’size()
// =============================================================================
function <<paramTest.Test>> meta::relational::tests::mapping::relation::variant::comprehensive::testArraySizeIsEmptyIsNotEmpty(conn: Connection[1]):Boolean[1]
{
  firmExecute($conn,
    |Person.all()->project(~[
      'First Name'      : x|$x.firstName,
      'Other Name Count': x|$x.otherNameCount,
      'Has Other Names' : x|$x.hasOtherNames,
      'Others Empty'    : x|$x.otherNamesEmpty,
      'Addr Line Count' : x|$x.addrLineCount,
      'Has Address'     : x|$x.hasAddress,
      'Has Street'      : x|$x.hasStreet
    ]),
    'First Name,Other Name Count,Has Other Names,Others Empty,Addr Line Count,Has Address,Has Street\n' +
    'Anthony,2,true,false,3,true,true\n' +
    'David,2,true,false,2,true,false\n' +
    'Fabrice,2,true,false,2,true,false\n' +
    'John,2,true,false,3,true,true\n' +
    'John,2,true,false,3,true,true\n' +
    'Oliver,2,true,false,2,true,true\n' +
    'Peter,2,true,false,3,true,true\n'
  );
}

// =============================================================================
