###Pure
import meta::relational::tests::mapping::union::*;
import meta::relational::tests::mapping::union::advanced::*;
import meta::pure::metamodel::relation::*;

function <<test.BeforePackage>> meta::relational::tests::mapping::union::relation::advanced::setUp():Boolean[1]
{
   meta::relational::tests::mapping::union::createTablesAndFillDb();
}

function meta::relational::tests::mapping::union::relation::advanced::personSet1WithFirmIdFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.PersonSet1}#->select(~[lastName_s1, FirmID]);
}

function meta::relational::tests::mapping::union::relation::advanced::personSet2WithFirmIdFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.PersonSet2}#->select(~[lastName_s2, FirmID]);
}

function meta::relational::tests::mapping::union::relation::advanced::firmFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.Firm}#->select(~[ID, name]);
}

// Sub-aggregation relation functions: each leg pre-aggregates by FirmID before
// the mapping unions them. Aggregations use deterministic operators (min/max)
// so result rows are stable across DB engines that don't preserve insertion
// order through GROUP BY.

function meta::relational::tests::mapping::union::relation::advanced::personSet1AggregatedByFirmFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.PersonSet1}#
      ->groupBy(~[FirmID], ~lastName_s1 : x | $x.lastName_s1 : y | $y->max());
}

function meta::relational::tests::mapping::union::relation::advanced::personSet2AggregatedByFirmFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.PersonSet2}#
      ->groupBy(~[FirmID], ~lastName_s2 : x | $x.lastName_s2 : y | $y->max());
}

function meta::relational::tests::mapping::union::relation::advanced::personSet1AggregatedByFirmMinMaxFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.PersonSet1}#
      ->groupBy(~[FirmID], ~[firstName_s1 : x | $x.lastName_s1 : y | $y->min(),
                             lastName_s1  : x | $x.lastName_s1 : y | $y->max()]);
}

function meta::relational::tests::mapping::union::relation::advanced::personSet2AggregatedByFirmMinMaxFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::union::myDB.PersonSet2}#
      ->groupBy(~[FirmID], ~[firstName_s2 : x | $x.lastName_s2 : y | $y->min(),
                             lastName_s2  : x | $x.lastName_s2 : y | $y->max()]);
}

###Mapping
import meta::relational::tests::mapping::union::*;
import meta::relational::tests::model::simple::*;
import meta::relational::tests::mapping::union::relation::*;

Mapping meta::relational::tests::mapping::union::relation::advanced::mapping::unionOfTwoRelationMappingsWithFirm
(
   *Person : Operation
   {
      meta::pure::router::operations::union_OperationSetImplementation_1__SetImplementation_MANY_(rfSet1, rfSet2)
   }

   Person[rfSet1] : Relation
   {
      ~func meta::relational::tests::mapping::union::relation::advanced::personSet1WithFirmIdFunc():Relation<Any>[1]
      lastName: lastName_s1,
      +firmId: Integer[1]: FirmID
   }

   Person[rfSet2] : Relation
   {
      ~func meta::relational::tests::mapping::union::relation::advanced::personSet2WithFirmIdFunc():Relation<Any>[1]
      lastName: lastName_s2,
      +firmId: Integer[1]: FirmID
   }

   *Firm[firm] : Relation
   {
      ~func meta::relational::tests::mapping::union::relation::advanced::firmFunc():Relation<Any>[1]
      legalName: name,
      +id: Integer[1]: ID
   }

   Employment: ModelJoin
   {
      {employees: meta::relational::tests::model::simple::Person[1], firm: meta::relational::tests::model::simple::Firm[1]|$employees.firmId == $firm.id}
   }
)

// Sub-aggregation mappings: each Person set implementation is sourced from an
// already-aggregated relation. The mapping unions those pre-aggregated rows.

Mapping meta::relational::tests::mapping::union::relation::advanced::mapping::unionOfTwoRelationMappingsWithSubAggregation
(
   *Person : Operation
   {
      meta::pure::router::operations::union_OperationSetImplementation_1__SetImplementation_MANY_(rfAggSet1, rfAggSet2)
   }

   Person[rfAggSet1] : Relation
   {
      ~func meta::relational::tests::mapping::union::relation::advanced::personSet1AggregatedByFirmFunc():Relation<Any>[1]
      lastName: lastName_s1,
      +firmId: Integer[1]: FirmID
   }

   Person[rfAggSet2] : Relation
   {
      ~func meta::relational::tests::mapping::union::relation::advanced::personSet2AggregatedByFirmFunc():Relation<Any>[1]
      lastName: lastName_s2,
      +firmId: Integer[1]: FirmID
   }

   *Firm[firm] : Relation
   {
      ~func meta::relational::tests::mapping::union::relation::advanced::firmFunc():Relation<Any>[1]
      legalName: name,
      +id: Integer[1]: ID
   }

   Employment: ModelJoin
   {
      {employees: meta::relational::tests::model::simple::Person[1], firm: meta::relational::tests::model::simple::Firm[1]|$employees.firmId == $firm.id}
   }
)

Mapping meta::relational::tests::mapping::union::relation::advanced::mapping::unionOfTwoRelationMappingsWithMultiColumnSubAggregation
(
   *Person : Operation
   {
      meta::pure::router::operations::union_OperationSetImplementation_1__SetImplementation_MANY_(rfMmAggSet1, rfMmAggSet2)
   }

   Person[rfMmAggSet1] : Relation
   {
      ~func meta::relational::tests::mapping::union::relation::advanced::personSet1AggregatedByFirmMinMaxFunc():Relation<Any>[1]
      firstName: firstName_s1,
      lastName:  lastName_s1,
      +firmId: Integer[1]: FirmID
   }

   Person[rfMmAggSet2] : Relation
   {
      ~func meta::relational::tests::mapping::union::relation::advanced::personSet2AggregatedByFirmMinMaxFunc():Relation<Any>[1]
      firstName: firstName_s2,
      lastName:  lastName_s2,
      +firmId: Integer[1]: FirmID
   }

   *Firm[firm] : Relation
   {
      ~func meta::relational::tests::mapping::union::relation::advanced::firmFunc():Relation<Any>[1]
      legalName: name,
      +id: Integer[1]: ID
   }

   Employment: ModelJoin
   {
      {employees: meta::relational::tests::model::simple::Person[1], firm: meta::relational::tests::model::simple::Firm[1]|$employees.firmId == $firm.id}
   }
)
