// Translation of tests/semistructured/testSemiStructuredFlattening.pure to the RFPM
// variant-lift form.
//
// Source binding-based mapping replaced by a single lift mapping:
//   firm: $src.FIRM_DETAILS->to(@Firm)->toOne()
// No DB-level Join; manager self-reference omitted (no tests exercise it).
// Tests parametrized over conn:Connection[1] via <<paramTest.Test>> / <<paramTest.Ignore>>,
// mirroring the source's relationFunctionMapping:: namespace annotations.


###Relational
Database meta::relational::tests::mapping::relation::semistructured::flattening::H2DB
(
  Schema PERSON_SCHEMA
  (
    Table PERSON_TABLE
    (
      ID INTEGER PRIMARY KEY,
      FIRSTNAME VARCHAR(100) NOT NULL,
      LASTNAME VARCHAR(100) NOT NULL,
      FIRM_DETAILS SEMISTRUCTURED,
      MANAGERID INTEGER
    )
  )
)


###Pure
import meta::pure::functions::variant::convert::*;
import meta::pure::functions::variant::navigation::*;
import meta::pure::metamodel::variant::*;

Class meta::relational::tests::mapping::relation::semistructured::flattening::Person
{
  firstName: String[1];
  lastName : String[1];
  firm     : meta::relational::tests::mapping::relation::semistructured::flattening::Firm[1];
  conditionalAddressName()
  {
    if($this.firstName != 'Peter',
      |$this.firm.legalName,
      |$this.firm.addresses->filter(a | $a.name->startsWith('A1'))->first().name
    )
  }: String[0..1];
}

Class meta::relational::tests::mapping::relation::semistructured::flattening::Firm
{
  legalName : String[1];
  otherNames: String[*];
  addresses : meta::relational::tests::mapping::relation::semistructured::flattening::Address[*];
}

Class meta::relational::tests::mapping::relation::semistructured::flattening::Address
{
  name: String[1];
}

Class meta::relational::tests::mapping::relation::semistructured::flattening::AddressWithLines extends meta::relational::tests::mapping::relation::semistructured::flattening::Address
{
  lines: meta::relational::tests::mapping::relation::semistructured::flattening::AddressLine[*];
}

Class meta::relational::tests::mapping::relation::semistructured::flattening::AddressLine
{
  lineno: Integer[1];
}

Class meta::relational::tests::mapping::relation::semistructured::flattening::StreetAddressLine extends meta::relational::tests::mapping::relation::semistructured::flattening::AddressLine
{
  street: String[1];
}

Class meta::relational::tests::mapping::relation::semistructured::flattening::CityAddressLine extends meta::relational::tests::mapping::relation::semistructured::flattening::AddressLine
{
  city: String[1];
}

Class meta::relational::tests::mapping::relation::semistructured::flattening::StateAddressLine extends meta::relational::tests::mapping::relation::semistructured::flattening::AddressLine
{
  state: String[1];
}

function meta::relational::tests::mapping::relation::semistructured::flattening::personFunction(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::relation::semistructured::flattening::H2DB.PERSON_SCHEMA.PERSON_TABLE}#
    ->select(~[ID, FIRSTNAME, LASTNAME, FIRM_DETAILS, MANAGERID])
}


###Mapping
import meta::relational::tests::mapping::relation::semistructured::flattening::*;
import meta::pure::functions::variant::convert::*;
import meta::pure::functions::variant::navigation::*;

Mapping meta::relational::tests::mapping::relation::semistructured::flattening::FlatteningSemiStructuredMapping
(
  *Person[person]: Relation
  {
    ~func meta::relational::tests::mapping::relation::semistructured::flattening::personFunction():Relation<Any>[1]
    firstName: FIRSTNAME,
    lastName : LASTNAME,
    firm     : $src.FIRM_DETAILS->to(@meta::relational::tests::mapping::relation::semistructured::flattening::Firm)->toOne()
  }
)


###Pure
import meta::pure::test::*;
import meta::core::runtime::*;
import meta::relational::metamodel::execute::tests::*;
import meta::relational::tests::mapping::relation::semistructured::flattening::*;

function <<access.private>> meta::relational::tests::mapping::relation::semistructured::flattening::flatteningCsv(): String[1]
{
  'PERSON_SCHEMA\n' +
  'PERSON_TABLE\n' +
  'ID,FIRSTNAME,LASTNAME,FIRM_DETAILS,MANAGERID\n' +
  '1,Peter,Smith,"{""legalName"": ""Firm X"", ""otherNames"": [""O1"", ""O2""], ""addresses"": [{""name"": ""A1"", ""lines"": [{""lineno"": 1, ""street"": ""S1""}, {""lineno"": 2, ""city"": ""C1""}]}, {""name"": ""A11"", ""lines"": [{""lineno"": 1, ""street"": ""S1""}, {""lineno"": 2, ""city"": ""C2""}]}]}",2\n' +
  '2,John,Johnson,"{""legalName"": ""Firm X"", ""otherNames"": [""O1"", ""O2""], ""addresses"": [{""name"": ""A2"", ""lines"": [{""lineno"": 1, ""street"": ""S2""}, {""lineno"": 2, ""city"": ""C2""}]}, {""name"": ""A22"", ""lines"": [{""lineno"": 1, ""street"": ""S1""}, {""lineno"": 2, ""city"": ""C3""}]}]}",4\n' +
  '3,John,Hill,"{""legalName"": ""Firm X"", ""otherNames"": [""O1"", ""O2""], ""addresses"": [{""name"": ""A3"", ""lines"": [{""lineno"": 1, ""street"": ""S3""}, {""lineno"": 2, ""city"": ""C1""}]}, {""name"": ""A32"", ""lines"": [{""lineno"": 1, ""street"": ""S1""}, {""lineno"": 2, ""city"": ""C1""}]}]}",2\n' +
  '4,Anthony,Allen,"{""legalName"": ""Firm X"", ""otherNames"": [""O1"", ""O2""], ""addresses"": [{""name"": ""A4"", ""lines"": [{""lineno"": 1, ""street"": ""S1""}, {""lineno"": 2, ""city"": ""C3""}]}]}",\n' +
  '5,Fabrice,Roberts,"{""legalName"": ""Firm A"", ""otherNames"": [""O3"", ""O4""], ""addresses"": [{""name"": ""A5"", ""lines"": [{""lineno"": 1, ""street"": ""S4""}, {""lineno"": 2, ""city"": ""C2""}]}, {""name"": ""A52"", ""lines"": [{""lineno"": 1, ""street"": ""S1""}, {""lineno"": 2, ""city"": ""C4""}]}]}",\n' +
  '6,Oliver,Hill,"{""legalName"": ""Firm B"", ""otherNames"": [""O5"", ""O6""], ""addresses"": [{""name"": ""A6"", ""lines"": [{""lineno"": 1, ""street"": ""S5""}, {""lineno"": 2, ""city"": ""C4""}]}]}",7\n' +
  '7,David,Harris,"{""legalName"": ""Firm B"", ""otherNames"": [""O5"", ""O6""], ""addresses"": [{""name"": ""A7"", ""lines"": [{""lineno"": 1, ""street"": ""S1""}, {""lineno"": 2, ""city"": ""C1""}]}]}",\n'
}

function <<access.private>> meta::relational::tests::mapping::relation::semistructured::flattening::flatteningExecute(conn: Connection[1], func: FunctionDefinition<Any>[1], expected: String[1]): Boolean[1]
{
  executeLegendFunction($func, FlatteningSemiStructuredMapping, H2DB, $conn, [flatteningCsv()], $expected, false);
}

function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::flattening::testSemiStructuredPrimitivePropertyFlattening(conn: Connection[1]): Boolean[1]
{
  flatteningExecute($conn,
    |Person.all()->project(~[
      'First Name'     : x|$x.firstName,
      'Firm Name'      : x|$x.firm.legalName,
      'Firm Other Name': x|$x.firm.otherNames
    ]),
    'First Name,Firm Name,Firm Other Name\n' +
    'Peter,Firm X,O1\n' +
    'Peter,Firm X,O2\n' +
    'John,Firm X,O1\n' +
    'John,Firm X,O2\n' +
    'John,Firm X,O1\n' +
    'John,Firm X,O2\n' +
    'Anthony,Firm X,O1\n' +
    'Anthony,Firm X,O2\n' +
    'Fabrice,Firm A,O3\n' +
    'Fabrice,Firm A,O4\n' +
    'Oliver,Firm B,O5\n' +
    'Oliver,Firm B,O6\n' +
    'David,Firm B,O5\n' +
    'David,Firm B,O6\n'
  );
}

function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::flattening::testSemiStructuredComplexPropertyFlattening(conn: Connection[1]): Boolean[1]
{
  flatteningExecute($conn,
    |Person.all()->project(~[
      'First Name'       : x|$x.firstName,
      'Firm Name'        : x|$x.firm.legalName,
      'Firm Address Name': x|$x.firm.addresses.name
    ]),
    'First Name,Firm Name,Firm Address Name\n' +
    'Peter,Firm X,A1\n' +
    'Peter,Firm X,A11\n' +
    'John,Firm X,A2\n' +
    'John,Firm X,A22\n' +
    'John,Firm X,A3\n' +
    'John,Firm X,A32\n' +
    'Anthony,Firm X,A4\n' +
    'Fabrice,Firm A,A5\n' +
    'Fabrice,Firm A,A52\n' +
    'Oliver,Firm B,A6\n' +
    'David,Firm B,A7\n'
  );
}

function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::flattening::testSemiStructuredPrimitivePropertyArrayIndexing(conn: Connection[1]): Boolean[1]
{
  flatteningExecute($conn,
    |Person.all()->project(~[
      'First Name'      : x|$x.firstName,
      'Firm Name'       : x|$x.firm.legalName,
      'Firm Other Name 0': x|$x.firm.otherNames->at(0),
      'Firm Other Name 2': x|$x.firm.otherNames->at(2)
    ]),
    'First Name,Firm Name,Firm Other Name 0,Firm Other Name 2\n' +
    'Peter,Firm X,O1,\n' +
    'John,Firm X,O1,\n' +
    'John,Firm X,O1,\n' +
    'Anthony,Firm X,O1,\n' +
    'Fabrice,Firm A,O3,\n' +
    'Oliver,Firm B,O5,\n' +
    'David,Firm B,O5,\n'
  );
}

function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::flattening::testSemiStructuredComplexPropertyArrayIndexing(conn: Connection[1]): Boolean[1]
{
  flatteningExecute($conn,
    |Person.all()->project(~[
      'First Name'        : x|$x.firstName,
      'Firm Name'         : x|$x.firm.legalName,
      'Firm Address 0 Name': x|$x.firm.addresses->at(0).name,
      'Firm Address 2 Name': x|$x.firm.addresses->at(2).name
    ]),
    'First Name,Firm Name,Firm Address 0 Name,Firm Address 2 Name\n' +
    'Peter,Firm X,A1,\n' +
    'John,Firm X,A2,\n' +
    'John,Firm X,A3,\n' +
    'Anthony,Firm X,A4,\n' +
    'Fabrice,Firm A,A5,\n' +
    'Oliver,Firm B,A6,\n' +
    'David,Firm B,A7,\n'
  );
}

function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::flattening::testSemiStructuredComplexPropertyFlatteningFollowedBySubType(conn: Connection[1]): Boolean[1]
{
  flatteningExecute($conn,
    |Person.all()->project(~[
      'First Name'               : x|$x.firstName,
      'Firm Name'                : x|$x.firm.legalName,
      'Firm Address Line 0 Line No': x|$x.firm.addresses->subType(@AddressWithLines)->map(a | $a.lines->at(0).lineno)
    ]),
    'First Name,Firm Name,Firm Address Line 0 Line No\n' +
    'Peter,Firm X,1\n' +
    'Peter,Firm X,1\n' +
    'John,Firm X,1\n' +
    'John,Firm X,1\n' +
    'John,Firm X,1\n' +
    'John,Firm X,1\n' +
    'Anthony,Firm X,1\n' +
    'Fabrice,Firm A,1\n' +
    'Fabrice,Firm A,1\n' +
    'Oliver,Firm B,1\n' +
    'David,Firm B,1\n'
  );
}

function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::flattening::testSemiStructuredComplexPropertyArrayIndexingFollowedBySubType(conn: Connection[1]): Boolean[1]
{
  flatteningExecute($conn,
    |Person.all()->project(~[
      'First Name'                 : x|$x.firstName,
      'Firm Name'                  : x|$x.firm.legalName,
      'Firm Address 0 Line 0 Line No': x|$x.firm.addresses->at(0)->subType(@AddressWithLines).lines->at(0).lineno
    ]),
    'First Name,Firm Name,Firm Address 0 Line 0 Line No\n' +
    'Peter,Firm X,1\n' +
    'John,Firm X,1\n' +
    'John,Firm X,1\n' +
    'Anthony,Firm X,1\n' +
    'Fabrice,Firm A,1\n' +
    'Oliver,Firm B,1\n' +
    'David,Firm B,1\n'
  );
}

function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::flattening::testSemiStructuredPrimitivePropertyFiltering(conn: Connection[1]): Boolean[1]
{
  flatteningExecute($conn,
    |Person.all()
      ->filter(x | $x.firm.otherNames->contains('A'))
      ->project(~[
        'First Name': x|$x.firstName,
        'Firm Name' : x|$x.firm.legalName
      ])
      ->distinct(),
    'First Name,Firm Name\n'
  );
}

// Ignored because filter-in-project on semi-structured arrays is not yet supported.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::flattening::testSemiStructuredPrimitivePropertyFilteringInProject(conn: Connection[1]): Boolean[1]
{
  flatteningExecute($conn,
    |Person.all()->project(~[
      'First Name'     : x|$x.firstName,
      'Firm Name'      : x|$x.firm.legalName,
      'Firm Other Name': x|$x.firm.otherNames->filter(x | $x->startsWith('A'))
    ]),
    'First Name,Firm Name,Firm Other Name\n' +
    'Anthony,Firm X,O1\n' +
    'Anthony,Firm X,O2\n' +
    'David,Firm B,O5\n' +
    'David,Firm B,O6\n' +
    'Fabrice,Firm A,O3\n' +
    'Fabrice,Firm A,O4\n' +
    'John,Firm X,O1\n' +
    'John,Firm X,O1\n' +
    'John,Firm X,O2\n' +
    'John,Firm X,O2\n' +
    'Oliver,Firm B,O5\n' +
    'Oliver,Firm B,O6\n' +
    'Peter,Firm X,O1\n' +
    'Peter,Firm X,O2\n'
  );
}

// Ignored because sub-aggregation queries aren't supported yet on Relation Function Class Mappings.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::flattening::testSemiStructuredSubAggregation(conn: Connection[1]): Boolean[1]
{
  flatteningExecute($conn,
    |Person.all()->project(~[
      'First Name'        : x|$x.firstName,
      'Firm Name'         : x|$x.firm.legalName,
      'Firm Address Names': x|$x.firm.addresses.name->joinStrings(';')
    ]),
    'First Name,Firm Name,Firm Address Names\n' +
    'Peter,Firm X,A1;A11\n' +
    'John,Firm X,A2;A22\n' +
    'John,Firm X,A3;A32\n' +
    'Anthony,Firm X,A4\n' +
    'Fabrice,Firm A,A5;A52\n' +
    'Oliver,Firm B,A6\n' +
    'David,Firm B,A7\n'
  );
}

// Ignored because sub-aggregation queries aren't supported yet on Relation Function Class Mappings.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::flattening::testSemiStructuredSubAggregationDeep(conn: Connection[1]): Boolean[1]
{
  flatteningExecute($conn,
    |Person.all()->project(~[
      'First Name'             : x|$x.firstName,
      'Firm Name'              : x|$x.firm.legalName,
      'Firm Address Line No Sum': x|$x.firm.addresses->subType(@AddressWithLines).lines.lineno->sum()
    ]),
    'First Name,Firm Name,Firm Address Line No Sum\n' +
    'Peter,Firm X,6\n' +
    'John,Firm X,6\n' +
    'John,Firm X,6\n' +
    'Anthony,Firm X,3\n' +
    'Fabrice,Firm A,6\n' +
    'Oliver,Firm B,3\n' +
    'David,Firm B,3\n'
  );
}

function <<paramTest.Test>> meta::relational::tests::mapping::relation::semistructured::flattening::testSemiStructuredMultiLevelFlatten(conn: Connection[1]): Boolean[1]
{
  flatteningExecute($conn,
    |Person.all()->project(~[
      'First Name'            : x|$x.firstName,
      'Firm Name'             : x|$x.firm.legalName,
      'Firm Address Name Line No': x|$x.firm.addresses->filter(a | $a.name == 'A')->subType(@AddressWithLines).lines.lineno
    ]),
    'First Name,Firm Name,Firm Address Name Line No\n' +
    'Peter,Firm X,1\n' +
    'Peter,Firm X,2\n' +
    'Peter,Firm X,1\n' +
    'Peter,Firm X,2\n' +
    'John,Firm X,1\n' +
    'John,Firm X,2\n' +
    'John,Firm X,1\n' +
    'John,Firm X,2\n' +
    'John,Firm X,1\n' +
    'John,Firm X,2\n' +
    'John,Firm X,1\n' +
    'John,Firm X,2\n' +
    'Anthony,Firm X,1\n' +
    'Anthony,Firm X,2\n' +
    'Fabrice,Firm A,1\n' +
    'Fabrice,Firm A,2\n' +
    'Fabrice,Firm A,1\n' +
    'Fabrice,Firm A,2\n' +
    'Oliver,Firm B,1\n' +
    'Oliver,Firm B,2\n' +
    'David,Firm B,1\n' +
    'David,Firm B,2\n'
  );
}

