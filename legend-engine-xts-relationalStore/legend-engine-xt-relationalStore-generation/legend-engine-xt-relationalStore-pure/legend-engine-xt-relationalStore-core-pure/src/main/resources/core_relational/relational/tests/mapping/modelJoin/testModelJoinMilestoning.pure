    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  assertEquals( '#TDS\n' +
            '   Order,Carrier\n' +
            '   OrderA,DHL\n' +
            '   OrderB,UPS\n' +
            '#',
            $result.values->at(0)->sort([~'Order'->ascending()])->toString());
}

// =============================================================================
// Relational: Target milestoned (Order) — Relational class mappings
//
// Expected: WarehouseA→OrderA, WarehouseB→OrderC.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::milestoning::testRelationalMilestoningTargetOnly():Boolean[1]
{
  let orderCsv =
    'default\n' +
    'orderTable\n' +
    'ID,PRODUCTID,DESCRIPTION,REFCODE,FROM_Z,THRU_Z\n' +
    '1,1,OrderA,REF1,2023-01-01,2025-01-01\n' +
    '2,2,OrderB,REF2,2025-01-01,9999-12-31\n' +
    '3,3,OrderC,REF3,2023-06-01,2024-06-01\n';

  let productCsv =
    'default\n' +
    'productTable\n' +
    'ID,ORDERID,CODE,CATEGORY\n' +
    '1,1,ELEC,electronics\n' +
    '2,2,ELEC,electronics\n' +
    '3,3,FOOD,food\n';

  let warehouseCsv =
    'default\n' +
    'warehouseTable\n' +
    'ID,NAME,SECTIONID\n' +
    '1,WarehouseA,1\n' +
    '2,WarehouseB,2\n';

  let sectionCsv =
    'default\n' +
    'sectionTable\n' +
    'ID,WAREHOUSEID,ZONE\n' +
    '1,1,electronics\n' +
    '2,2,food\n';

  let db = meta::relational::tests::mapping::modelJoin::milestoning::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$orderCsv, $productCsv, $warehouseCsv, $sectionCsv], $db, $runtime);

  let result = execute(
    |Warehouse.all()->project(
      ~[
        'Warehouse': x|$x.name,
        'Order': x|$x.orders(%2024-01-01).description
       ]
    ),
    RelationalMilestonedOrderWarehouseMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "root".NAME as "Warehouse", "ordertable_0".DESCRIPTION as "Order" ' +
    'from warehouseTable as "root" left outer join sectionTable as "sectiontable_0" on ("root".ID = "sectiontable_0".WAREHOUSEID) ' +
    'left outer join (select "root".DESCRIPTION as "description", "root".REFCODE as "refCode", "root".ID as "id", ' +
         '"root".PRODUCTID as "productId", \'2024-01-01\' as "k_businessDate", "producttable_0".CATEGORY as CATEGORY, ' +
         '"root".DESCRIPTION as DESCRIPTION from orderTable as "root" ' +
         'left outer join productTable as "producttable_0" on ("root".ID = "producttable_0".ORDERID) ' +
         'where "root".FROM_Z <= DATE\'2024-01-01\' and "root".THRU_Z > DATE\'2024-01-01\') as "ordertable_0" ' +
    'on ("ordertable_0".CATEGORY = "sectiontable_0".ZONE)';
  assertEquals($expectedSql, $result->sql());

  assertEquals( '#TDS\n' +
            '   Warehouse,Order\n' +
            '   WarehouseA,OrderA\n' +
            '   WarehouseB,OrderC\n' +
            '#',
            $result.values->at(0)->sort([~'Warehouse'->ascending()])->toString());
}

// =============================================================================
// Relational: Source milestoned (Order) — Relational class mappings
//
// Expected: OrderA→WarehouseA, OrderC→WarehouseB.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::milestoning::testRelationalMilestoningSourceOnly():Boolean[1]
{
  let orderCsv =
    'default\n' +
    'orderTable\n' +
    'ID,PRODUCTID,DESCRIPTION,REFCODE,FROM_Z,THRU_Z\n' +
    '1,1,OrderA,REF1,2023-01-01,2025-01-01\n' +
    '2,2,OrderB,REF2,2025-01-01,9999-12-31\n' +
    '3,3,OrderC,REF3,2023-06-01,2024-06-01\n';

  let productCsv =
    'default\n' +
    'productTable\n' +
    'ID,ORDERID,CODE,CATEGORY\n' +
    '1,1,ELEC,electronics\n' +
    '2,2,ELEC,electronics\n' +
    '3,3,FOOD,food\n';

  let warehouseCsv =
    'default\n' +
    'warehouseTable\n' +
    'ID,NAME,SECTIONID\n' +
    '1,WarehouseA,1\n' +
    '2,WarehouseB,2\n';

  let sectionCsv =
    'default\n' +
    'sectionTable\n' +
    'ID,WAREHOUSEID,ZONE\n' +
    '1,1,electronics\n' +
    '2,2,food\n';

  let db = meta::relational::tests::mapping::modelJoin::milestoning::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$orderCsv, $productCsv, $warehouseCsv, $sectionCsv], $db, $runtime);

  let result = execute(
    |Order.all(%2024-01-01)->project(
      ~[
        'Order': x|$x.description,
        'Warehouse': x|$x.warehouse.name
       ]
    ),
    RelationalMilestonedOrderWarehouseMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "root".DESCRIPTION as "Order", "warehousetable_0".NAME as "Warehouse" ' +
    'from orderTable as "root" left outer join productTable as "producttable_0" on ("root".ID = "producttable_0".ORDERID) ' +
    'left outer join (select "root".NAME as "name", "root".ID as "id", "root".SECTIONID as "sectionId", ' +
         '\'2024-01-01\' as "k_businessDate", "sectiontable_0".ZONE as ZONE, "root".NAME as NAME ' +
         'from warehouseTable as "root" left outer join sectionTable as "sectiontable_0" ' +
         'on ("root".ID = "sectiontable_0".WAREHOUSEID)) as "warehousetable_0" ' +
    'on ("producttable_0".CATEGORY = "warehousetable_0".ZONE) ' +
    'where "root".FROM_Z <= DATE\'2024-01-01\' and "root".THRU_Z > DATE\'2024-01-01\'';
  assertEquals($expectedSql, $result->sql());

  assertEquals( '#TDS\n' +
            '   Order,Warehouse\n' +
            '   OrderA,WarehouseA\n' +
            '   OrderC,WarehouseB\n' +
            '#',
            $result.values->at(0)->sort([~'Order'->ascending()])->toString());
}

// =============================================================================
// Relational: Both sides milestoned same scheme — Relational class mappings
//
// Expected: OrderA→null, OrderB→DHL+UPS.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::milestoning::testRelationalMilestoningSameScheme():Boolean[1]
{
  let orderCsv =
    'default\n' +
    'orderTable\n' +
    'ID,PRODUCTID,DESCRIPTION,REFCODE,FROM_Z,THRU_Z\n' +
    '1,1,OrderA,REF1,2023-01-01,2024-06-01\n' +
    '2,2,OrderB,REF2,2024-01-01,2025-01-01\n' +
    '3,3,OrderC,REF3,2024-06-01,2025-01-01\n';

  let productCsv =
    'default\n' +
    'productTable\n' +
    'ID,ORDERID,CODE,CATEGORY\n' +
    '1,1,ALPHA,cat1\n' +
    '2,2,BETA,cat2\n' +
    '3,3,ALPHA,cat3\n';

  let shipmentCsv =
    'default\n' +
    'shipmentTable\n' +
    'ID,ORDERID,CARRIER,TRACKINGID,FROM_Z,THRU_Z\n' +
    '1,1,FedEx,1,2024-01-01,2024-06-01\n' +
    '2,1,DHL,2,2024-06-01,2025-01-01\n' +
    '3,2,UPS,3,2024-01-01,2025-01-01\n';

  let trackingCsv =
    'default\n' +
    'trackingTable\n' +
    'ID,SHIPMENTID,PREFIX\n' +
    '1,1,ALPHA\n' +
    '2,2,BETA\n' +
    '3,3,BETA\n';

  let db = meta::relational::tests::mapping::modelJoin::milestoning::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$orderCsv, $productCsv, $shipmentCsv, $trackingCsv], $db, $runtime);

  let result = execute(
    |Order.all(%2024-03-01)->project(
      ~[
        'Order': x|$x.description,
        'Carrier': x|$x.shipments(%2024-07-01).carrier
       ]
    ),
    RelationalMilestoningSameSchemeBothMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "root".DESCRIPTION as "Order", "shipmenttable_0".CARRIER as "Carrier" ' +
    'from orderTable as "root" left outer join productTable as "producttable_0" on ("root".ID = "producttable_0".ORDERID) ' +
    'left outer join (select "root".CARRIER as "carrier", "root".ID as "id", "root".ORDERID as "orderId", ' +
         '"root".TRACKINGID as "trackingId", \'2024-07-01\' as "k_businessDate", "trackingtable_0".PREFIX as PREFIX, ' +
         '"root".CARRIER as CARRIER from shipmentTable as "root" ' +
         'left outer join trackingTable as "trackingtable_0" on ("root".ID = "trackingtable_0".SHIPMENTID) ' +
         'where "root".FROM_Z <= DATE\'2024-07-01\' and "root".THRU_Z > DATE\'2024-07-01\') as "shipmenttable_0" ' +
    'on ("producttable_0".CODE = "shipmenttable_0".PREFIX) ' +
    'where "root".FROM_Z <= DATE\'2024-03-01\' and "root".THRU_Z > DATE\'2024-03-01\''; 
  assertEquals($expectedSql, $result->sql());

  assertEquals( '#TDS\n' +
            '   Order,Carrier\n' +
            '   OrderA,TDSNull\n' +
            '   OrderB,DHL\n' +
            '   OrderB,UPS\n' +
            '#',
            $result.values->at(0)->sort([~'Order'->ascending(), ~'Carrier'->ascending()])->toString());
}

// =============================================================================
// Relational: Different milestoning schemes — Relational class mappings
//
// Expected: OrderA→Audit1.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::milestoning::testRelationalMilestoningDiffScheme():Boolean[1]
{
  let orderCsv =
    'default\n' +
    'orderTable\n' +
    'ID,PRODUCTID,DESCRIPTION,REFCODE,FROM_Z,THRU_Z\n' +
    '1,1,OrderA,REF1,2023-01-01,2025-01-01\n' +
    '2,2,OrderB,REF2,2025-01-01,9999-12-31\n';

  let productCsv =
    'default\n' +
    'productTable\n' +
    'ID,ORDERID,CODE,CATEGORY\n' +
    '1,1,ALPHA,cat1\n' +
    '2,2,BETA,cat2\n';

  let auditCsv =
    'default\n' +
    'auditTable\n' +
    'ID,ENTITYREF,MESSAGE,IN_Z,OUT_Z\n' +
    '1,ALPHA,Audit1,2023-01-01 00:00:00,2025-01-01 00:00:00\n' +
    '2,ALPHA,Audit2,2025-01-01 00:00:00,9999-12-31 00:00:00\n' +
    '3,BETA,Audit3,2023-01-01 00:00:00,2025-01-01 00:00:00\n';

  let db = meta::relational::tests::mapping::modelJoin::milestoning::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$orderCsv, $productCsv, $auditCsv], $db, $runtime);

  let result = execute(
    |Order.all(%2024-01-01)->project(
      ~[
        'Order': x|$x.description,
        'Audit': x|$x.auditEntries(%2024-01-01T10:00:00).message
       ]
    ),
    RelationalMilestoningDiffSchemeMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "root".DESCRIPTION as "Order", "audittable_0".MESSAGE as "Audit" ' +
    'from orderTable as "root" left outer join productTable as "producttable_0" on ("root".ID = "producttable_0".ORDERID) ' +
    'left outer join (select "audittable_1".ENTITYREF as ENTITYREF, "audittable_1".MESSAGE as MESSAGE ' +
         'from auditTable as "audittable_1" ' +
         'where "audittable_1".IN_Z <= TIMESTAMP\'2024-01-01 10:00:00\' and "audittable_1".OUT_Z > TIMESTAMP\'2024-01-01 10:00:00\') as "audittable_0" ' +
    'on ("producttable_0".CODE = "audittable_0".ENTITYREF) ' +
    'where "root".FROM_Z <= DATE\'2024-01-01\' and "root".THRU_Z > DATE\'2024-01-01\'';
  assertEquals($expectedSql, $result->sql());

  assertEquals( '#TDS\n' +
            '   Order,Audit\n' +
            '   OrderA,Audit1\n' +
            '#',
            $result.values->at(0)->sort([~'Order'->ascending()])->toString());
}
