// =============================================================================
// Milestoned contract: Person→Contract via model join, Contract is businesstemporal
//   Query at businessDate=2024-01-01
//
// Expected: Alice→ContractA (active), Bob→ContractC (active).
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::milestoning::testMilestonedContract():Boolean[1]
{
  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n';

  let contractCsv =
    'default\n' +
    'contractLogTable\n' +
    'ID,PERSONID,DESCRIPTION,FROM_Z,THRU_Z\n' +
    '1,1,ContractA,2023-01-01,2025-01-01\n' +
    '2,1,ContractB,2025-01-01,2099-01-01\n' +
    '3,2,ContractC,2023-06-01,2024-06-01\n';

  let db = meta::relational::tests::mapping::modelJoin::milestoning::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$personCsv, $contractCsv], $db, $runtime);

  let result = execute(
    |Person.all()->project(
      ~[
        'First Name': x|$x.firstName,
        'Contract': x|$x.contracts(%2024-01-01).description
       ]
    ),
    MilestonedContractMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "persontable_0".FIRSTNAME as "First Name", "contractlogtable_0".DESCRIPTION as "Contract" ' +
    'from (select "persontable_1".ID as ID, "persontable_1".FIRSTNAME as FIRSTNAME, "persontable_1".LASTNAME as LASTNAME, ' +
         '"persontable_1".FIRMID as FIRMID, "persontable_1".AGE as AGE from personTable as "persontable_1") as "persontable_0" ' +
    'left outer join (select "contractlogtable_1".ID as ID, "contractlogtable_1".PERSONID as PERSONID, ' +
         '"contractlogtable_1".DESCRIPTION as DESCRIPTION, "contractlogtable_1".FROM_Z as FROM_Z, "contractlogtable_1".THRU_Z as THRU_Z ' +
         'from contractLogTable as "contractlogtable_1" ' +
         'where "contractlogtable_1".FROM_Z <= DATE\'2024-01-01\' and "contractlogtable_1".THRU_Z > DATE\'2024-01-01\') as "contractlogtable_0" ' +
    'on ("persontable_0".ID = "contractlogtable_0".PERSONID)';
  assertEquals($expectedSql, $result->sql());

  assertEquals( '#TDS\n' +
            '   \'First Name\',Contract\n' +
            '   Alice,ContractA\n' +
            '   Bob,ContractC\n' +
            '#',
            $result.values->at(0)->sort([~'First Name'->ascending()])->toString());
}

// =============================================================================
// Target milestoned (Order), source NOT milestoned (Warehouse)
//   Nested condition: orders.product.category == warehouse.section.zone
//   Only Order has milestoning → temporal filter on orderTable (target)
//
// Expected at businessDate=2024-01-01: WarehouseA→OrderA, WarehouseB→OrderC.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::milestoning::testMilestoningTargetOnly():Boolean[1]
{
  let orderCsv =
    'default\n' +
    'orderTable\n' +
    'ID,PRODUCTID,DESCRIPTION,REFCODE,FROM_Z,THRU_Z\n' +
    '1,1,OrderA,REF1,2023-01-01,2025-01-01\n' +
    '2,2,OrderB,REF2,2025-01-01,9999-12-31\n' +
    '3,3,OrderC,REF3,2023-06-01,2024-06-01\n';

  let productCsv =
    'default\n' +
    'productTable\n' +
    'ID,ORDERID,CODE,CATEGORY\n' +
    '1,1,ELEC,electronics\n' +
    '2,2,ELEC,electronics\n' +
    '3,3,FOOD,food\n';

  let warehouseCsv =
    'default\n' +
    'warehouseTable\n' +
    'ID,NAME,SECTIONID\n' +
    '1,WarehouseA,1\n' +
    '2,WarehouseB,2\n';

  let sectionCsv =
    'default\n' +
    'sectionTable\n' +
    'ID,WAREHOUSEID,ZONE\n' +
    '1,1,electronics\n' +
    '2,2,food\n';

  let db = meta::relational::tests::mapping::modelJoin::milestoning::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$orderCsv, $productCsv, $warehouseCsv, $sectionCsv], $db, $runtime);

  let result = execute(
    |Warehouse.all()->project(
      ~[
        'Warehouse': x|$x.name,
        'Order': x|$x.orders(%2024-01-01).description
       ]
    ),
    MilestonedOrderWarehouseMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "warehousetable_0".NAME as "Warehouse", "ordertable_0".DESCRIPTION as "Order" ' +
    'from (select "warehousetable_1".ID as ID, "warehousetable_1".NAME as NAME, "warehousetable_1".SECTIONID as SECTIONID ' +
         'from warehouseTable as "warehousetable_1") as "warehousetable_0" ' +
    'left outer join (select "producttable_1".ID as ID, "producttable_1".WAREHOUSEID as WAREHOUSEID, "producttable_1".ZONE as ZONE ' +
         'from sectionTable as "producttable_1") as "sectiontable_0" on ("warehousetable_0".ID = "sectiontable_0".WAREHOUSEID) ' +
    'left outer join (select "producttable_0".CATEGORY as CATEGORY, "ordertable_1".DESCRIPTION as DESCRIPTION ' +
         'from (select "ordertable_2".ID as ID, "ordertable_2".PRODUCTID as PRODUCTID, "ordertable_2".DESCRIPTION as DESCRIPTION, ' +
              '"ordertable_2".REFCODE as REFCODE, "ordertable_2".FROM_Z as FROM_Z, "ordertable_2".THRU_Z as THRU_Z ' +
              'from orderTable as "ordertable_2" ' +
              'where "ordertable_2".FROM_Z <= DATE\'2024-01-01\' and "ordertable_2".THRU_Z > DATE\'2024-01-01\') as "ordertable_1" ' +
         'left outer join (select "producttable_1".ID as ID, "producttable_1".ORDERID as ORDERID, "producttable_1".CODE as CODE, ' +
              '"producttable_1".CATEGORY as CATEGORY from productTable as "producttable_1") as "producttable_0" ' +
         'on ("ordertable_1".ID = "producttable_0".ORDERID)) as "ordertable_0" ' +
    'on ("ordertable_0".CATEGORY = "sectiontable_0".ZONE)';
  assertEquals($expectedSql, $result->sql());

  assertEquals( '#TDS\n' +
            '   Warehouse,Order\n' +
            '   WarehouseA,OrderA\n' +
            '   WarehouseB,OrderC\n' +
            '#',
            $result.values->at(0)->sort([~'Warehouse'->ascending()])->toString());
}

// =============================================================================
// Source milestoned (Order), target NOT milestoned (Warehouse)
//   Order.all(%2024-01-01)→warehouse.name
//
// Expected: OrderA→WarehouseA, OrderC→WarehouseB.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::milestoning::testMilestoningSourceOnly():Boolean[1]
{
  let orderCsv =
    'default\n' +
    'orderTable\n' +
    'ID,PRODUCTID,DESCRIPTION,REFCODE,FROM_Z,THRU_Z\n' +
    '1,1,OrderA,REF1,2023-01-01,2025-01-01\n' +
    '2,2,OrderB,REF2,2025-01-01,9999-12-31\n' +
    '3,3,OrderC,REF3,2023-06-01,2024-06-01\n';

  let productCsv =
    'default\n' +
    'productTable\n' +
    'ID,ORDERID,CODE,CATEGORY\n' +
    '1,1,ELEC,electronics\n' +
    '2,2,ELEC,electronics\n' +
    '3,3,FOOD,food\n';

  let warehouseCsv =
    'default\n' +
    'warehouseTable\n' +
    'ID,NAME,SECTIONID\n' +
    '1,WarehouseA,1\n' +
    '2,WarehouseB,2\n';

  let sectionCsv =
    'default\n' +
    'sectionTable\n' +
    'ID,WAREHOUSEID,ZONE\n' +
    '1,1,electronics\n' +
    '2,2,food\n';

  let db = meta::relational::tests::mapping::modelJoin::milestoning::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$orderCsv, $productCsv, $warehouseCsv, $sectionCsv], $db, $runtime);

  let result = execute(
    |Order.all(%2024-01-01)->project(
      ~[
        'Order': x|$x.description,
        'Warehouse': x|$x.warehouse.name
       ]
    ),
    MilestonedOrderWarehouseMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "ordertable_0".DESCRIPTION as "Order", "warehousetable_0".NAME as "Warehouse" ' +
    'from (select "ordertable_1".ID as ID, "ordertable_1".PRODUCTID as PRODUCTID, "ordertable_1".DESCRIPTION as DESCRIPTION, ' +
         '"ordertable_1".REFCODE as REFCODE, "ordertable_1".FROM_Z as FROM_Z, "ordertable_1".THRU_Z as THRU_Z ' +
         'from orderTable as "ordertable_1" ' +
         'where "ordertable_1".FROM_Z <= DATE\'2024-01-01\' and "ordertable_1".THRU_Z > DATE\'2024-01-01\') as "ordertable_0" ' +
    'left outer join (select "producttable_1".ID as ID, "producttable_1".ORDERID as ORDERID, "producttable_1".CODE as CODE, ' +
         '"producttable_1".CATEGORY as CATEGORY from productTable as "producttable_1") as "producttable_0" ' +
    'on ("ordertable_0".ID = "producttable_0".ORDERID) ' +
    'left outer join (select "sectiontable_0".ZONE as ZONE, "warehousetable_1".NAME as NAME ' +
         'from (select "warehousetable_2".ID as ID, "warehousetable_2".NAME as NAME, "warehousetable_2".SECTIONID as SECTIONID ' +
              'from warehouseTable as "warehousetable_2") as "warehousetable_1" ' +
         'left outer join (select "producttable_1".ID as ID, "producttable_1".WAREHOUSEID as WAREHOUSEID, "producttable_1".ZONE as ZONE ' +
              'from sectionTable as "producttable_1") as "sectiontable_0" ' +
         'on ("warehousetable_1".ID = "sectiontable_0".WAREHOUSEID)) as "warehousetable_0" ' +
    'on ("producttable_0".CATEGORY = "warehousetable_0".ZONE)';
  assertEquals($expectedSql, $result->sql());

  assertEquals( '#TDS\n' +
            '   Order,Warehouse\n' +
            '   OrderA,WarehouseA\n' +
            '   OrderC,WarehouseB\n' +
            '#',
            $result.values->at(0)->sort([~'Order'->ascending()])->toString());
}

// =============================================================================
// Both sides milestoned same scheme (Order + Shipment, both business)
//   Order at %2024-03-01, Shipment at %2024-07-01
//
// Expected: OrderA→null, OrderB→DHL+UPS.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::milestoning::testMilestoningSameScheme():Boolean[1]
{
  let orderCsv =
    'default\n' +
    'orderTable\n' +
    'ID,PRODUCTID,DESCRIPTION,REFCODE,FROM_Z,THRU_Z\n' +
    '1,1,OrderA,REF1,2023-01-01,2024-06-01\n' +
    '2,2,OrderB,REF2,2024-01-01,2025-01-01\n' +
    '3,3,OrderC,REF3,2024-06-01,2025-01-01\n';

  let productCsv =
    'default\n' +
    'productTable\n' +
    'ID,ORDERID,CODE,CATEGORY\n' +
    '1,1,ALPHA,cat1\n' +
    '2,2,BETA,cat2\n' +
    '3,3,ALPHA,cat3\n';

  let shipmentCsv =
    'default\n' +
    'shipmentTable\n' +
    'ID,ORDERID,CARRIER,TRACKINGID,FROM_Z,THRU_Z\n' +
    '1,1,FedEx,1,2024-01-01,2024-06-01\n' +
    '2,1,DHL,2,2024-06-01,2025-01-01\n' +
    '3,2,UPS,3,2024-01-01,2025-01-01\n';

  let trackingCsv =
    'default\n' +
    'trackingTable\n' +
    'ID,SHIPMENTID,PREFIX\n' +
    '1,1,ALPHA\n' +
    '2,2,BETA\n' +
    '3,3,BETA\n';

  let db = meta::relational::tests::mapping::modelJoin::milestoning::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$orderCsv, $productCsv, $shipmentCsv, $trackingCsv], $db, $runtime);

  let result = execute(
    |Order.all(%2024-03-01)->project(
      ~[
        'Order': x|$x.description,
        'Carrier': x|$x.shipments(%2024-07-01).carrier
       ]
    ),
    MilestoningSameSchemeBothMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "ordertable_0".DESCRIPTION as "Order", "shipmenttable_0".CARRIER as "Carrier" ' +
    'from (select "ordertable_1".ID as ID, "ordertable_1".PRODUCTID as PRODUCTID, "ordertable_1".DESCRIPTION as DESCRIPTION, ' +
         '"ordertable_1".REFCODE as REFCODE, "ordertable_1".FROM_Z as FROM_Z, "ordertable_1".THRU_Z as THRU_Z ' +
         'from orderTable as "ordertable_1" ' +
         'where "ordertable_1".FROM_Z <= DATE\'2024-03-01\' and "ordertable_1".THRU_Z > DATE\'2024-03-01\') as "ordertable_0" ' +
    'left outer join (select "producttable_1".ID as ID, "producttable_1".ORDERID as ORDERID, "producttable_1".CODE as CODE, ' +
         '"producttable_1".CATEGORY as CATEGORY from productTable as "producttable_1") as "producttable_0" ' +
    'on ("ordertable_0".ID = "producttable_0".ORDERID) ' +
    'left outer join (select "trackingtable_0".PREFIX as PREFIX, "shipmenttable_1".CARRIER as CARRIER ' +
         'from (select "shipmenttable_2".ID as ID, "shipmenttable_2".ORDERID as ORDERID, "shipmenttable_2".CARRIER as CARRIER, ' +
              '"shipmenttable_2".TRACKINGID as TRACKINGID, "shipmenttable_2".FROM_Z as FROM_Z, "shipmenttable_2".THRU_Z as THRU_Z ' +
              'from shipmentTable as "shipmenttable_2" ' +
              'where "shipmenttable_2".FROM_Z <= DATE\'2024-07-01\' and "shipmenttable_2".THRU_Z > DATE\'2024-07-01\') as "shipmenttable_1" ' +
         'left outer join (select "producttable_1".ID as ID, "producttable_1".SHIPMENTID as SHIPMENTID, "producttable_1".PREFIX as PREFIX ' +
              'from trackingTable as "producttable_1") as "trackingtable_0" ' +
         'on ("shipmenttable_1".ID = "trackingtable_0".SHIPMENTID)) as "shipmenttable_0" ' +
    'on ("producttable_0".CODE = "shipmenttable_0".PREFIX)';
  assertEquals($expectedSql, $result->sql());

  assertEquals( '#TDS\n' +
            '   Order,Carrier\n' +
            '   OrderA,TDSNull\n' +
            '   OrderB,DHL\n' +
            '   OrderB,UPS\n' +
            '#',
            $result.values->at(0)->sort([~'Order'->ascending(), ~'Carrier'->ascending()])->toString());
}

// =============================================================================
// Different milestoning schemes (Order=business, AuditEntry=processing)
//   Order at %2024-01-01, AuditEntry at %2024-01-01 10:00:00
//
// Expected: OrderA→Audit1.
// =============================================================================
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::modelJoin::milestoning::testMilestoningDiffScheme():Boolean[1]
{
  let orderCsv =
    'default\n' +
    'orderTable\n' +
    'ID,PRODUCTID,DESCRIPTION,REFCODE,FROM_Z,THRU_Z\n' +
    '1,1,OrderA,REF1,2023-01-01,2025-01-01\n' +
    '2,2,OrderB,REF2,2025-01-01,9999-12-31\n';

  let productCsv =
    'default\n' +
    'productTable\n' +
    'ID,ORDERID,CODE,CATEGORY\n' +
    '1,1,ALPHA,cat1\n' +
    '2,2,BETA,cat2\n';

  let auditCsv =
    'default\n' +
    'auditTable\n' +
    'ID,ENTITYREF,MESSAGE,IN_Z,OUT_Z\n' +
    '1,ALPHA,Audit1,2023-01-01 00:00:00,2025-01-01 00:00:00\n' +
    '2,ALPHA,Audit2,2025-01-01 00:00:00,9999-12-31 00:00:00\n' +
    '3,BETA,Audit3,2023-01-01 00:00:00,2025-01-01 00:00:00\n';

  let db = meta::relational::tests::mapping::modelJoin::milestoning::store::Db;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  meta::relational::tests::mapping::modelJoin::setupTestData([$orderCsv, $productCsv, $auditCsv], $db, $runtime);

  let result = execute(
    |Order.all(%2024-01-01)->project(
      ~[
        'Order': x|$x.description,
        'Audit': x|$x.auditEntries(%2024-01-01T10:00:00).message
       ]
    ),
    MilestoningDiffSchemeMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  let expectedSql =
    'select "ordertable_0".DESCRIPTION as "Order", "audittable_0".MESSAGE as "Audit" ' +
    'from (select "ordertable_1".ID as ID, "ordertable_1".PRODUCTID as PRODUCTID, "ordertable_1".DESCRIPTION as DESCRIPTION, ' +
         '"ordertable_1".REFCODE as REFCODE, "ordertable_1".FROM_Z as FROM_Z, "ordertable_1".THRU_Z as THRU_Z ' +
         'from orderTable as "ordertable_1" ' +
         'where "ordertable_1".FROM_Z <= DATE\'2024-01-01\' and "ordertable_1".THRU_Z > DATE\'2024-01-01\') as "ordertable_0" ' +
    'left outer join (select "producttable_1".ID as ID, "producttable_1".ORDERID as ORDERID, "producttable_1".CODE as CODE, ' +
         '"producttable_1".CATEGORY as CATEGORY from productTable as "producttable_1") as "producttable_0" ' +
    'on ("ordertable_0".ID = "producttable_0".ORDERID) ' +
    'left outer join (select "audittable_1".ID as ID, "audittable_1".ENTITYREF as ENTITYREF, "audittable_1".MESSAGE as MESSAGE, ' +
         '"audittable_1".IN_Z as IN_Z, "audittable_1".OUT_Z as OUT_Z from auditTable as "audittable_1" ' +
         'where "audittable_1".IN_Z <= TIMESTAMP\'2024-01-01 10:00:00\' and "audittable_1".OUT_Z > TIMESTAMP\'2024-01-01 10:00:00\') as "audittable_0" ' +
    'on ("producttable_0".CODE = "audittable_0".ENTITYREF)';
  assertEquals($expectedSql, $result->sql());

  assertEquals( '#TDS\n' +
            '   Order,Audit\n' +
            '   OrderA,Audit1\n' +
            '#',
            $result.values->at(0)->sort([~'Order'->ascending()])->toString());
}

// =============================================================================
