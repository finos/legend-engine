  let trackingMilCsv =
    'default\n' +
    'trackingMilTable\n' +
    'ID,SHIPMENTID,PREFIX,FROM_Z,THRU_Z\n' +
    '1,1,ALPHA,2024-01-01,2024-06-01\n' +
