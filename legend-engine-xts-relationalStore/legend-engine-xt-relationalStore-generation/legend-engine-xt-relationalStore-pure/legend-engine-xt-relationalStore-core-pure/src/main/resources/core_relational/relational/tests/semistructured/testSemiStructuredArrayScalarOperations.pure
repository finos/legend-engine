function meta::relational::tests::semistructured::flattening::arrayScalarExecute(conn: Connection[1], func: String[1], mapping: String[1], expected: String[1]):Boolean[1]
{
  let csv =
        'PERSON_SCHEMA\n' +
        'PERSON_TABLE\n' +
        'ID,FIRSTNAME,LASTNAME,FIRM_DETAILS,MANAGERID\n' +
        '1,Peter,Smith,"{\\"legalName\\": \\"Firm X\\", \\"otherNames\\": [\\"O1\\", \\"O2\\"], \\"addresses\\": [{\\"name\\": \\"A1\\"}, {\\"name\\": \\"A11\\"}]}",2\n' +
        '2,John,Johnson,"{\\"legalName\\": \\"Firm X\\", \\"otherNames\\": [\\"O1\\", \\"O2\\"], \\"addresses\\": [{\\"name\\": \\"A2\\"}, {\\"name\\": \\"A22\\"}]}",4\n' +
        '3,John,Hill,"{\\"legalName\\": \\"Firm X\\", \\"otherNames\\": [\\"O1\\", \\"O2\\"], \\"addresses\\": [{\\"name\\": \\"A3\\"}, {\\"name\\": \\"A32\\"}]}",2\n' +
        '4,Anthony,Allen,"{\\"legalName\\": \\"Firm X\\", \\"otherNames\\": [\\"O1\\", \\"O2\\"], \\"addresses\\": [{\\"name\\": \\"A4\\"}]}",\n' +
        '5,Fabrice,Roberts,"{\\"legalName\\": \\"Firm A\\", \\"otherNames\\": [\\"O3\\", \\"O4\\"], \\"addresses\\": [{\\"name\\": \\"A5\\"}, {\\"name\\": \\"A52\\"}]}",\n' +
        '6,Oliver,Hill,"{\\"legalName\\": \\"Firm B\\", \\"otherNames\\": [\\"O5\\", \\"O6\\"], \\"addresses\\": [{\\"name\\": \\"A6\\"}]}",7\n' +
        '7,David,Harris,"{\\"legalName\\": \\"Firm B\\", \\"otherNames\\": [\\"O5\\", \\"O6\\"], \\"addresses\\": [{\\"name\\": \\"A7\\"}]}",\n'
        ;

  let model = '/core_relational/relational/tests/semistructured/model/semiStructuredArrayScalarOperations.legend';
  let store = 'flatten::store::H2DB';

  meta::relational::metamodel::execute::tests::executeLegendFunction($conn, $csv, $model, $func, $mapping, $store, $expected);
}

function <<paramTest.Test>> meta::relational::tests::semistructured::flattening::testSemiStructuredArrayDirectIsEmpty(conn: Connection[1]):Boolean[1]
{
  arrayScalarExecute($conn,
    'flatten::semiStructuredArrayDirectIsEmpty__TabularDataSet_1_',
    'flatten::mapping::H2Mapping',
    'First Name,Firm Name,Has No Addresses\n' +
    'Anthony,Firm X,false\n' +
    'David,Firm B,false\n' +
    'Fabrice,Firm A,false\n' +
    'John,Firm X,false\n' +
    'John,Firm X,false\n' +
    'Oliver,Firm B,false\n' +
    'Peter,Firm X,false\n'
  );
}

