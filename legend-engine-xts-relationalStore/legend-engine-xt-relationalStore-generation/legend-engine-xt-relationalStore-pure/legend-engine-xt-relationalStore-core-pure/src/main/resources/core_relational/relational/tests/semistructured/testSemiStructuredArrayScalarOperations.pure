function meta::relational::tests::semistructured::flattening::semiRecordExecute(conn: Connection[1], func: String[1], expected: String[1]):Boolean[1]
{
  let csv =
        'SEMI_SCHEMA\n' +
        'RECORD_TABLE\n' +
        'ID,FIRSTNAME,CONTENT\n' +
        '1,Peter,"{\\"payload\\": {\\"recordId\\": \\"R1\\", \\"recordVersion\\": 1, \\"revision\\": 1, \\"section\\": \\"GroupA\\", \\"batchId\\": \\"B1\\", \\"action\\": \\"CREATE\\", \\"tags\\": [{\\"code\\": \\"P1\\", \\"category\\": \\"Primary\\"}, {\\"code\\": \\"S1\\", \\"category\\": \\"Secondary\\"}], \\"participants\\": [{\\"participantId\\": \\"A1\\", \\"role\\": \\"Active\\"}, {\\"participantId\\": \\"V1\\", \\"role\\": \\"Passive\\"}], \\"lineItems\\": [{\\"itemId\\": \\"L1\\", \\"itemVersion\\": 1}, {\\"itemId\\": \\"L2\\", \\"itemVersion\\": 2}]}}"\n' +
        '2,Fabrice,"{\\"payload\\": {\\"recordId\\": \\"R2\\", \\"recordVersion\\": 1, \\"revision\\": 1, \\"section\\": \\"GroupA\\", \\"batchId\\": \\"B2\\", \\"action\\": \\"UPDATE\\", \\"tags\\": [{\\"code\\": \\"S2\\", \\"category\\": \\"Secondary\\"}, {\\"code\\": \\"X2\\", \\"category\\": \\"Other\\"}], \\"participants\\": [{\\"participantId\\": \\"V2\\", \\"role\\": \\"Passive\\"}, {\\"participantId\\": \\"Z2\\", \\"role\\": \\"Other\\"}], \\"lineItems\\": [{\\"itemId\\": \\"L3\\", \\"itemVersion\\": 1}, {\\"itemId\\": \\"L4\\", \\"itemVersion\\": 2}]}}"\n' +
        '3,Anthony,"{\\"payload\\": {\\"recordId\\": \\"R3\\", \\"recordVersion\\": 1, \\"revision\\": 1, \\"section\\": \\"GroupA\\", \\"batchId\\": \\"B3\\", \\"action\\": \\"CREATE\\", \\"tags\\": [{\\"code\\": \\"X3\\", \\"category\\": \\"Other\\"}, {\\"code\\": \\"Y3\\", \\"category\\": \\"Unknown\\"}], \\"participants\\": [{\\"participantId\\": \\"Z3\\", \\"role\\": \\"Other\\"}, {\\"participantId\\": \\"W3\\", \\"role\\": \\"Unknown\\"}], \\"lineItems\\": [{\\"itemId\\": \\"L5\\", \\"itemVersion\\": 1}, {\\"itemId\\": \\"L6\\", \\"itemVersion\\": 2}]}}"\n'
        ;

  let model = '/core_relational/relational/tests/semistructured/model/semiStructuredArrayScalarOperations.legend';
  let store = 'flatten::store::SemiDB';

  meta::relational::metamodel::execute::tests::executeLegendFunction($conn, $csv, $model, $func, 'flatten::mapping::SemiRecordMapping', $store, $expected);
}

function <<paramTest.Test>> meta::relational::tests::semistructured::flattening::testMultiArrayOlapWithNestedIfExists(conn: Connection[1]):Boolean[1]
{
  semiRecordExecute($conn,
    'flatten::multiArrayOlapWithNestedIfExists__TabularDataSet_1_',
    'recordId,recordVersion,revision,section,batchId,action,tagCode,tagCategory,_tagCategoryRanking,participantId,_participantRoleRanking,itemId,itemVersion,_revisionRecencyIndex,_versionRecencyIndex,_tagCategoryRankingIndex,_participantRoleRankingIndex\n' +
    'R1,1,1,GroupA,B1,CREATE,P1,Primary,1,A1,1,L1,1,1,1,1,1\n' +
    'R1,1,1,GroupA,B1,CREATE,P1,Primary,1,A1,1,L2,2,1,1,1,1\n' +
    'R2,1,1,GroupA,B2,UPDATE,S2,Secondary,2,V2,2,L3,1,1,1,1,1\n' +
    'R2,1,1,GroupA,B2,UPDATE,S2,Secondary,2,V2,2,L4,2,1,1,1,1\n' +
    'R3,1,1,GroupA,B3,CREATE,X3,Other,999,W3,999,L5,1,1,1,1,1\n' +
    'R3,1,1,GroupA,B3,CREATE,X3,Other,999,W3,999,L6,2,1,1,1,1\n' +
    'R3,1,1,GroupA,B3,CREATE,X3,Other,999,Z3,999,L5,1,1,1,1,1\n' +
    'R3,1,1,GroupA,B3,CREATE,X3,Other,999,Z3,999,L6,2,1,1,1,1\n' +
    'R3,1,1,GroupA,B3,CREATE,Y3,Unknown,999,W3,999,L5,1,1,1,1,1\n' +
    'R3,1,1,GroupA,B3,CREATE,Y3,Unknown,999,W3,999,L6,2,1,1,1,1\n' +
    'R3,1,1,GroupA,B3,CREATE,Y3,Unknown,999,Z3,999,L5,1,1,1,1,1\n' +
    'R3,1,1,GroupA,B3,CREATE,Y3,Unknown,999,Z3,999,L6,2,1,1,1,1\n'
  );
}
