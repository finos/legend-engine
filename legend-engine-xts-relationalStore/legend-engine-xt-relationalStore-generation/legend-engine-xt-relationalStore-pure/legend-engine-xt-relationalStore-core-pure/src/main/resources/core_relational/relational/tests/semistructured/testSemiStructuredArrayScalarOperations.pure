// ===========================================================================================================
// Tests for scalar operations on semi-structured arrays (filter->isEmpty, filter->first, filter->size, etc.)
//
// These tests verify that scalar operations on filtered/mapped semi-structured arrays produce correct SQL
// without triggering the auto-flatten (LATERAL FLATTEN) behavior. The key mechanism is the disableAutoFlatten
// flag which suppresses row-expansion and instead generates vendor-specific scalar array functions
// (e.g. Snowflake's FILTER, ARRAY_SIZE, etc.).
//
// Covered patterns:
//   - filter()->isEmpty()       : scalar boolean — is the filtered array empty?
//   - filter()->first().prop    : scalar extraction — get a property from the first matching element
//   - filter()->at(n).prop      : scalar extraction — get a property from the nth matching element
//   - filter()->size()          : scalar integer — count of matching elements
//   - filter()->map(a|a.prop)   : array projection — extract a property from each matching element (still to-many)
//   - filter()->fold(fn, init)  : scalar aggregation — fold/reduce over matching elements
//   - if(cond, filter()->first().prop, fallback) : scalar extraction within conditional logic
//
// The query functions are defined in semiStructuredFlattening.legend alongside the shared model/mapping/store.
// ===========================================================================================================

import meta::relational::tests::semistructured::flattening::*;

function <<paramTest.Test>> meta::relational::tests::semistructured::flattening::testSemiStructuredArrayFilterWithIsEmpty(conn: Connection[1]):Boolean[1]
{
  semiStructuredExecute($conn,
    'flatten::semiStructuredArrayFilterWithIsEmpty__TabularDataSet_1_',
    'flatten::mapping::H2Mapping',
    'First Name,Firm Name,Has No Matching Address\n' +
    'Anthony,Firm X,true\n' +
    'David,Firm B,true\n' +
    'Fabrice,Firm A,true\n' +
    'John,Firm X,true\n' +
    'John,Firm X,true\n' +
    'Oliver,Firm B,true\n' +
    'Peter,Firm X,false\n'
  );
}

function <<paramTest.Test>> meta::relational::tests::semistructured::flattening::testSemiStructuredArrayFilterOnly(conn: Connection[1]):Boolean[1]
{
  semiStructuredExecute($conn,
    'flatten::semiStructuredArrayFilterOnly__TabularDataSet_1_',
    'flatten::mapping::H2Mapping',
    'First Name,Firm Name,Filtered Address Name\n' +
    'Peter,Firm X,A1\n' +
    'Peter,Firm X,A11\n'
  );
}

