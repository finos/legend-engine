// =========================================================================
// Simple equality: employees.firmId == firm.id
// =========================================================================
Mapping meta::relational::tests::mapping::modelJoin::simple::SimpleEqualityMapping
(
  *meta::relational::tests::mapping::modelJoin::domain::Person[person]: Relation
  {
    ~func meta::relational::tests::mapping::modelJoin::function::personTable():Relation<Any>[1]
    firstName: FIRSTNAME,
    lastName: LASTNAME,
    age: AGE,
    +firmId: Integer[1]: FIRMID,
    +id: Integer[1]: ID
  }
  *meta::relational::tests::mapping::modelJoin::domain::Firm[firm]: Relation
  {
    ~func meta::relational::tests::mapping::modelJoin::function::firmTable():Relation<Any>[1]
    legalName: LEGALNAME,
    +id: Integer[1]: ID,
    +code: String[0..1]: CODE
  }

  *meta::relational::tests::mapping::modelJoin::domain::Person_Firm: ModelJoin
  {
    {employees: meta::relational::tests::mapping::modelJoin::domain::Person[1], firm: meta::relational::tests::mapping::modelJoin::domain::Firm[1]|$employees.firmId == $firm.id}
  }
)

