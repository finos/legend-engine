###Relational
Database meta::relational::tests::mapping::modelJoin::store::Db
(
  // Columns property-mapped to [1] properties via ~func Relation mappings are
  // NOT NULL so they satisfy the strict multiplicity check; columns mapped to
  // [0..1] properties (firmTable.{CITY,COUNTRY,CODE}, departmentTable.CODE,
  // projectTable.CITY) stay nullable. personTable.SALARY is intentionally
  // nullable to drive the [0..1]-column → [0..1]-property NullableSalaryMapping.
  Schema default
  (
    Table firmTable
    (
      ID INTEGER PRIMARY KEY,
      LEGALNAME VARCHAR(100) NOT NULL,
      CITY VARCHAR(100),
      COUNTRY VARCHAR(100),
      CODE VARCHAR(50)
    )

    Table personTable
    (
      ID INTEGER PRIMARY KEY,
      FIRSTNAME VARCHAR(100) NOT NULL,
      LASTNAME VARCHAR(100) NOT NULL,
      FIRMID INTEGER NOT NULL,
      AGE INTEGER NOT NULL,
      SALARY FLOAT
    )

    Table addressTable
    (
      ID INTEGER PRIMARY KEY,
      PERSONID INTEGER NOT NULL,
      CITY VARCHAR(100) NOT NULL,
      COUNTRY VARCHAR(100) NOT NULL
    )

    Table headquartersTable
    (
      ID INTEGER PRIMARY KEY,
      FIRMID INTEGER NOT NULL,
      CITY VARCHAR(100) NOT NULL,
      COUNTRY VARCHAR(100) NOT NULL
    )

    Table departmentTable
    (
      ID INTEGER PRIMARY KEY,
      FIRMID INTEGER NOT NULL,
      NAME VARCHAR(100) NOT NULL,
      CODE VARCHAR(50)
    )

    Table projectTable
    (
      ID INTEGER PRIMARY KEY,
      DEPTID INTEGER NOT NULL,
      NAME VARCHAR(100) NOT NULL,
      CITY VARCHAR(100)
    )

    Table profileTable
    (
      ID INTEGER PRIMARY KEY,
      PERSONID INTEGER NOT NULL,
      RANK VARCHAR(50) NOT NULL
    )
  )

  Filter ActivePersonFilter(default.personTable.AGE > 25)
  Filter ProfileRankFilter(default.profileTable.RANK = 'US')

  Join PersonAddress(default.personTable.ID = default.addressTable.PERSONID)
  Join PersonProfile(default.personTable.ID = default.profileTable.PERSONID)
)

