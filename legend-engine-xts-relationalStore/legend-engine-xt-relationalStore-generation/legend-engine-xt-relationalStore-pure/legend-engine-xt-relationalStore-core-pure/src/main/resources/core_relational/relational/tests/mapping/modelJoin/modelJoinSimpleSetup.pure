function meta::relational::tests::mapping::modelJoin::function::personTable(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::modelJoin::store::Db.personTable}#->select(~[ID, FIRSTNAME, LASTNAME, FIRMID, AGE])
}

