// =========================================================================
// Nullable-column → [0..1]-property mapping under strict multiplicity check.
// SALARY is the lone nullable column on personTable; PersonWithOptionalSalary.salary
// is Float[0..1]. The bare-column `salary: SALARY` lowers (in legend-pure) to
// `{src | $src.SALARY}` which preserves the [0..1] inferred multiplicity end to end.
// Uses personTableWithSalary() so existing tests' personTable() projections are
// unchanged.
// =========================================================================
Mapping meta::relational::tests::mapping::modelJoin::simple::NullableSalaryMapping
(
  *meta::relational::tests::mapping::modelJoin::domain::PersonWithOptionalSalary[personWithSalary]: Relation
  {
    ~func meta::relational::tests::mapping::modelJoin::function::personTableWithSalary():Relation<Any>[1]
    firstName: FIRSTNAME,
    lastName: LASTNAME,
    age: AGE,
    salary: SALARY
  }
)

