// =========================================================================
// Helper: load CSV data into H2 test database
// =========================================================================
function meta::relational::tests::mapping::modelJoin::setupTestData(csvs: String[*], db: Database[1], runtime: Runtime[1]):Boolean[1]
{
  let connection = $runtime.connectionByElement($db)->cast(@meta::external::store::relational::runtime::TestDatabaseConnection);
  let dbConfig = meta::relational::functions::sqlQueryToString::createDbConfig($connection.type);
  let sqls = $csvs->joinStrings('\n-\n')->meta::alloy::service::execution::setUpDataSQLsV2($db, $dbConfig);
  $sqls->map(sql | meta::relational::metamodel::execute::executeInDb($sql, $connection));
  true;
}

