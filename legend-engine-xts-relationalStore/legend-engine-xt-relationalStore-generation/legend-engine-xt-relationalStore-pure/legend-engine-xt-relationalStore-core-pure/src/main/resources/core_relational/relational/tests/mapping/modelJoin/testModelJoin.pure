// =============================================================================
// Test R23: Both sides milestoned same scheme — Relational class mappings
//   Same scenario as Test 23 but with Relational mappings.
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinRelationalMilestoningSameScheme():Boolean[1]
{
  let orderCsv =
    'default\n' +
    'orderTable\n' +
    'ID,PRODUCTID,DESCRIPTION,REFCODE,FROM_Z,THRU_Z\n' +
    '1,1,OrderA,REF1,2023-01-01,2024-06-01\n' +
    '2,2,OrderB,REF2,2024-01-01,2025-01-01\n' +
    '3,3,OrderC,REF3,2024-06-01,2025-01-01\n';

  let productCsv =
    'default\n' +
    'productTable\n' +
    'ID,ORDERID,CODE,CATEGORY\n' +
    '1,1,ALPHA,cat1\n' +
    '2,2,BETA,cat2\n' +
    '3,3,ALPHA,cat3\n';

  let shipmentCsv =
    'default\n' +
    'shipmentTable\n' +
    'ID,ORDERID,CARRIER,TRACKINGID,FROM_Z,THRU_Z\n' +
    '1,1,FedEx,1,2024-01-01,2024-06-01\n' +
    '2,1,DHL,2,2024-06-01,2025-01-01\n' +
    '3,2,UPS,3,2024-01-01,2025-01-01\n';

  let trackingCsv =
    'default\n' +
    'trackingTable\n' +
    'ID,SHIPMENTID,PREFIX\n' +
    '1,1,ALPHA\n' +
    '2,2,BETA\n' +
    '3,3,BETA\n';

  let expected =
    'Order,Carrier\n' +
    'OrderA,null\n' +
    'OrderB,DHL\n' +
    'OrderB,UPS\n';

  let expectedSql = 'select "root".DESCRIPTION as "Order", "shipmenttable_0".CARRIER as "Carrier" from orderTable as "root" left outer join productTable as "producttable_0" on ("root".ID = "producttable_0".ORDERID) left outer join (select "root".CARRIER as "carrier", "root".ID as "id", "root".ORDERID as "orderId", "root".TRACKINGID as "trackingId", \'2024-07-01\' as "k_businessDate", "trackingtable_0".PREFIX as PREFIX, "root".CARRIER as CARRIER from shipmentTable as "root" left outer join trackingTable as "trackingtable_0" on ("root".ID = "trackingtable_0".SHIPMENTID) where "root".FROM_Z <= DATE\'2024-07-01\' and "root".THRU_Z > DATE\'2024-07-01\') as "shipmenttable_0" on ("producttable_0".CODE = "shipmenttable_0".PREFIX) where "root".FROM_Z <= DATE\'2024-03-01\' and "root".THRU_Z > DATE\'2024-03-01';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoinAdvanced.legend',
    'showcase::modelJoinTests::advanced::query::orderWithShipments__Relation_1_',
    'showcase::modelJoinTests::advanced::mapping::relational::MilestoningSameSchemeBothMapping',
    'showcase::modelJoinTests::advanced::store::Database',
    'showcase::modelJoinTests::advanced::connection::H2Connection',
    [$orderCsv, $productCsv, $shipmentCsv, $trackingCsv],
    $expected,
    $expectedSql
  );
}

