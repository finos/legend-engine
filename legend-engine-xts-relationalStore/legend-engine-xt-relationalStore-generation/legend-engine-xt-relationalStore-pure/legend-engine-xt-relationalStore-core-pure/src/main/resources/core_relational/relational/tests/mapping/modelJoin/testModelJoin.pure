// =============================================================================
// Test: 2x2 union with subType in query on source class
//   Person = union(fullTime, contract) mapped as ExtendedPerson
//   Firm = union(firmA, firmB)
//   Condition: employees.firmId == firm.id
//   Query uses ->subType(@ExtendedPerson).employeeCode on source
//
// Data:
//   fullTimeTable: (1, Alice, ACODE, 1, 30)  — LASTNAME used as employeeCode
//   contractTable: (2, Bob, BCODE, 2, 25)
//   firmTable:  (1, Apple)
//   firmTableB: (2, Google)
//
// Expected: Apple←null, Google←BCODE
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinUnionWithSubtypeQuery():Boolean[1]
{
  let fullTimeCsv =
    'default\n' +
    'fullTimeTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,ACODE,1,30\n';

  let contractCsv =
    'default\n' +
    'contractTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '2,Bob,BCODE,2,25\n';

  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n';

  let firmBCsv =
    'default\n' +
    'firmTableB\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '2,Google,,,\n';

  let expected =
    'Legal Name,Employee Code\n' +
    'Apple,null\n' +
    'Google,BCODE\n';

  let expectedSql = 'select "unionBase"."firmTableLEGALNAME_firmTableBLEGALNAME" as "Legal Name", "contracttable_0".LASTNAME as "Employee Code" from (select "root".ID as "pk_0_0", null as "pk_0_1", "root".LEGALNAME as "firmTableLEGALNAME_firmTableBLEGALNAME", "root".ID as id from firmTable as "root" union all select null as "pk_0_0", "root".ID as "pk_0_1", "root".LEGALNAME as "firmTableLEGALNAME_firmTableBLEGALNAME", "root".ID as id from firmTableB as "root") as "unionBase" left outer join contractTable as "contracttable_0" on ("contracttable_0".FIRMID = "unionBase".id)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoinAdvanced.legend',
    'showcase::modelJoinTests::advanced::query::firmWithExtendedEmployees__Relation_1_',
    'showcase::modelJoinTests::advanced::mapping::UnionWithSubtypeQueryMapping',
    'showcase::modelJoinTests::advanced::store::Database',
    'showcase::modelJoinTests::advanced::connection::H2Connection',
    [$fullTimeCsv, $contractCsv, $firmCsv, $firmBCsv],
    $expected,
    $expectedSql
  );
}

// =============================================================================
// Test: Relational union + sub-aggregation
//   Person = union(fullTimeTable, contractTable), Firm = simple
//   Query: Firm.all()->project(~[legalName, employees->count()])
//   Sub-aggregation (count) across union-mapped model join association.
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinRelationalUnionSubAggregation():Boolean[1]
{
  let fullTimeCsv =
    'default\n' +
    'fullTimeTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n';

  let contractCsv =
    'default\n' +
    'contractTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '2,Bob,Jones,1,25\n' +
    '3,Charlie,Brown,2,35\n';

  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  // Apple has 2 employees (Alice from fullTime + Bob from contract)
  // Google has 1 employee (Charlie from contract)
  let expected =
    'Legal Name,Employee Count\n' +
    'Apple,2\n' +
    'Google,1\n';

  let expectedSql = 'select "root".LEGALNAME as "Legal Name", "firmtable_1".aggCol as "Employee Count" from firmTable as "root" left outer join (select "firmtable_2".ID as ID, count(*) as aggCol from firmTable as "firmtable_2" left outer join (select "root".FIRMID as firmId from fullTimeTable as "root" union all select "root".FIRMID as firmId from contractTable as "root") as "unionalias_0" on ("unionalias_0".firmId = "firmtable_2".ID) group by "firmtable_2".ID) as "firmtable_1" on ("root".ID = "firmtable_1".ID)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoinAdvanced.legend',
    'showcase::modelJoinTests::advanced::query::firmWithEmployeeCount__Relation_1_',
    'showcase::modelJoinTests::advanced::mapping::UnionWithExistsMapping',
    'showcase::modelJoinTests::advanced::store::Database',
    'showcase::modelJoinTests::advanced::connection::H2Connection',
    [$fullTimeCsv, $contractCsv, $firmCsv],
    $expected,
    $expectedSql
  );
}

// =============================================================================
// Test: Relational sub-filter (no union)
//   Person, Address, Firm all Relational class mappings
//   Condition: employees.address.city == firm.city && employees.address.country == firm.country
//   Query: sub-filter employees->filter(e | e.address.city == 'NYC').firstName
//   Relational equivalent of testModelJoinSubFilter (which uses Relation function mappings)
// =============================================================================
function <<test.ToFix>> meta::relational::tests::mapping::relation::testModelJoinRelationalSubFilter():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,NYC,US\n' +
    '2,Google,,London,UK\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n' +
    '3,3,NYC,US\n';

  // Apple(NYC,US): employees matched by city/country = Alice(NYC,US), Charlie(NYC,US)
  //   sub-filter city=='NYC' → Alice, Charlie
  // Google(London,UK): employee = Bob(London,UK)
  //   sub-filter city=='NYC' → none
  let expected =
    'Legal Name,NYC Employee\n' +
    'Apple,Alice\n' +
    'Apple,Charlie\n' +
    'Google,null\n';

  let expectedSql = '';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::firmWithFilteredEmployees__Relation_1_',
    'showcase::modelJoinTests::mapping::relational::NestedPropertyChainMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv, $addressCsv],
    $expected,
    $expectedSql
  );
}

