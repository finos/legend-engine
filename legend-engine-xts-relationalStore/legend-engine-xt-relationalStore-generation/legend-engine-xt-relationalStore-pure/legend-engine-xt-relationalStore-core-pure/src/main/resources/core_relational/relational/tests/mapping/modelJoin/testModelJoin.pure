    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n' +
    '3,3,NYC,US\n';

  // Firm→Person via NestedPropertyChainMapping (address.city == firm.city && address.country == firm.country)
  // Then sub-filter: only employees whose address.city == 'NYC'
  // Apple(NYC,US): employees matched by city/country = Alice(NYC,US), Charlie(NYC,US)
