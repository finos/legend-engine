  let expectedSql = 'select "ordertable_0".DESCRIPTION as "Order", "warehousetable_0".NAME as "Warehouse" from (select "ordertable_1".ID as ID, "ordertable_1".PRODUCTID as PRODUCTID, "ordertable_1".DESCRIPTION as DESCRIPTION, "ordertable_1".REFCODE as REFCODE, "ordertable_1".FROM_Z as FROM_Z, "ordertable_1".THRU_Z as THRU_Z from orderTable as "ordertable_1" where "ordertable_1".FROM_Z <= DATE\'2024-01-01\' and "ordertable_1".THRU_Z > DATE\'2024-01-01\') as "ordertable_0" left outer join (select "producttable_1".ID as ID, "producttable_1".ORDERID as ORDERID, "producttable_1".CODE as CODE, "producttable_1".CATEGORY as CATEGORY from productTable as "producttable_1") as "producttable_0" on ("ordertable_0".ID = "producttable_0".ORDERID) left outer join (select "sectiontable_0".ZONE as ZONE, "warehousetable_1".NAME as NAME from (select "warehousetable_2".ID as ID, "warehousetable_2".NAME as NAME, "warehousetable_2".SECTIONID as SECTIONID from warehouseTable as "warehousetable_2") as "warehousetable_1" left outer join (select "producttable_1".ID as ID, "producttable_1".WAREHOUSEID as WAREHOUSEID, "producttable_1".ZONE as ZONE from sectionTable as "producttable_1") as "sectiontable_0" on ("warehousetable_1".ID = "sectiontable_0".WAREHOUSEID)) as "warehousetable_0" on ("producttable_0".CATEGORY = "warehousetable_0".ZONE)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoinAdvanced.legend',
    'showcase::modelJoinTests::advanced::query::orderWithWarehouse__Relation_1_',
    'showcase::modelJoinTests::advanced::mapping::MilestonedOrderWarehouseMapping',
