// =============================================================================
// Test: Union source + exists() in query filter
//   Person is union (fullTime + contract), Firm is simple
//   Query: Firm.all()->filter(f | $f.employees->exists(e | $e.age > 30))->project(...)
//   Only firms that have at least one employee with age > 30 are included.
//   Tests combination of union processing with exists-style filter.
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinUnionWithExistsFilter():Boolean[1]
{
  let fullTimeCsv =
    'default\n' +
    'fullTimeTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,25\n';

  let contractCsv =
    'default\n' +
    'contractTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '3,Charlie,Brown,2,35\n' +
    '4,Diana,White,3,22\n';

  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n' +
    '3,Meta,,,\n';

  let expected =
    'Legal Name,Employee First Name\n' +
    'Google,Charlie\n';

  let expectedSql = 'select "root".LEGALNAME as "Legal Name", "unionalias_0"."fullTimeTableFIRSTNAME_contractTableFIRSTNAME" as "Employee First Name" from firmTable as "root" left outer join (select "root".FIRMID as firmId, "root".FIRSTNAME as "fullTimeTableFIRSTNAME_contractTableFIRSTNAME" from fullTimeTable as "root" union all select "root".FIRMID as firmId, "root".FIRSTNAME as "fullTimeTableFIRSTNAME_contractTableFIRSTNAME" from contractTable as "root") as "unionalias_0" on ("unionalias_0".firmId = "root".ID) where exists (select 1 from (select "root".FIRMID as firmId, "root".AGE as "fullTimeTableAGE_contractTableAGE" from fullTimeTable as "root" union all select "root".FIRMID as firmId, "root".AGE as "fullTimeTableAGE_contractTableAGE" from contractTable as "root") as "unionalias_1" where "unionalias_1".firmId = "root".ID and "unionalias_1"."fullTimeTableAGE_contractTableAGE" > 30)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoinAdvanced.legend',
    'showcase::modelJoinTests::advanced::query::firmWithEmployeesExists__Relation_1_',
    'showcase::modelJoinTests::advanced::mapping::UnionWithExistsMapping',
    'showcase::modelJoinTests::advanced::store::Database',
    'showcase::modelJoinTests::advanced::connection::H2Connection',
    [$fullTimeCsv, $contractCsv, $firmCsv],
    $expected,
    $expectedSql
  );
}

