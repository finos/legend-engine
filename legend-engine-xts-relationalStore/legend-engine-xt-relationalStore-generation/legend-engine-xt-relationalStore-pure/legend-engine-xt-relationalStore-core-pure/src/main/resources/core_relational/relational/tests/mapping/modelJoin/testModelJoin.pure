// =============================================================================
// Test 18: Milestoning via model join
//   Person→Contract via model join, Contract is <<temporal.businesstemporal>>
//   Query passes business date: contracts(%2024-01-01)
//
// Data:
//   personTable: (1, 'Alice', 'Smith', 0, 30), (2, 'Bob', 'Jones', 0, 25)
//   contractLogTable: (1, 1, 'ContractA', 2023-01-01, 2025-01-01),
//                     (2, 1, 'ContractB', 2025-01-01, 2099-01-01),
//                     (3, 2, 'ContractC', 2023-06-01, 2024-06-01)
//
// Expected at businessDate=2024-01-01:
//   Alice → ContractA (2023-01-01 <= 2024-01-01 < 2025-01-01)
//   Bob → ContractC (2023-06-01 <= 2024-01-01 < 2024-06-01)
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinMilestoning():Boolean[1]
{
  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n';

  let contractCsv =
    'default\n' +
    'contractLogTable\n' +
    'ID,PERSONID,DESCRIPTION,FROM_Z,THRU_Z\n' +
    '1,1,ContractA,2023-01-01,2025-01-01\n' +
    '2,1,ContractB,2025-01-01,2099-01-01\n' +
    '3,2,ContractC,2023-06-01,2024-06-01\n';

  let expected =
    'First Name,Contract\n' +
    'Alice,ContractA\n' +
    'Bob,ContractC\n';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoinAdvanced.legend',
    'showcase::modelJoinTests::advanced::query::personWithContract__Relation_1_',
    'showcase::modelJoinTests::advanced::mapping::MilestonedMapping',
    'showcase::modelJoinTests::advanced::store::Database',
    'showcase::modelJoinTests::advanced::connection::H2Connection',
    [$personCsv, $contractCsv],
    $expected,
    true
  );
}

