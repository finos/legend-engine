    'Google,Charlie\n';

  let expectedSql = 'select "root".LEGALNAME as "Legal Name", "persontable_0".FIRSTNAME as "Employee First Name" from firmTable as "root" left outer join (select "root".FIRSTNAME as "firstName", "root".LASTNAME as "lastName", "root".AGE as "age", "root".ID as "id", "root".FIRMID as "firmId", "addresstable_0".CITY as CITY, "root".FIRSTNAME as FIRSTNAME from personTable as "root" left outer join addressTable as "addresstable_0" on ("root".ID = "addresstable_0".PERSONID) where "root".AGE > 25) as "persontable_0" on ("persontable_0".CITY = "root".CITY)';

  executeLegendFunction(
