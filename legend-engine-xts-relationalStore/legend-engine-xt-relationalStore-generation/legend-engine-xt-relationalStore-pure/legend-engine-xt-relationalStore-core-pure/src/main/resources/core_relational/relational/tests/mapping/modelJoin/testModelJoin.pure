    'Apple,Bob\n' +
    'Meta,Charlie\n' +
    '';

  let expectedSql = 'select "unionBase"."firmTableLEGALNAME_firmTableBLEGALNAME" as "Legal Name", "unionalias_1"."fullTimeTableFIRSTNAME_contractTableFIRSTNAME" as "Employee First Name" from (select "root".ID as "pk_0_0", null as "pk_0_1", "root".LEGALNAME as "firmTableLEGALNAME_firmTableBLEGALNAME", "root".ID as id from firmTable as "root" union all select null as "pk_0_0", "root".ID as "pk_0_1", "root".LEGALNAME as "firmTableLEGALNAME_firmTableBLEGALNAME", "root".ID as id from firmTableB as "root") as "unionBase" left outer join (select "root".FIRMID as firmId, "root".FIRSTNAME as "fullTimeTableFIRSTNAME_contractTableFIRSTNAME" from fullTimeTable as "root" union all select "root".FIRMID as firmId, "root".FIRSTNAME as "fullTimeTableFIRSTNAME_contractTableFIRSTNAME" from contractTable as "root") as "unionalias_1" on ("unionalias_1".firmId = "unionBase".id)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoinAdvanced.legend',
    'showcase::modelJoinTests::advanced::query::firmWithEmployees__Relation_1_',
