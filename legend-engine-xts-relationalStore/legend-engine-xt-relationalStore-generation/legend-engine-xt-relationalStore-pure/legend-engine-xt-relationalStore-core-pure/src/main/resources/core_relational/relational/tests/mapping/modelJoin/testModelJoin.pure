// =============================================================================
// Qualified property in query that traverses model joins
//   Firm.employeesInCity('NYC') — the qualified property body uses
//   $this.employees (model join) and $emp.address (model join).
//   Tests that the engine resolves qualified property bodies that
//   internally traverse model-join-mapped associations.
//
// Data:
//   firmTable: (1, 'Apple', '', 'NYC', 'US'), (2, 'Google', '', 'London', 'UK')
//   personTable: (1, 'Alice', 'Smith', 0, 30), (2, 'Bob', 'Jones', 0, 25), (3, 'Charlie', 'Brown', 0, 35)
//   addressTable: (1, 1, 'NYC', 'US'), (2, 2, 'London', 'UK'), (3, 3, 'NYC', 'US')
//
// Expected:
//   Apple(NYC) employees matched by city/country: Alice(NYC,US), Charlie(NYC,US)
//     filtered by employeesInCity('NYC'): Alice, Charlie
//   Google(London) employees matched: Bob(London,UK)
//     filtered by employeesInCity('NYC'): none → null
// =============================================================================
function <<test.ToFix>> meta::relational::tests::mapping::relation::testModelJoinQualifiedPropertyInQuery():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,NYC,US\n' +
    '2,Google,,London,UK\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n' +
    '3,3,NYC,US\n';

  let expected =
    'Legal Name,Employee In NYC\n' +
    'Apple,Alice\n' +
    'Apple,Charlie\n' +
    'Google,null\n';

  let expectedSql = 'select "firmtable_0".LEGALNAME as "Legal Name", "persontable_0".FIRSTNAME as "Employee In NYC" from (select "firmtable_1".ID as ID, "firmtable_1".LEGALNAME as LEGALNAME, "firmtable_1".CITY as CITY, "firmtable_1".COUNTRY as COUNTRY, "firmtable_1".CODE as CODE from firmTable as "firmtable_1") as "firmtable_0" left outer join (select "persontable_1".ID as ID, "persontable_1".FIRSTNAME as FIRSTNAME, "persontable_1".LASTNAME as LASTNAME, "persontable_1".FIRMID as FIRMID, "persontable_1".AGE as AGE, "addresstable_0".CITY as CITY, "addresstable_0".COUNTRY as COUNTRY from personTable as "persontable_1" left outer join (select "addresstable_1".ID as ID, "addresstable_1".PERSONID as PERSONID, "addresstable_1".CITY as CITY, "addresstable_1".COUNTRY as COUNTRY from addressTable as "addresstable_1") as "addresstable_0" on ("persontable_1".ID = "addresstable_0".PERSONID) left outer join (select "addresstable_3".ID as ID, "addresstable_3".PERSONID as PERSONID, "addresstable_3".CITY as CITY, "addresstable_3".COUNTRY as COUNTRY from addressTable as "addresstable_3") as "addresstable_2" on ("persontable_1".ID = "addresstable_2".PERSONID) where "addresstable_2".CITY = \'NYC\') as "persontable_0" on ("persontable_0".CITY = "firmtable_0".CITY and "persontable_0".COUNTRY = "firmtable_0".COUNTRY)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoinAdvanced.legend',
    'showcase::modelJoinTests::advanced::query::firmWithEmployeesInCity__Relation_1_',
    'showcase::modelJoinTests::advanced::mapping::QualifiedPropertyMapping',
    'showcase::modelJoinTests::advanced::store::Database',
    'showcase::modelJoinTests::advanced::connection::H2Connection',
    [$firmCsv, $personCsv, $addressCsv],
    $expected,
    $expectedSql,
    true
  );
}

// =============================================================================
// Test 21: Target milestoned (Order), source NOT milestoned (Warehouse)
//   Nested condition: orders.product.category == warehouse.section.zone
//   Only Order has milestoning → expect temporal filter on orderTable (target)
//
// Data:
//   orderTable: (1, 1, 'OrderA', 'REF1', 2023-01-01, 2025-01-01) — active at 2024-01-01
//               (2, 2, 'OrderB', 'REF2', 2025-01-01, 9999-12-31) — NOT active at 2024-01-01
//               (3, 3, 'OrderC', 'REF3', 2023-06-01, 2024-06-01) — active at 2024-01-01
//   productTable: (1, 1, 'ELEC', 'electronics'), (2, 2, 'ELEC', 'electronics'), (3, 3, 'FOOD', 'food')
//   warehouseTable: (1, 'WarehouseA', 1), (2, 'WarehouseB', 2)
//   sectionTable: (1, 1, 'electronics'), (2, 2, 'food')
//
// Expected at businessDate=2024-01-01:
//   WarehouseA (section.zone=electronics) → OrderA (product.category=electronics, active)
//   WarehouseB (section.zone=food) → OrderC (product.category=food, active)
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinMilestoningTargetOnly():Boolean[1]
{
  let orderCsv =
    'default\n' +
    'orderTable\n' +
    'ID,PRODUCTID,DESCRIPTION,REFCODE,FROM_Z,THRU_Z\n' +
    '1,1,OrderA,REF1,2023-01-01,2025-01-01\n' +
    '2,2,OrderB,REF2,2025-01-01,9999-12-31\n' +
    '3,3,OrderC,REF3,2023-06-01,2024-06-01\n';

  let productCsv =
    'default\n' +
    'productTable\n' +
    'ID,ORDERID,CODE,CATEGORY\n' +
    '1,1,ELEC,electronics\n' +
    '2,2,ELEC,electronics\n' +
    '3,3,FOOD,food\n';

  let warehouseCsv =
    'default\n' +
    'warehouseTable\n' +
    'ID,NAME,SECTIONID\n' +
    '1,WarehouseA,1\n' +
    '2,WarehouseB,2\n';

  let sectionCsv =
    'default\n' +
    'sectionTable\n' +
    'ID,WAREHOUSEID,ZONE\n' +
    '1,1,electronics\n' +
    '2,2,food\n';

  let expected =
    'Warehouse,Order\n' +
    'WarehouseA,OrderA\n' +
    'WarehouseB,OrderC\n';
  let expectedSql = 'select "warehousetable_0".NAME as "Warehouse", "ordertable_0".DESCRIPTION as "Order" from (select "warehousetable_1".ID as ID, "warehousetable_1".NAME as NAME, "warehousetable_1".SECTIONID as SECTIONID from warehouseTable as "warehousetable_1") as "warehousetable_0" left outer join (select "producttable_1".ID as ID, "producttable_1".WAREHOUSEID as WAREHOUSEID, "producttable_1".ZONE as ZONE from sectionTable as "producttable_1") as "sectiontable_0" on ("warehousetable_0".ID = "sectiontable_0".WAREHOUSEID) left outer join (select "producttable_0".CATEGORY as CATEGORY, "ordertable_1".DESCRIPTION as DESCRIPTION from (select "ordertable_2".ID as ID, "ordertable_2".PRODUCTID as PRODUCTID, "ordertable_2".DESCRIPTION as DESCRIPTION, "ordertable_2".REFCODE as REFCODE, "ordertable_2".FROM_Z as FROM_Z, "ordertable_2".THRU_Z as THRU_Z from orderTable as "ordertable_2" where "ordertable_2".FROM_Z <= DATE\'2024-01-01\' and "ordertable_2".THRU_Z > DATE\'2024-01-01\') as "ordertable_1" left outer join (select "producttable_1".ID as ID, "producttable_1".ORDERID as ORDERID, "producttable_1".CODE as CODE, "producttable_1".CATEGORY as CATEGORY from productTable as "producttable_1") as "producttable_0" on ("ordertable_1".ID = "producttable_0".ORDERID)) as "ordertable_0" on ("ordertable_0".CATEGORY = "sectiontable_0".ZONE)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoinAdvanced.legend',
    'showcase::modelJoinTests::advanced::query::warehouseWithOrders__Relation_1_',
    'showcase::modelJoinTests::advanced::mapping::MilestonedOrderWarehouseMapping',
    'showcase::modelJoinTests::advanced::store::Database',
    'showcase::modelJoinTests::advanced::connection::H2Connection',
    [$orderCsv, $productCsv, $warehouseCsv, $sectionCsv],
    $expected,
    $expectedSql
  );
}

// =============================================================================
// Test 22: Source milestoned (Order), target NOT milestoned (Warehouse)
//   Same ModelJoin as test 21 but inverted: Order.all(%2024-01-01)→warehouse.name
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinMilestoningSourceOnly():Boolean[1]
{
  let orderCsv =
    'default\n' +
    'orderTable\n' +
    'ID,PRODUCTID,DESCRIPTION,REFCODE,FROM_Z,THRU_Z\n' +
    '1,1,OrderA,REF1,2023-01-01,2025-01-01\n' +
    '2,2,OrderB,REF2,2025-01-01,9999-12-31\n' +
    '3,3,OrderC,REF3,2023-06-01,2024-06-01\n';

  let productCsv =
    'default\n' +
    'productTable\n' +
    'ID,ORDERID,CODE,CATEGORY\n' +
    '1,1,ELEC,electronics\n' +
    '2,2,ELEC,electronics\n' +
    '3,3,FOOD,food\n';

  let warehouseCsv =
    'default\n' +
