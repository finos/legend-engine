    'showcase::modelJoinTests::advanced::connection::H2Connection',
    [$orderCsv, $productCsv, $warehouseCsv, $sectionCsv],
    $expected,
    $expectedSql
  );
}

// =============================================================================
// Test 23: Both sides milestoned same scheme (Order + Shipment, both business)
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinMilestoningSameScheme():Boolean[1]
{
  let orderCsv =
    'default\n' +
    'orderTable\n' +
    'ID,PRODUCTID,DESCRIPTION,REFCODE,FROM_Z,THRU_Z\n' +
    '1,1,OrderA,REF1,2023-01-01,2024-06-01\n' +
    '2,2,OrderB,REF2,2024-01-01,2025-01-01\n' +
    '3,3,OrderC,REF3,2024-06-01,2025-01-01\n';

  let productCsv =
    'default\n' +
    'productTable\n' +
    'ID,ORDERID,CODE,CATEGORY\n' +
    '1,1,ALPHA,cat1\n' +
    '2,2,BETA,cat2\n' +
    '3,3,ALPHA,cat3\n';

  let shipmentCsv =
    'default\n' +
    'shipmentTable\n' +
    'ID,ORDERID,CARRIER,TRACKINGID,FROM_Z,THRU_Z\n' +
    '1,1,FedEx,1,2024-01-01,2024-06-01\n' +
    '2,1,DHL,2,2024-06-01,2025-01-01\n' +
    '3,2,UPS,3,2024-01-01,2025-01-01\n';

  let trackingCsv =
    'default\n' +
    'trackingTable\n' +
    'ID,SHIPMENTID,PREFIX\n' +
    '1,1,ALPHA\n' +
    '2,2,BETA\n' +
    '3,3,BETA\n';

  let expected =
    'Order,Carrier\n' +
    'OrderA,null\n' +
    'OrderB,DHL\n' +
    'OrderB,UPS\n';

  let expectedSql = 'select "ordertable_0".DESCRIPTION as "Order", "shipmenttable_0".CARRIER as "Carrier" from (select "ordertable_1".ID as ID, "ordertable_1".PRODUCTID as PRODUCTID, "ordertable_1".DESCRIPTION as DESCRIPTION, "ordertable_1".REFCODE as REFCODE, "ordertable_1".FROM_Z as FROM_Z, "ordertable_1".THRU_Z as THRU_Z from orderTable as "ordertable_1" where "ordertable_1".FROM_Z <= DATE\'2024-03-01\' and "ordertable_1".THRU_Z > DATE\'2024-03-01\') as "ordertable_0" left outer join (select "producttable_1".ID as ID, "producttable_1".ORDERID as ORDERID, "producttable_1".CODE as CODE, "producttable_1".CATEGORY as CATEGORY from productTable as "producttable_1") as "producttable_0" on ("ordertable_0".ID = "producttable_0".ORDERID) left outer join (select "trackingtable_0".PREFIX as PREFIX, "shipmenttable_1".CARRIER as CARRIER from (select "shipmenttable_2".ID as ID, "shipmenttable_2".ORDERID as ORDERID, "shipmenttable_2".CARRIER as CARRIER, "shipmenttable_2".TRACKINGID as TRACKINGID, "shipmenttable_2".FROM_Z as FROM_Z, "shipmenttable_2".THRU_Z as THRU_Z from shipmentTable as "shipmenttable_2" where "shipmenttable_2".FROM_Z <= DATE\'2024-07-01\' and "shipmenttable_2".THRU_Z > DATE\'2024-07-01\') as "shipmenttable_1" left outer join (select "producttable_1".ID as ID, "producttable_1".SHIPMENTID as SHIPMENTID, "producttable_1".PREFIX as PREFIX from trackingTable as "producttable_1") as "trackingtable_0" on ("shipmenttable_1".ID = "trackingtable_0".SHIPMENTID)) as "shipmenttable_0" on ("producttable_0".CODE = "shipmenttable_0".PREFIX)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoinAdvanced.legend',
    'showcase::modelJoinTests::advanced::query::orderWithShipments__Relation_1_',
    'showcase::modelJoinTests::advanced::mapping::MilestoningSameSchemeBothMapping',
    'showcase::modelJoinTests::advanced::store::Database',
    'showcase::modelJoinTests::advanced::connection::H2Connection',
    [$orderCsv, $productCsv, $shipmentCsv, $trackingCsv],
    $expected,
    $expectedSql
  );
}

// =============================================================================
// Test 24: Different milestoning schemes (Order=business, AuditEntry=processing)
//   Nested condition: order_audit.product.code == auditEntries.entityRef
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinMilestoningDiffScheme():Boolean[1]
{
  let orderCsv =
    'default\n' +
    'orderTable\n' +
    'ID,PRODUCTID,DESCRIPTION,REFCODE,FROM_Z,THRU_Z\n' +
    '1,1,OrderA,REF1,2023-01-01,2025-01-01\n' +
    '2,2,OrderB,REF2,2025-01-01,9999-12-31\n';

  let productCsv =
    'default\n' +
    'productTable\n' +
    'ID,ORDERID,CODE,CATEGORY\n' +
    '1,1,ALPHA,cat1\n' +
    '2,2,BETA,cat2\n';

  let auditCsv =
    'default\n' +
    'auditTable\n' +
    'ID,ENTITYREF,MESSAGE,IN_Z,OUT_Z\n' +
    '1,ALPHA,Audit1,2023-01-01 00:00:00,2025-01-01 00:00:00\n' +
    '2,ALPHA,Audit2,2025-01-01 00:00:00,9999-12-31 00:00:00\n' +
    '3,BETA,Audit3,2023-01-01 00:00:00,2025-01-01 00:00:00\n';

  let expected =
    'Order,Audit\n' +
    'OrderA,Audit1\n';

  let expectedSql = 'select "ordertable_0".DESCRIPTION as "Order", "audittable_0".MESSAGE as "Audit" from (select "ordertable_1".ID as ID, "ordertable_1".PRODUCTID as PRODUCTID, "ordertable_1".DESCRIPTION as DESCRIPTION, "ordertable_1".REFCODE as REFCODE, "ordertable_1".FROM_Z as FROM_Z, "ordertable_1".THRU_Z as THRU_Z from orderTable as "ordertable_1" where "ordertable_1".FROM_Z <= DATE\'2024-01-01\' and "ordertable_1".THRU_Z > DATE\'2024-01-01\') as "ordertable_0" left outer join (select "producttable_1".ID as ID, "producttable_1".ORDERID as ORDERID, "producttable_1".CODE as CODE, "producttable_1".CATEGORY as CATEGORY from productTable as "producttable_1") as "producttable_0" on ("ordertable_0".ID = "producttable_0".ORDERID) left outer join (select "audittable_1".ID as ID, "audittable_1".ENTITYREF as ENTITYREF, "audittable_1".MESSAGE as MESSAGE, "audittable_1".IN_Z as IN_Z, "audittable_1".OUT_Z as OUT_Z from auditTable as "audittable_1" where "audittable_1".IN_Z <= TIMESTAMP\'2024-01-01 10:00:00\' and "audittable_1".OUT_Z > TIMESTAMP\'2024-01-01 10:00:00\') as "audittable_0" on ("producttable_0".CODE = "audittable_0".ENTITYREF)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoinAdvanced.legend',
    'showcase::modelJoinTests::advanced::query::orderWithAudit__Relation_1_',
    'showcase::modelJoinTests::advanced::mapping::MilestoningDiffSchemeMapping',
    'showcase::modelJoinTests::advanced::store::Database',
    'showcase::modelJoinTests::advanced::connection::H2Connection',
    [$orderCsv, $productCsv, $auditCsv],
    $expected,
    $expectedSql
  );
}

