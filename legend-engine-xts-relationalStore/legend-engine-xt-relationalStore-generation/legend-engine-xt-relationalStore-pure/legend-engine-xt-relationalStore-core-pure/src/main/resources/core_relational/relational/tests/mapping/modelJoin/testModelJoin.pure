  let expected =
    'Legal Name,Employee First Name\n' +
    'Apple,Alice\n' +
    'Google,Bob\n';

  let expectedSql = 'select "root".LEGALNAME as "Legal Name", "persontable_0".FIRSTNAME as "Employee First Name" from firmTable as "root" left outer join headquartersTable as "headquarterstable_0" on ("root".ID = "headquarterstable_0".FIRMID) left outer join (select "root".FIRSTNAME as "firstName", "root".LASTNAME as "lastName", "root".AGE as "age", "root".ID as "id", "root".FIRMID as "firmId", "addresstable_0".CITY as CITY, "root".FIRSTNAME as FIRSTNAME from personTable as "root" left outer join addressTable as "addresstable_0" on ("root".ID = "addresstable_0".PERSONID)) as "persontable_0" on ("persontable_0".CITY = "headquarterstable_0".CITY)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::firmWithEmployees__Relation_1_',
