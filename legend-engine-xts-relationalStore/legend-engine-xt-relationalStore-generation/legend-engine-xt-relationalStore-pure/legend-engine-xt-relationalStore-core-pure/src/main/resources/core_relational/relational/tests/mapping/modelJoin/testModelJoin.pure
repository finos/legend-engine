// =============================================================================
// Test 29: Model Join where target has ~filter (same as test 26 but querying from person side)
//
// Data:
//   firmTable: (1, 'Apple'), (2, 'Google')
//   personTable: (1, 'Alice', 'Smith', 1, 30), (2, 'Bob', 'Jones', 1, 20), (3, 'Charlie', 'Brown', 2, 35)
//
// Expected: Query from Person -> Firm (reverse direction of the model join)
//   Only active persons (age>25) have their firm resolved
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinFilterOnTargetReverse():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,20\n' +
    '3,Charlie,Brown,2,35\n';

  let expected =
    'First Name,Firm Name\n' +
    'Alice,Apple\n' +
    'Charlie,Google\n';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::personWithFirm__Relation_1_',
    'showcase::modelJoinTests::mapping::relational::FilterOnTargetMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv],
    $expected,
    true
  );
}

// =============================================================================
// Test 30: Model Join where target has inner join filter
//
// The person class mapping has ~filter (INNER) @PersonProfile | ProfileRankFilter
// which inner-joins personTable to profileTable and filters profileTable.RANK = 'US'.
//
// Data:
//   firmTable: (1, 'Apple'), (2, 'Google')
//   personTable: (1, 'Alice', 'Smith', 1, 30), (2, 'Bob', 'Jones', 1, 25), (3, 'Charlie', 'Brown', 2, 35)
//   profileTable: (1, 1, 'US'), (2, 2, 'UK'), (3, 3, 'US')
//
// Expected: Only persons with profile rank='US' pass the filter.
//   Alice (profile rank=US, firmId=1) → Apple
//   Bob (profile rank=UK) → filtered out
//   Charlie (profile rank=US, firmId=2) → Google
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinFilterWithInnerJoinOnTarget():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,25\n' +
    '3,Charlie,Brown,2,35\n';

  let profileCsv =
    'default\n' +
    'profileTable\n' +
    'ID,PERSONID,RANK\n' +
    '1,1,US\n' +
    '2,2,UK\n' +
    '3,3,US\n';

  let expected =
    'Legal Name,Employee First Name\n' +
    'Apple,Alice\n' +
    'Google,Charlie\n';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::firmWithEmployees__Relation_1_',
    'showcase::modelJoinTests::mapping::relational::FilterWithInnerJoinOnTargetMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv, $profileCsv],
    $expected,
    true
  );
}

// =============================================================================
// Test: Subtype in model join condition (Relational class mappings)
//   employees->subType(@ExtendedPerson).employeeCode == firm.code
//   ExtendedPerson.employeeCode is mapped to LASTNAME column
//
// Data:
//   firmTable: (1, 'Apple', 'Smith', '', ''), (2, 'Google', 'Brown', '', '')
//   personTable: (1, 'Alice', 'Smith', 0, 30), (2, 'Bob', 'Jones', 0, 25), (3, 'Charlie', 'Brown', 0, 35)
//
// Expected: Alice→Apple (Smith==Smith), Charlie→Google (Brown==Brown), Bob→null
// =============================================================================
function <<test.ToFix>> meta::relational::tests::mapping::relational::testModelJoinRelationalSubtypeInCondition():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,Smith,,\n' +
    '2,Google,Brown,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let expected =
    'First Name,Firm Name\n' +
    'Alice,Apple\n' +
    'Bob,null\n' +
    'Charlie,Google\n';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoinAdvanced.legend',
    'showcase::modelJoinTests::advanced::query::personWithFirm__Relation_1_',
