// =============================================================================
// Test: Column collision in materializeTargetAsSubselect
//   Person→Firm where the ModelJoin condition produces two target-side
//   CITY columns: firmTable.CITY (from firm.city) and hqTableA.CITY
//   (from firm.headquarters.city). buildColumnRenameMap must rename
//   the second to CITY_1 to avoid ambiguity in the materialized subselect.
//
//   Condition: employees.address.city == firm.city
//           && employees.address.country == firm.headquarters.city
//   Query: Person.all()->project(~[firstName, firm.legalName])
//
// Data:
//   personTable: (1, Alice, Smith, 1, 30), (2, Bob, Jones, 2, 25)
//   firmTable:  (1, Apple, , NYC, US), (2, Google, , London, UK)
//   addressTable: (1, 1, NYC, US), (2, 2, London, UK)
//   hqTableA: (1, 1, US, ), (2, 2, UK, )
//
// Match logic (target = Firm):
//   Condition: address.CITY == firm.CITY  AND  address.COUNTRY == hq.CITY
//   Alice: address(NYC, US) → firm.city=NYC matches Apple, hq.city=US matches hqA(firmId=1)
//   Bob: address(London, UK) → firm.city=London matches Google, hq.city=UK matches hqA(firmId=2)
//
// Expected: Alice→Apple, Bob→Google
// ============================================================================= 
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinColumnCollisionInSubselect():Boolean[1]
{
  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,2,25\n';

  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,NYC,US\n' +
    '2,Google,,London,UK\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n';

  let hqCsv =
    'default\n' +
    'hqTableA\n' +
    'ID,FIRMID,CITY,COUNTRY\n' +
    '1,1,US,\n' +
    '2,2,UK,\n';
  let expected =
    'First Name,Firm Name\n' +
    'Alice,Apple\n' +
    'Bob,Google\n';
  
  let expectedSql = 'select "root".FIRSTNAME as "First Name", "firmtable_0".LEGALNAME as "Firm Name" from personTable as "root" left outer join addressTable as "addresstable_0" on ("root".ID = "addresstable_0".PERSONID) left outer join (select "root".LEGALNAME as "legalName", "root".CITY as "city", "root".ID as "id", "root".CITY as CITY, "hqtablea_0".CITY as CITY_1, "root".LEGALNAME as LEGALNAME from firmTable as "root" left outer join hqTableA as "hqtablea_0" on ("root".ID = "hqtablea_0".FIRMID)) as "firmtable_0" on ("addresstable_0".CITY = "firmtable_0".CITY and "addresstable_0".COUNTRY = "firmtable_0".CITY_1)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoinAdvanced.legend',
    'showcase::modelJoinTests::advanced::query::personWithFirm__Relation_1_',
    'showcase::modelJoinTests::advanced::mapping::ColumnCollisionMapping',
    'showcase::modelJoinTests::advanced::store::Database',
    'showcase::modelJoinTests::advanced::connection::H2Connection',
    [$personCsv, $firmCsv, $addressCsv, $hqCsv],
    $expected,
    $expectedSql
  );
}

