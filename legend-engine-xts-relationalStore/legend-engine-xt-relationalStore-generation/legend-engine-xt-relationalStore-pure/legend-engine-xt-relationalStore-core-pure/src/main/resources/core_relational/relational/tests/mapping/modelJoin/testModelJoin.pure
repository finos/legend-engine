// =============================================================================
// Test 12: Sub-filter within project — filter on nested model-join property
//   Firm.all()->project(~[legalName, employees->filter(e|e.address.city=='NYC').firstName])
//   Model join used inside a sub-filter within a project column.
// =============================================================================
function <<test.ToFix>> meta::relational::tests::mapping::relation::testModelJoinSubFilter():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,NYC,US\n' +
    '2,Google,,London,UK\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n' +
    '3,3,NYC,US\n';

  // Firm→Person via NestedPropertyChainMapping (address.city == firm.city && address.country == firm.country)
  // Then sub-filter: only employees whose address.city == 'NYC'
  // Apple(NYC,US): employees matched by city/country = Alice(NYC,US), Charlie(NYC,US)
  //   sub-filter city=='NYC' → Alice, Charlie
  // Google(London,UK): employee = Bob(London,UK)
  //   sub-filter city=='NYC' → none
  let expected =
    'Legal Name,NYC Employee\n' +
    'Apple,Alice\n' +
    'Apple,Charlie\n' +
    'Google,null\n';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::firmWithFilteredEmployees__Relation_1_',
    'showcase::modelJoinTests::mapping::NestedPropertyChainMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv, $addressCsv],
    $expected
  );
}

