// =============================================================================
// Test 10: 3 levels of model join nesting — inner condition does multi-depth traversal
//   Outer: Firm→Person via employees.address.city == firm.headquarters.city
//   Middle: Person→Address via person.profile.rank == address.country && person.id == address.personId
//   Innermost: Person→Profile via person_prof.id == profile.personId
//
//   Processing the middle condition triggers the innermost model join (person.profile).
//   This tests 3-level recursive model join resolution.
//
//   Data:
//     profileTable: Alice has rank='US', Bob has rank='UK'
//     addressTable: addr1(personId=1, city=NYC, country=US), addr2(personId=2, city=London, country=UK)
//     So person→address matches when profile.rank == address.country AND person.id == address.personId
//     Alice(rank=US, id=1) → addr1(country=US, personId=1) ✓
//     Bob(rank=UK, id=2) → addr2(country=UK, personId=2) ✓
//     Charlie has no profile → no address match
// =============================================================================
function <<test.ToFix>> meta::relational::tests::mapping::relation::testNestedModelJoinCompoundInnerCondition():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let profileCsv =
    'default\n' +
    'profileTable\n' +
    'ID,PERSONID,RANK\n' +
    '1,1,US\n' +
    '2,2,UK\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n' +
    '3,3,Paris,FR\n';

  let hqCsv =
    'default\n' +
    'headquartersTable\n' +
    'ID,FIRMID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n';

  let expected =
    'Legal Name,Employee First Name\n' +
    'Apple,Alice\n' +
    'Google,Bob\n';

  let expectedSql = '';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::firmWithEmployees__Relation_1_',
    'showcase::modelJoinTests::mapping::NestedModelJoinWithPropertyAccess',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv, $profileCsv, $addressCsv, $hqCsv],
    $expected,
    $expectedSql
  );
}

