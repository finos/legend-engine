###Pure
import meta::relational::runtime::*;
import meta::relational::metamodel::execute::tests::*;

// =============================================================================
// Test 1: Simple equality — employees.firmId == firm.id
//
// Data:
//   firmTable: (1, 'Apple'), (2, 'Google')
//   personTable: (1, 'Alice', 'Smith', 1, 30), (2, 'Bob', 'Jones', 1, 25), (3, 'Charlie', 'Brown', 2, 35)
//
// Expected: Firm 'Apple' has employees Alice, Bob; Firm 'Google' has Charlie
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinSimpleEquality():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,25\n' +
    '3,Charlie,Brown,2,35\n';

  let expected =
    'Legal Name,Employee First Name\n' +
    'Apple,Alice\n' +
    'Apple,Bob\n' +
    'Google,Charlie\n';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::firmWithEmployees__Relation_1_',
    'showcase::modelJoinTests::mapping::SimpleEqualityMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv],
    $expected
  );
}

// =============================================================================
// Test 2: Multiple AND conditions — (employees.firmId == firm.id) && (employees.lastName == firm.code)
//
// Data:
//   firmTable: (1, 'Apple', 'Smith'), (2, 'Google', 'Brown')
//   personTable: (1, 'Alice', 'Smith', 1, 30), (2, 'Bob', 'Jones', 1, 25),
//                (3, 'Charlie', 'Brown', 2, 35), (4, 'Diana', 'Smith', 2, 28)
//
// Expected: Only matches where BOTH firmId and lastName match:
//   Alice(firmId=1, lastName=Smith) matches Apple(id=1, code=Smith)
//   Charlie(firmId=2, lastName=Brown) matches Google(id=2, code=Brown)
//   Bob(firmId=1, lastName=Jones) - no match (Jones != Smith)
//   Diana(firmId=2, lastName=Smith) - no match (Smith != Brown)
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinMultipleAndConditions():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,Smith,,\n' +
    '2,Google,Brown,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,25\n' +
    '3,Charlie,Brown,2,35\n' +
    '4,Diana,Smith,2,28\n';

  let expected =
    'First Name,Firm Name\n' +
    'Alice,Apple\n' +
    'Bob,null\n' +
    'Charlie,Google\n' +
    'Diana,null\n';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::personWithFirm__Relation_1_',
    'showcase::modelJoinTests::mapping::MultipleAndMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv],
    $expected
  );
}

// =============================================================================
// Test 3: OR conditions — (employees.firmId == firm.id) || (employees.lastName == firm.code)
//
// Data:
//   firmTable: (1, 'Apple', 'Jones'), (2, 'Google', 'Smith')
//   personTable: (1, 'Alice', 'Smith', 1, 30), (2, 'Bob', 'Jones', 3, 25),
//                (3, 'Charlie', 'Brown', 2, 35)
//
// Expected: Match if firmId matches OR lastName matches code:
//   Alice(firmId=1, lastName=Smith) matches Apple(id=1) by firmId, matches Google(code=Smith) by lastName
//   Bob(firmId=3, lastName=Jones) matches Apple(code=Jones) by lastName
//   Charlie(firmId=2, lastName=Brown) matches Google(id=2) by firmId
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinOrConditions():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,Jones,,\n' +
    '2,Google,Smith,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,3,25\n' +
    '3,Charlie,Brown,2,35\n';

  let expected =
    'First Name,Firm Name\n' +
    'Alice,Apple\n' +
    'Alice,Google\n' +
    'Bob,Apple\n' +
    'Charlie,Google\n';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::personWithFirm__Relation_1_',
    'showcase::modelJoinTests::mapping::OrConditionsMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv],
    $expected
  );
}

// =============================================================================
// Test 4: Function in condition — toLower(employees.code) == toLower(firm.code)
//   (where Person.code is mapped to LASTNAME)
//
// Data:
//   firmTable: (1, 'Apple', 'SMITH'), (2, 'Google', 'brown')
//   personTable: (1, 'Alice', 'Smith', 1, 30), (2, 'Bob', 'BROWN', 2, 25),
//                (3, 'Charlie', 'Jones', 1, 35)
//
// Expected: Case-insensitive match via toLower:
//   Alice(lastName=Smith) matches Apple(code=SMITH) — toLower both = 'smith'
//   Bob(lastName=BROWN) matches Google(code=brown) — toLower both = 'brown'
//   Charlie(lastName=Jones) — no match
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinFunctionInCondition():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,SMITH,,\n' +
    '2,Google,brown,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,BROWN,2,25\n' +
    '3,Charlie,Jones,1,35\n';

  let expected =
    'First Name,Firm Name\n' + 
    'Alice,Apple\n' +
    'Bob,Google\n' +
    'Charlie,null';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::personWithFirm__Relation_1_',
    'showcase::modelJoinTests::mapping::FunctionInConditionMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv],
    $expected
  );
}

// =============================================================================
// Test 5: Nested property chain — (employees.address.city == firm.city) && (employees.address.country == firm.country)
//
// Data:
//   firmTable: (1, 'Apple', '', 'NYC', 'US'), (2, 'Google', '', 'London', 'UK')
//   personTable: (1, 'Alice', 'Smith', 0, 30), (2, 'Bob', 'Jones', 0, 25), (3, 'Charlie', 'Brown', 0, 35)
//   addressTable: (1, 1, 'NYC', 'US'), (2, 2, 'London', 'UK'), (3, 3, 'Paris', 'FR')
//
// Expected: Match via nested address.city/country:
//   Alice -> address(NYC, US) -> matches Apple(NYC, US)
//   Bob -> address(London, UK) -> matches Google(London, UK)
//   Charlie -> address(Paris, FR) -> no match
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinNestedPropertyChain():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,NYC,US\n' +
    '2,Google,,London,UK\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n' +
    '3,3,Paris,FR\n';

  let expected =
    'Legal Name,Employee First Name\n' +
    'Apple,Alice\n' +
    'Google,Bob\n';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::firmWithEmployees__Relation_1_',
    'showcase::modelJoinTests::mapping::NestedPropertyChainMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv, $addressCsv],
    $expected
  );
}

// =============================================================================
// Test 6: Double-nested model joins — both sides traverse model joins
//   employees.address.city == firm.headquarters.city && employees.address.country == firm.headquarters.country
//
//   LHS chain: person → (ModelJoin Person_Address) → address → .city
//   RHS chain: firm   → (ModelJoin Firm_Headquarters) → headquarters → .city
//
// Data:
//   firmTable: (1, 'Apple', '', '', ''), (2, 'Google', '', '', '')
//   personTable: (1, 'Alice', 'Smith', 0, 30), (2, 'Bob', 'Jones', 0, 25), (3, 'Charlie', 'Brown', 0, 35)
//   addressTable: (1, 1, 'NYC', 'US'), (2, 2, 'London', 'UK'), (3, 3, 'Paris', 'FR')
//   headquartersTable: (1, 1, 'NYC', 'US'), (2, 2, 'London', 'UK')
//
// Expected: Match where person's address city/country == firm's HQ city/country:
//   Alice → address(NYC, US) matches Apple → HQ(NYC, US)
//   Bob → address(London, UK) matches Google → HQ(London, UK)
//   Charlie → address(Paris, FR) → no match
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinDoubleNestedBothSides():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n' +
    '3,3,Paris,FR\n';

  let hqCsv =
    'default\n' +
    'headquartersTable\n' +
    'ID,FIRMID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n';

  let expected =
    'Legal Name,Employee First Name\n' +
    'Apple,Alice\n' +
    'Google,Bob\n';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::firmWithEmployees__Relation_1_',
    'showcase::modelJoinTests::mapping::DoubleNestedModelJoinMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv, $addressCsv, $hqCsv],
    $expected,
    false
  );
}

// =============================================================================
// Test 7: Column collision during target subselect collapse
//   Firm→Department→Project chain. Both dept and project have ID and NAME columns.
//   collapseTargetIntoSubselect must disambiguate these in the subselect.
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinColumnCollision():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let deptCsv =
    'default\n' +
    'departmentTable\n' +
    'ID,FIRMID,NAME,CODE\n' +
    '10,1,Engineering,ENG\n' +
    '20,1,Marketing,MKT\n' +
    '30,2,Research,RES\n';

  let projectCsv =
    'default\n' +
    'projectTable\n' +
    'ID,DEPTID,NAME,CITY\n' +
    '100,10,ProjectX,NYC\n' +
    '200,10,ProjectY,LA\n' +
    '300,30,ProjectZ,London\n';

  let expected =
    'Legal Name,Project Name\n' +
    'Apple,ProjectX\n' +
    'Apple,ProjectY\n' +
    'Google,ProjectZ\n';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::firmWithDeptProjects__Relation_1_',
    'showcase::modelJoinTests::mapping::ColumnCollisionMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $deptCsv, $projectCsv],
    $expected
  );
}

