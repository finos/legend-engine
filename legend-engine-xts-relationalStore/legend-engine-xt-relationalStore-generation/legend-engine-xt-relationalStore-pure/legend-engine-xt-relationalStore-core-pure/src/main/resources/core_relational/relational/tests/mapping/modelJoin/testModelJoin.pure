// =============================================================================
// Test 26: Model Join where target has ~filter (AGE > 25)
//
// Data:
//   firmTable: (1, 'Apple'), (2, 'Google')
//   personTable: (1, 'Alice', 'Smith', 1, 30), (2, 'Bob', 'Jones', 1, 20), (3, 'Charlie', 'Brown', 2, 35)
//
// Expected: Bob (age=20) is filtered out by target ~filter (AGE > 25)
//   Apple has only Alice; Google has Charlie
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinFilterOnTarget():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,20\n' +
    '3,Charlie,Brown,2,35\n';

  let expected =
    'Legal Name,Employee First Name\n' +
    'Apple,Alice\n' +
    'Google,Charlie\n';

  let expectedSql = 'select "root".LEGALNAME as "Legal Name", "persontable_0".FIRSTNAME as "Employee First Name" from firmTable as "root" left outer join (select "root".FIRSTNAME as "firstName", "root".LASTNAME as "lastName", "root".AGE as "age", "root".ID as "id", "root".FIRMID as "firmId", "root".FIRMID as FIRMID, "root".FIRSTNAME as FIRSTNAME from personTable as "root" where "root".AGE > 25) as "persontable_0" on ("persontable_0".FIRMID = "root".ID)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::firmWithEmployees__Relation_1_',
    'showcase::modelJoinTests::mapping::relational::FilterOnTargetMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv],
    $expected,
    $expectedSql
  );
}

