//   personTable: (1, 'Alice', 'Smith', 1, 30), (2, 'Bob', 'Jones', 1, 20), (3, 'Charlie', 'Brown', 2, 35)
//   addressTable: (1, 1, 'NYC', 'US'), (2, 2, 'NYC', 'US'), (3, 3, 'SF', 'US')
//
// Expected: Bob is filtered out by AGE > 25.
