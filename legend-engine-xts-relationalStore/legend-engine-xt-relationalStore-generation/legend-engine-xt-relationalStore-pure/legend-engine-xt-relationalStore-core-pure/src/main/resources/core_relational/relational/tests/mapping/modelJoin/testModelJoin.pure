    'ID,FIRMID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n';

  // Apple has HQ in NYC → included; Google has HQ in London → excluded; Meta has no HQ → excluded
  let expected =
    'Legal Name\n' +
    'Apple\n';

  let expectedSql = 'select "firmtable_0".LEGALNAME as "Legal Name" from (select "firmtable_1".ID as ID, "firmtable_1".LEGALNAME as LEGALNAME, "firmtable_1".CITY as CITY, "firmtable_1".COUNTRY as COUNTRY, "firmtable_1".CODE as CODE from firmTable as "firmtable_1") as "firmtable_0" left outer join (select "headquarterstable_1".ID as ID, "headquarterstable_1".FIRMID as FIRMID, "headquarterstable_1".CITY as CITY, "headquarterstable_1".COUNTRY as COUNTRY from headquartersTable as "headquarterstable_1") as "headquarterstable_0" on ("firmtable_0".ID = "headquarterstable_0".FIRMID) where "headquarterstable_0".CITY = \'NYC';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
