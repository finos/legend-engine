    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n';

  let firmBCsv =
    'default\n' +
    'firmTableB\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '3,Meta,,,\n';

  let expected =
    'Legal Name,Employee First Name\n' +
