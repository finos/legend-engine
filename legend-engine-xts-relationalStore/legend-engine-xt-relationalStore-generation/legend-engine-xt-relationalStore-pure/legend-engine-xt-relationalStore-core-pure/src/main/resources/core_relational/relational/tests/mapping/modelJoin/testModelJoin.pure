// =============================================================================
// Test R1: Simple equality — Relational class mappings
//   Same scenario as Test 1 but with Relational mappings.
//   employees.firmId == firm.id
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinRelationalSimpleEquality():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,25\n' +
    '3,Charlie,Brown,2,35\n';

  let expected =
    'Legal Name,Employee First Name\n' +
    'Apple,Alice\n' +
    'Apple,Bob\n' +
    'Google,Charlie\n';

  let expectedSql = 'select "root".LEGALNAME as "Legal Name", "persontable_0".FIRSTNAME as "Employee First Name" from firmTable as "root" left outer join personTable as "persontable_0" on ("persontable_0".FIRMID = "root".ID)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::firmWithEmployees__Relation_1_',
    'showcase::modelJoinTests::mapping::relational::SimpleEqualityMapping',
    'showcase::modelJoinTests::store::Database',
