###Pure
import meta::relational::runtime::*;
import meta::relational::metamodel::execute::tests::*;

// =============================================================================
// Test 1: Simple equality — employees.firmId == firm.id
//
// Data:
//   firmTable: (1, 'Apple'), (2, 'Google')
//   personTable: (1, 'Alice', 'Smith', 1, 30), (2, 'Bob', 'Jones', 1, 25), (3, 'Charlie', 'Brown', 2, 35)
//
// Expected: Firm 'Apple' has employees Alice, Bob; Firm 'Google' has Charlie
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinSimpleEquality():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,25\n' +
    '3,Charlie,Brown,2,35\n';

  let expected =
    'Legal Name,Employee First Name\n' +
    'Apple,Alice\n' +
    'Apple,Bob\n' +
    'Google,Charlie\n';

  let expectedSql = 'select "firmtable_0".LEGALNAME as "Legal Name", "persontable_0".FIRSTNAME as "Employee First Name" from (select "firmtable_1".ID as ID, "firmtable_1".LEGALNAME as LEGALNAME, "firmtable_1".CITY as CITY, "firmtable_1".COUNTRY as COUNTRY, "firmtable_1".CODE as CODE from firmTable as "firmtable_1") as "firmtable_0" left outer join (select "persontable_1".ID as ID, "persontable_1".FIRSTNAME as FIRSTNAME, "persontable_1".LASTNAME as LASTNAME, "persontable_1".FIRMID as FIRMID, "persontable_1".AGE as AGE from personTable as "persontable_1") as "persontable_0" on ("persontable_0".FIRMID = "firmtable_0".ID)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::firmWithEmployees__Relation_1_',
    'showcase::modelJoinTests::mapping::SimpleEqualityMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv],
    $expected,
    $expectedSql
  );
}

// =============================================================================
// Test 2: Multiple AND conditions — (employees.firmId == firm.id) && (employees.lastName == firm.code)
//
// Data:
//   firmTable: (1, 'Apple', 'Smith'), (2, 'Google', 'Brown')
//   personTable: (1, 'Alice', 'Smith', 1, 30), (2, 'Bob', 'Jones', 1, 25),
//                (3, 'Charlie', 'Brown', 2, 35), (4, 'Diana', 'Smith', 2, 28)
//
// Expected: Only matches where BOTH firmId and lastName match:
//   Alice(firmId=1, lastName=Smith) matches Apple(id=1, code=Smith)
//   Charlie(firmId=2, lastName=Brown) matches Google(id=2, code=Brown)
//   Bob(firmId=1, lastName=Jones) - no match (Jones != Smith)
//   Diana(firmId=2, lastName=Smith) - no match (Smith != Brown)
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinMultipleAndConditions():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,Smith,,\n' +
    '2,Google,Brown,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,25\n' +
    '3,Charlie,Brown,2,35\n' +
    '4,Diana,Smith,2,28\n';

  let expected =
    'First Name,Firm Name\n' +
    'Alice,Apple\n' +
    'Bob,null\n' +
    'Charlie,Google\n' +
    'Diana,null\n';

  let expectedSql = 'select "persontable_0".FIRSTNAME as "First Name", "firmtable_0".LEGALNAME as "Firm Name" from (select "persontable_1".ID as ID, "persontable_1".FIRSTNAME as FIRSTNAME, "persontable_1".LASTNAME as LASTNAME, "persontable_1".FIRMID as FIRMID, "persontable_1".AGE as AGE from personTable as "persontable_1") as "persontable_0" left outer join (select "firmtable_1".ID as ID, "firmtable_1".LEGALNAME as LEGALNAME, "firmtable_1".CITY as CITY, "firmtable_1".COUNTRY as COUNTRY, "firmtable_1".CODE as CODE from firmTable as "firmtable_1") as "firmtable_0" on ("persontable_0".FIRMID = "firmtable_0".ID and "persontable_0".LASTNAME = "firmtable_0".CODE)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::personWithFirm__Relation_1_',
    'showcase::modelJoinTests::mapping::MultipleAndMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv],
    $expected,
    $expectedSql
  );
}

// =============================================================================
// Test 3: OR conditions — (employees.firmId == firm.id) || (employees.lastName == firm.code)
//
// Data:
//   firmTable: (1, 'Apple', 'Jones'), (2, 'Google', 'Smith')
//   personTable: (1, 'Alice', 'Smith', 1, 30), (2, 'Bob', 'Jones', 3, 25),
//                (3, 'Charlie', 'Brown', 2, 35)
//
// Expected: Match if firmId matches OR lastName matches code:
//   Alice(firmId=1, lastName=Smith) matches Apple(id=1) by firmId, matches Google(code=Smith) by lastName
//   Bob(firmId=3, lastName=Jones) matches Apple(code=Jones) by lastName
//   Charlie(firmId=2, lastName=Brown) matches Google(id=2) by firmId
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinOrConditions():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,Jones,,\n' +
    '2,Google,Smith,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,3,25\n' +
    '3,Charlie,Brown,2,35\n';

  let expected =
    'First Name,Firm Name\n' +
    'Alice,Apple\n' +
    'Alice,Google\n' +
    'Bob,Apple\n' +
    'Charlie,Google\n';

  let expectedSql = 'select "persontable_0".FIRSTNAME as "First Name", "firmtable_0".LEGALNAME as "Firm Name" from (select "persontable_1".ID as ID, "persontable_1".FIRSTNAME as FIRSTNAME, "persontable_1".LASTNAME as LASTNAME, "persontable_1".FIRMID as FIRMID, "persontable_1".AGE as AGE from personTable as "persontable_1") as "persontable_0" left outer join (select "firmtable_1".ID as ID, "firmtable_1".LEGALNAME as LEGALNAME, "firmtable_1".CITY as CITY, "firmtable_1".COUNTRY as COUNTRY, "firmtable_1".CODE as CODE from firmTable as "firmtable_1") as "firmtable_0" on ("persontable_0".FIRMID = "firmtable_0".ID or "persontable_0".LASTNAME = "firmtable_0".CODE)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::personWithFirm__Relation_1_',
    'showcase::modelJoinTests::mapping::OrConditionsMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv],
    $expected,
    $expectedSql
  );
}

// =============================================================================
// Test 4: Function in condition — toLower(employees.code) == toLower(firm.code)
//   (where Person.code is mapped to LASTNAME)
//
// Data:
//   firmTable: (1, 'Apple', 'SMITH'), (2, 'Google', 'brown')
//   personTable: (1, 'Alice', 'Smith', 1, 30), (2, 'Bob', 'BROWN', 2, 25),
//                (3, 'Charlie', 'Jones', 1, 35)
//
// Expected: Case-insensitive match via toLower:
//   Alice(lastName=Smith) matches Apple(code=SMITH) — toLower both = 'smith'
//   Bob(lastName=BROWN) matches Google(code=brown) — toLower both = 'brown'
//   Charlie(lastName=Jones) — no match
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinFunctionInCondition():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,SMITH,,\n' +
    '2,Google,brown,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,BROWN,2,25\n' +
    '3,Charlie,Jones,1,35\n';

  let expected =
    'First Name,Firm Name\n' + 
    'Alice,Apple\n' +
    'Bob,Google\n' +
    'Charlie,null';

  let expectedSql = 'select "persontable_0".FIRSTNAME as "First Name", "firmtable_0".LEGALNAME as "Firm Name" from (select "persontable_1".ID as ID, "persontable_1".FIRSTNAME as FIRSTNAME, "persontable_1".LASTNAME as LASTNAME, "persontable_1".FIRMID as FIRMID, "persontable_1".AGE as AGE from personTable as "persontable_1") as "persontable_0" left outer join (select "firmtable_1".ID as ID, "firmtable_1".LEGALNAME as LEGALNAME, "firmtable_1".CITY as CITY, "firmtable_1".COUNTRY as COUNTRY, "firmtable_1".CODE as CODE from firmTable as "firmtable_1") as "firmtable_0" on (lower("persontable_0".LASTNAME) = lower("firmtable_0".CODE))';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::personWithFirm__Relation_1_',
    'showcase::modelJoinTests::mapping::FunctionInConditionMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv],
    $expected,
    $expectedSql
  );
}

// =============================================================================
// Test 5: Nested property chain — (employees.address.city == firm.city) && (employees.address.country == firm.country)
//
// Data:
//   firmTable: (1, 'Apple', '', 'NYC', 'US'), (2, 'Google', '', 'London', 'UK')
//   personTable: (1, 'Alice', 'Smith', 0, 30), (2, 'Bob', 'Jones', 0, 25), (3, 'Charlie', 'Brown', 0, 35)
//   addressTable: (1, 1, 'NYC', 'US'), (2, 2, 'London', 'UK'), (3, 3, 'Paris', 'FR')
//
// Expected: Match via nested address.city/country:
//   Alice -> address(NYC, US) -> matches Apple(NYC, US)
//   Bob -> address(London, UK) -> matches Google(London, UK)
//   Charlie -> address(Paris, FR) -> no match
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinNestedPropertyChain():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,NYC,US\n' +
    '2,Google,,London,UK\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n' +
    '3,3,Paris,FR\n';

  let expected =
    'Legal Name,Employee First Name\n' +
    'Apple,Alice\n' +
    'Google,Bob\n';

  let expectedSql = 'select "firmtable_0".LEGALNAME as "Legal Name", "persontable_0".FIRSTNAME as "Employee First Name" from (select "firmtable_1".ID as ID, "firmtable_1".LEGALNAME as LEGALNAME, "firmtable_1".CITY as CITY, "firmtable_1".COUNTRY as COUNTRY, "firmtable_1".CODE as CODE from firmTable as "firmtable_1") as "firmtable_0" left outer join (select "addresstable_0".CITY as CITY, "addresstable_0".COUNTRY as COUNTRY, "persontable_1".FIRSTNAME as FIRSTNAME from (select "persontable_2".ID as ID, "persontable_2".FIRSTNAME as FIRSTNAME, "persontable_2".LASTNAME as LASTNAME, "persontable_2".FIRMID as FIRMID, "persontable_2".AGE as AGE from personTable as "persontable_2") as "persontable_1" left outer join (select "addresstable_1".ID as ID, "addresstable_1".PERSONID as PERSONID, "addresstable_1".CITY as CITY, "addresstable_1".COUNTRY as COUNTRY from addressTable as "addresstable_1") as "addresstable_0" on ("persontable_1".ID = "addresstable_0".PERSONID)) as "persontable_0" on ("persontable_0".CITY = "firmtable_0".CITY and "persontable_0".COUNTRY = "firmtable_0".COUNTRY)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::firmWithEmployees__Relation_1_',
    'showcase::modelJoinTests::mapping::NestedPropertyChainMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv, $addressCsv],
    $expected,
    $expectedSql
  );
}

// =============================================================================
// Test 6: Double-nested model joins — both sides traverse model joins
//   employees.address.city == firm.headquarters.city && employees.address.country == firm.headquarters.country
//
//   LHS chain: person → (ModelJoin Person_Address) → address → .city
//   RHS chain: firm   → (ModelJoin Firm_Headquarters) → headquarters → .city
//
// Data:
//   firmTable: (1, 'Apple', '', '', ''), (2, 'Google', '', '', '')
//   personTable: (1, 'Alice', 'Smith', 0, 30), (2, 'Bob', 'Jones', 0, 25), (3, 'Charlie', 'Brown', 0, 35)
//   addressTable: (1, 1, 'NYC', 'US'), (2, 2, 'London', 'UK'), (3, 3, 'Paris', 'FR')
//   headquartersTable: (1, 1, 'NYC', 'US'), (2, 2, 'London', 'UK')
//
// Expected: Match where person's address city/country == firm's HQ city/country:
//   Alice → address(NYC, US) matches Apple → HQ(NYC, US)
//   Bob → address(London, UK) matches Google → HQ(London, UK)
//   Charlie → address(Paris, FR) → no match
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinDoubleNestedBothSides():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n' +
    '3,3,Paris,FR\n';

  let hqCsv =
    'default\n' +
    'headquartersTable\n' +
    'ID,FIRMID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n';

  let expected =
    'Legal Name,Employee First Name\n' +
    'Apple,Alice\n' +
    'Google,Bob\n';

  let expectedSql = 'select "firmtable_0".LEGALNAME as "Legal Name", "persontable_0".FIRSTNAME as "Employee First Name" from (select "firmtable_1".ID as ID, "firmtable_1".LEGALNAME as LEGALNAME, "firmtable_1".CITY as CITY, "firmtable_1".COUNTRY as COUNTRY, "firmtable_1".CODE as CODE from firmTable as "firmtable_1") as "firmtable_0" left outer join (select "addresstable_1".ID as ID, "addresstable_1".FIRMID as FIRMID, "addresstable_1".CITY as CITY, "addresstable_1".COUNTRY as COUNTRY from headquartersTable as "addresstable_1") as "headquarterstable_0" on ("firmtable_0".ID = "headquarterstable_0".FIRMID) left outer join (select "addresstable_0".CITY as CITY, "persontable_1".FIRSTNAME as FIRSTNAME from (select "persontable_2".ID as ID, "persontable_2".FIRSTNAME as FIRSTNAME, "persontable_2".LASTNAME as LASTNAME, "persontable_2".FIRMID as FIRMID, "persontable_2".AGE as AGE from personTable as "persontable_2") as "persontable_1" left outer join (select "addresstable_1".ID as ID, "addresstable_1".PERSONID as PERSONID, "addresstable_1".CITY as CITY, "addresstable_1".COUNTRY as COUNTRY from addressTable as "addresstable_1") as "addresstable_0" on ("persontable_1".ID = "addresstable_0".PERSONID)) as "persontable_0" on ("persontable_0".CITY = "headquarterstable_0".CITY)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::firmWithEmployees__Relation_1_',
    'showcase::modelJoinTests::mapping::DoubleNestedModelJoinMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv, $addressCsv, $hqCsv],
    $expected,
    $expectedSql
  );
}

// =============================================================================
// Test 7: Chained two-hop model joins — Firm→Department→Project
//   Two consecutive model joins: Firm→Department (via firm.id == dept.firmId)
//   then Department→Project (via dept.id == project.deptId).
//   Tests that chained model join traversals produce correct multi-join SQL.
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinChainedTwoHops():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let deptCsv =
    'default\n' +
    'departmentTable\n' +
    'ID,FIRMID,NAME,CODE\n' +
    '10,1,Engineering,ENG\n' +
    '20,1,Marketing,MKT\n' +
    '30,2,Research,RES\n';

  let projectCsv =
    'default\n' +
    'projectTable\n' +
    'ID,DEPTID,NAME,CITY\n' +
    '100,10,ProjectX,NYC\n' +
    '200,10,ProjectY,LA\n' +
    '300,30,ProjectZ,London\n';

  let expected =
    'Legal Name,Project Name\n' +
    'Apple,ProjectX\n' +
    'Apple,ProjectY\n' +
    'Apple,null\n' +
    'Google,ProjectZ\n';

  let expectedSql = 'select "firmtable_0".LEGALNAME as "Legal Name", "projecttable_0".NAME as "Project Name" from (select "firmtable_1".ID as ID, "firmtable_1".LEGALNAME as LEGALNAME, "firmtable_1".CITY as CITY, "firmtable_1".COUNTRY as COUNTRY, "firmtable_1".CODE as CODE from firmTable as "firmtable_1") as "firmtable_0" left outer join (select "departmenttable_1".ID as ID, "departmenttable_1".FIRMID as FIRMID, "departmenttable_1".NAME as NAME, "departmenttable_1".CODE as CODE from departmentTable as "departmenttable_1") as "departmenttable_0" on ("firmtable_0".ID = "departmenttable_0".FIRMID) left outer join (select "projecttable_1".ID as ID, "projecttable_1".DEPTID as DEPTID, "projecttable_1".NAME as NAME, "projecttable_1".CITY as CITY from projectTable as "projecttable_1") as "projecttable_0" on ("departmenttable_0".ID = "projecttable_0".DEPTID)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::firmWithDeptProjects__Relation_1_',
    'showcase::modelJoinTests::mapping::ChainedTwoHopsMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $deptCsv, $projectCsv],
    $expected,
    $expectedSql
  );
}

// =============================================================================
// Test 8: String concatenation in join condition
//   employees.firstName + ' ' + employees.lastName == firm.code
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinConcatCondition():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,Alice Smith,,\n' +
    '2,Google,Bob Jones,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,0,30\n' +
    '2,Bob,Jones,0,25\n' +
    '3,Charlie,Brown,0,35\n';

  let expected =
    'First Name,Firm Name\n' +
    'Alice,Apple\n' +
    'Bob,Google\n' +
    'Charlie,null\n';

  let expectedSql = 'select "persontable_0".FIRSTNAME as "First Name", "firmtable_0".LEGALNAME as "Firm Name" from (select "persontable_1".ID as ID, "persontable_1".FIRSTNAME as FIRSTNAME, "persontable_1".LASTNAME as LASTNAME, "persontable_1".FIRMID as FIRMID, "persontable_1".AGE as AGE from personTable as "persontable_1") as "persontable_0" left outer join (select "firmtable_1".ID as ID, "firmtable_1".LEGALNAME as LEGALNAME, "firmtable_1".CITY as CITY, "firmtable_1".COUNTRY as COUNTRY, "firmtable_1".CODE as CODE from firmTable as "firmtable_1") as "firmtable_0" on (concat("persontable_0".FIRSTNAME, \' \', "persontable_0".LASTNAME) = "firmtable_0".CODE)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::personWithFirm__Relation_1_',
    'showcase::modelJoinTests::mapping::ConcatConditionMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $personCsv],
    $expected,
    $expectedSql
  );
}

// =============================================================================
// Test 9: Arithmetic in condition — employees.age + 10 == firm.id
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinArithmeticCondition():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,2\n' +
    '2,Bob,Jones,2,4\n' +
    '3,Charlie,Brown,1,10\n';

  let expected =
    'First Name,Firm Name\n' +
    'Alice,Apple\n' +
    'Bob,Google\n' +
    'Charlie,null\n';

  let expectedSql = 'select "persontable_0".FIRSTNAME as "First Name", "firmtable_0".LEGALNAME as "Firm Name" from (select "persontable_1".ID as ID, "persontable_1".FIRSTNAME as FIRSTNAME, "persontable_1".LASTNAME as LASTNAME, "persontable_1".FIRMID as FIRMID, "persontable_1".AGE as AGE from personTable as "persontable_1") as "persontable_0" left outer join (select "firmtable_1".ID as ID, "firmtable_1".LEGALNAME as LEGALNAME, "firmtable_1".CITY as CITY, "firmtable_1".COUNTRY as COUNTRY, "firmtable_1".CODE as CODE from firmTable as "firmtable_1") as "firmtable_0" on ("persontable_0".FIRMID + "firmtable_0".ID = "persontable_0".AGE)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::personWithFirm__Relation_1_',
    'showcase::modelJoinTests::mapping::ArithmeticConditionMapping',
    'showcase::modelJoinTests::store::Database',
