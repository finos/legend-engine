// =============================================================================
// Test: Union on source side (Relational class mappings)
//   Person = union(fullTimeTable, contractTable), Firm = firmTable
//   Model join: employees.firmId == firm.id
//
// Data:
//   fullTimeTable: (1, 'Alice', 'Smith', 1, 30)
//   contractTable: (2, 'Bob', 'Jones', 1, 25), (3, 'Charlie', 'Brown', 2, 35)
//   firmTable: (1, 'Apple', '', '', ''), (2, 'Google', '', '', '')
//
// Expected: Firm.all→employees gives Alice+Bob for Apple, Charlie for Google
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relational::testModelJoinRelationalUnionSource():Boolean[1]
{
  let fullTimeCsv =
    'default\n' +
    'fullTimeTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n';

  let contractCsv =
    'default\n' +
    'contractTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '2,Bob,Jones,1,25\n' +
    '3,Charlie,Brown,2,35\n';

  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n';

  let expected =
    'Legal Name,Employee First Name\n' +
    'Apple,Alice\n' +
    'Apple,Bob\n' +
    'Google,Charlie\n';

  let expectedSql = 'select "root".LEGALNAME as "Legal Name", "unionalias_0"."fullTimeTableFIRSTNAME_contractTableFIRSTNAME" as "Employee First Name" from firmTable as "root" left outer join (select "root".FIRMID as firmId, "root".FIRSTNAME as "fullTimeTableFIRSTNAME_contractTableFIRSTNAME" from fullTimeTable as "root" union all select "root".FIRMID as firmId, "root".FIRSTNAME as "fullTimeTableFIRSTNAME_contractTableFIRSTNAME" from contractTable as "root") as "unionalias_0" on ("unionalias_0".firmId = "root".ID)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoinAdvanced.legend',
    'showcase::modelJoinTests::advanced::query::firmWithEmployees__Relation_1_',
    'showcase::modelJoinTests::advanced::mapping::relational::UnionSourceMapping',
    'showcase::modelJoinTests::advanced::store::Database',
    'showcase::modelJoinTests::advanced::connection::H2Connection',
    [$fullTimeCsv, $contractCsv, $firmCsv],
    $expected,
    $expectedSql
  );
}

// =============================================================================
// Test: Union on BOTH sides (Relational class mappings)
//   Person = union(fullTimeTable, contractTable)
//   Firm = union(firmTable, firmTableB)
