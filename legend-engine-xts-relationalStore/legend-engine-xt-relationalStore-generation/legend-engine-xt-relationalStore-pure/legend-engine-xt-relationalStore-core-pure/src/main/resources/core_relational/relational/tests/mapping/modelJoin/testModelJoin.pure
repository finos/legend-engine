    $expected,
    $expectedSql
  );
}


// =============================================================================
// Test: Complex RelationFunction definition (JOIN in relation function)
//   personWithAddressJoined() = personTable LEFT JOIN addressTable
//   ModelJoin condition: employees.city == firm.city
//   Tests that a relation function with an inline JOIN produces correct SQL.
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinComplexRelationFunction():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,NYC,US\n' +
    '2,Google,,London,UK\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
    '1,Alice,Smith,1,30\n' +
    '2,Bob,Jones,1,25\n' +
    '3,Charlie,Brown,2,35\n';

  let addressCsv =
    'default\n' +
    'addressTable\n' +
    'ID,PERSONID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n' +
    '3,3,London,UK\n';

  let expected =
    'Legal Name,Employee First Name\n' +
    'Apple,Alice\n' +
    'Google,Bob\n' +
    'Google,Charlie\n';

  let expectedSql = 'select "firmtable_0".LEGALNAME as "Legal Name", "persontable_0"."FIRSTNAME" as "Employee First Name" from (select "firmtable_1".ID as ID, "firmtable_1".LEGALNAME as LEGALNAME, "firmtable_1".CITY as CITY, "firmtable_1".COUNTRY as COUNTRY, "firmtable_1".CODE as CODE from firmTable as "firmtable_1") as "firmtable_0" left outer join (select "persontable_1"."ID" as "ID", "persontable_1"."FIRSTNAME" as "FIRSTNAME", "persontable_1"."LASTNAME" as "LASTNAME", "persontable_1"."FIRMID" as "FIRMID", "persontable_1"."AGE" as "AGE", "persontable_1"."CITY" as "CITY", "persontable_1"."COUNTRY" as "COUNTRY" from (select * from (select "persontable_3".ID as "ID", "persontable_3".FIRSTNAME as "FIRSTNAME", "persontable_3".LASTNAME as "LASTNAME", "persontable_3".FIRMID as "FIRMID", "persontable_3".AGE as "AGE" from personTable as "persontable_3") as "persontable_2" left outer join (select "addresstable_1".PERSONID as "PERSONID", "addresstable_1".CITY as "CITY", "addresstable_1".COUNTRY as "COUNTRY" from addressTable as "addresstable_1") as "addresstable_0" on ("persontable_2"."ID" = "addresstable_0"."PERSONID")) as "persontable_1") as "persontable_0" on ("persontable_0"."CITY" = "firmtable_0".CITY)';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoinAdvanced.legend',
    'showcase::modelJoinTests::advanced::query::firmWithEmployees__Relation_1_',
    'showcase::modelJoinTests::advanced::mapping::ComplexRelationFunctionMapping',
    'showcase::modelJoinTests::advanced::store::Database',
    'showcase::modelJoinTests::advanced::connection::H2Connection',
    [$firmCsv, $personCsv, $addressCsv],
    $expected,
    $expectedSql
  );
}

