//   fullName is a derived property: firstName + ' ' + lastName
//
// Data:
//   firmTable: (1, 'Apple', code='Alice Smith'), (2, 'Google', code='Charlie Brown')
//   personTable: (1, 'Alice', 'Smith', 0, 30), (2, 'Bob', 'Jones', 0, 25), (3, 'Charlie', 'Brown', 0, 35)
//
// Expected: Match by derived fullName == firm code:
//   Alice (fullName='Alice Smith') matches Apple (code='Alice Smith')
//   Bob (fullName='Bob Jones') — no match
//   Charlie (fullName='Charlie Brown') matches Google (code='Charlie Brown')
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinDerivedPropertyInCondition():Boolean[1]
{
