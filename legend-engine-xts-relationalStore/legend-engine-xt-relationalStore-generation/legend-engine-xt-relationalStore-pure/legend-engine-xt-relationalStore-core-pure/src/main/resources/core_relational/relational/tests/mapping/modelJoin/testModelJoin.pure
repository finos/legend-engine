//   Firm.all()->project(~[legalName, employees->filter(e|e.address.city=='NYC').firstName])
//   Model join used inside a sub-filter within a project column.
// =============================================================================
function <<test.ToFix>> meta::relational::tests::mapping::relation::testModelJoinSubFilter():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,NYC,US\n' +
    '2,Google,,London,UK\n';

  let personCsv =
    'default\n' +
    'personTable\n' +
    'ID,FIRSTNAME,LASTNAME,FIRMID,AGE\n' +
