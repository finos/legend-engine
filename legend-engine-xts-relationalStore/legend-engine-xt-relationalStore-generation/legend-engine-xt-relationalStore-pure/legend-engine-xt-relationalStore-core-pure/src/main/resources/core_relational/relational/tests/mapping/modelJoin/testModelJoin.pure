// =============================================================================
// Test 14: Filter on double-nested model-join property
//   Firm.all()->filter(f | f.headquarters.city == 'NYC')->project(~[legalName])
//   Model join traversal in a filter on a property that itself goes through a model join.
// =============================================================================
function <<test.Test>> meta::relational::tests::mapping::relation::testModelJoinNestedInFilter():Boolean[1]
{
  let firmCsv =
    'default\n' +
    'firmTable\n' +
    'ID,LEGALNAME,CODE,CITY,COUNTRY\n' +
    '1,Apple,,,\n' +
    '2,Google,,,\n' +
    '3,Meta,,,\n';

  let hqCsv =
    'default\n' +
    'headquartersTable\n' +
    'ID,FIRMID,CITY,COUNTRY\n' +
    '1,1,NYC,US\n' +
    '2,2,London,UK\n';

  // Apple has HQ in NYC → included; Google has HQ in London → excluded; Meta has no HQ → excluded
  let expected =
    'Legal Name\n' +
    'Apple\n';

  executeLegendFunction(
    '/core_relational/relational/tests/mapping/modelJoin/modelJoin.legend',
    'showcase::modelJoinTests::query::firmsInNYC__Relation_1_',
    'showcase::modelJoinTests::mapping::DoubleNestedModelJoinMapping',
    'showcase::modelJoinTests::store::Database',
    'showcase::modelJoinTests::connection::H2Connection',
    [$firmCsv, $hqCsv],
    $expected
  );
}

// =============================================================================
