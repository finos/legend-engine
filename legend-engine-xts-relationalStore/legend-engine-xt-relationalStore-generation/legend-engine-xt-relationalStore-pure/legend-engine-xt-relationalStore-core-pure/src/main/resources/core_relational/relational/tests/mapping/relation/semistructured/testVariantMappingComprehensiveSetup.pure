###Mapping
import meta::relational::tests::mapping::relation::variant::comprehensive::*;
import meta::pure::functions::variant::convert::*;
import meta::pure::functions::variant::navigation::*;
import meta::pure::functions::variant::convert::*;
import meta::pure::metamodel::variant::*;

// =============================================================================
// Mapping 1 — VariantFirmMapping
//
// The "kitchen-sink" mapping: every property-RHS exercises a different variant
// operation chain. Covers §2.1, §2.2, §2.3, §2.5, §2.7, §2.9, §2.15, §2.17,
// §2.19, §2.20.
// =============================================================================
Mapping meta::relational::tests::mapping::relation::variant::comprehensive::VariantFirmMapping
(
  *Person[person]: Relation
  {
    ~func meta::relational::tests::mapping::relation::variant::comprehensive::personFunction():Relation<Any>[1]
    firstName       : FIRSTNAME,
    lastName        : LASTNAME,
    // §2.7 — whole subtree deserialization
    firm            : $src.FIRM_DETAILS->to(@meta::relational::tests::mapping::relation::variant::comprehensive::Firm)->toOne(),
    // §2.1 — direct extraction of all primitive types
    firmName        : $src.FIRM_DETAILS->get('legalName')->to(@String)->toOne(),
    employeeCount   : $src.FIRM_DETAILS->get('employeeCount')->to(@Integer)->toOne(),
    revenue         : $src.FIRM_DETAILS->get('revenue')->to(@Float)->toOne(),
    isMnc           : $src.FIRM_DETAILS->get('mnc')->to(@Boolean)->toOne(),
    estDate         : $src.FIRM_DETAILS->get('estDate')->to(@StrictDate)->toOne(),
    lastUpdate      : $src.FIRM_DETAILS->get('lastUpdate')->to(@DateTime)->toOne(),
    // §2.2 — enum as string (optional — may be absent in JSON)
    entityType      : $src.FIRM_DETAILS->get('entityType')->to(@String),
    // §2.9 — nested object navigation
    addressName     : $src.FIRM_DETAILS->get('address')->get('name')->to(@String)->toOne(),
    addressStreet   : $src.FIRM_DETAILS->get('address')->get('street')->to(@String),
    // §2.15 — at / first / size / isEmpty / isNotEmpty
    firstAddrLine   : $src.FIRM_DETAILS->get('address')->get('lines')->at(0)->get('details')->to(@String),
    secondAddrLine  : $src.FIRM_DETAILS->get('address')->get('lines')->at(1)->get('details')->to(@String),
    addrLineCount   : $src.FIRM_DETAILS->get('address')->get('lines')->size(),
    hasAddress      : $src.FIRM_DETAILS->get('address')->isNotEmpty(),
    hasStreet       : $src.FIRM_DETAILS->get('address')->get('street')->isNotEmpty(),
    // §2.5 + §2.15 — toMany + size / first / at / isEmpty / isNotEmpty
    otherNameCount  : $src.FIRM_DETAILS->get('otherNames')->toMany(@String)->size(),
    firstOtherName  : $src.FIRM_DETAILS->get('otherNames')->toMany(@String)->first(),
    secondOtherName : $src.FIRM_DETAILS->get('otherNames')->toMany(@String)->at(1),
    hasOtherNames   : $src.FIRM_DETAILS->get('otherNames')->toMany(@String)->isNotEmpty(),
    otherNamesEmpty : $src.FIRM_DETAILS->get('otherNames')->toMany(@String)->isEmpty(),
    // §2.20 — distinct / contains / indexOf / concatenate
    distinctCtryCount: $src.FIRM_DETAILS->get('countries')->toMany(@String)->distinct()->size(),
    hasUkOffice     : $src.FIRM_DETAILS->get('countries')->toMany(@String)->contains('UK'),
    ukIndex         : $src.FIRM_DETAILS->get('countries')->toMany(@String)->indexOf('UK'),
    allNameCount    : $src.FIRM_DETAILS->get('countries')->toMany(@String)->concatenate($src.FIRM_DETAILS->get('otherNames')->toMany(@String))->size(),
    // §2.17 — numeric aggregations
    totalRevenue    : $src.FIRM_DETAILS->get('revenueHistory')->toMany(@Float)->plus(),
    maxRevenue      : $src.FIRM_DETAILS->get('revenueHistory')->toMany(@Float)->max(),
    minRevenue      : $src.FIRM_DETAILS->get('revenueHistory')->toMany(@Float)->min(),
    hasRevHistory   : $src.FIRM_DETAILS->get('revenueHistory')->toMany(@Float)->isNotEmpty(),
    // §2.19 — fold / take / drop
    ratingsFolded   : $src.FIRM_DETAILS->get('ratings')->toMany(@String)->fold({r, acc| $acc + ',' + $r}, ''),
    topTwoRatCt     : $src.FIRM_DETAILS->get('ratings')->toMany(@String)->take(2)->size(),
    tailRatCt       : $src.FIRM_DETAILS->get('ratings')->toMany(@String)->drop(1)->size(),
    // §2.3 — computed leaves (arithmetic, string assembly, conditional, boolean logic)
    displayName     : $src.FIRM_DETAILS->get('legalName')->to(@String)->toOne() + ' (' + $src.FIRSTNAME + ')',
    fteEquiv        : $src.FIRM_DETAILS->get('employeeCount')->to(@Float)->toOne() * $src.FIRM_DETAILS->get('revenue')->to(@Float)->toOne(),
    contactName     : if($src.FIRM_DETAILS->get('address')->get('street')->isNotEmpty(),
                  |$src.FIRM_DETAILS->get('address')->get('street')->to(@String)->toOne(),
                  |'N/A'),
    isLargeMnc      : $src.FIRM_DETAILS->get('mnc')->to(@Boolean)->toOne() && ($src.FIRM_DETAILS->get('employeeCount')->to(@Integer)->toOne() > 2),
    // §2.5 — exists
    existsO3        : $src.FIRM_DETAILS->get('otherNames')->toMany(@String)->exists(n | $n == 'O3'),
    filteredNameCt  : $src.FIRM_DETAILS->get('otherNames')->toMany(@String)->filter(n| $n->startsWith('O1'))->size(),
    // §A — collection ops: last, init, tail, sort, reverse, add
    lastOtherName   : $src.FIRM_DETAILS->get('otherNames')->toMany(@String)->last(),
    initRatingCt    : $src.FIRM_DETAILS->get('ratings')->toMany(@String)->init()->size(),
    tailRatingCt    : $src.FIRM_DETAILS->get('ratings')->toMany(@String)->tail()->size(),
    sortedCountries : $src.FIRM_DETAILS->get('countries')->toMany(@String)->sort()->first(),
    reversedFirst   : $src.FIRM_DETAILS->get('otherNames')->toMany(@String)->reverse()->first(),
    withExtraName   : $src.FIRM_DETAILS->get('otherNames')->toMany(@String)->add('NEW')->size(),
    // §C — round-trip: toJson
    firmDetailsJson : $src.FIRM_DETAILS->toOne()->toJson(),
    // §D — toMany (direct array flatten — produces multiple rows)
    otherNamesDirect : $src.FIRM_DETAILS->get('otherNames')->toMany(@String),
    countriesDirect  : $src.FIRM_DETAILS->get('countries')->toMany(@String),
    revenuesDirect   : $src.FIRM_DETAILS->get('revenueHistory')->toMany(@Float),
    // §D — toMany class (flatten + sub-property navigation)
    addressLines     : $src.FIRM_DETAILS->get('address')->get('lines')->toMany(@meta::relational::tests::mapping::relation::variant::comprehensive::AddressLine)
  }
)

// =============================================================================
// Mapping 2 — VariantOrderMapping (§2.4 fromJson + §2.3 computed)
// =============================================================================
Mapping meta::relational::tests::mapping::relation::variant::comprehensive::VariantOrderMapping
(
   *Order[order]: Relation
   {
      ~func meta::relational::tests::mapping::relation::variant::comprehensive::orderFunction():Relation<Any>[1]
      orderId      : $src.PAYLOAD_JSON->cast(@String)->toOne()->fromJson()->get('orderId')->to(@String)->toOne(),
      side         : $src.PAYLOAD_JSON->cast(@String)->toOne()->fromJson()->get('side')->to(@String)->toOne(),
      qty          : $src.PAYLOAD_JSON->cast(@String)->toOne()->fromJson()->get('qty')->to(@Integer)->toOne(),
      price        : $src.PAYLOAD_JSON->cast(@String)->toOne()->fromJson()->get('price')->to(@Float)->toOne(),
      isActive     : $src.PAYLOAD_JSON->cast(@String)->toOne()->fromJson()->get('isActive')->to(@Boolean)->toOne(),
      headerSource : $src.PAYLOAD_JSON->cast(@String)->toOne()->fromJson()->get('header')->get('source')->to(@String),
      totalValue   : $src.PAYLOAD_JSON->cast(@String)->toOne()->fromJson()->get('qty')->to(@Float)->toOne() * $src.PAYLOAD_JSON->cast(@String)->toOne()->fromJson()->get('price')->to(@Float)->toOne(),
      displayLabel : $src.PAYLOAD_JSON->cast(@String)->toOne()->fromJson()->get('side')->to(@String)->toOne() + ':' + $src.PAYLOAD_JSON->cast(@String)->toOne()->fromJson()->get('orderId')->to(@String)->toOne()
   }
)

// =============================================================================
// Mapping 3 — VariantEventMapping (§2.12 conditional + §2.18 discriminator)
// =============================================================================
Mapping meta::relational::tests::mapping::relation::variant::comprehensive::VariantEventMapping
(
  *PartyEvent[event]: Relation
  {
    ~func meta::relational::tests::mapping::relation::variant::comprehensive::eventFunction():Relation<Any>[1]
    eventId      : $src.ID,
    kind         : $src.PAYLOAD->get('kind')->to(@String)->toOne(),
    counterparty : if($src.PAYLOAD->get('kind')->to(@String)->toOne() == 'TRADE',
                |$src.PAYLOAD->get('counterparty')->to(@String),
                |[]),
    venue        : if($src.PAYLOAD->get('kind')->to(@String)->toOne() == 'EXEC',
                |$src.PAYLOAD->get('execution')->get('venue')->to(@String),
                |[]),
    priority     : $src.PAYLOAD->get('priority')->to(@Integer),
    isTradeEvent : $src.PAYLOAD->get('kind')->to(@String)->toOne() == 'TRADE',
    hasPriority  : $src.PAYLOAD->get('priority')->isNotEmpty()
  }
)

// =============================================================================
// Mapping 4 — VariantBlockMapping (§2.13 array aggregation + §2.15 + §2.19)
// =============================================================================
Mapping meta::relational::tests::mapping::relation::variant::comprehensive::VariantBlockMapping
(
  *BlockSummary[block]: Relation
  {
    ~func meta::relational::tests::mapping::relation::variant::comprehensive::blockFunction():Relation<Any>[1]
    blockId          : $src.ID->cast(@String)->toOne(),
    status           : $src.BLOCKDATA->get('status')->to(@String)->toOne(),
    tradeCount       : $src.BLOCKDATA->get('relatedEntities')->toMany(@Variant)->filter(e| $e->get('tag')->to(@String)->toOne() == 'trade')->size(),
    firstOrderId     : $src.BLOCKDATA->get('relatedEntities')->toMany(@Variant)->filter(e| $e->get('tag')->to(@String)->toOne() == 'order')->first()->get('tagId')->to(@String),
    totalValue       : $src.BLOCKDATA->get('relatedEntities')->toMany(@Variant)->filter(e| $e->get('active')->to(@Boolean)->toOne() == true)->fold({e, acc| $acc + $e->get('value')->to(@Float)->toOne()}, 0.0),
    entityCount      : $src.BLOCKDATA->get('relatedEntities')->size(),
    hasTradeEntities : $src.BLOCKDATA->get('relatedEntities')->toMany(@Variant)->filter(e| $e->get('tag')->to(@String)->toOne() == 'trade')->isNotEmpty()
  }
)

// =============================================================================
// Mapping 5 — VariantPetMapping (§2.6 polymorphic + §2.16 instanceOf/match)
// =============================================================================
Mapping meta::relational::tests::mapping::relation::variant::comprehensive::VariantPetMapping
(
  *PersonWithPet[pwp]: Relation
  {
    ~func meta::relational::tests::mapping::relation::variant::comprehensive::petFunction():Relation<Any>[1]
    personId : $src.ID,
    pet      : $src.PAYLOAD->to(@Pet, '_type', [pair('Dog', Dog), pair('Cat', Cat)])->toOne(),
    isDog    : $src.PAYLOAD->toOne()->instanceOf(Dog),
    isCat    : $src.PAYLOAD->toOne()->instanceOf(Cat),
    petType  : $src.PAYLOAD->match([d:Dog[1]|'dog', c:Cat[1]|'cat', a:Any[1]|'unknown'])
  }
)

// =============================================================================
// Mapping 6 — VariantMapMapping (§B Map ops via to(@Map<String,String>))
// =============================================================================
Mapping meta::relational::tests::mapping::relation::variant::comprehensive::VariantMapMapping
(
  *MapPerson[mp]: Relation
  {
    ~func meta::relational::tests::mapping::relation::variant::comprehensive::mapFunction():Relation<Any>[1]
    name         : $src.PAYLOAD->get('name')->to(@String)->toOne(),
    // tagRole      : $src.PAYLOAD->get('tags')->to(@Map<String, Variant>)->get('role'),
    // tagDept      : $src.PAYLOAD->get('tags')->to(@Map<String, Variant>)->get('dept'),
    tagKeys      : $src.PAYLOAD->get('tags')->to(@Map<String, String>)->toOne()->keys(),
    tagValues    : $src.PAYLOAD->get('tags')->to(@Map<String, String>)->toOne()->values(),
    withExtraTag : $src.PAYLOAD->get('tags')->to(@Map<String, String>)->toOne()->put('extra', 'yes')->get('extra')
  }
)

// =============================================================================
// Mapping 7 — VariantNestedMapping (§D chained getMany→getMany)
// =============================================================================
Mapping meta::relational::tests::mapping::relation::variant::comprehensive::VariantNestedMapping
(
  *NestedDoc[nd]: Relation
  {
    ~func meta::relational::tests::mapping::relation::variant::comprehensive::nestedFunction():Relation<Any>[1]
    docId     : $src.ID,
    allItems  : $src.PAYLOAD->get('sections')->toMany(@Variant)->map(s| $s->get('items')->toMany(@String)),
    allTitles : $src.PAYLOAD->get('sections')->toMany(@Variant)->map(s| $s->get('title')->to(@String)->toOne())
  }
)

###Pure
import meta::pure::test::*;
import meta::core::runtime::*;
import meta::relational::metamodel::execute::tests::*;
import meta::relational::tests::mapping::relation::variant::comprehensive::*;

// =============================================================================
// CSV test data — 7 rows with rich JSON blobs
// =============================================================================
function <<access.private>> meta::relational::tests::mapping::relation::variant::comprehensive::personCsv(): String[1]
{
  'VARIANT_SCHEMA\n' +
  'PERSON_TABLE\n' +
  'ID,FIRSTNAME,LASTNAME,FIRM_DETAILS,MANAGERID\n' +
