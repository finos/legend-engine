// =============================================================================
// Comprehensive Variant Mapping Tests — Setup
//
// Domain, Database, Mappings, CSV data, and test execution helpers.
// Tests variant-operation expressivity at the MAPPING LEVEL (§2.1–§2.20).
// Companion test file: testVariantMappingComprehensiveTests.pure
// =============================================================================


###Relational
Database meta::relational::tests::mapping::relation::variant::comprehensive::VariantDB
(
  Schema VARIANT_SCHEMA
  (
    Table PERSON_TABLE
    (
      ID INTEGER PRIMARY KEY,
      FIRSTNAME VARCHAR(100) NOT NULL,
      LASTNAME VARCHAR(100) NOT NULL,
      FIRM_DETAILS SEMISTRUCTURED,
      MANAGERID INTEGER
    )

    Table ORDER_TABLE
    (
      ID INTEGER PRIMARY KEY,
      PAYLOAD_JSON VARCHAR(4000)
    )

    Table EVENT_TABLE
    (
      ID INTEGER PRIMARY KEY,
      PAYLOAD SEMISTRUCTURED
    )

    Table BLOCK_TABLE
    (
      ID INTEGER PRIMARY KEY,
      BLOCKDATA SEMISTRUCTURED
    )

    Table PET_TABLE
    (
      ID INTEGER PRIMARY KEY,
      PAYLOAD SEMISTRUCTURED
    )

    Table MAP_TABLE
    (
      ID INTEGER PRIMARY KEY,
      PAYLOAD SEMISTRUCTURED
    )

    Table NESTED_TABLE
    (
      ID INTEGER PRIMARY KEY,
      PAYLOAD SEMISTRUCTURED
    )
  )
)


