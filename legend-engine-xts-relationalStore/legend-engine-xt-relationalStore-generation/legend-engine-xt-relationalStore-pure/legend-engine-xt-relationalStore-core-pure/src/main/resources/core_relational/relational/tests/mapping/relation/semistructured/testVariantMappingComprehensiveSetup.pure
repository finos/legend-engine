// =============================================================================
// Domain — Firm / Address / AddressLine (for whole-subtree §2.7)
// =============================================================================
Class meta::relational::tests::mapping::relation::variant::comprehensive::AddressLine
{
  details: String[1];
}

Class meta::relational::tests::mapping::relation::variant::comprehensive::Address
{
  name  : String[1];
  street: String[0..1];
  lines : meta::relational::tests::mapping::relation::variant::comprehensive::AddressLine[*];
}

Class meta::relational::tests::mapping::relation::variant::comprehensive::Firm
{
  legalName     : String[1];
  employeeCount : Integer[1];
  revenue       : Float[1];
  mnc           : Boolean[1];
  estDate       : StrictDate[1];
  lastUpdate    : DateTime[1];
  entityType    : String[0..1];
  otherNames    : String[*];
  address       : meta::relational::tests::mapping::relation::variant::comprehensive::Address[1];
  revenueHistory: Float[*];
  ratings       : String[*];
  countries     : String[*];
}

// =============================================================================
// Domain — Person (the rich "view model" with 40+ concrete properties)
// =============================================================================
Class meta::relational::tests::mapping::relation::variant::comprehensive::Person
{
  // Baseline columns
  firstName       : String[1];
  lastName        : String[1];
  // §2.7 — whole subtree deserialization
  firm            : meta::relational::tests::mapping::relation::variant::comprehensive::Firm[1];
  // §2.1 — direct extraction (all primitive types)
  firmName        : String[1];
  employeeCount   : Integer[1];
  revenue         : Float[1];
  isMnc           : Boolean[1];
  estDate         : StrictDate[1];
  lastUpdate      : DateTime[1];
  // §2.2 — enum-as-string
  entityType      : String[0..1];
  // §2.9 — nested object navigation
  addressName     : String[1];
  addressStreet   : String[0..1];
  // §2.15 — at / first / size / isEmpty / isNotEmpty
  firstAddrLine   : String[0..1];
  secondAddrLine  : String[0..1];
  addrLineCount   : Integer[1];
  hasAddress      : Boolean[1];
  hasStreet       : Boolean[1];
  // §2.5 + §2.15 — toMany + size / first / at / isEmpty / isNotEmpty
  otherNameCount  : Integer[1];
  firstOtherName  : String[0..1];
  secondOtherName : String[0..1];
  hasOtherNames   : Boolean[1];
  otherNamesEmpty : Boolean[1];
  // §2.20 — distinct / contains / indexOf / concatenate
  distinctCtryCount: Integer[1];
  hasUkOffice     : Boolean[1];
  ukIndex         : Integer[1];
  allNameCount    : Integer[1];
  // §2.17 — numeric aggregations
  totalRevenue    : Float[1];
  maxRevenue      : Float[0..1];
  minRevenue      : Float[0..1];
  hasRevHistory   : Boolean[1];
  // §2.19 — fold / take / drop
  ratingsFolded   : String[1];
  topTwoRatCt     : Integer[1];
  tailRatCt       : Integer[1];
  // §2.3 — computed leaves
  displayName     : String[1];
  fteEquiv        : Float[1];
  contactName     : String[1];
  isLargeMnc      : Boolean[1];
  // §2.5 — exists / filter+size
  existsO3        : Boolean[1];
  filteredNameCt  : Integer[1];
  // §A — collection ops: last, init, tail, sort, reverse, add
  lastOtherName   : String[0..1];
  initRatingCt    : Integer[1];
  tailRatingCt    : Integer[1];
  sortedCountries : String[0..1];
  reversedFirst   : String[0..1];
  withExtraName   : Integer[1];
  // §C — round-trip: toJson
  firmDetailsJson : String[1];
  // §D — toMany (direct array flatten)
  otherNamesDirect : String[*];
  countriesDirect  : String[*];
  revenuesDirect   : Float[*];
  // §D — toMany class (flatten then navigate sub-properties)
  addressLines     : meta::relational::tests::mapping::relation::variant::comprehensive::AddressLine[*];
}

