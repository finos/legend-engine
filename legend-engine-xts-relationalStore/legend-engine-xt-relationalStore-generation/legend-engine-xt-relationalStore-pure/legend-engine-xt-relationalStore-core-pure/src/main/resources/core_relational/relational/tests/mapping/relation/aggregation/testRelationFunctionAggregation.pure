###Pure
import meta::pure::metamodel::tds::*;
import meta::pure::mapping::*;
import meta::pure::router::*;
import meta::relational::mapping::*;
import meta::relational::tests::mapping::relation::*;
import meta::relational::metamodel::execute::*;
import meta::relational::runtime::*;
import meta::pure::executionPlan::*;
import meta::pure::executionPlan::toString::*;

// Sub-aggregation tests for RelationFunctionInstanceSetImplementation.
// Analogous to meta::relational::tests::projection::aggregation::testSubAggregation
// but with a relation (~func) class mapping as the root.
//
// Lives under meta::relational::tests::mapping::relation::aggregation so that the
// parent package's <<BeforePackage>> setUp() (relationMappingSetup.pure) runs and
// creates the personTable / firmTable schema this suite expects ("FIRST NAME"
// column, no ADDRESSID, etc.). Do NOT move these tests under
// meta::relational::tests::projection::aggregation — that package's existing
// BeforePackage installs an incompatible schema (FIRSTNAME / LASTNAME / ADDRESSID)
// and the two would clobber each other in the shared H2 instance.

function <<access.private>> meta::relational::tests::mapping::relation::aggregation::runFirmAgg(query:FunctionDefinition<{->TabularDataSet[1]}>[1]):TabularDataSet[1]
{
   execute(
      $query,
      meta::relational::tests::mapping::relation::SimpleMapping,
      meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
      meta::relational::extension::relationalExtensions()
   ).values->at(0);
}

// (1) Average — basic single sub-aggregation.
function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationOnRelationMapping():Boolean[1]
{
   let result = meta::relational::tests::mapping::relation::aggregation::runFirmAgg(
      |Firm.all()->project(~[a:f|$f.employees.age->average()])->cast(@TabularDataSet)
   );
   assertSize($result.rows, 5);
   assertSameElements(['30.0', '35.5', '52.0', 'TDSNull', 'TDSNull'], $result.rows->map(r|$r.values->at(0)->toString()));
}

// Average + simple property.
function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationOnRelationMappingWithSimpleProperty():Boolean[1]
{
   let result = meta::relational::tests::mapping::relation::aggregation::runFirmAgg(
      |Firm.all()->project(~[name:f|$f.legalName, a:f|$f.employees.age->average()])->cast(@TabularDataSet)
   );
   assertSameElements(
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | 35.5', 'Firm D | 52.0', 'Firm X | 30.0'],
      $result.rows->map(r|$r.values->makeString(' | '))
   );
}

// Two sub-aggregations on the same root (count + average).
function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testTwoSubAggregationOnRelationMapping():Boolean[1]
{
   let result = meta::relational::tests::mapping::relation::aggregation::runFirmAgg(
      |Firm.all()->project(~[
         b:f|$f.employees.firstName->count(),
         a:f|$f.employees.age->average()
      ])->cast(@TabularDataSet)
   );
   assertSameElements(
      ['0 | TDSNull', '0 | TDSNull', '1 | 30.0', '1 | 52.0', '2 | 35.5'],
      $result.rows->map(r|$r.values->makeString(' | '))
   );
}

// Sum (NULL for empty groups via LEFT OUTER JOIN).
function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationSumOnRelationMapping():Boolean[1]
{
   let result = meta::relational::tests::mapping::relation::aggregation::runFirmAgg(
      |Firm.all()->project(~[name:f|$f.legalName, s:f|$f.employees.age->sum()])->cast(@TabularDataSet)
   );
   assertSameElements(
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | 71', 'Firm D | 52', 'Firm X | 30'],
      $result.rows->map(r|$r.values->makeString(' | '))
   );
}

// Max.
function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationMaxOnRelationMapping():Boolean[1]
{
   let result = meta::relational::tests::mapping::relation::aggregation::runFirmAgg(
      |Firm.all()->project(~[name:f|$f.legalName, m:f|$f.employees.age->max()])->cast(@TabularDataSet)
   );
   assertSameElements(
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | 45', 'Firm D | 52', 'Firm X | 30'],
      $result.rows->map(r|$r.values->makeString(' | '))
   );
}

// Sub-aggregation with a filter inside the collection navigation.
function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationWithFilterOnRelationMapping():Boolean[1]
{
   let result = meta::relational::tests::mapping::relation::aggregation::runFirmAgg(
      |Firm.all()->project(~[name:f|$f.legalName, a:f|$f.employees->filter(e|$e.age > 30).age->average()])->cast(@TabularDataSet)
   );
   assertSameElements(
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | 45.0', 'Firm D | 52.0', 'Firm X | TDSNull'],
      $result.rows->map(r|$r.values->makeString(' | '))
   );
}

// Min.
function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationMinOnRelationMapping():Boolean[1]
{
   let result = meta::relational::tests::mapping::relation::aggregation::runFirmAgg(
      |Firm.all()->project(~[name:f|$f.legalName, m:f|$f.employees.age->min()])->cast(@TabularDataSet)
   );
   assertSameElements(
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | 26', 'Firm D | 52', 'Firm X | 30'],
      $result.rows->map(r|$r.values->makeString(' | '))
   );
}

// Count only — single aggregation column with no extra projected properties.
function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationCountOnlyOnRelationMapping():Boolean[1]
{
   let result = meta::relational::tests::mapping::relation::aggregation::runFirmAgg(
      |Firm.all()->project(~[c:f|$f.employees.firstName->count()])->cast(@TabularDataSet)
   );
   assertSize($result.rows, 5);
   assertSameElements(['0', '0', '1', '1', '2'], $result.rows->map(r|$r.values->at(0)->toString()));
}

// Top-level if wrapping a sub-aggregation (exercises CASE/WHEN wrapping path).
function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationWithIfOnRelationMapping():Boolean[1]
{
   let result = meta::relational::tests::mapping::relation::aggregation::runFirmAgg(
      |Firm.all()->project(~[name:f|$f.legalName, a:f|if($f.legalName == 'Firm X', |1.0, |$f.employees.age->average())])->cast(@TabularDataSet)
   );
   assertSameElements(
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | 35.5', 'Firm D | 52.0', 'Firm X | 1.0'],
      $result.rows->map(r|$r.values->makeString(' | '))
   );
}

// map + arithmetic then sum (validates expression wrapping inside aggregate).
function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationMapArithmeticOnRelationMapping():Boolean[1]
{
   let result = meta::relational::tests::mapping::relation::aggregation::runFirmAgg(
      |Firm.all()->project(~[name:f|$f.legalName, s:f|$f.employees.age->map(a|$a * 2)->sum()])->cast(@TabularDataSet)
   );
   assertSameElements(
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | 142', 'Firm D | 104', 'Firm X | 60'],
      $result.rows->map(r|$r.values->makeString(' | '))
   );
}

// joinStrings (listagg SQL path). sortBy makes the per-group order deterministic.
function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationJoinStringsOnRelationMapping():Boolean[1]
{
   let result = meta::relational::tests::mapping::relation::aggregation::runFirmAgg(
      |Firm.all()->project(~[name:f|$f.legalName, e:f|$f.employees->sortBy(p|$p.firstName).firstName->joinStrings('^')])->cast(@TabularDataSet)
   );
   assertSameElements(
      ['Firm A | ', 'Firm B | ', 'Firm C | Fabrice^Oliver', 'Firm D | David', 'Firm X | John'],
      $result.rows->map(r|$r.values->makeString(' | '))
   );
}

// Diagnostic: prints the generated plan AND executes. If H2 rejects the SQL, the SQL is right
// above the H2 stack trace in the test log — direct correlation, no separate run needed.
function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationOnRelationMapping_SQL():Boolean[1]
{
   let plan = executionPlan(
      |Firm.all()->project(~[a:f|$f.employees.age->average()])->cast(@TabularDataSet),
      meta::relational::tests::mapping::relation::SimpleMapping,
      meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
      meta::relational::extension::relationalExtensions()
   );
   let planStr = $plan->planToString(meta::relational::extension::relationalExtensions());
   println('### AVG plan ###\n' + $planStr + '\n### end AVG plan ###');
   // Now actually execute — succeeds or throws an H2 error we can see paired with the plan above.
   let res = meta::relational::tests::mapping::relation::aggregation::runFirmAgg(
      |Firm.all()->project(~[a:f|$f.employees.age->average()])->cast(@TabularDataSet)
   );
   println('### AVG row count = ' + $res.rows->size()->toString() + ' ###');
   true;
}

// Same pattern for the count case.
function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationCountOnlyOnRelationMapping_SQL():Boolean[1]
{
   let plan = executionPlan(
      |Firm.all()->project(~[c:f|$f.employees.firstName->count()])->cast(@TabularDataSet),
      meta::relational::tests::mapping::relation::SimpleMapping,
      meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
      meta::relational::extension::relationalExtensions()
   );
   let planStr = $plan->planToString(meta::relational::extension::relationalExtensions());
   println('### COUNT plan ###\n' + $planStr + '\n### end COUNT plan ###');
   let res = meta::relational::tests::mapping::relation::aggregation::runFirmAgg(
      |Firm.all()->project(~[c:f|$f.employees.firstName->count()])->cast(@TabularDataSet)
   );
   println('### COUNT row count = ' + $res.rows->size()->toString() + ' ###');
   true;
}

