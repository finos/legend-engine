function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationWithIfOnRelationMapping():Boolean[1]
{
   testFirmAgg(
      |Firm.all()->project(~[name:x|$x.legalName, a:x|if($x.legalName == 'Firm X', |1.0, |$x.employees.age->average())])->cast(@TabularDataSet),
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | 35.5', 'Firm D | 52.0', 'Firm X | 1.0']
   );
}

// TODO: map+arithmetic — inner lambda dropped during relation-function sub-aggregation.
function <<meta::pure::profiles::test.ToFix>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationMapArithmeticOnRelationMapping():Boolean[1]
{
   testFirmAgg(
      |Firm.all()->project(~[name:x|$x.legalName, s:x|$x.employees.age->map(a|$a * 2)->sum()])->cast(@TabularDataSet),
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | 142', 'Firm D | 104', 'Firm X | 60']
   );
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationJoinStringsOnRelationMapping():Boolean[1]
{
   testFirmAgg(
      |Firm.all()->project(~[name:x|$x.legalName, e:x|$x.employees->sortBy(p|$p.firstName).firstName->joinStrings('^')])->cast(@TabularDataSet),
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | Fabrice^Oliver', 'Firm D | David', 'Firm X | John']
   );
}
