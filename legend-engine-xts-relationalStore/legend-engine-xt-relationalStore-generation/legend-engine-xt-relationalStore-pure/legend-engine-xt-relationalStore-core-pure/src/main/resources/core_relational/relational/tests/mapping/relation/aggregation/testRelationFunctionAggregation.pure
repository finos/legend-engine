{
   testFirmAgg(
      |Firm.all()->project(~[name:x|$x.legalName, m:x|$x.employees.age->min()])->cast(@TabularDataSet),
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | 26', 'Firm D | 52', 'Firm X | 30']
   );
