// TODO: filter inside collection navigation — AGE column fails to resolve against inner relation.
function <<meta::pure::profiles::test.ToFix>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationWithFilterOnRelationMapping():Boolean[1]
{
   testFirmAgg(
      |Firm.all()->project(~[name:x|$x.legalName, a:x|$x.employees->filter(e|$e.age > 30).age->average()])->cast(@TabularDataSet),
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | 45.0', 'Firm D | 52.0', 'Firm X | TDSNull']
   );
}

