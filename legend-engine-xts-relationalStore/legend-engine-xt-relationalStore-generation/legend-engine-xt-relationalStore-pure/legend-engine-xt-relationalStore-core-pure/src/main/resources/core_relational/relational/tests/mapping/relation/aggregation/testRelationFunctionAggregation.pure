###Pure
import meta::pure::metamodel::tds::*;
import meta::pure::mapping::*;
import meta::pure::router::*;
import meta::relational::mapping::*;
import meta::relational::tests::mapping::relation::*;
import meta::relational::tests::mapping::relation::aggregation::*;
import meta::relational::metamodel::execute::*;
import meta::relational::runtime::*;
import meta::pure::executionPlan::*;
import meta::pure::executionPlan::toString::*;

// Sub-aggregation tests for RelationFunctionInstanceSetImplementation.
// Uses testFirmAgg helper to execute+assert in one call (avoids runner pre-evaluation issues).
function <<access.private>> meta::relational::tests::mapping::relation::aggregation::testFirmAgg(query:FunctionDefinition<{->TabularDataSet[1]}>[1], expectedRows:String[*]):Boolean[1]
{
   let result = execute(
      $query,
      meta::relational::tests::mapping::relation::SimpleMapping,
      meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
      meta::relational::extension::relationalExtensions()
   ).values->at(0);
   assertSameElements($expectedRows, $result.rows->map(r|$r.values->makeString(' | ')));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationOnRelationMapping():Boolean[1]
{
   testFirmAgg(
      |Firm.all()->project(~[name:x|$x.legalName, a:x|$x.employees.age->average()])->cast(@TabularDataSet),
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | 35.5', 'Firm D | 52.0', 'Firm X | 30.0']
   );
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testSubAggregationOnRelationMappingWithSimpleProperty():Boolean[1]
{
   testFirmAgg(
      |Firm.all()->project(~[name:x|$x.legalName, a:x|$x.employees.age->average()])->cast(@TabularDataSet),
      ['Firm A | TDSNull', 'Firm B | TDSNull', 'Firm C | 35.5', 'Firm D | 52.0', 'Firm X | 30.0']
   );
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::aggregation::testTwoSubAggregationOnRelationMapping():Boolean[1]
{
   testFirmAgg(
      |Firm.all()->project(~[name:x|$x.legalName, b:x|$x.employees.firstName->count(), a:x|$x.employees.age->average()])->cast(@TabularDataSet),
      ['Firm A | 0 | TDSNull', 'Firm B | 0 | TDSNull', 'Firm C | 2 | 35.5', 'Firm D | 1 | 52.0', 'Firm X | 1 | 30.0']
   );
}

