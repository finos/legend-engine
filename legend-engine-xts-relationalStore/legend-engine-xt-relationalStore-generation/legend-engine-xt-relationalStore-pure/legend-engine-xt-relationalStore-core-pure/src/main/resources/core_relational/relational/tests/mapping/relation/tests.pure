       t3
    #->toString(),
    $result.values->at(0)->sort([~tag->ascending()])->toString()
  );
}

// t12 — Unsupported: Map<String,Variant>[1] is a structural container. The router
// rejects this at plan-generation time via the isStructuralContainer check.
// Marked ToFix until the rejection is wired to a user-visible error message.
function <<test.ToFix, test.AlloyOnly>> meta::relational::tests::mapping::relation::testRfpmLiftUnsupportedStructuralContainer():Boolean[1]
{
  let db = meta::relational::tests::mapping::relation::testDB;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  setupRfpmLiftTestData(
    [
      'ID,PAYLOAD',
      '1,{"key":"value"}'
    ],
    $db, $runtime
  );
  // Expect plan generation to throw: Map<String,Variant> is excluded by isStructuralContainer.
  // The size() query is used to avoid ->to() which has no Java compiled-mode binding.
  let result = execute(
    |PersonLiftedUnsupported.all()->size(),
    meta::relational::tests::mapping::relation::LiftedUnsupportedMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );
  fail('Expected plan-generation error for Map<String,Variant> structural container');
  true;
}
