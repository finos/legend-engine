      |PersonWithEmployeeType.all()->project(~[type:x|$x.employeeType, age:x|$x.age])->groupBy(~type, ~count:x|$x.age:y|$y->count()),
      meta::relational::tests::mapping::relation::EnumerationRelationMapping,
