{
  // extend adds DOUBLE_AGE (PK still [ID]); select(~[AGE, FIRMID, DOUBLE_AGE])
  // drops ID → PK = [].
  assertEquals([], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestExtendThenSelectDroppingPKMapping, 'pk'));
}

