   assertEquals(
    #TDS
       name, type, active
       David, CONTRACT, ACTIVE
       Fabrice, FULL_TIME, ACTIVE
       John, FULL_TIME, ACTIVE
       Oliver, CONTRACT, ACTIVE
    #->toString(),
    $result.values->at(0)->sort(~name->ascending())->toString()
  );
}

