// -------------------------------------------------------------------------
// Primary-key auto-inference for Relation Function class mappings (PK only)
// -------------------------------------------------------------------------
// `resolveRelationFunctionPrimaryKeyColumnNames` walks the relation function
// body and applies the per-operator PK rule (see helperFunctions.pure):
//
//   filter / limit / drop / take / slice / sort / sortBy ... preserve PK
//   rename(rel, ~old, ~new)            ..................... swap old → new
//   select(rel) / select(rel, cols)    ..................... preserve iff PK ⊆ cols
//   extend(rel, ...)                   ..................... preserve PK
//   distinct(rel) / distinct(rel, cols) .................... cols (or input PK)
//   groupBy(rel, cols, agg)            ..................... PK = cols
//   join / asOfJoin                    ..................... PK = leftPK ∪ rightPK
//   aggregate / pivot / lateral / concatenate / flatten .... empty
//
// NOTE: explicit `~primaryKey: [...]` syntax is part of the engine grammar
// only — the upstream legend-pure parser used to compile this `.pure` file
// into a PAR does not recognise that token, so the explicit-PK acceptance
// path is covered by Java grammar/compiler tests instead
// (TestMappingGrammarParser, TestMappingGrammarRoundtrip,
//  TestMappingCompilationFromGrammar).

function <<access.private>> meta::relational::tests::mapping::relation::pkOf(mapping:meta::pure::mapping::Mapping[1], id:String[1]):String[*]
{
  let setImpl = $mapping->classMappingById($id)
                  ->toOne()
                  ->cast(@meta::pure::mapping::relation::RelationFunctionInstanceSetImplementation);
  meta::relational::mapping::resolveRelationFunctionPrimaryKeyColumnNames($setImpl);
}

// =========================================================================
// A. Single-operator coverage — one operator after a bare table accessor.
// =========================================================================

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKFromBareAccessor():Boolean[1]
{
  // #>{personTable}# — leaf rule: PK = table primary key = [ID].
  assertEquals(['ID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestBareMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughFilter():Boolean[1]
{
  // filter preserves leftPK.
  assertEquals(['ID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestFilterMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughLimit():Boolean[1]
{
  // limit preserves leftPK.
  assertEquals(['ID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestLimitMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughDrop():Boolean[1]
{
  // drop preserves leftPK.
  assertEquals(['ID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestDropMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughSlice():Boolean[1]
{
  // slice preserves leftPK.
  assertEquals(['ID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestSliceMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughSort():Boolean[1]
{
  // sort preserves leftPK.
  assertEquals(['ID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestSortMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughExtend():Boolean[1]
{
  // extend only adds columns; leftPK is preserved.
  assertEquals(['ID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestExtendMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughRename():Boolean[1]
{
  // rename(~ID, ~PERSON_ID): PK ID is swapped to PERSON_ID.
  assertEquals(['PERSON_ID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestRenameMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughSelectKeepingPKBare():Boolean[1]
{
  // select(~[ID, AGE]): PK ⊆ cols → PK preserved.
  assertEquals(['ID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestSelectKeepingPKMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughSelectDroppingPK():Boolean[1]
{
  // select(~[AGE, FIRMID]): PK not in cols → PK = [].
  assertEquals([], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestSelectDroppingPKMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughDistinctNoArgs():Boolean[1]
{
  // distinct() with no arg preserves leftPK.
  assertEquals(['ID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestDistinctNoArgsMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughDistinctWithCols():Boolean[1]
{
  // distinct(~[AGE, FIRMID]): PK = the explicit cols.
  assertSameElements(['AGE', 'FIRMID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestDistinctWithColsMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKFromGroupBy():Boolean[1]
{
  // personFunctionWithGroupBy body: #>{personTable}#->groupBy(~FIRMID, ~SUM:...)
  // groupBy → PK = group-by columns = [FIRMID].
  assertEquals(['FIRMID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::GroupByMapping,
    'meta_relational_tests_mapping_relation_GroupByClass'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKFromJoin():Boolean[1]
{
  // join(personTable, firmTable->rename(~ID, ~FIRM_ID), INNER, ...):
  // leftPK=[ID] ∪ rightPK=[FIRM_ID] (firmTable's PK is renamed before the
  // join so the row type doesn't have duplicate column names).
  assertSameElements(['ID', 'FIRM_ID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestJoinMapping, 'pk'));
}

// =========================================================================
// B. Unsupported / negative — operators we conservatively treat as empty.
// =========================================================================

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKEmptyForConcatenate():Boolean[1]
{
  // concatenate is not in the supported operator set → PK = [] (conservative).
  assertEquals([], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestConcatenateMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKEmptyForNonAccessorLeaf():Boolean[1]
{
  // MixedMapping['person'] uses personFunctionWithProject whose body is
  // PersonWithFirmId.all()->filter(...)->project(...)->select(...). The leaf
  // is a Class.all() expression, NOT a RelationStoreAccessor — so the leaf
  // rule yields no PK and the inference returns [].
  assertEquals([], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::MixedMapping, 'person'));
}

// =========================================================================
// C. Complex nested chains — multi-operator pipelines
//    Each test exercises propagation through
//    several layers so regressions in any single rule surface here.
// =========================================================================

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKFromSimpleTableAccessor():Boolean[1]
{
  // personFunction body: #>{personTable}#->filter(x|$x.AGE > 25)->limit(5)
  // filter & limit preserve PK → personTable.PK = [ID].
  assertEquals(['ID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::SimpleMapping, 'person'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughSelectKeepingPK():Boolean[1]
{
  // firmFunction body: #>{firmTable}#->limit(10)->select(~[ID, legalName])
  // limit preserves PK; select preserves PK because firmTable.PK=[ID] ⊆ cols.
  assertEquals(['ID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::SimpleMapping, 'firm'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKFromInnerJoinWithExtend():Boolean[1]
{
  // personFunctionWithJoinAndWindowColumn body:
  //   #>{personTable}#->join(#>{groupMembershipTable}#, INNER, ...)
  //                   ->extend(over(...), ~[RANK:...])
  // join → leftPK ∪ rightPK = [ID] ∪ [GROUPID]
  // extend → preserve PK
  assertSameElements(['ID', 'GROUPID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::WindowColumnMapping, 'person'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughFilterSortLimit():Boolean[1]
{
  // filter → sort → limit: all preserve leftPK = [ID].
  assertEquals(['ID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestFilterSortLimitMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughRenameThenSelectKeepingPK():Boolean[1]
{
  // rename(ID→PID) sets PK=[PID]; select(~[PID, AGE]) keeps PID.
  assertEquals(['PID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestRenameThenSelectKeepingPKMapping, 'pk'));
}

