// t11 — Explicit map: firms->map(f|$f.tags) flattened to String[*].
// The lift router must wrap the body in array_flatten before emitting the LATERAL join.
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testRfpmLiftExplicitMap():Boolean[1]
{
  let db = meta::relational::tests::mapping::relation::testDB;
