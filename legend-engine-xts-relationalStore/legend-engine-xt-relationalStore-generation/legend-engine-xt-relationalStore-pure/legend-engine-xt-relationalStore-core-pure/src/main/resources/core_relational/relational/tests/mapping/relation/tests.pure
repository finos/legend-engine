  assertSameElements(['ID', 'GROUPID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestJoinExtendFilterSelectMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughGroupByThenSelectDroppingPK():Boolean[1]
{
  // groupBy(~FIRMID, ...) sets PK=[FIRMID]; select(~[SUM]) drops FIRMID → [].
  assertEquals([], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestGroupByThenSelectDroppingPKMapping,
    'meta_relational_tests_mapping_relation_PkTestSum'));
}

