       David, Group D, 1
       Fabrice, Group C, 1
       John, Group A, 2
       Oliver, Group C, 2
    #->toString(),
    $result.values->at(0)->sort(~name->ascending())->toString()
  );
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testMappingWithGroupBy():Boolean[1]
{
