// --- Pure-expression-based RelationFunctionPropertyMapping tests --------------
// These exercise the general-case lambda walker (now `evaluateRfpmRhs` →
// `transformRelationFunctionPropertyMappingToRelational` in pureToSQLQuery.pure)
// that replaced the original bare-column-only placeholder helper. Bare-column
// property mappings lower (in legend-pure) to `{src | $src.<col>}`, and richer
// expressions like `$src.A + 5` flow through the same walker via the DynaFunction leg.

// Same query / fixture as testSimpleMappingQuery but driven by ExplicitSrcMapping
// where every property is written in `$src.<col>` form. Asserts the explicit
// lambda form produces results identical to the bare-column sugar.
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testExplicitSrcMappingQuery():Boolean[1]
{
  let result = execute(
    |Person.all()->project(~[name:x|$x.firstName, age:x|$x.age]),
    meta::relational::tests::mapping::relation::ExplicitSrcMapping,
    meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
    meta::relational::extension::relationalExtensions()
  );
  assertEquals(
    #TDS
       name, age
       David, 52
       Fabrice, 45
       John, 30
       Oliver, 26
    #->toString(),
    $result.values->at(0)->sort(~name->ascending())->toString()
  );
}

// Arithmetic expression on the RHS of a property mapping. `age` is mapped to
// `$src.AGE + 5`, so projected ages should be the underlying column values
// shifted by +5. This exercises the DynaFunction leg of the lambda walker
// (`plus`) over a TableAliasColumn + Literal.
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testExpressionMappingArithmetic():Boolean[1]
{
  let result = execute(
    |Person.all()->project(~[name:x|$x.firstName, age:x|$x.age]),
    meta::relational::tests::mapping::relation::ExpressionMapping,
    meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
    meta::relational::extension::relationalExtensions()
  );
  assertEquals(
    #TDS
      name, age
      David, 57
      Fabrice, 50
      John, 35
      Oliver, 31
    #->toString(),
    $result.values->at(0)->sort(~name->ascending())->toString()
  );
}

// Same arithmetic mapping, but the projection filters first to ensure the
// expression-form PM survives a downstream filter pushdown.
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testExpressionMappingArithmeticWithFilter():Boolean[1]
{
  let result = execute(
    |Person.all()->filter(p|$p.age > 35)->project(~[name:x|$x.firstName, age:x|$x.age]),
    meta::relational::tests::mapping::relation::ExpressionMapping,
    meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
    meta::relational::extension::relationalExtensions()
  );
  assertEquals(
    #TDS
      name, age
      David, 57
      Fabrice, 50
    #->toString(),
    $result.values->at(0)->sort(~name->ascending())->toString()
  );
}

// Demonstrates that the strict-multiplicity property-mapping check accepts
// a nullable column ([0..1]) feeding a [0..1] property. Source SALARY is
// declared nullable in `testDB.personTable`; PersonWithOptionalSalary.salary
// is Float[0..1]. The compile-time check passes because both ends are [0..1].
// All seed rows currently have non-null SALARY, so the [0..1] path is
// exercised at compile time only — matches the sibling test in
// testModelJoinSimple.pure::testNullableSalaryMapping.
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testNullableSalaryMapping():Boolean[1]
{
  let result = execute(
    |PersonWithOptionalSalary.all()->project(~[name:x|$x.firstName, salary:x|$x.salary]),
    meta::relational::tests::mapping::relation::NullableSalaryMapping,
    meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
    meta::relational::extension::relationalExtensions()
  );
  assertEquals(
    #TDS
       name, salary
       David, 88.88
       Fabrice, 19.29
       John, 72.4
       Oliver, 42.34
    #->toString(),
    $result.values->at(0)->sort(~name->ascending())->toString()
  );
}

// t6 — Non-variant DynaFunction (string concat). Lift router routes through
// the RelationalPropertyMapping arm (no SS PM).
// Uses the existing personFunction → personTable, seeded once by
// createTablesAndFillDb (no setupRfpmLiftTestData call needed).
// personFunction filters AGE > 25 and limits to 5 → John, Fabrice, Oliver, David.
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testRfpmLiftMixedConcat():Boolean[1]
{
  let db = meta::relational::tests::mapping::relation::testDB;
  let runtime = meta::external::store::relational::tests::testRuntime($db);

  let result = execute(
    |PersonLiftedConcat.all()->project(~[greeting: x | $x.greeting]),
    meta::relational::tests::mapping::relation::LiftedConcatMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );

  assertEquals(
    #TDS
      greeting
      Hello David
      Hello Fabrice
      Hello John
      Hello Oliver
    #->toString(),
    $result.values->at(0)->sort([~greeting->ascending()])->toString()
  );
}

// --- RFPM-lift variant tests (personPayloadTable) ----------------------------
// setupRfpmLiftTestData seeds personPayloadTable (NOT pre-populated by
// createTablesAndFillDb, so the seed block must also drive its CREATE TABLE). It
// joins its list elements with '\n-\n' and feeds them to setUpDataSQLsV2, so each
// element is ONE table block laid out as: schema line ('default'), table line
// ('personPayloadTable'), column header ('ID,PAYLOAD'), then data rows. The
// PAYLOAD column holds a JSON string; because the JSON contains commas and
// double-quotes it must be RFC4180-quoted (wrap the field in "..." and double
// every internal " as "") so the CSV parser keeps the whole payload as a single
// field.
//
// NOT COVERED — variant extraction via RFPM-lift (get()->to()/->toMany()):
// The tests testRfpmLiftPrimitive/Class/ClassToMany/ExplicitMap were removed
// because the feature is not executable on the path these <<test.AlloyOnly>>
// relation-mapping tests use. Property-mapping bodies like
// $src.PAYLOAD->get(..)->to(@T)/->toMany(@T) lower to the `variantTo`
// DynaFunction (pureToSQLQuery_variant.pure), but the sqlDialectTranslation model
// path (toPostgresModel.pure::getDynaFunctionConverterMap) has no `variantTo`
// converter — execution fails with "Couldn't find DynaFunction to Postgres model
// translation for variantTo()". ExplicitMap additionally failed earlier at
// routing: ->toMany(@PayloadFirm)->map(f|$f.tags) makes the router look for a
// class mapping for the unmapped PayloadFirm (helperFunctions.pure). The classic,
// supported way to read a SEMISTRUCTURED column is extractFromSemiStructured(..)
// (see meta::relational::tests::semistructured), which is wired into both the
// string and model paths. Re-add these tests once `variantTo` (and map-over-
// extracted-class routing) are supported in the model path.

// t12 — Unsupported: Map<String,Variant>[1] is a structural container. The router
// rejects this at plan-generation time via the isStructuralContainer check.
// Marked ToFix until the rejection is wired to a user-visible error message.
function <<test.ToFix, test.AlloyOnly>> meta::relational::tests::mapping::relation::testRfpmLiftUnsupportedStructuralContainer():Boolean[1]
{
  let db = meta::relational::tests::mapping::relation::testDB;
  let runtime = meta::external::store::relational::tests::testRuntime($db);
  let csv =
    'default\n' +
    'personPayloadTable\n' +
    'ID,PAYLOAD\n' +
    '1,"{""key"":""value""}"\n';
  setupRfpmLiftTestData([$csv], $db, $runtime);
  // Expect plan generation to throw: Map<String,Variant> is excluded by isStructuralContainer.
  // The size() query is used to avoid ->to() which has no Java compiled-mode binding.
  let result = execute(
    |PersonLiftedUnsupported.all()->size(),
    meta::relational::tests::mapping::relation::LiftedUnsupportedMapping,
    $runtime,
    meta::relational::extension::relationalExtensions()
  );
  fail('Expected plan-generation error for Map<String,Variant> structural container');
  true;
}

// ============================================================================
// Coverage tests migrated from the former relationCoverage{Dates,Filter,GroupBy,
// Distinct}.pure files. Each suite drives the coverageDB store + mappings defined
// in relationMappingSetup.pure and asserts the relation-mapping equivalent of the
// classic dates / ~filter / ~groupBy / ~distinct mapping behaviour.
// ============================================================================

// --- Dates coverage -------------------------------------------------------------
###Pure
import meta::relational::functions::asserts::*;
import meta::relational::tests::mapping::relation::*;
import meta::pure::functions::relation::*;
import meta::external::store::relational::tests::*;

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testStrictDateFilter():Boolean[1]
{
   let result = execute(
      |Trade.all()->filter(i|$i.date == %2014-12-01)->project(~[id:t|$t.id]),
      tradeRelationMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        id
        1
        2
        3
     #->toString(),
     $result.values->at(0)->sort(~id->ascending())->toString()
   );
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testStrictDateProject():Boolean[1]
{
   // Project the StrictDate as a String. A StrictDate (DATE) column materialised into
   // the relation result is a date-only value ('2014-12-01'); round-tripping that
   // through the TestTDS MINIMAL parser infers it as STRING and it is then rejected
   // against a StrictDate column ("Not supported data type STRING for Pure type
   // StrictDate"). Projecting ->toString() yields a String column, which sidesteps the
   // round-trip while still asserting the retrieved date values. (DateTime/TIMESTAMP
   // columns carry a time component and parse as datetime, so they project directly.)
   let result = execute(
      |Trade.all()->project(~[id:t|$t.id, date:t|$t.date->toString()]),
      tradeRelationMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        id, date
        1, 2014-12-01
        2, 2014-12-01
        3, 2014-12-01
        4, 2014-12-02
        5, 2014-12-02
        6, 2014-12-03
        7, 2014-12-03
        8, 2014-12-04
        9, 2014-12-04
        10, 2014-12-04
        11, 2014-12-05
        12, 2016-02-04
        13, 2016-03-28
        14, 2016-03-28
        15, 2016-02-14
     #->toString(),
     $result.values->at(0)->sort([~id->ascending()])->toString()
   );
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testDateTimeFilter():Boolean[1]
{
   // H2 stores TIMESTAMP at millisecond precision, so row 7's inserted
   // 2014-12-04 15:22:23.123456789 is stored as .123. The filter literal must
   // therefore use millisecond precision to match on equality.
   let exact = execute(
      |Trade.all()->filter(a|$a.settlementDateTime == %2014-12-04T15:22:23.123)->project(~[id:t|$t.id]),
      tradeRelationMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
   assertEquals(
     #TDS
        id
        7
     #->toString(),
     $exact.values->at(0)->sort(~id->ascending())->toString()
   );
}

