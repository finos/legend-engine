function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testEnumerationMapping():Boolean[1]
{
   testTds(|PersonWithEmployeeType.all()->project(~[name:x|$x.firstName, type:x|$x.employeeType])->cast(@TabularDataSet),
           meta::relational::tests::mapping::relation::EnumerationRelationMapping,
           meta::relational::tests::mapping::relation::testDB,
           ['John | FULL_TIME', 'Fabrice | FULL_TIME', 'Oliver | CONTRACT', 'David | CONTRACT']
         );
}

