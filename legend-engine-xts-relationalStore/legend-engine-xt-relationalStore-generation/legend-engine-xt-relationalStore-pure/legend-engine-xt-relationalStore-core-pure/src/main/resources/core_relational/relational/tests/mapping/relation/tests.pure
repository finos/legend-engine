{
  // filter preserves PK=[ID]; rename(ID→PID) swaps → PK=[PID].
  assertEquals(['PID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestFilterThenRenameMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughRenameThenGroupBy():Boolean[1]
{
  // rename(ID→PID) sets PK=[PID]; groupBy(~FIRMID, ...) overrides → PK=[FIRMID].
  assertEquals(['FIRMID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestRenameThenGroupByMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughJoinThenGroupBy():Boolean[1]
{
  // join(personTable, groupMembershipTable, INNER, ...): leftPK=[ID] ∪ rightPK=[GROUPID]
  // → [ID, GROUPID]; groupBy(~GROUPID, ...) overrides → PK=[GROUPID].
  assertEquals(['GROUPID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestJoinThenGroupByMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughFilterExtendDistinct():Boolean[1]
{
  // filter → extend → distinct(): all three preserve PK=[ID].
  assertEquals(['ID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestFilterExtendDistinctMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughGroupByExtendFilterSelect():Boolean[1]
{
  // groupBy(~FIRMID, ...) → PK=[FIRMID]; extend → filter → select(~[FIRMID, SUM, DOUBLE_SUM])
  // keeps FIRMID so PK=[FIRMID] survives.
  assertEquals(['FIRMID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestGroupByExtendFilterSelectMapping, 'pk'));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughSortLimitFilterRename():Boolean[1]
{
  // sort → limit → filter all preserve PK=[ID]; rename(ID→PERSON_ID) swaps → PK=[PERSON_ID].
  assertEquals(['PERSON_ID'], meta::relational::tests::mapping::relation::pkOf(
    meta::relational::tests::mapping::relation::PkTestSortLimitFilterRenameMapping, 'pk'));
}

// =========================================================================
// E. Function composition — the zero-arg user-function inlining path
//    The dispatcher's `ConcreteFunctionDefinition`
//    branch inlines the helper's body and recurses, so PK inference
//    "sees through" composed function calls.
//
//    NOTE: No mappings exist for these composed functions because they
//    return Relation<Any> (no concrete RelationType), which the Pure PAR
//    compiler cannot process into property mappings. Instead we call
//    `inferPrimaryKeyColumnNames` directly on the function's expression
//    body — this is the same code path that `pkOf` ultimately invokes.
//    The helper functions (pkHelperFilteredPersons, pkHelperFirms) use
//    concrete RelationType return types so the Pure compiler can
//    type-check column access in the composed functions.
// =========================================================================

function <<access.private>> meta::relational::tests::mapping::relation::pkOfFunc(func:FunctionDefinition<Any>[1]):String[*]
{
  let expr = $func.expressionSequence->evaluateAndDeactivate()->at(0);
  meta::relational::mapping::inferPrimaryKeyColumnNames($expr);
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughComposedFilter():Boolean[1]
{
  // pkTestComposedFilter body = pkHelperFilteredPersons()->filter(x|true)
  // pkHelperFilteredPersons body = #>{personTable}#->filter(...)
  // Inlined: filter preserves table PK → PK=[ID].
  assertEquals(['ID'], meta::relational::tests::mapping::relation::pkOfFunc(
    meta::relational::tests::mapping::relation::pkTestComposedFilter__Relation_1_));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughComposedJoin():Boolean[1]
{
  // pkTestComposedJoin body = pkHelperFilteredPersons()->join(pkHelperFirms()->rename(~ID, ~FIRM_ID), INNER, ...)
  // Left: inlines pkHelperFilteredPersons → filter(#>{personTable}#) → leftPK=[ID]
  // Right: inlines pkHelperFirms → select(#>{firmTable}#,~[ID,legalName]) → then rename(ID→FIRM_ID) → rightPK=[FIRM_ID]
  // join INNER: leftPK ∪ rightPK = [ID, FIRM_ID].
  assertSameElements(['ID', 'FIRM_ID'], meta::relational::tests::mapping::relation::pkOfFunc(
    meta::relational::tests::mapping::relation::pkTestComposedJoin__Relation_1_));
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testAutoInferPKThroughComposedGroupBy():Boolean[1]
{
  // pkTestComposedGroupBy body = pkHelperFilteredPersons()->groupBy(~FIRMID, ...)
  // Inlined: pkHelperFilteredPersons → filter(#>{personTable}#) → PK=[ID]
  // groupBy overrides → PK=[FIRMID].
  assertEquals(['FIRMID'], meta::relational::tests::mapping::relation::pkOfFunc(
    meta::relational::tests::mapping::relation::pkTestComposedGroupBy__Relation_1_));
}
