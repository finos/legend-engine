function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testSimpleMappingQuery():Boolean[1]
{
  let result = execute(
    |Person.all()->project(~[name:x|$x.firstName, age:x|$x.age]),
    meta::relational::tests::mapping::relation::SimpleMapping,
    meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
    meta::relational::extension::relationalExtensions()
  );
  assertEquals(
    #TDS
       name, age
       David, 52
       Fabrice, 45
       John, 30
       Oliver, 26
    #->toString(),
    $result.values->at(0)->sort(~name->ascending())->toString()
  );
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testSimpleMappingWithAssociation():Boolean[1]
{
  let result = execute(
    |Person.all()->project(~[name:x|$x.firstName, firmName:x|$x.firm.legalName]),
    meta::relational::tests::mapping::relation::SimpleMapping,
    meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
    meta::relational::extension::relationalExtensions()
  );
  assertEquals(
    #TDS
       name, firmName
       David, Firm D
       Fabrice, Firm C
       John, Firm X
       Oliver, Firm C
    #->toString(),
    $result.values->at(0)->sort(~name->ascending())->toString()
  );
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testSimpleMappingQueryWithPreFilter():Boolean[1]
{
  let result = execute(
    |Firm.all()->filter(x|$x.legalName != 'Firm X')->project(~[firmName:x|$x.legalName, name:x|$x.employees.firstName]),
    meta::relational::tests::mapping::relation::SimpleMapping,
    meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
    meta::relational::extension::relationalExtensions()
  );
  assertEquals(
    #TDS
       firmName, name
       Firm A, TDSNull
       Firm B, TDSNull
       Firm C, Fabrice
       Firm C, Oliver
       Firm D, David
    #->toString(),
    $result.values->at(0)->sort([~firmName->ascending(), ~name->ascending()])->toString()
  );
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testSimpleMappingQueryWithFilterInProject():Boolean[1]
{
  let result = execute(
    |Person.all()->project(~[name1:x|$x.firstName, name2:x|$x.firm.employees->filter(e|$e.age < 35).firstName]),
    meta::relational::tests::mapping::relation::SimpleMapping,
    meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
    meta::relational::extension::relationalExtensions()
  );
  assertEquals(
    #TDS
       name1, name2
       David, TDSNull
       Fabrice, TDSNull
       John, John
       Oliver, Fabrice
       Oliver, Oliver
    #->toString(),
    $result.values->at(0)->sort([~name1->ascending(), ~name2->ascending()])->toString()
  );
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testSimpleMappingQueryWithObjectGroupByAndTdsProject():Boolean[1]
{
  let result = execute(
    |Person.all()->project(~[name:x|$x.firm.legalName, age:x|$x.age])->groupBy(~name, ~averageAge:x|$x.age:y|$y->average()),
    meta::relational::tests::mapping::relation::SimpleMapping,
    meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
    meta::relational::extension::relationalExtensions()
  );
  assertEquals(
    #TDS
       name, averageAge
       Firm C, 35.5
       Firm D, 52.0
       Firm X, 30.0
    #->toString(),
    $result.values->at(0)->sort(~name->ascending())->toString()
  );
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testMixedCaseMappingThroughAssociationChain():Boolean[1]
{
  let result = execute(
    |Person.all()
       ->filter(p | $p.group.groupName == 'Group C')
       ->project(~[
          memberName: p | $p.firstName,
          groupName : p | $p.group.groupName,
          firmName  : p | $p.firm.legalName
       ]),
    meta::relational::tests::mapping::relation::MixedCaseAssociationChainMapping,
    meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
    meta::relational::extension::relationalExtensions()
  );
  assertEquals(
    #TDS
       memberName, groupName, firmName
       Anthony, Group C, Firm B
       Fabrice, Group C, Firm C
       Oliver, Group C, Firm C
    #->toString(),
    $result.values->at(0)->sort(~memberName->ascending())->toString()
  );
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testMixedMappingRelationalClassSet():Boolean[1]
{
  let result = execute(
    |PersonWithFirmId.all()->project(~[name:x|$x.firstName, firmId:x|$x.firmId]),
    meta::relational::tests::mapping::relation::MixedMapping,
    meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
    meta::relational::extension::relationalExtensions()
  );
  assertEquals(
    #TDS
       name, firmId
       Anthony, 3
       David, 5
       Fabrice, 4
       Jane, 2
       John, 1
       Oliver, 4
       Peter, 1
    #->toString(),
    $result.values->at(0)->sort(~name->ascending())->toString()
  );
}

