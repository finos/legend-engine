function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testMappingWithProcessingSnapshotMilestoning():Boolean[1]
{
  let result = execute(
    |ProcessingTemporalPerson.all(%2025-01-01)->project(~[firstName:x|$x.firstName, legalName:x|$x.ptFirm(%2024-11-01).legalName]),
    meta::relational::tests::mapping::relation::SnapshotMilestonedMapping,
    meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::MilestonedDB),
    meta::relational::extension::relationalExtensions()
  );
  assertEquals('#TDS\n' +
               '   firstName,legalName\n' +
               '   Anthony,Firm B\n' +
               '   David,TDSNull\n' +
               '   Peter,TDSNull\n' +
               '#',
               $result.values->at(0)->sort(ascending(~firstName))->toString());
}

