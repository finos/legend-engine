function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testInlineEmbeddedRelationMappingGroupBy():Boolean[1]
{
   testTds(|PersonWithAddress.all()->groupBy([x|$x.address.city], [agg(x|$x.age, y|$y->count())], ['city', 'count'])
                                   ->project([col(r:TDSRow[1]|$r.getString('city'), 'city'), col(r:TDSRow[1]|$r.getInteger('count'), 'count')]),
           meta::relational::tests::mapping::relation::InlineEmbeddedRelationMapping,
           meta::relational::tests::mapping::relation::testDB,
           ['Boston | 1', 'Chicago | 1', 'New York | 1', 'Seattle | 1']
         );
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testInlineEmbeddedRelationMappingWithAssociation():Boolean[1]
