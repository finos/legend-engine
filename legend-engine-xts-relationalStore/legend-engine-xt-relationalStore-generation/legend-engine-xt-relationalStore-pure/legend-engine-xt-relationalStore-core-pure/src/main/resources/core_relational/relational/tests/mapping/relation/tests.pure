import meta::relational::tests::mapping::relation::*;

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testSimpleMappingQuery():Boolean[1]
{
  let result = execute(
    |Person.all()->project(~[name:x|$x.firstName, age:x|$x.age]),
    meta::relational::tests::mapping::relation::SimpleMapping,
    meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
    meta::relational::extension::relationalExtensions()
  );
  assertEquals('#TDS\n' +
               '   name,age\n' +
               '   David,52\n' +
               '   Fabrice,45\n' +
               '   John,30\n' +
               '   Oliver,26\n' +
               '#',
               $result.values->at(0)->sort(ascending(~name))->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testSimpleMappingWithAssociation():Boolean[1]
{
  let result = execute(
    |Person.all()->project(~[name:x|$x.firstName, firmName:x|$x.firm.legalName]),
    meta::relational::tests::mapping::relation::SimpleMapping,
    meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
    meta::relational::extension::relationalExtensions()
  );
  assertEquals('#TDS\n' +
               '   name,firmName\n' +
               '   David,Firm D\n' +
               '   Fabrice,Firm C\n' +
               '   John,Firm X\n' +
               '   Oliver,Firm C\n' +
               '#',
               $result.values->at(0)->sort(ascending(~name))->toString());
}

// SQL Gen fails during isolation when adding a self join, need to investigate further
function <<test.Test, test.AlloyOnly, test.ToFix>> meta::relational::tests::mapping::relation::testSimpleMappingQueryWithPreFilter():Boolean[1]
{
  let result = execute(
    |Firm.all()->filter(x|$x.legalName != 'Firm X')->project(~[firmName:x|$x.legalName, name:x|$x.employees.firstName]),
    meta::relational::tests::mapping::relation::SimpleMapping,
    meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
    meta::relational::extension::relationalExtensions()
  );
  assertEquals('#TDS\n' +
               '   firmName,name\n' +
               '   Firm A,TDSNull\n' +
               '   Firm B,TDSNull\n' +
               '   Firm C,Fabrice\n' +
               '   Firm C,Oliver\n' +
               '   Firm D,David\n' +
               '#',
               $result.values->at(0)->sort([ascending(~firmName), ascending(~name)])->toString());
}

// SQL Gen fails during isolation when adding a self join, need to investigate further
function <<test.Test, test.AlloyOnly, test.ToFix>> meta::relational::tests::mapping::relation::testSimpleMappingQueryWithFilterInProject():Boolean[1]
{
  let result = execute(
    |Person.all()->project(~[name1:x|$x.firstName, name2:x|$x.firm.employees->filter(e|$e.age < 35).firstName]),
    meta::relational::tests::mapping::relation::SimpleMapping,
    meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
    meta::relational::extension::relationalExtensions()
  );
  assertEquals('#TDS\n' +
               '   name1,name2\n' +
               '   David,TDSNull\n' +
               '   Fabrice,TDSNull\n' +
               '   John,John\n' +
               '   Oliver,Fabrice\n' +
               '   Oliver,Oliver\n' +
               '#',
               $result.values->at(0)->sort([ascending(~name1), ascending(~name2)])->toString());
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testSimpleMappingQueryWithObjectGroupByAndTdsProject():Boolean[1]
{
  let result = execute(
    |Person.all()->project(~[name:x|$x.firm.legalName, age:x|$x.age])->groupBy(~name, ~averageAge:x|$x.age:y|$y->average()),
    meta::relational::tests::mapping::relation::SimpleMapping,
    meta::external::store::relational::tests::testRuntime(meta::relational::tests::mapping::relation::testDB),
    meta::relational::extension::relationalExtensions()
  );
  assertEquals('#TDS\n' +
               '   name,averageAge\n' +
               '   Firm C,35.5\n' +
               '   Firm D,52.0\n' +
               '   Firm X,30.0\n' +
               '#',
               $result.values->at(0)->sort(ascending(~name))->toString());
}

