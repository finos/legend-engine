function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testDateTimeInclusiveRangeQuery():Boolean[1]
{
   let result = execute(
      |Trade.all()->filter(i|(%2014-12-04T15:22:23.123456789 <= $i.settlementDateTime) && ($i.settlementDateTime < %2014-12-04T23:59:59.999999999))->project(~[settlementDateTime:t|$t.settlementDateTime]),
      tradeRelationMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
   assertTdsEquivalent(
     #TDS
        settlementDateTime:Date[1]
        2014-12-04T15:22:23.123+0000
        2014-12-04T21:00:00.000+0000
     #,
     $result.values->at(0)->sort(~settlementDateTime->ascending()),
     0,
     1
   );
}

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::testDateTimeRetrieveWithTimeZone():Boolean[1]
{
   let result = execute(
      |Trade.all()->filter(i|$i.id->in([12, 13, 14, 15]))->project(~[id:t|$t.id, settlementDateTime:t|$t.settlementDateTime]),
      tradeRelationMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions()
   );
   assertTdsEquivalent(
     #TDS
        id:Integer[1], settlementDateTime:Date[1]
        12, 2016-02-05T21:00:00.123+0000
        13, 2016-03-29T21:00:00.123+0000
        14, 2016-03-29T21:00:00.123+0000
        15, 2016-02-15T21:00:00.123+0000
     #,
     $result.values->at(0)->sort(~id->ascending()),
     0,
     1
   );
}

