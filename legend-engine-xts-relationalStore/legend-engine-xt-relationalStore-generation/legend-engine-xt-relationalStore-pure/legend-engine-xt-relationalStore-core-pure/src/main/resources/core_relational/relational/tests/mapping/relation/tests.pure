function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testInlineEmbeddedRelationMappingWithFilter():Boolean[1]
{
   testTds(|PersonWithAddress.all()->filter(x|$x.address.city == 'Boston')->project(~[name:x|$x.firstName, street:x|$x.address.street, city:x|$x.address.city])->cast(@TabularDataSet),
           meta::relational::tests::mapping::relation::InlineEmbeddedRelationMapping,
           meta::relational::tests::mapping::relation::testDB,
           ['David | Pine Rd | Boston']
         );
}

function <<meta::pure::profiles::test.Test>> meta::relational::tests::mapping::relation::testInlineEmbeddedRelationMappingWithComplexFilter():Boolean[1]
{
   testTds(|PersonWithAddress.all()->filter(x|$x.address.city == 'Boston' || $x.address.city == 'Seattle')->project(~[name:x|$x.firstName, street:x|$x.address.street, city:x|$x.address.city])->cast(@TabularDataSet),
           meta::relational::tests::mapping::relation::InlineEmbeddedRelationMapping,
