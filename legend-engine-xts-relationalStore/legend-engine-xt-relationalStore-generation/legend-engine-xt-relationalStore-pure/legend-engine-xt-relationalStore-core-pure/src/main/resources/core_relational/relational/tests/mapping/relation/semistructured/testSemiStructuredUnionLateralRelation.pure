// Ignored because the lift RFPM form has no Operation/union combinator and
// the test also requires Association traversal across two unioned root
// classes (Order, OrderFulfillment) — pending router work for both
// union-of-relation-implementations and union-aware ModelJoin resolution.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::testSemiStructuredUnionFlattenWithAssociation(conn: Connection[1]):Boolean[1]
{
  meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::lateralExecute(
    $conn,
    |meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::Order.all()
      ->filter(x|$x.orderId != '')
      ->project(~[
        'Order Id'           : x|$x.orderId,
        'Order Status'       : x|$x.orderStatus,
        'Order Version'      : x|$x.fulfillment.orderVersion,
        'Fulfillment Version': x|$x.fulfillment.fulfillmentVersion,
        'Item Categories'    : x|$x.fulfillment.itemCategories
      ]),
    'Order Id,Order Status,Order Version,Fulfillment Version,Item Categories\n' +
    '1,Open,10,1,Electronics\n' +
    '1,Open,10,1,Books\n' +
    '2,Closed,20,1,Clothing\n' +
    '3,Open,30,1,Food\n' +
    '3,Open,30,1,Toys\n'
  );
}
