function <<access.private>> meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::lateralExecute(
  conn: Connection[1],
  func: FunctionDefinition<Any>[1],
  expected: String[1]
):Boolean[1]
{
  executeLegendFunction(
    $func,
