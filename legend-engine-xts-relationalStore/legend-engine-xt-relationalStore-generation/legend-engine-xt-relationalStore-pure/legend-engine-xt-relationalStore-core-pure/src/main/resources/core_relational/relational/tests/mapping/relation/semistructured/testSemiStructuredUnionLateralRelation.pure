Class meta::relational::tests::mapping::relation::semistructured::unionlateral::union::Firm
{
  firmName: String[1];
}

Class meta::relational::tests::mapping::relation::semistructured::unionlateral::union::Person
{
  firm: meta::relational::tests::mapping::relation::semistructured::unionlateral::union::Firm[1];
}

function meta::relational::tests::mapping::relation::semistructured::unionlateral::union::personTable1Function(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::relation::semistructured::unionlateral::union::H2DB.PERSON_SCHEMA.PERSON_TABLE_1}#
    ->select(~[ID, FIRM_DETAILS, NAME])
