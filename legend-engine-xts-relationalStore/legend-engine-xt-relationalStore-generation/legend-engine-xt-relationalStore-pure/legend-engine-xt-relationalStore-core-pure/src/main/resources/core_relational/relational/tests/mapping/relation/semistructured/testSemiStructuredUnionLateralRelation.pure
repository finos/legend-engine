// -----------------------------------------------------------------------------
// Lateral sub-package — Order/OrderFulfillment with derived itemCategories()
// -----------------------------------------------------------------------------
Class meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::Order
{
  orderId    : String[1];
  orderStatus: String[0..1];
}

Class meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::OrderFulfillment
{
  orderVersion      : Integer[1];
  fulfillmentVersion: Integer[1];
  details           : meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::FulfillmentDetails[1];
  itemCategories() {$this.details.lineItems.category}: String[*];
}

Class meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::FulfillmentDetails
{
  lineItems: meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::LineItem[*];
}

Class meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::LineItem
{
  category: String[1];
}

// Association replaces the source DB-level joins order_fulfillment_a/_b — the
// match is on (ORDER_ID, ORDER_VERSION) composite key, mapped via ModelJoin
// using +localOrderId/+localOrderVersion mapping properties on the
// OrderFulfillment side.
Association meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::OrderFulfillmentAssociation
{
  order      : meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::Order[1];
  fulfillment: meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::OrderFulfillment[1];
}

function meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::orderTableAFunction(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::H2DB.ORDER_SCHEMA.ORDER_TABLE_A}#
    ->select(~[ORDER_ID, ORDER_VERSION, ORDER_STATUS])
}

function meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::orderTableBFunction(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::H2DB.ORDER_SCHEMA.ORDER_TABLE_B}#
    ->select(~[ORDER_ID, ORDER_VERSION, ORDER_STATUS])
}

function meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::fulfillmentTableAFunction(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::H2DB.FULFILLMENT_SCHEMA.FULFILLMENT_TABLE_A}#
    ->select(~[FULFILLMENT_ID, FULFILLMENT_VERSION, ORDER_ID, ORDER_VERSION, DETAILS])
}

function meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::fulfillmentTableBFunction(): meta::pure::metamodel::relation::Relation<meta::pure::metamodel::type::Any>[1]
{
  #>{meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::H2DB.FULFILLMENT_SCHEMA.FULFILLMENT_TABLE_B}#
    ->select(~[FULFILLMENT_ID, FULFILLMENT_VERSION, ORDER_ID, ORDER_VERSION, DETAILS])
}


// =============================================================================
// Mappings — best-effort RFPM lift shape for the union pattern.
//
// Source uses `*Class: Operation { meta::pure::router::operations::union(...) }`
// with two `Relational` implementations. The lift form has no documented
// equivalent: there is no `*Class: Operation` block accepting two `Relation`
// implementations. We DECLARE the two implementations per root class so the
// model is faithful, but no Operation block is added; tests are
// <<paramTest.Ignore>> until the lift router gains union support.
// =============================================================================
###Mapping
import meta::relational::tests::mapping::relation::semistructured::unionlateral::union::*;
import meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::*;
import meta::pure::functions::variant::convert::*;
import meta::pure::functions::variant::navigation::*;

// -----------------------------------------------------------------------------
// Union mapping — two implementations of Person.
// Source pattern: Person[Type_A] uses `extractFromSemiStructured` (path 'firm')
// to navigate into FIRM_DETAILS; Person[Type_B] treats the whole FIRM_DETAILS
// blob as the Firm. In the lift form both collapse to a `$src.<COL>->to(@Firm)
// ->toOne()` shape — the navigation depth differs by one level of `->get('firm')`.
// -----------------------------------------------------------------------------
Mapping meta::relational::tests::mapping::relation::semistructured::unionlateral::union::UnionSemiStructuredMapping
(
  // *meta::relational::tests::mapping::relation::semistructured::unionlateral::union::Person[personTypeA]: Relation
  // {
  //   ~func meta::relational::tests::mapping::relation::semistructured::unionlateral::union::personTable1Function():Relation<Any>[1]
  //   firm: $src.FIRM_DETAILS->get('firm')->to(@meta::relational::tests::mapping::relation::semistructured::unionlateral::union::Firm)->toOne(),
  //   +id: Integer[1]: ID
  // }

  // *meta::relational::tests::mapping::relation::semistructured::unionlateral::union::Person[personTypeB]: Relation
  // {
  //   ~func meta::relational::tests::mapping::relation::semistructured::unionlateral::union::personTable2Function():Relation<Any>[1]
  //   firm: $src.FIRM_DETAILS->to(@meta::relational::tests::mapping::relation::semistructured::unionlateral::union::Firm)->toOne(),
  //   +id: Integer[1]: ID
  // }
)

// -----------------------------------------------------------------------------
// Lateral mapping — Order union (orderA/orderB) + OrderFulfillment union
// (fulfillmentA/fulfillmentB) + Association via ModelJoin on composite key
// (orderId, orderVersion).
// -----------------------------------------------------------------------------
Mapping meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::LateralSemiStructuredMapping
(
  // *meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::Order[orderA]: Relation
  // {
  //   ~func meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::orderTableAFunction():Relation<Any>[1]
  //   orderId    : ORDER_ID,
  //   orderStatus: ORDER_STATUS,
  //   +orderVersion: Integer[1]: ORDER_VERSION
  // }

  // *meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::Order[orderB]: Relation
  // {
  //   ~func meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::orderTableBFunction():Relation<Any>[1]
  //   orderId    : ORDER_ID,
  //   orderStatus: ORDER_STATUS,
  //   +orderVersion: Integer[1]: ORDER_VERSION
  // }

  // *meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::OrderFulfillment[fulfillmentA]: Relation
  // {
  //   ~func meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::fulfillmentTableAFunction():Relation<Any>[1]
  //   orderVersion      : ORDER_VERSION,
  //   fulfillmentVersion: FULFILLMENT_VERSION,
  //   details           : $src.DETAILS->to(@meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::FulfillmentDetails)->toOne(),
  //   +localOrderId     : String[1] : ORDER_ID,
  //   +localOrderVersion: Integer[1]: ORDER_VERSION
  // }

  // *meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::OrderFulfillment[fulfillmentB]: Relation
  // {
  //   ~func meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::fulfillmentTableBFunction():Relation<Any>[1]
  //   orderVersion      : ORDER_VERSION,
  //   fulfillmentVersion: FULFILLMENT_VERSION,
  //   details           : $src.DETAILS->to(@meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::FulfillmentDetails)->toOne(),
  //   +localOrderId     : String[1] : ORDER_ID,
  //   +localOrderVersion: Integer[1]: ORDER_VERSION
  // }

  // *meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::OrderFulfillmentAssociation: ModelJoin
  // {
  //   {order      : meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::Order[1],
  //    fulfillment: meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::OrderFulfillment[1]
  //     | $fulfillment.localOrderId == $order.orderId &&
  //       $fulfillment.localOrderVersion == $order.orderVersion}
  // }
)


