// =============================================================================
// ====== union ======
// =============================================================================
function <<access.private>> meta::relational::tests::mapping::relation::semistructured::unionlateral::union::unionCsv(): String[1]
{
  'PERSON_SCHEMA\n' +
  'PERSON_TABLE_1\n' +
  'ID,FIRM_DETAILS,NAME\n' +
  '1,"{""firm"": {""firmName"": ""firm_A""}}",ABC\n' +
  '3,"{""firm"": {""firmName"": ""firm_B""}}",PQR\n' +
  '5,"{""firm"": {""firmName"": ""firm_C""}}",XYZ\n'
}

function <<access.private>> meta::relational::tests::mapping::relation::semistructured::unionlateral::union::unionCsv2(): String[1]
{
  'PERSON_SCHEMA\n' +
  'PERSON_TABLE_2\n' +
  'ID,FIRM_DETAILS,NAME\n' +
  '2,"{""firmName"": ""firm_D""}",MNO\n' +
  '4,"{""firmName"": ""firm_E""}",DEF\n' +
  '6,"{""firmName"": ""firm_F""}",STU\n'
}

function <<access.private>> meta::relational::tests::mapping::relation::semistructured::unionlateral::union::unionExecute(
  conn: Connection[1],
  func: FunctionDefinition<Any>[1],
  expected: String[1]
):Boolean[1]
{
  executeLegendFunction(
    $func,
    meta::relational::tests::mapping::relation::semistructured::unionlateral::union::UnionSemiStructuredMapping,
    meta::relational::tests::mapping::relation::semistructured::unionlateral::union::H2DB,
    $conn,
    [meta::relational::tests::mapping::relation::semistructured::unionlateral::union::unionCsv(),
     meta::relational::tests::mapping::relation::semistructured::unionlateral::union::unionCsv2()],
    $expected,
    false
  );
}

// Ignored because the lift RFPM form has no Operation/union combinator —
// `*Person: Operation { union(personTypeA, personTypeB) }` does not exist
// for relation mappings; pending router work.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::unionlateral::union::testSemiStructuredUnionMappingWithBinding(conn: Connection[1]):Boolean[1]
{
  meta::relational::tests::mapping::relation::semistructured::unionlateral::union::unionExecute(
    $conn,
    |meta::relational::tests::mapping::relation::semistructured::unionlateral::union::Person.all()
      ->project(~['Firm/FirmName': x|$x.firm.firmName]),
    'Firm/FirmName\n' +
    'firm_A\n' +
    'firm_B\n' +
    'firm_C\n' +
    'firm_D\n' +
    'firm_E\n' +
    'firm_F\n'
  );
}

// Ignored because the lift RFPM form has no Operation/union combinator —
// `*Person: Operation { union(personTypeA, personTypeB) }` does not exist
// for relation mappings; pending router work.
function <<paramTest.Ignore>> meta::relational::tests::mapping::relation::semistructured::unionlateral::union::testSemiStructuredUnionMappingWithBindingAndFilter(conn: Connection[1]):Boolean[1]
{
  meta::relational::tests::mapping::relation::semistructured::unionlateral::union::unionExecute(
    $conn,
    |meta::relational::tests::mapping::relation::semistructured::unionlateral::union::Person.all()
      ->filter(x|$x.firm.firmName->in(['firm_A', 'firm_B', 'firm_D'])->and())
      ->project(~['Firm/FirmName': x|$x.firm.firmName]),
    'Firm/FirmName\n' +
    'firm_A\n' +
    'firm_B\n' +
    'firm_D\n'
  );
}


