// =============================================================================
// Translation of tests/semistructured/testSemiStructuredUnionMapping.pure +
//                tests/semistructured/testSemiStructuredLateralFlatten.pure
// into the RFPM variant-lift form. Output groups two distinct models under
// sub-packages to avoid class/mapping/helper collisions:
//
//   ::unionlateral::union::*    — testSemiStructuredUnionMapping
//     Person/Firm across PERSON_TABLE_1 + PERSON_TABLE_2 (operation-mapping
//     union of two RFPMs — one with `extractFromSemiStructured`-style nested
//     navigation, one with the whole SS column being the embedded Firm).
//
//   ::unionlateral::lateral::*  — testSemiStructuredLateralFlatten
//     Order/OrderFulfillment with Association + ModelJoin, union mapping on
//     both root classes (orderA/orderB, fulfillmentA/fulfillmentB), and a
//     derived `itemCategories()` traversing an embedded SS array.
//
// ToFix policy: all 3 tests are <<paramTest.Ignore>>. The lift RFPM form has
// no known equivalent of the source `*Class: Operation { union(impl1, impl2) }`
// combinator — there is no router wiring that synthesises a union of two
// `Relation`-typed implementations on the same root class. We translate the
// model + mapping structure as faithfully as possible so a future router
// extension can flip these tests back to `<<paramTest.Test>>` without
// retouching the model/queries, but until then they remain ignored.
// =============================================================================


// =============================================================================
// Database — Union (PERSON_SCHEMA with PERSON_TABLE_1 + PERSON_TABLE_2)
// =============================================================================
###Relational
Database meta::relational::tests::mapping::relation::semistructured::unionlateral::union::H2DB
(
  Schema PERSON_SCHEMA
  (
    Table PERSON_TABLE_1
    (
      ID INTEGER PRIMARY KEY,
      FIRM_DETAILS SEMISTRUCTURED,
      NAME VARCHAR(32)
    )
    Table PERSON_TABLE_2
    (
      ID INTEGER PRIMARY KEY,
      FIRM_DETAILS SEMISTRUCTURED,
      NAME VARCHAR(32)
    )
  )
)


// =============================================================================
// Database — Lateral (ORDER + FULFILLMENT, two tables each, drop DB-level joins)
// =============================================================================
###Relational
Database meta::relational::tests::mapping::relation::semistructured::unionlateral::lateral::H2DB
(
  Schema ORDER_SCHEMA
  (
    Table ORDER_TABLE_A
    (
      ORDER_ID VARCHAR(100) PRIMARY KEY,
      ORDER_VERSION INTEGER PRIMARY KEY,
      ORDER_STATUS VARCHAR(50)
    )
    Table ORDER_TABLE_B
    (
      ORDER_ID VARCHAR(100) PRIMARY KEY,
      ORDER_VERSION INTEGER PRIMARY KEY,
      ORDER_STATUS VARCHAR(50)
    )
  )
  Schema FULFILLMENT_SCHEMA
  (
    Table FULFILLMENT_TABLE_A
    (
      FULFILLMENT_ID VARCHAR(100) PRIMARY KEY,
      FULFILLMENT_VERSION INTEGER PRIMARY KEY,
      ORDER_ID VARCHAR(100),
      ORDER_VERSION INTEGER,
      DETAILS SEMISTRUCTURED
    )
    Table FULFILLMENT_TABLE_B
    (
      FULFILLMENT_ID VARCHAR(100) PRIMARY KEY,
      FULFILLMENT_VERSION INTEGER PRIMARY KEY,
      ORDER_ID VARCHAR(100),
      ORDER_VERSION INTEGER,
      DETAILS SEMISTRUCTURED
    )
  )
)


// =============================================================================
// Pure model + relation functions
// =============================================================================
###Pure
import meta::pure::functions::variant::convert::*;
import meta::pure::functions::variant::navigation::*;
import meta::pure::metamodel::variant::*;

