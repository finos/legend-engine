// Gap #26: subtype / inheritance for relation mappings. Marked test.Test per
// request; the doc classifies this as NEW_DEV (polymorphic dispatch through
// RelationFunctionInstanceSetImplementation may be unimplemented), so these may
// need to move to test.ToFix after the run. Reuses the shared PersonWithEmployeeType
// (extends Person) class and EmployeeType enum.

###Pure
import meta::pure::functions::relation::*;
import meta::pure::metamodel::relation::*;
import meta::relational::tests::mapping::relation::coverage::*;

function meta::relational::tests::mapping::relation::coverage::subtypePersonFunc():Relation<Any>[1]
{
   #>{meta::relational::tests::mapping::relation::coverage::coverageDB.personTable}#
      ->select(~[FIRSTNAME, EMPTYPE]);
}

###Mapping
import meta::relational::tests::mapping::relation::*;
import meta::relational::tests::mapping::relation::coverage::*;

Mapping meta::relational::tests::mapping::relation::coverage::subtypeMapping
(
   meta::relational::tests::mapping::relation::EmployeeType: EnumerationMapping employeeTypeMapping
   {
      CONTRACT:  'CONTRACT',
      FULL_TIME: 'FULL_TIME'
   }

   *PersonWithEmployeeType: Relation
   {
      ~func meta::relational::tests::mapping::relation::coverage::subtypePersonFunc():Relation<Any>[1]
      firstName: FIRSTNAME,
      employeeType: EnumerationMapping employeeTypeMapping : EMPTYPE
   }
)

###Pure
import meta::relational::functions::asserts::*;
import meta::relational::tests::mapping::relation::*;
import meta::relational::tests::mapping::relation::coverage::*;
import meta::pure::functions::relation::*;
import meta::external::store::relational::tests::*;

function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testSubtypeDirectQuery():Boolean[1]
{
   let result = execute(
      |PersonWithEmployeeType.all()->project(~[firstName:p|$p.firstName, employeeType:p|$p.employeeType->toString()]),
      subtypeMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions());
   assertEquals(
     #TDS
        firstName, employeeType
        Anthony, CONTRACT
        Jane, FULL_TIME
        John, FULL_TIME
        Peter, CONTRACT
     #->toString(),
     $result.values->at(0)->sort([~firstName->ascending()])->toString());
}

// Polymorphic: querying the superclass Person must resolve the subtype set.
function <<test.Test, test.AlloyOnly>> meta::relational::tests::mapping::relation::coverage::testSubtypeSuperclassQuery():Boolean[1]
{
   let result = execute(
      |Person.all()->project(~[firstName:p|$p.firstName]),
      subtypeMapping,
      meta::external::store::relational::tests::testRuntime(coverageDB),
      meta::relational::extension::relationalExtensions());
   assertEquals(
     #TDS
        firstName
        Anthony
        Jane
        John
        Peter
     #->toString(),
     $result.values->at(0)->sort([~firstName->ascending()])->toString());
}
