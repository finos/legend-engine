// All salaries are non-null (avoids null-ordering ambiguity in the window function's
// ->ascending() clause). Two employees per firm so rank is non-trivial (1 and 2).
###Data
Data demo::relation::data::RankedEmployeeData
{
  Relation
  #{
    default.EmployeeTable:
      ID,FIRST_NAME,LAST_NAME,FIRM_ID,EMP_TYPE,ACTIVE,HIRE_DATE,SALARY,STREET,CITY
      1,Alice,Green,1,FULL_TIME,1,2020-01-15 00:00:00,50000.0,Main St,London
      2,Bob,Smith,1,CONTRACT,1,2021-06-01 00:00:00,70000.0,Oak Ave,Paris
      3,Carol,White,2,FULL_TIME,1,2019-03-10 00:00:00,60000.0,Pine Rd,Berlin
      4,David,Jones,2,FULL_TIME,1,2018-05-20 00:00:00,80000.0,High St,Madrid;
    default.FirmTable:
      ID,LEGAL_NAME
      1,Acme
      2,Beta;
  }#
}
