// rank is a REAL property on a model-local subclass, not a `+local` mapping property —
// local mapping properties are only usable inside an XStore/ModelJoin predicate, not
// queryable/projectable from an arbitrary lambda (confirmed while building Wave 1's
// relation-filter uplift). This mirrors relationMappingSetup.pure's own pattern:
// ExtendedPerson.rank is a real declared property, not a +local one.

###Pure
import meta::pure::metamodel::relation::*;

Class demo::relation::domain::RankedEmployee extends demo::relation::domain::Employee
{
  rank: Integer[1];
}

function demo::relation::func::rankedEmployees(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{demo::relation::db::EmployeeDB.EmployeeTable}#
    ->extend(over(~FIRM_ID, ~SALARY->ascending()), ~[RANK: {p, w, r | $p->rank($w, $r)}])
}

function demo::relation::func::windowFirms(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{demo::relation::db::EmployeeDB.FirmTable}#
}

###Mapping
import demo::relation::func::*;

Mapping demo::relation::mapping::RankedEmployeeMapping
(
  *demo::relation::domain::RankedEmployee[emp]: Relation
  {
    ~func demo::relation::func::rankedEmployees():Relation<Any>[1]
    id: ID,
    firstName: FIRST_NAME,
    lastName: LAST_NAME,
    employeeType: EnumerationMapping EmployeeTypeMapping: EMP_TYPE,
    active: $src.ACTIVE == 1,
    hireDate: HIRE_DATE,
    salary: SALARY,
    rank: RANK,
    +firmId: Integer[1]: FIRM_ID
  }

  *demo::relation::domain::Firm[firm]: Relation
  {
    ~func demo::relation::func::windowFirms():Relation<Any>[1]
    id: ID,
    legalName: LEGAL_NAME
  }

  demo::relation::domain::EmployeeType: EnumerationMapping EmployeeTypeMapping
  {
    FULL_TIME: ['FULL_TIME'],
    CONTRACT: ['CONTRACT']
  }

  demo::relation::domain::Employment: XStore
  {
    employer[emp, firm]: $this.firmId == $that.id,
    employees[firm, emp]: $this.id == $that.firmId
  }

  testSuites:
  [
    rankWithinFirmSuite:
    {
      // Rank is computed per-firm (partitioned by FIRM_ID, ordered by SALARY ascending)
      // by the window function, then projected together with the XStore-traversed
      // employer.legalName in the same query.
      function: |demo::relation::domain::RankedEmployee.all()
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.rank, x | $x.employer.legalName],
                    ['Name', 'Rank', 'Firm']
                  );
      tests:
      [
        rankedBySalaryWithinFirm:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::RankedEmployeeData
              }#
          ];
          asserts:
          [
            shouldRankWithinFirmAndProjectAssociation:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"Name":"Alice","Rank":1,"Firm":"Acme"},{"Name":"Bob","Rank":2,"Firm":"Acme"},{"Name":"Carol","Rank":1,"Firm":"Beta"},{"Name":"David","Rank":2,"Firm":"Beta"}]';
                  }#;
              }#
          ];
        }
      ];
    }
  ]
)
