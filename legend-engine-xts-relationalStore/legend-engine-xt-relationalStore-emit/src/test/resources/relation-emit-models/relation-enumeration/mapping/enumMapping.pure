// EmployeeWithStatus is declared here (model-local), not in the shared domain: adding
// a [1] activeStatus property directly to the shared Employee class would require every
// other model mapping Employee to map it too. ACTIVE_STATUS is a nullable column at the
// schema level (added in Wave 0), so the [1] property is backed via a ->toOne() coercion,
// same pattern as the existing ACTIVE BIT->Boolean coercion.

###Pure
import meta::pure::metamodel::relation::*;

Class demo::relation::domain::EmployeeWithStatus extends demo::relation::domain::Employee
{
  activeStatus: demo::relation::domain::ActiveStatus[1];
}


###Mapping
import demo::relation::func::*;

Mapping demo::relation::mapping::EmployeeEnumerationMapping
(
  *demo::relation::domain::EmployeeWithStatus: Relation
  {
    ~func demo::relation::func::employeesWithAddress():Relation<Any>[1]
    id: ID,
    firstName: FIRST_NAME,
    lastName: LAST_NAME,
    employeeType: EnumerationMapping EmployeeTypeMapping: EMP_TYPE,
    active: $src.ACTIVE == 1,
    hireDate: HIRE_DATE,
    salary: SALARY,
    activeStatus: EnumerationMapping ActiveStatusMapping: $src.ACTIVE_STATUS->toOne()
  }

  demo::relation::domain::EmployeeType: EnumerationMapping EmployeeTypeMapping
  {
    FULL_TIME: ['FULL_TIME'],
    CONTRACT: ['CONTRACT']
  }

  demo::relation::domain::ActiveStatus: EnumerationMapping ActiveStatusMapping
  {
    ACTIVE: ['ACTIVE'],
    INACTIVE: ['INACTIVE']
  }

  testSuites:
  [
    allEnumsSuite:
    {
      function: |demo::relation::domain::EmployeeWithStatus.all()
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.employeeType->toString(), x | $x.firstName],
                    ['Type', 'First Name']
                  );
      tests:
      [
        enumLabels:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeEnumData
              }#
          ];
          asserts:
          [
            shouldDecodeEnums:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"Type":"FULL_TIME","First Name":"Alice"},{"Type":"CONTRACT","First Name":"Bob"},{"Type":"FULL_TIME","First Name":"Carol"}]';
                  }#;
              }#
          ];
        }
      ];
    },
    fullTimeOnlySuite:
    {
      function: |demo::relation::domain::EmployeeWithStatus.all()
                  ->filter(e | $e.employeeType == demo::relation::domain::EmployeeType.FULL_TIME)
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.employeeType->toString(), x | $x.firstName],
                    ['Type', 'First Name']
                  );
      tests:
      [
        filterByEnum:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeEnumData
              }#
          ];
          asserts:
          [
            shouldReturnFullTimeOnly:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"Type":"FULL_TIME","First Name":"Alice"},{"Type":"FULL_TIME","First Name":"Carol"}]';
                  }#;
              }#
          ];
        }
      ];
    },
    twoEnumsAndedSuite:
    {
      // Two independently-declared EnumerationMappings (EmployeeType, ActiveStatus) on the
      // same class, ANDed together in a single filter. Only Alice is FULL_TIME AND ACTIVE:
      // Bob is CONTRACT, Carol is FULL_TIME but INACTIVE.
      function: |demo::relation::domain::EmployeeWithStatus.all()
                  ->filter(e | $e.employeeType == demo::relation::domain::EmployeeType.FULL_TIME
                            && $e.activeStatus == demo::relation::domain::ActiveStatus.ACTIVE)
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.employeeType->toString(), x | $x.activeStatus->toString()],
                    ['First Name', 'Type', 'Status']
                  );
      tests:
      [
        fullTimeAndActiveOnly:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeEnumData
              }#
          ];
          asserts:
          [
            shouldReturnOnlyRowsMatchingBothEnums:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"First Name":"Alice","Type":"FULL_TIME","Status":"ACTIVE"}]';
                  }#;
              }#
          ];
        }
      ];
    }
  ]
)
