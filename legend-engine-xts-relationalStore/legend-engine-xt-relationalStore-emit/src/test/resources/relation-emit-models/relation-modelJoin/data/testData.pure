###Data
Data demo::relation::data::EmployeeModelJoinData
{
  Relation
  #{
    default.EmployeeTable:
      ID,FIRST_NAME,LAST_NAME,FIRM_ID,EMP_TYPE,ACTIVE,HIRE_DATE,SALARY,STREET,CITY
      1,Alice,Green,1,FULL_TIME,1,2020-01-15 00:00:00,90000.0,Main St,London
      2,Bob,Smith,2,CONTRACT,1,2021-06-01 00:00:00,75000.0,Oak Ave,Paris;
    default.FirmTable:
      ID,LEGAL_NAME
      1,Acme
      2,Beta;
  }#
}

// Row 2 is an exact duplicate of row 1 (same ID, same every column) so ->distinct()
// in modelJoinEmployees() has a visible effect: without it, Alice would appear twice.
###Data
Data demo::relation::data::EmployeeDistinctData
{
  Relation
  #{
    default.EmployeeTable:
      ID,FIRST_NAME,LAST_NAME,FIRM_ID,EMP_TYPE,ACTIVE,HIRE_DATE,SALARY,STREET,CITY
      1,Alice,Green,1,FULL_TIME,1,2020-01-15 00:00:00,90000.0,Main St,London
      1,Alice,Green,1,FULL_TIME,1,2020-01-15 00:00:00,90000.0,Main St,London;
    default.FirmTable:
      ID,LEGAL_NAME
      1,Acme;
  }#
}
