// ModelJoin pairs lambda parameters to association ends by TYPE, not by name (name
// matching is only required for self-associations, where both ends share a type).
// The join condition references the same +firmId / id local-and-real properties used
// by relation-join's XStore form — ModelJoin is a drop-in alternative wiring for the
// same underlying association.

###Pure
import meta::pure::metamodel::relation::*;

// ->distinct() with no explicit keys dedupes on the full row. The existing
// EmployeeModelJoinData has no duplicate rows, so this is a no-op there; the new
// distinctSuite below supplies data with an intentional exact-duplicate row to make
// the dedup effect visible.
function demo::relation::func::modelJoinEmployees(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{demo::relation::db::EmployeeDB.EmployeeTable}#
    ->distinct()
}

function demo::relation::func::modelJoinFirms(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{demo::relation::db::EmployeeDB.FirmTable}#
}

###Mapping
import demo::relation::func::*;

Mapping demo::relation::mapping::EmployeeModelJoinMapping
(
  *demo::relation::domain::Employee[emp]: Relation
  {
    ~func demo::relation::func::modelJoinEmployees():Relation<Any>[1]
    id: ID,
    firstName: FIRST_NAME,
    lastName: LAST_NAME,
    employeeType: EnumerationMapping EmployeeTypeMapping: EMP_TYPE,
    active: $src.ACTIVE == 1,
    hireDate: HIRE_DATE,
    salary: SALARY,
    +firmId: Integer[1]: FIRM_ID
  }

  *demo::relation::domain::Firm[firm]: Relation
  {
    ~func demo::relation::func::modelJoinFirms():Relation<Any>[1]
    id: ID,
    legalName: LEGAL_NAME
  }

  demo::relation::domain::EmployeeType: EnumerationMapping EmployeeTypeMapping
  {
    FULL_TIME: ['FULL_TIME'],
    CONTRACT: ['CONTRACT']
  }

  demo::relation::domain::Employment: ModelJoin
  {
    {employer: demo::relation::domain::Firm[1], employees: demo::relation::domain::Employee[1] | $employer.id == $employees.firmId}
  }

  testSuites:
  [
    modelJoinSuite:
    {
      function: |demo::relation::domain::Employee.all()
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.employer.legalName],
                    ['Name', 'Firm']
                  );
      tests:
      [
        withFirm:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeModelJoinData
              }#
          ];
          asserts:
          [
            shouldJoinViaModelJoin:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"Name":"Alice","Firm":"Acme"},{"Name":"Bob","Firm":"Beta"}]';
                  }#;
              }#
          ];
        }
      ];
    },
    distinctSuite:
    {
      // EmployeeDistinctData carries an exact-duplicate Alice row (same ID, same every
      // column). ->distinct() in the function body dedupes it before the ModelJoin
      // association is ever resolved, so the result still has exactly one Alice.
      function: |demo::relation::domain::Employee.all()
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.employer.legalName],
                    ['Name', 'Firm']
                  );
      tests:
      [
        duplicateRowDeduped:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeDistinctData
              }#
          ];
          asserts:
          [
            shouldDedupeBeforeModelJoin:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"Name":"Alice","Firm":"Acme"}]';
                  }#;
              }#
          ];
        }
      ];
    }
  ]
)
