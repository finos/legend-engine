// ~src requires the source function to return a TYPED Relation (not Relation<Any>).
// A raw #>{store.table}# literal causes a parser stack-overflow under ~src, so each
// source expression is wrapped in a zero-arg helper that returns the typed result via
// ->select() + ->cast(). The mapping references it as ~src funcName() (call expression,
// not the mangled-name form used by ~func).

###Pure
import meta::pure::metamodel::relation::*;

function demo::relation::func::employeeSource():
  meta::pure::metamodel::relation::Relation<(ID:Integer[1], FIRST_NAME:String[1], LAST_NAME:String[1])>[1]
{
  #>{demo::relation::db::EmployeeDB.EmployeeTable}#
    ->select(~[ID, FIRST_NAME, LAST_NAME])
    ->cast(@meta::pure::metamodel::relation::Relation<(ID:Integer[1], FIRST_NAME:String[1], LAST_NAME:String[1])>)
}

function demo::relation::func::activeEmployeeSource():
  meta::pure::metamodel::relation::Relation<(ID:Integer[1], FIRST_NAME:String[1], LAST_NAME:String[1])>[1]
{
  #>{demo::relation::db::EmployeeDB.EmployeeTable}#
    ->filter(r | $r.ACTIVE == 1)
    ->select(~[ID, FIRST_NAME, LAST_NAME])
    ->cast(@meta::pure::metamodel::relation::Relation<(ID:Integer[1], FIRST_NAME:String[1], LAST_NAME:String[1])>)
}

###Mapping
Mapping demo::relation::mapping::EmployeePlainSrcMapping
(
  *demo::relation::domain::Employee: Relation
  {
    ~src demo::relation::func::employeeSource()
    id: ID,
    firstName: FIRST_NAME,
    lastName: LAST_NAME
  }

  testSuites:
  [
    plainSrcSuite:
    {
      function: |demo::relation::domain::Employee.all()
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.lastName],
                    ['First Name', 'Last Name']
                  );
      tests:
      [
        allEmployees:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeSrcData
              }#
          ];
          asserts:
          [
            shouldReturnAll:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"First Name":"Alice","Last Name":"Green"},{"First Name":"Bob","Last Name":"Smith"},{"First Name":"Carol","Last Name":"White"}]';
                  }#;
              }#
          ];
        }
      ];
    }
  ]
)

Mapping demo::relation::mapping::EmployeeFilteredSrcMapping
(
  *demo::relation::domain::Employee: Relation
  {
    ~src demo::relation::func::activeEmployeeSource()
    id: ID,
    firstName: FIRST_NAME,
    lastName: LAST_NAME
  }

  testSuites:
  [
    filteredSrcSuite:
    {
      function: |demo::relation::domain::Employee.all()
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.lastName],
                    ['First Name', 'Last Name']
                  );
      tests:
      [
        activeEmployees:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeSrcData
              }#
          ];
          asserts:
          [
            shouldReturnActiveOnly:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"First Name":"Alice","Last Name":"Green"},{"First Name":"Bob","Last Name":"Smith"}]';
                  }#;
              }#
          ];
        }
      ];
    }
  ]
)
