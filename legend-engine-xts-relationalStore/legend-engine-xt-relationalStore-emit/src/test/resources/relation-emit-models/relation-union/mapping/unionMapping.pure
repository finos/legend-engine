###Pure
import meta::pure::metamodel::relation::*;

function demo::relation::func::contractEmployees(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{demo::relation::db::EmployeeDB.EmployeeTable}#
    ->filter(r | $r.EMP_TYPE == 'CONTRACT')
}

function demo::relation::func::fullTimeEmployees(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{demo::relation::db::EmployeeDB.EmployeeTable}#
    ->filter(r | $r.EMP_TYPE == 'FULL_TIME')
}

###Mapping
import demo::relation::func::*;

Mapping demo::relation::mapping::EmployeeUnionMapping
(
  *demo::relation::domain::Employee: Operation
  {
    meta::pure::router::operations::union_OperationSetImplementation_1__SetImplementation_MANY_(contractSet, fullTimeSet)
  }

  demo::relation::domain::Employee[contractSet]: Relation
  {
    ~func demo::relation::func::contractEmployees():Relation<Any>[1]
    id: ID,
    firstName: FIRST_NAME,
    lastName: LAST_NAME,
    employeeType: EnumerationMapping EmployeeTypeMapping: EMP_TYPE,
    active: $src.ACTIVE == 1,
    hireDate: HIRE_DATE,
    salary: SALARY
  }

  demo::relation::domain::Employee[fullTimeSet]: Relation
  {
    ~func demo::relation::func::fullTimeEmployees():Relation<Any>[1]
    id: ID,
    firstName: FIRST_NAME,
    lastName: LAST_NAME,
    employeeType: EnumerationMapping EmployeeTypeMapping: EMP_TYPE,
    active: $src.ACTIVE == 1,
    hireDate: HIRE_DATE,
    salary: SALARY
  }

  demo::relation::domain::EmployeeType: EnumerationMapping EmployeeTypeMapping
  {
    FULL_TIME: ['FULL_TIME'],
    CONTRACT: ['CONTRACT']
  }

  testSuites:
  [
    allUnionedSuite:
    {
      function: |demo::relation::domain::Employee.all()
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.lastName],
                    ['First Name', 'Last Name']
                  );
      tests:
      [
        bothLegs:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeUnionData
              }#
          ];
          asserts:
          [
            shouldCombineBothSets:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"First Name":"Alice","Last Name":"Green"},{"First Name":"Bob","Last Name":"Smith"},{"First Name":"Carol","Last Name":"White"},{"First Name":"David","Last Name":"Jones"}]';
                  }#;
              }#
          ];
        }
      ];
    },
    activeFilterSuite:
    {
      function: |demo::relation::domain::Employee.all()
                  ->filter(e | $e.active == true)
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.lastName],
                    ['First Name', 'Last Name']
                  );
      tests:
      [
        activeAcrossBothLegs:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeUnionData
              }#
          ];
          asserts:
          [
            shouldFilterAcrossSets:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"First Name":"Alice","Last Name":"Green"},{"First Name":"Bob","Last Name":"Smith"},{"First Name":"David","Last Name":"Jones"}]';
                  }#;
              }#
          ];
        }
      ];
    }
  ]
)
