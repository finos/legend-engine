// The engine's ~func grammar only accepts a full function descriptor (funcName():Type[mult]),
// and the descriptor's return type must be UNQUALIFIED (no package path) — see
// FunctionDescriptor.validateType in legend-pure. A mangled id (funcName__Relation_1_)
// or a fully-qualified return type both fail here (parser or "can't find element" respectively).

###Pure
import meta::pure::metamodel::relation::*;

function demo::relation::func::temporalEmployees(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{demo::relation::db::EmployeeDB.TemporalEmployeeTable}#
}

###Mapping
Mapping demo::relation::mapping::TemporalEmployeeMapping
(
  *demo::relation::domain::TemporalEmployee: Relation
  {
    ~func demo::relation::func::temporalEmployees():Relation<Any>[1]
    id: ID,
    firstName: FIRST_NAME,
    salary: SALARY
  }

  testSuites:
  [
    allVersionsSuite:
    {
      function: |demo::relation::domain::TemporalEmployee.allVersions()
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName],
                    ['First Name']
                  );
      tests:
      [
        allRows:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::TemporalEmployeeData
              }#
          ];
          asserts:
          [
            shouldReturnAllVersions:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"First Name":"Alice"},{"First Name":"Bob"},{"First Name":"Carol"}]';
                  }#;
              }#
          ];
        }
      ];
    },
    pointInTimeSuite:
    {
      function: |demo::relation::domain::TemporalEmployee.all(%2025-01-01)
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName],
                    ['First Name']
                  );
      tests:
      [
        activeAtDate:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::TemporalEmployeeData
              }#
          ];
          asserts:
          [
            shouldFilterByDate:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"First Name":"Alice"},{"First Name":"Bob"}]';
                  }#;
              }#
          ];
        }
      ];
    }
  ]
)
