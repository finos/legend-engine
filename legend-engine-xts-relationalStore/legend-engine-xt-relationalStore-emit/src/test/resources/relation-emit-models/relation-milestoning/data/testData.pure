// 3 rows. For all(%2025-01-01) the milestoning filter is IN_Z <= 2025-01-01 < OUT_Z:
//   Alice:  IN_Z=2024-01-01 <= 2025-01-01 < OUT_Z=9999-12-31  → INCLUDED
//   Bob:    IN_Z=2024-06-01 <= 2025-01-01 < OUT_Z=9999-12-31  → INCLUDED
//   Carol:  IN_Z=2023-01-01 <= 2025-01-01 < OUT_Z=2024-01-01? → 2025-01-01 >= OUT_Z → EXCLUDED
// allVersions() returns all 3 rows.

###Data
Data demo::relation::data::TemporalEmployeeData
{
  Relation
  #{
    default.TemporalEmployeeTable:
      ID,FIRST_NAME,SALARY,IN_Z,OUT_Z
      1,Alice,90000.0,2024-01-01,9999-12-31
      2,Bob,75000.0,2024-06-01,9999-12-31
      3,Carol,60000.0,2023-01-01,2024-01-01;
  }#
}

// Same shape as TemporalEmployeeData (processing-temporal), mirrored for the
// business-temporal scheme: Dave/Eve open-ended, Frank closed 2023-01-01..2024-01-01.
###Data
Data demo::relation::data::BusinessTemporalEmployeeData
{
  Relation
  #{
    default.BusinessTemporalEmployeeTable:
      ID,FIRST_NAME,SALARY,FROM_Z,THRU_Z
      1,Dave,95000.0,2024-01-01,9999-12-31
      2,Eve,80000.0,2024-06-01,9999-12-31
      3,Frank,65000.0,2023-01-01,2024-01-01;
  }#
}
