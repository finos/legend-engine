###Service
Service demo::relation::service::EmployeeService
{
  pattern: '/api/relation/employees';
  documentation: 'Count of employees per employeeType via relation mapping.';
  autoActivateUpdates: true;
  execution: Single
  {
    // Aggregating query (project -> groupBy) rather than a flat projection, so this
    // service's PLAN_GENERATION is exercised for a query shape richer than a plain
    // project — count of employees per employeeType.
    query: |demo::relation::domain::Employee.all()
              ->project(~[type: x | $x.employeeType->toString(), name: x | $x.firstName])
              ->groupBy(~type, ~headcount: x | $x.name : y | $y->count())
              ->sort([~type->ascending()]);
    mapping: demo::relation::mapping::EmployeeSimpleMapping;
    runtime: demo::relation::runtime::EmployeeRuntime;
  }
  testSuites:
  [
    serviceSuite:
    {
      data:
      [
        connections:
        [
          h2:
            Relational
            #{
              default.EmployeeTable:
                'ID,FIRST_NAME,LAST_NAME,FIRM_ID,EMP_TYPE,ACTIVE,HIRE_DATE,SALARY,STREET,CITY\n' +
                '1,Alice,Green,1,FULL_TIME,1,2020-01-15 00:00:00,90000.0,Main St,London\n' +
                '2,Bob,Smith,2,CONTRACT,1,2021-06-01 00:00:00,75000.0,Oak Ave,Paris\n';
            }#
        ]
      ]
      tests:
      [
        allEmployees:
        {
          serializationFormat: PURE_TDSOBJECT;
          asserts:
          [
            shouldMatch:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"type":"CONTRACT","headcount":1},{"type":"FULL_TIME","headcount":1}]';
                  }#;
              }#
          ]
        }
      ]
    }
  ]
}
