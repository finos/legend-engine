// Uses ExtendedEmployee (not the shared Employee) so the embedded address property is
// available without touching the shared Employee class.

###Mapping
import demo::relation::func::*;

Mapping demo::relation::mapping::EmployeeUnionEnumMapping
(
  *demo::relation::domain::ExtendedEmployee: Operation
  {
    meta::pure::router::operations::union_OperationSetImplementation_1__SetImplementation_MANY_(contractSet, fullTimeSet)
  }

  demo::relation::domain::ExtendedEmployee[contractSet]: Relation
  {
    ~func demo::relation::func::contractEmployees():Relation<Any>[1]
    id: ID,
    firstName: FIRST_NAME,
    lastName: LAST_NAME,
    employeeType: EnumerationMapping EmployeeTypeMapping: EMP_TYPE,
    active: $src.ACTIVE == 1,
    hireDate: HIRE_DATE,
    salary: SALARY,
    address
    (
      street: STREET,
      city: CITY
    )
  }

  demo::relation::domain::ExtendedEmployee[fullTimeSet]: Relation
  {
    ~func demo::relation::func::fullTimeEmployees():Relation<Any>[1]
    id: ID,
    firstName: FIRST_NAME,
    lastName: LAST_NAME,
    employeeType: EnumerationMapping EmployeeTypeMapping: EMP_TYPE,
    active: $src.ACTIVE == 1,
    hireDate: HIRE_DATE,
    salary: SALARY,
    address
    (
      street: STREET,
      city: CITY
    )
  }

  demo::relation::domain::EmployeeType: EnumerationMapping EmployeeTypeMapping
  {
    FULL_TIME: ['FULL_TIME'],
    CONTRACT: ['CONTRACT']
  }

  testSuites:
  [
    enumFilterAcrossUnionSuite:
    {
      function: |demo::relation::domain::ExtendedEmployee.all()
                  ->filter(e | $e.employeeType == demo::relation::domain::EmployeeType.FULL_TIME)
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.employeeType->toString()],
                    ['Name', 'Type']
                  );
      tests:
      [
        fullTimeAcrossUnion:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeUnionEnumData
              }#
          ];
          asserts:
          [
            shouldFilterByEnumAcrossUnion:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"Name":"Carol","Type":"FULL_TIME"},{"Name":"David","Type":"FULL_TIME"}]';
                  }#;
              }#
          ];
        }
      ];
    },
    embeddedProjectAcrossUnionSuite:
    {
      // Mirrors testUnionTwoRelationMappings_EmbeddedFirmProject's shape (embedded
      // property projected uniformly across both union legs), substituting the
      // embedded address for the reference's embedded firm.
      function: |demo::relation::domain::ExtendedEmployee.all()
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.address.city],
                    ['Name', 'City']
                  );
      tests:
      [
        allCitiesAcrossUnion:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeUnionEnumData
              }#
          ];
          asserts:
          [
            shouldProjectEmbeddedPropertyAcrossUnion:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"Name":"Alice","City":"London"},{"Name":"Bob","City":"Paris"},{"Name":"Carol","City":"Berlin"},{"Name":"David","City":"London"}]';
                  }#;
              }#
          ];
        }
      ];
    },
    embeddedFilterAcrossUnionSuite:
    {
      // Filtering on the embedded property across the union — matches one row from
      // EACH leg (Alice from contractSet, David from fullTimeSet), both in London.
      function: |demo::relation::domain::ExtendedEmployee.all()
                  ->filter(e | $e.address.city == 'London')
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.address.city],
                    ['Name', 'City']
                  );
      tests:
      [
        londonAcrossBothLegs:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeUnionEnumData
              }#
          ];
          asserts:
          [
            shouldFilterEmbeddedPropertyAcrossUnion:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"Name":"Alice","City":"London"},{"Name":"David","City":"London"}]';
                  }#;
              }#
          ];
        }
      ];
    }
  ]
)
