// Both temporal tables here use DATE (not TIMESTAMP) milestoning columns — matching
// this repo's existing TemporalEmployeeTable/BusinessTemporalEmployeeTable schemas —
// so both sides are navigated with a plain %date argument (not the date-vs-datetime
// asymmetry the reference unit test also exercises, which doesn't apply to our schema).

###Pure
import meta::pure::metamodel::relation::*;

Association demo::relation::domain::EmployeeTemporalLink
{
  businessRecord: demo::relation::domain::BusinessTemporalEmployee[1];
  processingRecord: demo::relation::domain::TemporalEmployee[1];
}

// Same-scheme link: both TemporalEmployee and TemporalDepartment are processing-temporal.
Association demo::relation::domain::EmployeeDepartmentSameScheme
{
  employee: demo::relation::domain::TemporalEmployee[1];
  department: demo::relation::domain::TemporalDepartment[1];
}

function demo::relation::func::sameSchemeDepartments(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{demo::relation::db::EmployeeDB.TemporalDepartmentTable}#
}

###Mapping
import demo::relation::func::*;

Mapping demo::relation::mapping::AsymmetricMilestoningModelJoinMapping
(
  *demo::relation::domain::BusinessTemporalEmployee[biz]: Relation
  {
    ~func demo::relation::func::businessTemporalEmployees():Relation<Any>[1]
    id: ID,
    firstName: FIRST_NAME,
    salary: SALARY
  }

  *demo::relation::domain::TemporalEmployee[proc]: Relation
  {
    ~func demo::relation::func::temporalEmployees():Relation<Any>[1]
    id: ID,
    firstName: FIRST_NAME,
    salary: SALARY
  }

  *demo::relation::domain::TemporalDepartment[dept]: Relation
  {
    ~func demo::relation::func::sameSchemeDepartments():Relation<Any>[1]
    id: ID,
    name: NAME,
    employeeId: EMPLOYEE_ID
  }

  demo::relation::domain::EmployeeTemporalLink: ModelJoin
  {
    {businessRecord: demo::relation::domain::BusinessTemporalEmployee[1], processingRecord: demo::relation::domain::TemporalEmployee[1] | $businessRecord.id == $processingRecord.id}
  }

  demo::relation::domain::EmployeeDepartmentSameScheme: ModelJoin
  {
    {employee: demo::relation::domain::TemporalEmployee[1], department: demo::relation::domain::TemporalDepartment[1] | $employee.id == $department.employeeId}
  }

  testSuites:
  [
    diffSchemeModelJoinSuite:
    {
      // BusinessTemporalEmployee.all(%date) queries the business-temporal endpoint;
      // navigating .processingRecord(%date) queries the processing-temporal endpoint at
      // its own as-of date, through the same ModelJoin. Both employees are temporally
      // valid on both sides at the query date, so both sides' names match.
      function: |demo::relation::domain::BusinessTemporalEmployee.all(%2025-01-01)
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.processingRecord(%2025-01-01).firstName],
                    ['BizName', 'ProcName']
                  );
      tests:
      [
        crossSchemeModelJoinAtDate:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::AsymmetricMilestoningData
              }#
          ];
          asserts:
          [
            shouldJoinAcrossDifferentMilestoningSchemes:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"BizName":"Alice","ProcName":"Alice"},{"BizName":"Bob","ProcName":"Bob"}]';
                  }#;
              }#
          ];
        }
      ];
    },
    sameSchemeModelJoinSuite:
    {
      // Both TemporalEmployee and TemporalDepartment are processing-temporal. The employee
      // side is queried at %2025-01-01, the department side at %2025-06-01 (a LATER date,
      // deliberately different) — Alice's department is renamed between those two dates
      // (Engineering -> Platform Engineering on 2025-03-01), so this proves the department
      // navigation resolves its own independent as-of date rather than reusing the
      // employee query's date: if it incorrectly reused %2025-01-01, Alice would still show
      // "Engineering".
      function: |demo::relation::domain::TemporalEmployee.all(%2025-01-01)
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.department(%2025-06-01).name],
                    ['EmpName', 'DeptName']
                  );
      tests:
      [
        sameSchemeModelJoinAtIndependentDates:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::SameSchemeMilestoningData
              }#
          ];
          asserts:
          [
            shouldResolveDepartmentAtItsOwnDate:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"EmpName":"Alice","DeptName":"Platform Engineering"},{"EmpName":"Bob","DeptName":"Marketing"}]';
                  }#;
              }#
          ];
        }
      ];
    }
  ]
)
