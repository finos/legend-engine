###Pure
import meta::pure::metamodel::relation::*;

function demo::relation::func::serviceJoinEmployees(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{demo::relation::db::EmployeeDB.EmployeeTable}#
}

function demo::relation::func::serviceJoinFirms(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{demo::relation::db::EmployeeDB.FirmTable}#
}

###Mapping
import demo::relation::func::*;

Mapping demo::relation::mapping::EmployeeServiceJoinMapping
(
  *demo::relation::domain::Employee[emp]: Relation
  {
    ~func demo::relation::func::serviceJoinEmployees():Relation<Any>[1]
    id: ID,
    firstName: FIRST_NAME,
    lastName: LAST_NAME,
    employeeType: EnumerationMapping EmployeeTypeMapping: EMP_TYPE,
    active: $src.ACTIVE == 1,
    hireDate: HIRE_DATE,
    salary: SALARY,
    +firmId: Integer[1]: FIRM_ID
  }

  *demo::relation::domain::Firm[firm]: Relation
  {
    ~func demo::relation::func::serviceJoinFirms():Relation<Any>[1]
    id: ID,
    legalName: LEGAL_NAME
  }

  demo::relation::domain::EmployeeType: EnumerationMapping EmployeeTypeMapping
  {
    FULL_TIME: ['FULL_TIME'],
    CONTRACT: ['CONTRACT']
  }

  demo::relation::domain::Employment: XStore
  {
    employer[emp, firm]: $this.firmId == $that.id,
    employees[firm, emp]: $this.id == $that.firmId
  }
)
