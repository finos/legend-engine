###Service
Service demo::relation::service::EmployeeServiceJoinService
{
  pattern: '/api/relation/employeesByFirm';
  documentation: 'List each employee with their employer, via a relation mapping.';
  autoActivateUpdates: true;
  execution: Single
  {
    // Combines a qualified/derived property (fullName(), no column mapping) with an
    // XStore association traversal (employer.legalName) in the same project() — the
    // combination relation-service (groupBy only) and relation-join (association only,
    // no Service) don't individually cover.
    query: |demo::relation::domain::Employee.all()
              ->sortBy(x | $x.firstName)
              ->project(
                [x | $x.fullName(), x | $x.employer.legalName],
                ['Full Name', 'Firm']
              );
    mapping: demo::relation::mapping::EmployeeServiceJoinMapping;
    runtime: demo::relation::runtime::EmployeeServiceJoinRuntime;
  }
  testSuites:
  [
    serviceSuite:
    {
      data:
      [
        connections:
        [
          h2:
            Relational
            #{
              default.EmployeeTable:
                'ID,FIRST_NAME,LAST_NAME,FIRM_ID,EMP_TYPE,ACTIVE,HIRE_DATE,SALARY,STREET,CITY\n' +
                '1,Alice,Green,1,FULL_TIME,1,2020-01-15 00:00:00,90000.0,Main St,London\n' +
                '2,Bob,Smith,2,CONTRACT,1,2021-06-01 00:00:00,75000.0,Oak Ave,Paris\n';
              default.FirmTable:
                'ID,LEGAL_NAME\n' +
                '1,Acme\n' +
                '2,Beta\n';
            }#
        ]
      ]
      tests:
      [
        joinedQuery:
        {
          serializationFormat: PURE_TDSOBJECT;
          asserts:
          [
            shouldJoinAndProjectDerivedProperty:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"Full Name":"Alice Green","Firm":"Acme"},{"Full Name":"Bob Smith","Firm":"Beta"}]';
                  }#;
              }#
          ]
        }
      ]
    }
  ]
}
