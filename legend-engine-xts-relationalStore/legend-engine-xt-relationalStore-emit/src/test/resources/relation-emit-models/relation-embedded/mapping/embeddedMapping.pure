###Mapping
import demo::relation::func::*;

Mapping demo::relation::mapping::EmployeeEmbeddedMapping
(
  *demo::relation::domain::ExtendedEmployee: Relation
  {
    ~func demo::relation::func::employeesWithAddress():Relation<Any>[1]
    id: ID,
    firstName: FIRST_NAME,
    lastName: LAST_NAME,
    employeeType: EnumerationMapping EmployeeTypeMapping: EMP_TYPE,
    active: $src.ACTIVE == 1,
    hireDate: HIRE_DATE,
    salary: SALARY,
    address
    (
      street: STREET,
      city: CITY
    )
  }

  demo::relation::domain::EmployeeType: EnumerationMapping EmployeeTypeMapping
  {
    FULL_TIME: ['FULL_TIME'],
    CONTRACT: ['CONTRACT']
  }

  testSuites:
  [
    addressCitySuite:
    {
      function: |demo::relation::domain::ExtendedEmployee.all()
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.address.city],
                    ['First Name', 'City']
                  );
      tests:
      [
        citiesProjected:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeData
              }#
          ];
          asserts:
          [
            shouldProjectCity:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"First Name":"Alice","City":"London"},{"First Name":"Bob","City":"Paris"},{"First Name":"Carol","City":"Berlin"}]';
                  }#;
              }#
          ];
        }
      ];
    },
    londonFilterSuite:
    {
      function: |demo::relation::domain::ExtendedEmployee.all()
                  ->filter(e | $e.address.city == 'London')
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.address.city],
                    ['First Name', 'City']
                  );
      tests:
      [
        londonOnly:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeData
              }#
          ];
          asserts:
          [
            shouldReturnLondon:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"First Name":"Alice","City":"London"}]';
                  }#;
              }#
          ];
        }
      ];
    },
    cityHeadcountSuite:
    {
      // NOTE: this deliberately does NOT combine the embedded address property with an
      // association traversal (e.g. $x.employer.legalName) in the same query. That
      // combination mirrors tests.pure::testEmbeddedRelationMappingWithAssociation, which
      // is a documented active shared-suite regression (firm resolves to TDSNull for
      // cross-firm rows, caused by the #4932 XStore->ModelJoin rewrite) as of this
      // session's gap analysis. Query-level groupBy over the embedded property's field
      // is a safe combination that doesn't touch the regressed association-resolution path.
      function: |demo::relation::domain::ExtendedEmployee.all()
                  ->project(~[city: x | $x.address.city, name: x | $x.firstName])
                  ->groupBy(~city, ~headcount: x | $x.name : y | $y->count())
                  ->sort([~city->ascending()]);
      tests:
      [
        headcountPerCity:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeCityHeadcountData
              }#
          ];
          asserts:
          [
            shouldCountEmployeesPerCity:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"city":"Berlin","headcount":1},{"city":"London","headcount":2},{"city":"Paris","headcount":1}]';
                  }#;
              }#
          ];
        }
      ];
    }
  ]
)
