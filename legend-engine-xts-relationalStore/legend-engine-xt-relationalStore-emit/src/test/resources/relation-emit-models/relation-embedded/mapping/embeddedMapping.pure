###Pure
import meta::pure::metamodel::relation::*;

function demo::relation::func::employeesWithAddress(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{demo::relation::db::EmployeeDB.EmployeeTable}#
}

###Mapping
import demo::relation::func::*;

Mapping demo::relation::mapping::EmployeeEmbeddedMapping
(
  *demo::relation::domain::ExtendedEmployee: Relation
  {
    ~func demo::relation::func::employeesWithAddress__Relation_1_
    id: ID,
    firstName: FIRST_NAME,
    lastName: LAST_NAME,
    employeeType: EnumerationMapping EmployeeTypeMapping: EMP_TYPE,
    active: $src.ACTIVE == 1,
    hireDate: HIRE_DATE,
    salary: SALARY,
    address
    (
      street: STREET,
      city: CITY
    )
  }

  demo::relation::domain::EmployeeType: EnumerationMapping EmployeeTypeMapping
  {
    FULL_TIME: ['FULL_TIME'],
    CONTRACT: ['CONTRACT']
  }

  testSuites:
  [
    addressCitySuite:
    {
      function: |demo::relation::domain::ExtendedEmployee.all()
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.address.city],
                    ['First Name', 'City']
                  );
      tests:
      [
        citiesProjected:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeAddressData
              }#
          ];
          asserts:
          [
            shouldProjectCity:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"First Name":"Alice","City":"London"},{"First Name":"Bob","City":"Paris"},{"First Name":"Carol","City":"Berlin"}]';
                  }#;
              }#
          ];
        }
      ];
    },
    londonFilterSuite:
    {
      function: |demo::relation::domain::ExtendedEmployee.all()
                  ->filter(e | $e.address.city == 'London')
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.address.city],
                    ['First Name', 'City']
                  );
      tests:
      [
        londonOnly:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeAddressData
              }#
          ];
          asserts:
          [
            shouldReturnLondon:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"First Name":"Alice","City":"London"}]';
                  }#;
              }#
          ];
        }
      ];
    }
  ]
)
