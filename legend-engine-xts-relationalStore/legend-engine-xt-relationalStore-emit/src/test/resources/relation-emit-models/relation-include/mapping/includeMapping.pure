// Mirrors relationCoverageInclude.pure's shape exactly: a base mapping with the real
// property mappings, and an outer mapping that does nothing but `include base`. Queries
// execute against the outer mapping to prove include is wired end-to-end, not just at
// parse/compile time.

###Pure
import meta::pure::metamodel::relation::*;

function demo::relation::func::includeEmployees(): meta::pure::metamodel::relation::Relation<Any>[1]
{
  #>{demo::relation::db::EmployeeDB.EmployeeTable}#
}

###Mapping
import demo::relation::func::*;

Mapping demo::relation::mapping::BaseIncludeMapping
(
  *demo::relation::domain::Employee: Relation
  {
    ~func demo::relation::func::includeEmployees():Relation<Any>[1]
    id: ID,
    firstName: FIRST_NAME,
    lastName: LAST_NAME,
    employeeType: EnumerationMapping EmployeeTypeMapping: EMP_TYPE,
    active: $src.ACTIVE == 1,
    hireDate: HIRE_DATE,
    salary: SALARY
  }

  demo::relation::domain::EmployeeType: EnumerationMapping EmployeeTypeMapping
  {
    FULL_TIME: ['FULL_TIME'],
    CONTRACT: ['CONTRACT']
  }
)

Mapping demo::relation::mapping::OuterIncludeMapping
(
  include demo::relation::mapping::BaseIncludeMapping

  testSuites:
  [
    includeSuite:
    {
      function: |demo::relation::domain::Employee.all()
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName, x | $x.lastName],
                    ['First Name', 'Last Name']
                  );
      tests:
      [
        allEmployeesThroughInclude:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeData
              }#
          ];
          asserts:
          [
            shouldQueryThroughIncludedMapping:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"First Name":"Alice","Last Name":"Green"},{"First Name":"Bob","Last Name":"Smith"},{"First Name":"Carol","Last Name":"White"}]';
                  }#;
              }#
          ];
        }
      ];
    },
    includeFilterSuite:
    {
      function: |demo::relation::domain::Employee.all()
                  ->filter(e | $e.active == true)
                  ->sortBy(x | $x.firstName)
                  ->project(
                    [x | $x.firstName],
                    ['First Name']
                  );
      tests:
      [
        activeOnlyThroughInclude:
        {
          data:
          [
            demo::relation::db::EmployeeDB:
              Reference
              #{
                demo::relation::data::EmployeeData
              }#
          ];
          asserts:
          [
            shouldFilterThroughIncludedMapping:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"First Name":"Alice"},{"First Name":"Bob"}]';
                  }#;
              }#
          ];
        }
      ];
    }
  ]
)
