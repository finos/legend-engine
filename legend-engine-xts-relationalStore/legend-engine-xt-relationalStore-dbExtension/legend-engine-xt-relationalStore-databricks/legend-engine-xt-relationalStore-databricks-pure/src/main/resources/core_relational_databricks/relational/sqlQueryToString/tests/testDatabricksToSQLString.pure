function <<test.Test>> meta::relational::tests::functions::sqlstring::databricks::testToSQLStringDatabricksSchemaNameShouldContainCatalogName():Boolean[1]
{
   let s = toSQLString(|Person.all(), meta::relational::tests::simpleRelationalMappingPersonForDatabricksCatalog, meta::relational::runtime::DatabaseType.Databricks, meta::relational::extension::relationalExtensions());
   assertEquals('select `root`.ID as `pk_0`, `root`.FIRSTNAME as `firstName`, `root`.LASTNAME as `lastName`, `root`.AGE as `age` from catalog.schema.personTable as `root`', $s);
}

function <<test.Test>> meta::relational::tests::functions::sqlstring::databricks::testToSQLStringDatabricksSchemaNameShouldNotContainCatalogName():Boolean[1]
{
   let s = toSQLString(|Person.all(), meta::relational::tests::simpleRelationalMappingPersonForDatabricks, meta::relational::runtime::DatabaseType.Databricks, meta::relational::extension::relationalExtensions());
   assertEquals('select `root`.ID as `pk_0`, `root`.FIRSTNAME as `firstName`, `root`.LASTNAME as `lastName`, `root`.AGE as `age` from schema.personTable as `root`', $s);
}

function <<test.Test>> meta::relational::tests::functions::sqlstring::databricks::testCreateViewForDatabricks(): Boolean[*]
{
   let dbConfig = meta::relational::functions::sqlQueryToString::createDbConfig(DatabaseType.Databricks);
   let extensions = meta::relational::extension::relationalExtensions();

   // Test basic create or replace view (no copyGrants, no secure)
   let basicView = ^meta::relational::metamodel::CreateViewSQL(name = 'personView', generatedSQL = 'select `FIRSTNAME`, `LASTNAME`, `AGE` from `personTable`', secure = false, copyGrants = false);
   let basicResult = meta::relational::functions::sqlQueryToString::databricks::createView($basicView, $dbConfig, $extensions);
   assertEquals('CREATE OR REPLACE VIEW `personView` as select `FIRSTNAME`, `LASTNAME`, `AGE` from `personTable`;', $basicResult);

   // Test create view with schema name
   let schemaView = ^meta::relational::metamodel::CreateViewSQL(name = 'personView', schemaName = 'hr', generatedSQL = 'select `FIRSTNAME`, `LASTNAME`, `AGE` from `personTable`', secure = false, copyGrants = false);
   let schemaResult = meta::relational::functions::sqlQueryToString::databricks::createView($schemaView, $dbConfig, $extensions);
   assertEquals('CREATE OR REPLACE VIEW `hr`.`personView` as select `FIRSTNAME`, `LASTNAME`, `AGE` from `personTable`;', $schemaResult);

   // Test create view with copyGrants generates two SQL statements
   let copyGrantsView = ^meta::relational::metamodel::CreateViewSQL(name = 'personView', schemaName = 'hr', generatedSQL = 'select `FIRSTNAME`, `LASTNAME`, `AGE` from `personTable`', secure = false, copyGrants = true);
   let copyGrantsResult = meta::relational::functions::sqlQueryToString::databricks::createView($copyGrantsView, $dbConfig, $extensions);
   assertEquals('CREATE VIEW IF NOT EXISTS `hr`.`personView` as select `FIRSTNAME`, `LASTNAME`, `AGE` from `personTable`; \nALTER VIEW `hr`.`personView` as select `FIRSTNAME`, `LASTNAME`, `AGE` from `personTable`;', $copyGrantsResult);

   let secureView = ^meta::relational::metamodel::CreateViewSQL(name = 'personView', generatedSQL = 'select `FIRSTNAME`, `LASTNAME`, `AGE` from `personTable`', secure = true, copyGrants = false);
   assertError({|meta::relational::functions::sqlQueryToString::databricks::createView($secureView, $dbConfig, $extensions)}, 'For Databricks we dont support SECURE views yet.');
}

function <<test.Test>> meta::relational::tests::functions::sqlstring::databricks::testCreateTableForDatabricks(): Boolean[*]
{
   let dbConfig = meta::relational::functions::sqlQueryToString::createDbConfig(DatabaseType.Databricks);

   // Test create table with all supported datatypes
   let columns = [
      ^meta::relational::metamodel::Column(name='col_boolean', type=^meta::relational::metamodel::datatype::Boolean()),
      ^meta::relational::metamodel::Column(name='col_integer', type=^meta::relational::metamodel::datatype::Integer()),
      ^meta::relational::metamodel::Column(name='col_float', type=^meta::relational::metamodel::datatype::Float()),
      ^meta::relational::metamodel::Column(name='col_varchar', type=^meta::relational::metamodel::datatype::Varchar(size=256)),
      ^meta::relational::metamodel::Column(name='col_char', type=^meta::relational::metamodel::datatype::Char(size=10)),
      ^meta::relational::metamodel::Column(name='col_decimal', type=^meta::relational::metamodel::datatype::Decimal(precision=18, scale=6)),
      ^meta::relational::metamodel::Column(name='col_timestamp', type=^meta::relational::metamodel::datatype::Timestamp()),
      ^meta::relational::metamodel::Column(name='col_date', type=^meta::relational::metamodel::datatype::Date()),
      ^meta::relational::metamodel::Column(name='col_bigint', type=^meta::relational::metamodel::datatype::BigInt()),
      ^meta::relational::metamodel::Column(name='col_smallint', type=^meta::relational::metamodel::datatype::SmallInt()),
      ^meta::relational::metamodel::Column(name='col_tinyint', type=^meta::relational::metamodel::datatype::TinyInt()),
      ^meta::relational::metamodel::Column(name='col_double', type=^meta::relational::metamodel::datatype::Double()),
      ^meta::relational::metamodel::Column(name='col_numeric', type=^meta::relational::metamodel::datatype::Numeric(precision=12, scale=4)),
      ^meta::relational::metamodel::Column(name='col_binary', type=^meta::relational::metamodel::datatype::Binary(size=512)),
      ^meta::relational::metamodel::Column(name='col_variant', type=^meta::relational::metamodel::datatype::SemiStructured())
   ];
   let table = ^meta::relational::metamodel::relation::Table(
      name = 'allTypesTable',
      schema = ^meta::relational::metamodel::Schema(name = 'hr', database = ^meta::relational::metamodel::Database(name='testDb')),
      columns = $columns
   );
   let createTableSQL = ^meta::relational::metamodel::CreateTableSQL(table = $table);
   let result = $createTableSQL->meta::relational::functions::sqlQueryToString::ddlSqlQueryToString($dbConfig);
   assertEquals('Create Table hr.allTypesTable(col_boolean BOOLEAN,col_integer DECIMAL(19,0),col_float FLOAT,col_varchar VARCHAR(256),col_char CHAR(10),col_decimal DECIMAL(18, 6),col_timestamp TIMESTAMP,col_date DATE,col_bigint BIGINT,col_smallint SMALLINT,col_tinyint TINYINT,col_double DOUBLE,col_numeric DECIMAL(12, 4),col_binary BINARY,col_variant VARIANT) TBLPROPERTIES ( \'delta.minReaderVersion\' = \'2\', \'delta.minWriterVersion\' = \'5\', \'delta.columnMapping.mode\' = \'name\' );', $result->toOne());

   // Test create table with default schema
   let defaultTable = ^meta::relational::metamodel::relation::Table(
      name = 'allTypesTable',
      schema = ^meta::relational::metamodel::Schema(name = 'default', database = ^meta::relational::metamodel::Database(name='testDb')),
      columns = $columns
   );
   let defaultCreateTableSQL = ^meta::relational::metamodel::CreateTableSQL(table = $defaultTable);
   let defaultResult = $defaultCreateTableSQL->meta::relational::functions::sqlQueryToString::ddlSqlQueryToString($dbConfig);
   assertEquals('Create Table allTypesTable(col_boolean BOOLEAN,col_integer DECIMAL(19,0),col_float FLOAT,col_varchar VARCHAR(256),col_char CHAR(10),col_decimal DECIMAL(18, 6),col_timestamp TIMESTAMP,col_date DATE,col_bigint BIGINT,col_smallint SMALLINT,col_tinyint TINYINT,col_double DOUBLE,col_numeric DECIMAL(12, 4),col_binary BINARY,col_variant VARIANT) TBLPROPERTIES ( \'delta.minReaderVersion\' = \'2\', \'delta.minWriterVersion\' = \'5\', \'delta.columnMapping.mode\' = \'name\' );', $defaultResult->toOne());
}

function <<test.Test>> meta::relational::tests::functions::sqlstring::databricks::testCreateFunctionForDatabricks(): Boolean[*]            
{            
   let dbConfig = meta::relational::functions::sqlQueryToString::createDbConfig(DatabaseType.Databricks);            
   let extensions = meta::relational::extension::relationalExtensions();            
            
   // Test basic create function with schema and params            
   let basicFunc = ^meta::relational::metamodel::CreateFunctionSQL(            
      name = 'my_func',            
      schemaName = 'test_schema',            
      typedParameters = [^meta::relational::metamodel::SQLParameter(name='name', type=^meta::relational::metamodel::datatype::Varchar(size=200))],    
      typedReturn = [    
         ^meta::relational::metamodel::SQLParameter(name='name', type=^meta::relational::metamodel::datatype::Varchar(size=200)),    
         ^meta::relational::metamodel::SQLParameter(name='DESCRIPTION', type=^meta::relational::metamodel::datatype::Varchar(size=200)),    
         ^meta::relational::metamodel::SQLParameter(name='START_ID', type=^meta::relational::metamodel::datatype::Decimal(precision=10, scale=0)),    
         ^meta::relational::metamodel::SQLParameter(name='END_ID', type=^meta::relational::metamodel::datatype::Decimal(precision=10, scale=0))    
      ],     
      generatedSQL = 'SELECT t.name AS name, t.DESCRIPTION AS DESCRIPTION, t.START_ID AS START_ID, t.END_ID AS END_ID FROM test_schema.my_table AS t WHERE t.name = name',            
      secure = false,            
      copyGrants = false            
   );            
   let basicResult = meta::relational::functions::sqlQueryToString::databricks::createFunction($basicFunc, $dbConfig, $extensions);            
   assertEquals('CREATE OR REPLACE FUNCTION `test_schema`.`my_func`(name STRING) \nRETURNS TABLE(name STRING, DESCRIPTION STRING, START_ID DECIMAL(10, 0), END_ID DECIMAL(10, 0)) \nLANGUAGE SQL \nRETURN \nWITH func_param_table AS (SELECT name AS param_name) \nSELECT t.name AS name, t.DESCRIPTION AS DESCRIPTION, t.START_ID AS START_ID, t.END_ID AS END_ID FROM test_schema.my_table AS t WHERE t.name = name;', $basicResult);      
      
   // Test without schema            
   let noSchemaFunc = ^meta::relational::metamodel::CreateFunctionSQL(            
      name = 'my_func',            
      typedParameters = [^meta::relational::metamodel::SQLParameter(name='batchId', type=^meta::relational::metamodel::datatype::Decimal(precision=10, scale=0))],    
      typedReturn = [^meta::relational::metamodel::SQLParameter(name='name', type=^meta::relational::metamodel::datatype::Varchar(size=200))],    
      generatedSQL = 'SELECT t.name AS name FROM test_schema.my_table AS t WHERE t.START_ID <= batchId',            
      secure = false,            
      copyGrants = false            
   );            
   let noSchemaResult = meta::relational::functions::sqlQueryToString::databricks::createFunction($noSchemaFunc, $dbConfig, $extensions);            
   assertEquals('CREATE OR REPLACE FUNCTION `my_func`(batchId DECIMAL(10, 0)) \nRETURNS TABLE(name STRING) \nLANGUAGE SQL \nRETURN \nWITH func_param_table AS (SELECT batchId AS param_batchId) \nSELECT t.name AS name FROM test_schema.my_table AS t WHERE t.START_ID <= batchId;', $noSchemaResult);      
      
   // Test with copyGrants = true (should still generate CREATE OR REPLACE)      
   let copyGrantsFunc = ^meta::relational::metamodel::CreateFunctionSQL(            
      name = 'my_func',            
      schemaName = 'test_schema',            
      typedParameters = [^meta::relational::metamodel::SQLParameter(name='currentWatermark', type=^meta::relational::metamodel::datatype::Varchar(size=200))],    
      typedReturn = [    
         ^meta::relational::metamodel::SQLParameter(name='name', type=^meta::relational::metamodel::datatype::Varchar(size=200)),    
         ^meta::relational::metamodel::SQLParameter(name='DESCRIPTION', type=^meta::relational::metamodel::datatype::Varchar(size=200)),    
         ^meta::relational::metamodel::SQLParameter(name='START_ID', type=^meta::relational::metamodel::datatype::Decimal(precision=10, scale=0)),    
         ^meta::relational::metamodel::SQLParameter(name='END_ID', type=^meta::relational::metamodel::datatype::Decimal(precision=10, scale=0))    
      ],    
      generatedSQL = 'SELECT t.name AS name, t.DESCRIPTION AS DESCRIPTION, t.START_ID AS START_ID, t.END_ID AS END_ID FROM test_schema.my_table AS t WHERE t.name = \'ee\'',            
      secure = false,            
      copyGrants = true            
   );            
   let copyGrantsResult = meta::relational::functions::sqlQueryToString::databricks::createFunction($copyGrantsFunc, $dbConfig, $extensions);            
   assertEquals('CREATE OR REPLACE FUNCTION `test_schema`.`my_func`(currentWatermark STRING) \nRETURNS TABLE(name STRING, DESCRIPTION STRING, START_ID DECIMAL(10, 0), END_ID DECIMAL(10, 0)) \nLANGUAGE SQL \nRETURN \nWITH func_param_table AS (SELECT currentWatermark AS param_currentWatermark) \nSELECT t.name AS name, t.DESCRIPTION AS DESCRIPTION, t.START_ID AS START_ID, t.END_ID AS END_ID FROM test_schema.my_table AS t WHERE t.name = \'ee\';', $copyGrantsResult);      
      
   // Test with multiple parameters            
   let multiParamFunc = ^meta::relational::metamodel::CreateFunctionSQL(            
      name = 'my_func_multi',            
      schemaName = 'test_schema',            
      typedParameters = [    
         ^meta::relational::metamodel::SQLParameter(name='startId', type=^meta::relational::metamodel::datatype::Decimal(precision=10, scale=0)),    
         ^meta::relational::metamodel::SQLParameter(name='endId', type=^meta::relational::metamodel::datatype::Decimal(precision=10, scale=0))    
      ],    
      typedReturn = [    
         ^meta::relational::metamodel::SQLParameter(name='name', type=^meta::relational::metamodel::datatype::Varchar(size=200)),    
         ^meta::relational::metamodel::SQLParameter(name='START_ID', type=^meta::relational::metamodel::datatype::Decimal(precision=10, scale=0)),    
         ^meta::relational::metamodel::SQLParameter(name='END_ID', type=^meta::relational::metamodel::datatype::Decimal(precision=10, scale=0))    
      ],    
      generatedSQL = 'SELECT t.name AS name, t.START_ID AS START_ID, t.END_ID AS END_ID FROM test_schema.my_table AS t WHERE t.START_ID <= startId AND t.END_ID >= endId',            
      secure = false,            
      copyGrants = false            
   );            
   let multiParamResult = meta::relational::functions::sqlQueryToString::databricks::createFunction($multiParamFunc, $dbConfig, $extensions);            
   assertEquals('CREATE OR REPLACE FUNCTION `test_schema`.`my_func_multi`(startId DECIMAL(10, 0), endId DECIMAL(10, 0)) \nRETURNS TABLE(name STRING, START_ID DECIMAL(10, 0), END_ID DECIMAL(10, 0)) \nLANGUAGE SQL \nRETURN \nWITH func_param_table AS (SELECT startId AS param_startId, endId AS param_endId) \nSELECT t.name AS name, t.START_ID AS START_ID, t.END_ID AS END_ID FROM test_schema.my_table AS t WHERE t.START_ID <= startId AND t.END_ID >= endId;', $multiParamResult);      
}