function <<meta::protocols::pure::vX_X_X::extension::RelationalModule.SerializerExtension>>
meta::protocols::pure::vX_X_X::transformation::fromPureGraph::connection::athenaBSerializerExtension(): meta::protocols::pure::vX_X_X::extension::RelationalModuleSerializerExtension[1]
{
  ^meta::protocols::pure::vX_X_X::extension::RelationalModuleSerializerExtension(
    module = 'athena',
    transfers_connection_transformDatasourceSpecification = [
        d:meta::pure::alloy::connections::alloy::specification::AthenaDatasourceSpecification[1] |
                  ^meta::protocols::pure::vX_X_X::metamodel::store::relational::connection::alloy::specification::AthenaDatasourceSpecification(
                      _type = 'athena',
                      region = $d.region,
                      catalog = $d.catalog,
                      workGroup = $d.workGroup,
                      outputLocation = $d.outputLocation,
                      athenaEndpoint = $d.athenaEndpoint,
                      database = $d.database
                 )
    ],
    reverse_transfers_typeLookups = [
        pair('athena', 'AthenaDatasourceSpecification')
    ],
    reverse_transfers_connection_transformDatasourceSpecification = [
        d:meta::protocols::pure::vX_X_X::metamodel::store::relational::connection::alloy::specification::AthenaDatasourceSpecification[1] |
                  ^meta::pure::alloy::connections::alloy::specification::AthenaDatasourceSpecification(
                      region = $d.region,
                      catalog = $d.catalog,
                      workGroup = $d.workGroup,
                      outputLocation = $d.outputLocation,
                      athenaEndpoint = $d.athenaEndpoint,
                      database = $d.database
                 )
    ]
  )
}
