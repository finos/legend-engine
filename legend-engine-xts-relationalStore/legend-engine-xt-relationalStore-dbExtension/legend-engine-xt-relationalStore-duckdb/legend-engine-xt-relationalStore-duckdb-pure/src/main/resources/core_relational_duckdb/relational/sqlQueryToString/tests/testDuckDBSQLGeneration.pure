function <<test.Test>> meta::relational::tests::sqlQueryToString::duckDB::testToSQLStringConvertDateSlashedFormatInDuckDB(): Boolean[1]
{
   let s = toSQLString(|SqlFunctionDemo.all()->project([s | $s.convertToDateUserDefinedFormat2], ['convertToDate']), testMapping, meta::relational::runtime::DatabaseType.DuckDB, meta::relational::extension::relationalExtensions());
   assertEquals('select strptime("root".stringUserDefinedDateFormat, \'%Y/%m/%d\')::DATE as "convertToDate" from dataTable as "root"', $s);
