{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Pure",
  "scopeName": "source.pure",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#variables" },
    { "include": "#operators" },
    { "include": "#annotations" },
    { "include": "#packages" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.pure",
          "match": "//.*$"
        },
        {
          "name": "comment.block.pure",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.pure",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.pure",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.double.pure",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.pure",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.pure",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.pure",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.pure",
          "match": "\\b(if|else|let|in|extends|implements)\\b"
        },
        {
          "name": "keyword.declaration.pure",
          "match": "\\b(Class|Enum|Profile|Association|function|native|Mapping|Store|Database|Schema|Table|View|Join|Filter|Runtime|Connection|Diagram)\\b"
        },
        {
          "name": "keyword.other.pure",
          "match": "\\b(import|package|uses|projects|tests|constraint|derivation|milestoning|stereotypes|tags)\\b"
        },
        {
          "name": "constant.language.boolean.pure",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.pure",
          "match": "\\b(nil)\\b"
        },
        {
          "name": "storage.modifier.pure",
          "match": "\\b(abstract|final|private|protected|public)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.pure",
          "match": "\\b(String|Integer|Float|Boolean|Date|DateTime|StrictDate|Number|Decimal|Any|Nil)\\b"
        },
        {
          "name": "entity.name.type.pure",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.pure",
          "match": "\\b([a-z][a-zA-Z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.pure",
          "match": "\\b(filter|map|fold|size|isEmpty|isNotEmpty|first|last|at|take|drop|sort|distinct|concatenate|union|intersect|except|zip|range|repeat|reverse|slice|tail|init|indexOf|contains|startsWith|endsWith|trim|toLower|toUpper|split|joinStrings|replace|substring|length|parseInteger|parseFloat|parseDate|toString|toOne|toOneMany|cast|match|assert|print|println|now|today|hasDay|hasMonth|hasYear|dayOfWeek|dayOfMonth|weekOfYear|monthNumber|year|hour|minute|second|datePart|timePart|adjust|dateDiff|plus|minus|times|divide|rem|abs|floor|ceiling|round|sqrt|pow|exp|log|sin|cos|tan|asin|acos|atan|max|min|sum|average|count|and|or|not|equal|lessThan|lessThanEqual|greaterThan|greaterThanEqual|compare|if|match|case|let|new|copy|dynamicNew|getAll|getAllVersions|getAllVersionsInRange|get|getClass|id|genericType|rawType|class|properties|qualifiedProperties|propertiesFromAssociations|generalizations|specializations|hasStereotype|hasTaggedValue|stereotype|taggedValue|elementToPath|pathToElement|deactivate|evaluate|reactivate|meta|compileValueSpecification|buildLambda|lambdaFunction|openVariableValues|funcType|parametersValues|expressionSequence)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.pure",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "variable.parameter.pure",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b(?=\\s*:)"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.pure",
          "match": "->"
        },
        {
          "name": "keyword.operator.pipe.pure",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.comparison.pure",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.pure",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arithmetic.pure",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.assignment.pure",
          "match": "="
        },
        {
          "name": "keyword.operator.path.pure",
          "match": "::"
        },
        {
          "name": "keyword.operator.multiplicity.pure",
          "match": "\\[\\s*(\\*|\\d+\\s*(\\.\\.\\s*(\\*|\\d+))?)\\s*\\]"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.pure",
          "match": "<<[^>]+>>"
        },
        {
          "name": "meta.stereotype.pure",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*(\\.[a-zA-Z_][a-zA-Z0-9_]*)?"
        }
      ]
    },
    "packages": {
      "patterns": [
        {
          "name": "entity.name.namespace.pure",
          "match": "\\b[a-z][a-zA-Z0-9_]*(?=::)"
        }
      ]
    }
  }
}
