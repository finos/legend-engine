                'id,val\n'+
                '1,1.0\n'+
                '1,2.0\n'+
                '1,3\n'+
                '2,1.5\n'+
                '2,2.5\n'+
                '2,3.5\n'+
                '3,1\n'+
                '3,1.5\n'+
                '3,2.0}#->meta::pure::functions::relation::extend(~id->meta::pure::functions::relation::over(), ~newCol:{p: meta::pure::metamodel::relation::Relation<(id:Integer[0..1], val:Float[0..1])>[1], w: meta::pure::functions::relation::_Window<(id:Integer[0..1], val:Float[0..1])>[1], r: (id:Integer[0..1], val:Float[0..1])[1]|$r.val}:y: Float[*]|$y->meta::pure::functions::math::percentile(0.6, false, true))',
               '(lambda frame: frame.window_extend(' +
                'frame.window("id", []), ("newCol", lambda p , w , r : r.val , lambda c : c.percentile(0.6, ascending=False, continuous=True)))'+
              ')(csv_frame("\\nid,val\\n1,1.0\\n1,2.0\\n1,3\\n2,1.5\\n2,2.5\\n2,3.5\\n3,1\\n3,1.5\\n3,2.0"))')
        ]
      )
    ]->combine()
    
  ]
}