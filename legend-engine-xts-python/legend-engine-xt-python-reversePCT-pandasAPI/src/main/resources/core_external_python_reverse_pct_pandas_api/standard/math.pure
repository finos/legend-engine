      meta::pure::functions::math::tests::percentile::testPercentile_Relation_Aggregate_Function_1__Boolean_1_->testRev(
        [
          rev('|#TDS{\n'+
                'id,val\n'+
                '1,1.0\n'+
                '1,2.0\n'+
                '1,3\n'+
                '2,1.5\n'+
                '2,2.5\n'+
                '2,3.5\n'+
                '3,1\n'+
                '3,1.5\n'+
                '3,2.0}#->meta::pure::functions::relation::groupBy(~[id], ~[newCol:x: (id:Integer[0..1], val:Float[0..1])[1]|$x.val:y: Float[*]|$y->meta::pure::functions::math::percentile(0.6, true, false)])',
              '(lambda frame:' +
               '  frame.groupby("id").agg({"val": lambda c: c.percentile(0.6, ascending=True, continuous=False)}).rename(columns={"val": "newCol"})' +
               ')(csv_frame("\\nid,val\\n1,1.0\\n1,2.0\\n1,3\\n2,1.5\\n2,2.5\\n2,3.5\\n3,1\\n3,1.5\\n3,2.0"))')
        ]
