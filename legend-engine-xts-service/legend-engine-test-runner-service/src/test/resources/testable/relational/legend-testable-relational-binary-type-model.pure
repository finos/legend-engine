###Pure
Class model::BinaryData
{
  name: String[1];
  checksum: String[0..1];
  payload: String[0..1];
  uuid: String[0..1];
}


###Relational
Database store::BinaryDB
(
  Table BinaryTable
  (
    id INTEGER PRIMARY KEY,
    name VARCHAR(200),
    checksum BINARY(32),
    payload VARBINARY(256),
    uuid BINARY(16)
  )
)


###Mapping
Mapping execution::BinaryMapping
(
  *model::BinaryData: Relational
  {
    ~primaryKey
    (
      [store::BinaryDB]BinaryTable.id
    )
    ~mainTable [store::BinaryDB]BinaryTable
    name: [store::BinaryDB]BinaryTable.name,
    checksum: [store::BinaryDB]BinaryTable.checksum,
    payload: [store::BinaryDB]BinaryTable.payload,
    uuid: [store::BinaryDB]BinaryTable.uuid
  }
)


###Connection
RelationalDatabaseConnection model::BinaryConnection
{
  store: store::BinaryDB;
  type: H2;
  specification: LocalH2
  {
  };
  auth: DefaultH2;
}


###Runtime
Runtime execution::BinaryRuntime
{
  mappings:
  [
    execution::BinaryMapping
  ];
  connectionStores:
  [
    model::BinaryConnection:
    [
      store::BinaryDB
    ]
  ];
}


