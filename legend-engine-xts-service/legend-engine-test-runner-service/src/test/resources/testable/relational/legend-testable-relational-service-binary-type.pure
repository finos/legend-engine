###Service
Service service::RelationalServiceWithBinaryTypes
{
  pattern: '/testBinaryTypes';
  documentation: '';
  autoActivateUpdates: true;
  execution: Single
  {
    query: |model::BinaryData.all()->project(~[name: x|$x.name, checksum: x|$x.checksum, payload: x|$x.payload, uuid: x|$x.uuid]);
    mapping: execution::BinaryMapping;
    runtime: execution::BinaryRuntime;
  }
  testSuites:
  [
    testSuite1:
    {
      data:
      [
        connections:
        [
          model::BinaryConnection:
            Relational
            #{
              default.BinaryTable:
                'id,name,checksum,payload,uuid\n' +
                '1,FileA,48656c6c6f,576f726c64,550e8400e29b41d4a716446655440000\n' +
                '2,FileB,cafebabe,deadbeef,6ba7b8109dad11d180b400c04fd430c8\n';
            }#
        ]
      ]
      tests:
      [
        test1:
        {
          serializationFormat: PURE_TDSOBJECT;
          asserts:
          [
            shouldPass:
              EqualToJson
              #{
                expected :
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"name":"FileA","checksum":"48656c6c6f","payload":"576f726c64","uuid":"550e8400e29b41d4a716446655440000"},{"name":"FileB","checksum":"cafebabe","payload":"deadbeef","uuid":"6ba7b8109dad11d180b400c04fd430c8"}]\n';
                  }#;
              }#
          ]
        }
      ]
    }
  ]
}







