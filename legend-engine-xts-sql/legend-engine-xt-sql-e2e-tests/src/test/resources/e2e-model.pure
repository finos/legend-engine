// Relation functions for each table
function e2e::rel_persons(): meta::pure::metamodel::relation::Relation<(id:Integer, name:String, age:Integer, salary:Float, hire_date:Date, active:Boolean, dept_id:Integer)>[1]
{
  e2e::Person.all()->project(~[
    id: x | $x.id,
    name: x | $x.name,
    age: x | $x.age,
    salary: x | $x.salary,
    hire_date: x | $x.hireDate,
    active: x | $x.active,
    dept_id: x | $x.deptId
  ])
}

function e2e::rel_departments(): meta::pure::metamodel::relation::Relation<(id:Integer, name:String, budget:Float, created_at:DateTime)>[1]
{
