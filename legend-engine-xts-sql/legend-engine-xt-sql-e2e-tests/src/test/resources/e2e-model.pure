###Relational
Database e2e::TestDB
(
  Schema public
  (
    Table persons
    (
      id INTEGER PRIMARY KEY,
      name VARCHAR(200),
      age INTEGER,
      salary DECIMAL(10,2),
      hire_date DATE,
      active BIT,
      dept_id INTEGER
    )
    Table departments
    (
      id INTEGER PRIMARY KEY,
      name VARCHAR(200),
      budget DECIMAL(15,2),
      created_at TIMESTAMP
    )
    Table orders
    (
      id INTEGER PRIMARY KEY,
      person_id INTEGER,
      amount DECIMAL(10,2),
      order_date TIMESTAMP,
      status VARCHAR(50)
    )
    Table numbers
    (
      id INTEGER PRIMARY KEY,
      int_val INTEGER,
      float_val DOUBLE,
      numeric_val DECIMAL(20,5),
      small_val INTEGER,
      big_val BIGINT
    )
    Table strings
    (
      id INTEGER PRIMARY KEY,
      val VARCHAR(500),
      nullable_val VARCHAR(500),
      unicode_val VARCHAR(500),
      empty_val VARCHAR(500)
    )
    Table dates
    (
      id INTEGER PRIMARY KEY,
      d DATE,
      ts TIMESTAMP,
      tsz TIMESTAMP
    )
    Table empty_table
    (
      id INTEGER PRIMARY KEY,
      val VARCHAR(200)
    )
  )

  Join PersonDepartment(public.persons.dept_id = public.departments.id)
  Join PersonOrder(public.persons.id = public.orders.person_id)
)


###Pure
Class e2e::Person
{
  id: Integer[1];
  name: String[0..1];
  age: Integer[0..1];
  salary: Float[0..1];
  hireDate: StrictDate[0..1];
  active: Boolean[0..1];
  deptId: Integer[0..1];
}

Class e2e::Department
{
  id: Integer[1];
  name: String[0..1];
  budget: Float[0..1];
  createdAt: DateTime[0..1];
}

Class e2e::Order
{
  id: Integer[1];
  personId: Integer[0..1];
  amount: Float[0..1];
  orderDate: DateTime[0..1];
  status: String[0..1];
}

Class e2e::NumberRow
{
  id: Integer[1];
  intVal: Integer[0..1];
  floatVal: Float[0..1];
  numericVal: Float[0..1];
  smallVal: Integer[0..1];
  bigVal: Integer[0..1];
}

Class e2e::StringRow
{
  id: Integer[1];
  val: String[0..1];
  nullableVal: String[0..1];
  unicodeVal: String[0..1];
  emptyVal: String[0..1];
}

Class e2e::DateRow
{
  id: Integer[1];
  d: StrictDate[0..1];
  ts: DateTime[0..1];
  tsz: DateTime[0..1];
}

Class e2e::EmptyRow
{
  id: Integer[1];
  val: String[0..1];
}

Association e2e::PersonDepartment
{
  persons: e2e::Person[*];
  department: e2e::Department[0..1];
}


// TDS functions for each table
function e2e::tds_persons(): meta::pure::tds::TabularDataSet[1]
{
  e2e::Person.all()->project([
    col(x | $x.id, 'id'),
    col(x | $x.name, 'name'),
    col(x | $x.age, 'age'),
    col(x | $x.salary, 'salary'),
    col(x | $x.hireDate, 'hire_date'),
    col(x | $x.active, 'active'),
    col(x | $x.deptId, 'dept_id')
  ])
}

function e2e::tds_departments(): meta::pure::tds::TabularDataSet[1]
{
  e2e::Department.all()->project([
    col(x | $x.id, 'id'),
    col(x | $x.name, 'name'),
    col(x | $x.budget, 'budget'),
    col(x | $x.createdAt, 'created_at')
  ])
}

