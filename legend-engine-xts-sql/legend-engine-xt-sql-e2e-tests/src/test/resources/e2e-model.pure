    id: x | $x.id,
    val: x | $x.val
  ])
}

// Joined functions — perform the join inside Pure so SQL only references one func() call
function e2e::tds_person_with_dept(): meta::pure::tds::TabularDataSet[1]
{
  e2e::Person.all()
    ->filter(p | $p.deptId->isNotEmpty())
    ->project([
      col(p | $p.name, 'name'),
      col(p | $p.department.name, 'dept_name')
    ])
}

function e2e::rel_person_with_dept(): meta::pure::metamodel::relation::Relation<(name:String, dept_name:String)>[1]
{
  e2e::Person.all()
    ->filter(p | $p.deptId->isNotEmpty())
    ->project(~[
      name: p | $p.name,
      dept_name: p | $p.department.name
    ])
}

// Parameterized functions — accept parameters for filtering
function e2e::tds_persons_by_dept(deptId: Integer[1]): meta::pure::tds::TabularDataSet[1]
{
  e2e::Person.all()
    ->filter(p | $p.deptId == $deptId)
    ->project([
      col(p | $p.id, 'id'),
      col(p | $p.name, 'name'),
      col(p | $p.age, 'age'),
      col(p | $p.salary, 'salary')
    ])
}

function e2e::tds_persons_by_name(name: String[1]): meta::pure::tds::TabularDataSet[1]
{
  e2e::Person.all()
    ->filter(p | $p.name == $name)
    ->project([
      col(p | $p.id, 'id'),
      col(p | $p.name, 'name'),
      col(p | $p.age, 'age'),
      col(p | $p.salary, 'salary')
    ])
}

function e2e::tds_persons_by_min_age(minAge: Integer[1]): meta::pure::tds::TabularDataSet[1]
{
  e2e::Person.all()
    ->filter(p | $p.age->isNotEmpty() && ($p.age->toOne() >= $minAge))
    ->project([
      col(p | $p.id, 'id'),
      col(p | $p.name, 'name'),
      col(p | $p.age, 'age')
    ])
}

function e2e::tds_persons_by_active(active: Boolean[1]): meta::pure::tds::TabularDataSet[1]
{
  e2e::Person.all()
    ->filter(p | $p.active == $active)
    ->project([
      col(p | $p.id, 'id'),
      col(p | $p.name, 'name'),
      col(p | $p.active, 'active')
    ])
}


