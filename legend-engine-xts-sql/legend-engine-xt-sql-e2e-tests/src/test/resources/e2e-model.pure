    id: x | $x.id,
    name: x | $x.name,
    budget: x | $x.budget,
    created_at: x | $x.createdAt
  ])
}

function e2e::rel_orders(): meta::pure::metamodel::relation::Relation<(id:Integer, person_id:Integer, amount:Float, order_date:DateTime, status:String)>[1]
{
  e2e::Order.all()->project(~[
    id: x | $x.id,
