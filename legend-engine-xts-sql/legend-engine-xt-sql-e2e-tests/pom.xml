        </dependency>

        <!-- Legend SQL server (wire protocol) -->
        <dependency>
            <groupId>org.finos.legend.engine</groupId>
            <artifactId>legend-engine-xt-sql-postgres-server</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Legend SQL HTTP API (SqlExecute, SQLSourceProvider) -->
        <dependency>
            <groupId>org.finos.legend.engine</groupId>
            <artifactId>legend-engine-xt-sql-http-api</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.finos.legend.engine</groupId>
            <artifactId>legend-engine-xt-sql-http-api</artifactId>
            <type>test-jar</type>
            <scope>test</scope>
        </dependency>

        <!-- JUnit 4 (needed for ResourceTestRule) -->
        <dependency>
