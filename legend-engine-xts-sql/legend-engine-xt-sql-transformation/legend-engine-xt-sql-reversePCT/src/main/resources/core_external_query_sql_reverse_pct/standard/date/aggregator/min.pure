                                 '"Unused format args. [2] arguments provided to expression "max(%s)""'
                        )
                      ]
                 ),
                 revsForTest(
                      'meta::pure::functions::date::tests::min::testMin_DateTime_Function_1__Boolean_1_',
                      [
                        rev('|%2025-02-10T20:10:20+0000->meta::pure::functions::date::min(%2025-01-10T15:25:30+0000)',
