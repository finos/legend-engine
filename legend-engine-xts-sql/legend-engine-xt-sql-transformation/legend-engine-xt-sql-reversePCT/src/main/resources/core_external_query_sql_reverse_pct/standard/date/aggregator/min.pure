                 revsForTest(
                      'meta::pure::functions::date::tests::min::testExtendMinDate_Function_1__Boolean_1_',
                      [
                        noRev('|#TDS{\n'+
                              'id:Integer[1],time:Date[1],volume:Integer[1]\n'+
                              '1,2026-01-07T00:00:00.000+0000,820000\n'+
                              '2,2026-01-07T06:00:00.000+0000,520000\n'+
                              '3,2026-01-07T06:00:00.000+0000,480000\n'+
                              '4,2026-01-08T00:00:00.000+0000,480000\n'+
                              '5,2026-01-08T00:00:00.000+0000,480000\n'+
                              '6,2026-01-09T00:00:00.000+0000,520000\n'+
