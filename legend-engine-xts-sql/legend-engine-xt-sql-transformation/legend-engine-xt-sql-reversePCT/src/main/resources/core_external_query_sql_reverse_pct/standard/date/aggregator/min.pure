import meta::pure::test::pct::reversePCT::framework::*;

function meta::external::query::sql::reversePCT::tests::standard::date::aggregator::min::reverses():ReversesForSource[1]
{
  ^ReversesForSource(
    source = '/core_functions_standard/date/aggregator/min.pure',
    reverses = [
                 revsForTest(
                      'meta::pure::functions::date::tests::min::testMin_Date_Function_1__Boolean_1_',
                      [
                        rev('|%2025-02-10T20:10:20+0000->meta::pure::functions::date::min(%2025-02-10)',
                            'select case when Date\'2025-02-10\' < Timestamp\'2025-02-10 20:10:20\' then Date\'2025-02-10\' else Timestamp\'2025-02-10 20:10:20\' end'
                        ),
                        rev('|%2025-02-10->meta::pure::functions::date::min(%2025-02-10T20:10:20+0000)',
                            'select case when Timestamp\'2025-02-10 20:10:20\' < Date\'2025-02-10\' then Timestamp\'2025-02-10 20:10:20\' else Date\'2025-02-10\' end'
                        )
