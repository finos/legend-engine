                                 '',
                                 'Unexpected token',
                                 '"Unused format args. [2] arguments provided to expression "max(%s)""'
                        ),
                        revError('|[%2025-02-10T20:10:20+0000, %2025-01-10T15:25:30+0000]->meta::pure::functions::date::min()',
                                 '',
                                 'Unexpected token',
