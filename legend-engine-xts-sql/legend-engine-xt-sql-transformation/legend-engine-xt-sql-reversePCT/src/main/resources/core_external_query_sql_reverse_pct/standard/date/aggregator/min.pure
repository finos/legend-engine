                        ),
                        revError('|[%2025-01-10T15:25:30+0000, %2025-02-10T20:10:20+0000]->meta::pure::functions::date::min()',
                                 '',
                                 'Unexpected token',
                                 '"Unused format args. [2] arguments provided to expression "max(%s)""'
                        ),
                        revError('|[%2025-01-10T15:25:30+0000, %2025-02-10T10:11:15+0000, %2025-02-10T20:10:20+0000, %2024-05-17T23:11:14+0000]->meta::pure::functions::date::min()',
                                 '',
                                 'Unexpected token',
                                 '"Unused format args. [2] arguments provided to expression "max(%s)""'
                        )
                      ]
                 ),
                 revsForTest(
                      'meta::pure::functions::date::tests::min::testMin_StrictDate_Function_1__Boolean_1_',
                      [
                        rev('|%2025-04-09->meta::pure::functions::date::min(%2025-02-09)',
                            'select case when Date\'2025-02-09\' < Date\'2025-04-09\' then Date\'2025-02-09\' else Date\'2025-04-09\' end'
